import { Page, Header, Title, Subtitle, TermContainer, StatusBar, StatusLabel, StatusValue } from './pty_test_cls';

function App() {
  return (
    <C.Page>
      <C.Header>
        <C.Title>PTY Test</C.Title>
        <C.Subtitle>Shell via Render surface — click to focus, type to interact</C.Subtitle>
      </C.Header>

      <C.TermContainer>
        <Render src="app:bash" style={{ flexGrow: 1 }} />
      </C.TermContainer>

      <C.StatusBar>
        <C.StatusLabel>Backend:</C.StatusLabel>
        <C.StatusValue>Xvfb + XShm + XTest (appembed)</C.StatusValue>
        <C.StatusLabel>Shell:</C.StatusLabel>
        <C.StatusValue>bash (render surface manages PTY)</C.StatusValue>
      </C.StatusBar>
    </C.Page>
  );
}
