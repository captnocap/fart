#!/bin/bash
# dev — push a cart into the running reactjit dev host, or spawn one.
#
# Usage:  scripts/dev <cart-name>
#
# Flow:
#   1. Bundle <cart> → .cache/bundle-<cart>.js
#   2. If a host is running at /tmp/reactjit.sock, push the bundle and exit.
#      The host upserts the tab and switches active to this cart.
#   3. If no host is running, copy the bundle to ./bundle.js (bootstrap path),
#      compile the dev binary if missing, launch it in the background, then
#      enter a watch loop that re-pushes on every save.
#
# Phase 1 behavior: pushing switches the active tab. Swap between previously
# pushed carts by re-running this command with the target cart's name.
# Phase 2 will add a chrome strip + mouse/keyboard tab switching.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

NAME="${1:-}"
if [[ -z "$NAME" ]]; then
    echo "Usage: scripts/dev <cart-name>" >&2
    echo "  Cart expected at: cart/<name>/index.tsx or cart/<name>.tsx" >&2
    exit 1
fi

if [[ -f "cart/${NAME}/index.tsx" ]]; then
    CART_FILE="cart/${NAME}/index.tsx"
elif [[ -f "cart/${NAME}.tsx" ]]; then
    CART_FILE="cart/${NAME}.tsx"
else
    echo "[dev] not found: cart/${NAME}/index.tsx or cart/${NAME}.tsx" >&2
    exit 1
fi

SOCKET=/tmp/reactjit.sock
PER_CART_BUNDLE=".cache/bundle-${NAME}.js"
mkdir -p .cache

# Heal top-level `const { useX } = React;` and stray require('react') lines —
# patterns that fail at module-init before globalThis.React is set.
scripts/fix-react-imports

echo "[dev] bundling ${CART_FILE} → ${PER_CART_BUNDLE}"
# BUNDLE_FROM_HARNESS=1 is the sentinel the bundler looks for. Direct
# `tools/v8cli scripts/cart-bundle.js ...` invocations (e.g. ad-hoc from an
# agent) are refused — they race with the watcher and stamp stale bundles over disk.
BUNDLE_FROM_HARNESS=1 tools/v8cli scripts/cart-bundle.js "$CART_FILE" --out "$PER_CART_BUNDLE"

# Fast path: host already running — push and exit.
if [[ -S "$SOCKET" ]]; then
    echo "[dev] host detected — pushing '${NAME}'"
    if tools/v8cli scripts/push-bundle.js "$NAME" "$PER_CART_BUNDLE"; then
        echo "[dev] host switched to tab '${NAME}'"
        exit 0
    fi
    # Stale socket file — remove and fall through to spawn.
    rm -f "$SOCKET"
fi

# Spawn path — bootstrap via bundle.js on disk, compile if needed, launch.
cp "$PER_CART_BUNDLE" bundle.js

BIN="zig-out/bin/reactjit-dev"
# Rebuild when missing OR when any framework/build.zig source is newer than the
# binary. Without this, editing framework/*.zig and restarting the host silently
# reuses a stale ELF — a specific gotcha that has cost real debugging time
# (e.g. chasing a letter-spacing wrap bug against a binary built before the fix).
needs_build=0
if [[ ! -x "$BIN" ]]; then
    needs_build=1
elif [[ -n "$(find framework build.zig -newer "$BIN" 2>/dev/null | head -1)" ]]; then
    needs_build=1
    echo "[dev] framework source newer than binary — rebuilding..."
fi
if [[ "$needs_build" -eq 1 ]]; then
    # ReleaseFast: Debug builds silently exit on click (pre-existing framework
    # issue — cockpit-raw reproduces it without dev mode). Dev-mode is a
    # RUNTIME flag, it doesn't need Debug compilation. Smaller binary too.
    # V8 is the default runtime (per CLAUDE.md). QJS is legacy maintenance-only.
    echo "[dev] compiling dev binary ($BIN, V8, ReleaseFast)..."
    zig build app -Dapp-name="reactjit-dev" -Dapp-source=v8_app.zig -Duse-v8=true -Ddev-mode=true -Doptimize=ReleaseFast
fi

./"$BIN" &
BIN_PID=$!

cleanup() {
    # Two-phase shutdown: polite SIGTERM first, then SIGKILL after a brief grace
    # period. Without the SIGKILL fallback a binary that ignores TERM (or a
    # race between trap firing and the host fully coming up) leaves the dev
    # process attached to this terminal, still streaming telemetry + tick
    # lines into stdout long after scripts/dev has exited.
    kill -TERM "$BIN_PID" 2>/dev/null || true
    pkill -TERM -P $$ 2>/dev/null || true
    for _ in 1 2 3 4 5; do
        kill -0 "$BIN_PID" 2>/dev/null || break
        sleep 0.1
    done
    kill -KILL "$BIN_PID" 2>/dev/null || true
    pkill -KILL -P $$ 2>/dev/null || true
    exit 0
}
trap cleanup INT TERM EXIT

echo "[dev] host PID=$BIN_PID — run 'scripts/dev <other>' from another terminal to add tabs"

# Watch loop pushes each rebuild to the host over the socket.
tools/v8cli scripts/watch-and-push.js "$NAME" "$CART_FILE" "$PER_CART_BUNDLE"
