#!/usr/bin/env bash
# gallery-component — thin launcher for scripts/gallery-component.js.
#
# Runs the v8cli port:
#   tools/v8cli scripts/gallery-component.js ...

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

cd "$REPO_ROOT"

exec tools/v8cli scripts/gallery-component.js "$@"
