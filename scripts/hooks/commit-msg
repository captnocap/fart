#!/bin/bash
# commit-msg: block casual edits to hardened framework files unless the commit
# message contains `[hardened-ok]`.
#
# Why commit-msg (not pre-commit): pre-commit fires before the message is
# finalized, so `-m "..."` commits can't be reliably inspected there.
# commit-msg receives the final message file as $1 — always correct.
#
# Hardened list lives in .hardened-paths (prefix match against staged paths).

set -euo pipefail

MSG_FILE="$1"
REPO_ROOT="$(git rev-parse --show-toplevel)"
HARDENED_FILE="$REPO_ROOT/.hardened-paths"
[ -f "$HARDENED_FILE" ] || exit 0

mapfile -t HARDENED < <(grep -v '^\s*#' "$HARDENED_FILE" | grep -v '^\s*$')
[ "${#HARDENED[@]}" -gt 0 ] || exit 0

STAGED="$(git diff --cached --name-only --diff-filter=ACMDR)"
[ -n "$STAGED" ] || exit 0

TOUCHED=()
while IFS= read -r path; do
    for prefix in "${HARDENED[@]}"; do
        if [[ "$path" == "$prefix"* ]]; then
            TOUCHED+=("$path (matches '$prefix')")
            break
        fi
    done
done <<< "$STAGED"

[ "${#TOUCHED[@]}" -eq 0 ] && exit 0

if ! grep -q '\[hardened-ok\]' "$MSG_FILE"; then
    echo "================================================"
    echo "  BLOCKED: commit touches hardened path(s)"
    echo "================================================"
    printf '  %s\n' "${TOUCHED[@]}"
    echo
    echo "  These files have outsized blast radius. A careless"
    echo "  edit has burned real debugging time here before."
    echo "  If you have justified the change, include the token"
    echo
    echo "    [hardened-ok]"
    echo
    echo "  somewhere in your commit message."
    echo
    echo "  List lives in .hardened-paths"
    echo "================================================"
    exit 1
fi
