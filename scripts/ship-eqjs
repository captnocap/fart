#!/usr/bin/env bash
# ship-eqjs — build cursor-ide under the EQJS (LuaJIT) backend and launch it.
#
# Requires the pre-compiled Lua bundle at:
#   /home/siah/eqjs/generated/cursor-ide-boot/boot_bundle.lua
#   /home/siah/eqjs/compiler/cursor_ide_boot_runtime.lua
#
# Usage:
#   scripts/ship-eqjs                   # release build
#   scripts/ship-eqjs -d                # debug build

set -euo pipefail
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

DEBUG=0
for arg in "${@}"; do
    case "$arg" in -d|--debug) DEBUG=1 ;; esac
done

OPT_FLAG="-Doptimize=ReleaseFast"
[[ "$DEBUG" -eq 1 ]] && OPT_FLAG="-Doptimize=Debug"

echo "[ship-eqjs] building cursor-ide-eqjs..."
zig build app -Dapp-name=cursor-ide-eqjs -Dapp-source=cursor_ide_eqjs_app.zig $OPT_FLAG

echo "[ship-eqjs] launching cursor-ide under --backend=eqjs"
exec ./zig-out/bin/cursor-ide-eqjs
