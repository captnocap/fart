import React, { useState } from 'react';
import './Chat.css';

const Chat = () => {
  const [messages, setMessages] = useState([
    { id: 1, author: "User", text: "Hello there!", timestamp: new Date().toLocaleTimeString() },
    { id: 2, author: "Bot", text: "Hi! How can I assist you?", timestamp: new Date().toLocaleTimeString() }
  ]);
  const [newMessage, setNewMessage] = useState('');
  const [align, setAlign] = useState('left');

  const handleAddMessage = () => {
    if (newMessage.trim()) {
      setMessages([
        ...messages,
        { id: messages.length + 1, author: align === 'left' ? "User" : "Bot", text: newMessage, timestamp: new Date().toLocaleTimeString() }
      ]);
      setNewMessage('');
    }
  };

  const handleAlignLeft = () => {
    setAlign('left');
  };

  const handleAlignRight = () => {
    setAlign('right');
  };

  return (
    <div className="container">
      <h2>Chat Interface</h2>

      {messages.map((message) => (
        <div key={message.id} className={`message ${align}`}>
          <div className="header">{message.author}</div>
          <div className="text">{message.text}</div>
          <div className="timestamp">{message.timestamp}</div>
        </div>
      ))}

      <input
        type="text"
        value={newMessage}
        onChange={(e) => setNewMessage(e.target.value)}
      />
      <button onClick={handleAddMessage}>Send</button>

      <button onClick={handleAlignLeft}>Align Left</button>
      <button onClick={handleAlignRight}>Align Right</button>
    </div>
  );
};

export default Chat;

