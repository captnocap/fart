export class Pipeline<T> {
  constructor(private data: T[]) {}

  map(fn: (x: T) => any) {
    return new Pipeline(this.data.map(fn));
  }

  filter(fn: (x: T) => boolean) {
    return new Pipeline(this.data.filter(fn));
  }

  take(n: number) {
    return new Pipeline(this.data.slice(0, n));
  }

  collect() {
    return this.data;
  }
}

// usage
