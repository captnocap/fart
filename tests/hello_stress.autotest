# hello_stress: wider bridge smoke for JSRT -> reconciler -> engine.
# Exercises ten independent state updates instead of a single toy counter.

# Initial render
expect "hello stress"
expect "10 useState counters arranged as a grid."
expect "counter 1: 0"
expect "counter 10: 0"

# Counter updates
click "counter 1: 0"
expect "counter 1: 1"

click "counter 2: 0"
expect "counter 2: 1"

click "counter 3: 0"
expect "counter 3: 1"

click "counter 4: 0"
expect "counter 4: 1"

click "counter 5: 0"
expect "counter 5: 1"

click "counter 6: 0"
expect "counter 6: 1"

click "counter 7: 0"
expect "counter 7: 1"

click "counter 8: 0"
expect "counter 8: 1"

click "counter 9: 0"
expect "counter 9: 1"

click "counter 10: 0"
expect "counter 10: 1"
