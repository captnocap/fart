// ChatCard — conversation view driven by props from cockpit.app.tsz.
// Messages flow in from __claude_poll() events; slot 0..msgCount-1 hold
// the active conversation, shifted when we overflow MAX_MSGS.
//
// NOTE: the compiler currently collapses functions with multiple early
// returns to always pick the first branch. Block uses a single return
// with conditional children so each kind renders correctly.

// Three stand-alone Block variants — one per layout family.
// Keep them as block messages, not bubbles, because the compiler is still
// touchy around style ternaries and the UI reads better as stacked log rows.

function BlockUser(props) {
  return (
    <C.MsgRow>
      <C.MsgBlockUser>
        <C.MsgAuthorUser>you</C.MsgAuthorUser>
        <C.MsgTextUser>{props.text}</C.MsgTextUser>
      </C.MsgBlockUser>
    </C.MsgRow>
  );
}

function BlockAssistant(props) {
  const isAssistant = props.kind == 'assistant';
  const isThinking = props.kind == 'thinking';
  const isTool = props.kind == 'tool';
  const isResult = props.kind == 'result';
  return (
    <C.MsgRow>
      <C.MsgBlockAssistant>
        {isAssistant && <C.MsgAuthorAssistant>agent</C.MsgAuthorAssistant>}
        {isThinking && <C.MsgAuthorMeta>thinking</C.MsgAuthorMeta>}
        {isTool && <C.MsgAuthorMeta>tool</C.MsgAuthorMeta>}
        {isResult && <C.MsgAuthorMeta>result</C.MsgAuthorMeta>}
        <C.MsgText>{props.text}</C.MsgText>
      </C.MsgBlockAssistant>
    </C.MsgRow>
  );
}

function BlockSystem(props) {
  return (
    <C.MsgRow>
      <C.MsgBlockSystem>
        <C.MsgSystemLine>{props.text}</C.MsgSystemLine>
      </C.MsgBlockSystem>
    </C.MsgRow>
  );
}

// Block is flattened into a single row always emitting ONE MsgRow. The
// author label and bubble body are chosen inline per kind. A dispatcher
// with conditional whole-component children caused nil-gap children in
// the emitted Lua table, and the layout collapsed siblings onto each
// other. Keeping every slot as one unconditional MsgRow whose INTERNAL
// conditionals pick the bubble avoids that shape.
// ONE unconditional bubble per slot. No kind-based bubble dispatch at the
// outer level — the compiler's conditional-children emit gets nil-gaps
// that break sibling stacking. Only the inline author label varies; the
// bubble Box + MsgText body are always present.
function Block(props) {
  const kind = props.kind;
  const isUser = kind == 'user';
  const isAssistant = kind == 'assistant';
  const isThinking = kind == 'thinking';
  const isTool = kind == 'tool';
  const isResult = kind == 'result';
  const isSystem = kind == 'system';
  return (
    <C.MsgBlockAssistant>
      {isUser && <C.MsgAuthorUser>you</C.MsgAuthorUser>}
      {isAssistant && <C.MsgAuthorAssistant>agent</C.MsgAuthorAssistant>}
      {isThinking && <C.MsgAuthorMeta>thinking</C.MsgAuthorMeta>}
      {isTool && <C.MsgAuthorMeta>tool</C.MsgAuthorMeta>}
      {isResult && <C.MsgAuthorMeta>result</C.MsgAuthorMeta>}
      {isSystem && <C.MsgAuthorMeta>system</C.MsgAuthorMeta>}
      <C.MsgText>{props.text}</C.MsgText>
    </C.MsgBlockAssistant>
  );
}

function SpawnButton(props) {
  return (
    <C.SpawnButton hoverable={1} onPress={props.onPress}>
      <C.SpawnButtonTop>
        <C.SpawnButtonProvider>{props.provider}</C.SpawnButtonProvider>
        <C.SpawnButtonBadge>{props.badge}</C.SpawnButtonBadge>
      </C.SpawnButtonTop>
      <C.SpawnButtonNameWrap>
        <C.SpawnButtonName>{props.name}</C.SpawnButtonName>
      </C.SpawnButtonNameWrap>
      <C.SpawnButtonModel>{props.model}</C.SpawnButtonModel>
      <C.SpawnButtonMeta>{props.meta}</C.SpawnButtonMeta>
    </C.SpawnButton>
  );
}

function SpawnPanel(props) {
  return (
    <C.SpawnPanel>
      <C.SpawnPanelHeader>
        <C.SpawnPanelTitle>spawn agent</C.SpawnPanelTitle>
        <C.SpawnPanelStatus>{props.statusText}</C.SpawnPanelStatus>
      </C.SpawnPanelHeader>
      <C.SpawnPanelGrid>
        <SpawnButton
          provider="Claude"
          name="Opus 4.7"
          badge="live"
          model="claude-opus-4-7"
          meta="Deep reasoning"
          onPress={props.onSpawnClaudeOpus}
        />
        <SpawnButton
          provider="Claude"
          name="Sonnet 4.6"
          badge="live"
          model="claude-sonnet-4-6"
          meta="Default coding lane"
          onPress={props.onSpawnClaudeSonnet}
        />
        <SpawnButton
          provider="Claude"
          name="Haiku 4.5"
          badge="live"
          model="claude-haiku-4-5"
          meta="Fastest Claude"
          onPress={props.onSpawnClaudeHaiku}
        />
        <SpawnButton
          provider="Kimi"
          name="K2.5"
          badge="live"
          model="kimi-k2.5"
          meta="Current flagship"
          onPress={props.onSpawnKimiK25}
        />
        <SpawnButton
          provider="Kimi"
          name="K2"
          badge="live"
          model="kimi-k2"
          meta="Base code model"
          onPress={props.onSpawnKimiK2}
        />
        <SpawnButton
          provider="Kimi"
          name="K2 Thinking"
          badge="live"
          model="kimi-k2-thinking"
          meta="Longer reasoning"
          onPress={props.onSpawnKimiThinking}
        />
        <SpawnButton
          provider="OpenAI"
          name="GPT-5-Codex"
          badge="soon"
          model="gpt-5-codex"
          meta="Agentic coding"
          onPress={props.onSpawnGpt5Codex}
        />
        <SpawnButton
          provider="OpenAI"
          name="GPT-5.4"
          badge="soon"
          model="gpt-5.4"
          meta="Frontier general"
          onPress={props.onSpawnGpt54}
        />
        <SpawnButton
          provider="OpenAI"
          name="GPT-5.4 mini"
          badge="soon"
          model="gpt-5.4-mini"
          meta="Fast subagent"
          onPress={props.onSpawnGpt54Mini}
        />
        <SpawnButton
          provider="Gemini"
          name="Gemini 2.5 Pro"
          badge="soon"
          model="gemini-2.5-pro"
          meta="Deep reasoning"
          onPress={props.onSpawnGeminiPro}
        />
        <SpawnButton
          provider="Gemini"
          name="Gemini 2.5 Flash"
          badge="soon"
          model="gemini-2.5-flash"
          meta="Fast reasoning"
          onPress={props.onSpawnGeminiFlash}
        />
        <SpawnButton
          provider="Gemini"
          name="Gemini 2.5 Flash-Lite"
          badge="soon"
          model="gemini-2.5-flash-lite"
          meta="Budget lane"
          onPress={props.onSpawnGeminiFlashLite}
        />
        <SpawnButton
          provider="OpenAI"
          name="Codex"
          badge="soon"
          model="offline"
          meta="CLI lane pending"
          onPress={props.onSpawnCodexLegacy}
        />
      </C.SpawnPanelGrid>
    </C.SpawnPanel>
  );
}

export function ChatCard(props) {
  return (
    <C.MsgCard>
      <C.MsgHeader>
        <C.HeaderAvatar>
          <C.HeaderAvatarLetter>{props.backendLetter || 'W'}</C.HeaderAvatarLetter>
        </C.HeaderAvatar>
        <C.HeaderTextCol>
          <C.HeaderName>{props.backendLabel || 'Worker'}</C.HeaderName>
          <C.HeaderModel>{props.modelLabel || 'no model selected'}</C.HeaderModel>
        </C.HeaderTextCol>
        {props.isStreaming == 1 && <C.HeaderStatusDot />}
      </C.MsgHeader>

      <C.MsgBody>
        <SpawnPanel
          statusText={props.spawnStatusText}
          onSpawnClaudeOpus={props.onSpawnClaudeOpus}
          onSpawnClaudeSonnet={props.onSpawnClaudeSonnet}
          onSpawnClaudeHaiku={props.onSpawnClaudeHaiku}
          onSpawnKimiK25={props.onSpawnKimiK25}
          onSpawnKimiK2={props.onSpawnKimiK2}
          onSpawnKimiThinking={props.onSpawnKimiThinking}
          onSpawnGpt5Codex={props.onSpawnGpt5Codex}
          onSpawnGpt54={props.onSpawnGpt54}
          onSpawnGpt54Mini={props.onSpawnGpt54Mini}
          onSpawnGeminiPro={props.onSpawnGeminiPro}
          onSpawnGeminiFlash={props.onSpawnGeminiFlash}
          onSpawnGeminiFlashLite={props.onSpawnGeminiFlashLite}
          onSpawnCodexLegacy={props.onSpawnCodexLegacy}
        />
        <ScrollView style={{ flexGrow: 1, flexBasis: 0 }}>
          <C.MsgStack>
          {props.mk0 != '' && <Block kind={props.mk0} text={props.mt0} />}
          {props.mk1 != '' && <Block kind={props.mk1} text={props.mt1} />}
          {props.mk2 != '' && <Block kind={props.mk2} text={props.mt2} />}
          {props.mk3 != '' && <Block kind={props.mk3} text={props.mt3} />}
          {props.mk4 != '' && <Block kind={props.mk4} text={props.mt4} />}
          {props.mk5 != '' && <Block kind={props.mk5} text={props.mt5} />}
          {props.mk6 != '' && <Block kind={props.mk6} text={props.mt6} />}
          {props.mk7 != '' && <Block kind={props.mk7} text={props.mt7} />}
          {props.mk8 != '' && <Block kind={props.mk8} text={props.mt8} />}
          {props.mk9 != '' && <Block kind={props.mk9} text={props.mt9} />}
          {props.mk10 != '' && <Block kind={props.mk10} text={props.mt10} />}
          {props.mk11 != '' && <Block kind={props.mk11} text={props.mt11} />}
          {props.mk12 != '' && <Block kind={props.mk12} text={props.mt12} />}
          {props.mk13 != '' && <Block kind={props.mk13} text={props.mt13} />}
          {props.mk14 != '' && <Block kind={props.mk14} text={props.mt14} />}
          {props.mk15 != '' && <Block kind={props.mk15} text={props.mt15} />}
          {props.mk16 != '' && <Block kind={props.mk16} text={props.mt16} />}
          {props.mk17 != '' && <Block kind={props.mk17} text={props.mt17} />}
          {props.mk18 != '' && <Block kind={props.mk18} text={props.mt18} />}
          {props.mk19 != '' && <Block kind={props.mk19} text={props.mt19} />}
          </C.MsgStack>
        </ScrollView>
      </C.MsgBody>

      <C.MsgFoot>
        <C.MsgFootLabelRow>
          <C.MsgFootLabel>{props.turnText}</C.MsgFootLabel>
          <C.Spacer />
          <C.MsgFootValue>{props.costText}</C.MsgFootValue>
        </C.MsgFootLabelRow>
      </C.MsgFoot>
    </C.MsgCard>
  );
}
