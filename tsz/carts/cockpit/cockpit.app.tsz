import { _cockpitDawnAnchor } from './theme/cockpit_dawn.tcls';
import { _cockpitDuskAnchor } from './theme/cockpit_dusk.tcls';
import { _cockpitClarityAnchor } from './theme/cockpit_clarity.tcls';
import { _cockpitBsodAnchor } from './theme/cockpit_bsod.tcls';
import { Root as _clsAnchor } from './style_cls';
import { ChatFrame } from './ChatFrame.c';
import { RaidFrame, RaidFrameEmpty } from './RaidFrame.c';
import { QuestCard } from './QuestLog.c';

// Variant indices match tcls import order: 0 dawn | 1 dusk | 2 clarity | 3 bsod
const THEME_NAMES = ['dawn', 'dusk', 'clarity', 'bsod'];

// ── Worker chat state ──────────────────────────────────────────────────────
const [initState, setInitState] = useState(0); // 0 = idle, 1 = ok, 2 = error
const [selectedBackend, setSelectedBackend] = useState('');
const [selectedModel, setSelectedModel] = useState('');
const [activeBackend, setActiveBackend] = useState('');
const [activeModel, setActiveModel] = useState('');
const [sessionId, setSessionId] = useState('');
const [turnCount, setTurnCount] = useState(0);
const [turnText, setTurnText] = useState('turns 0');
const [totalCost, setTotalCost] = useState(0);
const [costText, setCostText] = useState('$0.0000');
const [isStreaming, setIsStreaming] = useState(0);
const [actionFlash, setActionFlash] = useState(0);
const [hoveredAction, setHoveredAction] = useState(0);

// ── Raid-frame targeting ────────────────────────────────────────────────
// One Canvas.Node today (gx=24,gy=24,gw=500,gh=460 → center 274,254).
// Raid-frame clicks pan the camera onto the matching node center.
const [targetAgentId, setTargetAgentId] = useState('claude-0');
const [viewX, setViewX] = useState(274);
const [viewY, setViewY] = useState(254);
const [viewZoom, setViewZoom] = useState(1);

// ── Quest log ───────────────────────────────────────────────────────────
// Seeded from .sweatshop/supervisor.db for now via hand-mirrored hardcoded
// props. Live sqlite read comes in quest-log-tile step 7. Only one card
// expanded at a time — toggles by id.
const [expandedQuestId, setExpandedQuestId] = useState('');

// 20 message slots — kind + text per slot, count tracks populated slots.
// Kinds: 'user' | 'assistant' | 'thinking' | 'tool' | 'result' | 'system' | ''
const [msgCount, setMsgCount] = useState(0);
const [mk0, setMk0] = useState(''); const [mt0, setMt0] = useState('');
const [mk1, setMk1] = useState(''); const [mt1, setMt1] = useState('');
const [mk2, setMk2] = useState(''); const [mt2, setMt2] = useState('');
const [mk3, setMk3] = useState(''); const [mt3, setMt3] = useState('');
const [mk4, setMk4] = useState(''); const [mt4, setMt4] = useState('');
const [mk5, setMk5] = useState(''); const [mt5, setMt5] = useState('');
const [mk6, setMk6] = useState(''); const [mt6, setMt6] = useState('');
const [mk7, setMk7] = useState(''); const [mt7, setMt7] = useState('');
const [mk8, setMk8] = useState(''); const [mt8, setMt8] = useState('');
const [mk9, setMk9] = useState(''); const [mt9, setMt9] = useState('');
const [mk10, setMk10] = useState(''); const [mt10, setMt10] = useState('');
const [mk11, setMk11] = useState(''); const [mt11, setMt11] = useState('');
const [mk12, setMk12] = useState(''); const [mt12, setMt12] = useState('');
const [mk13, setMk13] = useState(''); const [mt13, setMt13] = useState('');
const [mk14, setMk14] = useState(''); const [mt14, setMt14] = useState('');
const [mk15, setMk15] = useState(''); const [mt15, setMt15] = useState('');
const [mk16, setMk16] = useState(''); const [mt16, setMt16] = useState('');
const [mk17, setMk17] = useState(''); const [mt17, setMt17] = useState('');
const [mk18, setMk18] = useState(''); const [mt18, setMt18] = useState('');
const [mk19, setMk19] = useState(''); const [mt19, setMt19] = useState('');

<script>
var MAX_MSGS = 20;
var _hotbarBound = false;
var _turnsCounter = 0;
var _booted = false;
var COMMAND_HELP = 'commands: /use <claude|kimi|local> <model> | /backend <claude|kimi|local> | /model <model> | /connect | /disconnect | /status | /help';

var ACTIONS = [
  { key: '1', chord: 'Ctrl+1', icon: '✦', label: 'scan' },
  { key: '2', chord: 'Ctrl+2', icon: '⌘', label: 'plan' },
  { key: '3', chord: 'Ctrl+3', icon: '⌖', label: 'patch' },
  { key: '4', chord: 'Ctrl+4', icon: '◈', label: 'audit' },
  { key: '5', chord: 'Ctrl+5', icon: '✧', label: 'ship' },
  { key: '6', chord: 'Ctrl+6', icon: '⬢', label: 'clear' },
];


// Write kind+text into slot i via setters arrays.
var sK = [setMk0,setMk1,setMk2,setMk3,setMk4,setMk5,setMk6,setMk7,setMk8,setMk9,
         setMk10,setMk11,setMk12,setMk13,setMk14,setMk15,setMk16,setMk17,setMk18,setMk19];
var sT = [setMt0,setMt1,setMt2,setMt3,setMt4,setMt5,setMt6,setMt7,setMt8,setMt9,
         setMt10,setMt11,setMt12,setMt13,setMt14,setMt15,setMt16,setMt17,setMt18,setMt19];
var gK = function(i) { return [mk0,mk1,mk2,mk3,mk4,mk5,mk6,mk7,mk8,mk9,
                               mk10,mk11,mk12,mk13,mk14,mk15,mk16,mk17,mk18,mk19][i]; };
var gT = function(i) { return [mt0,mt1,mt2,mt3,mt4,mt5,mt6,mt7,mt8,mt9,
                               mt10,mt11,mt12,mt13,mt14,mt15,mt16,mt17,mt18,mt19][i]; };

function appendMsg(kind, text) {
  var n = msgCount;
  if (n >= MAX_MSGS) {
    var i = 0;
    while (i < MAX_MSGS - 1) {
      sK[i](gK(i + 1));
      sT[i](gT(i + 1));
      i = i + 1;
    }
    sK[MAX_MSGS - 1](kind);
    sT[MAX_MSGS - 1](text);
    return;
  }
  sK[n](kind);
  sT[n](text);
  setMsgCount(n + 1);
}

function appendToLastAssistant(delta) {
  var n = msgCount;
  if (n == 0) { appendMsg('assistant', delta); return; }
  var lastIdx = n - 1;
  if (gK(lastIdx) != 'assistant') { appendMsg('assistant', delta); return; }
  sT[lastIdx](gT(lastIdx) + delta);
}

function trimText(text) {
  return (text || '').trim();
}

function splitWords(text) {
  var raw = trimText(text).split(' ');
  var out = [];
  var i = 0;
  while (i < raw.length) {
    if (raw[i] && raw[i].length > 0) out.push(raw[i]);
    i = i + 1;
  }
  return out;
}

function joinWords(parts, start) {
  var out = '';
  var i = start;
  while (i < parts.length) {
    if (i > start) out = out + ' ';
    out = out + parts[i];
    i = i + 1;
  }
  return trimText(out);
}

function normalizeBackend(name) {
  var lower = trimText(name).toLowerCase();
  if (lower == 'claude' || lower == 'anthropic') return 'claude';
  if (lower == 'kimi' || lower == 'moonshot') return 'kimi';
  if (lower == 'local' || lower == 'llama' || lower == 'qwen' || lower == 'localai') return 'local';
  return '';
}

function backendDisplayName(name) {
  if (name == 'claude') return 'Claude';
  if (name == 'kimi') return 'Kimi';
  if (name == 'local') return 'Local';
  return 'Worker';
}

function backendModelShortLabel(backendName, model) {
  var backend = normalizeBackend(backendName);
  var clean = trimText(model);
  if (!clean) return '';
  if (backend == 'claude' && clean == 'claude-opus-4-7') return 'Opus 4.7';
  if (backend == 'claude' && clean == 'claude-sonnet-4-6') return 'Sonnet 4.6';
  if (backend == 'claude' && clean == 'claude-haiku-4-5') return 'Haiku 4.5';
  if (backend == 'kimi' && clean == 'kimi-k2.5') return 'K2.5';
  if (backend == 'kimi' && clean == 'kimi-k2') return 'K2';
  if (backend == 'kimi' && clean == 'kimi-k2-thinking') return 'K2 Thinking';
  return modelDisplayLabel(backend, clean);
}


function backendLetter(name) {
  if (name == 'claude') return 'C';
  if (name == 'kimi') return 'K';
  if (name == 'local') return 'L';
  return 'W';
}

function modelDisplayLabel(backendName, model) {
  var clean = trimText(model);
  if (!clean) return '';
  if (normalizeBackend(backendName) != 'local') return clean;
  var lastSep = -1;
  var i = 0;
  while (i < clean.length) {
    var cc = clean.charCodeAt(i);
    if (cc == 47 || cc == 92) lastSep = i;
    i = i + 1;
  }
  if (lastSep >= 0 && lastSep + 1 < clean.length) return clean.substring(lastSep + 1);
  return clean;
}

function selectedOrActiveBackend() {
  return activeBackend || selectedBackend;
}

function selectedOrActiveModel() {
  return activeModel || selectedModel;
}

function paneLabelText() {
  var backend = selectedOrActiveBackend();
  var model = selectedOrActiveModel();
  var modelLabel = modelDisplayLabel(backend, model);
  if (!backend && !model) return 'unconfigured';
  if (backend && modelLabel) return backendDisplayName(backend) + ' · ' + modelLabel;
  if (backend) return backendDisplayName(backend);
  return modelLabel;
}

function spawnStatusText() {
  if (initState == 1) {
    return 'active ' + backendDisplayName(activeBackend) + ' · ' + (backendModelShortLabel(activeBackend, activeModel) || activeModel || 'ready');
  }
  if (initState == 2) return 'last launch failed';
  return 'click a lane to launch';
}

function inputPlaceholder() {
  if (!selectedBackend || !selectedModel) {
    return 'set backend + model with /use <claude|kimi|local> <model>';
  }
  if (initState == 2) return 'connection failed - is the CLI on PATH?';
  if (isStreaming == 1) return 'streaming ' + backendDisplayName(selectedOrActiveBackend()).toLowerCase() + '...';
  if (initState == 1) return 'ask ' + backendDisplayName(selectedOrActiveBackend()).toLowerCase() + '...';
  return 'press send or Enter to connect ' + backendDisplayName(selectedBackend).toLowerCase() + '...';
}

function spawnPreset(backendName, modelName, agentId, x, y, zoom) {
  setSelectedBackend(backendName);
  setSelectedModel(modelName);
  setTargetAgentId(agentId);
  setViewX(x);
  setViewY(y);
  setViewZoom(zoom);
  connectBackend(backendName, modelName, 1);
}

function announceUnavailable(providerName, modelName) {
  appendMsg('system', providerName + ' lane not wired yet · ' + modelName);
}


function currentWorkDir() {
  return __getenv('PWD') || __getenv('HOME') || '/tmp';
}

function closeActiveSession(announce) {
  var backend = activeBackend;
  if (backend == 'claude') {
    __claude_close();
  } else if (backend == 'kimi') {
    __kimi_close();
  } else if (backend == 'local') {
    __localai_close();
  }
  if (backend && announce) appendMsg('system', 'disconnected ' + backendDisplayName(backend));
  setActiveBackend('');
  setActiveModel('');
  setSessionId('');
  setInitState(0);
  setIsStreaming(0);
}

function connectBackend(backendName, modelName, announce) {
  var backend = normalizeBackend(backendName);
  var model = trimText(modelName);
  if (!backend) {
    appendMsg('system', 'unknown backend: ' + backendName);
    setInitState(2);
    return 0;
  }
  if (!model) {
    appendMsg('system', 'select a model first with /model <model> or /use ' + backend + ' <model>');
    setInitState(0);
    return 0;
  }
  if (initState == 1 && activeBackend == backend && activeModel == model) return 1;
  if (activeBackend && (activeBackend != backend || activeModel != model)) {
    closeActiveSession(announce);
  }

  var cwd = currentWorkDir();
  var ok = 0;
  if (backend == 'claude') {
    ok = __claude_init(cwd, model);
  } else if (backend == 'kimi') {
    ok = __kimi_init(cwd, model);
  } else if (backend == 'local') {
    ok = __localai_init(cwd, model);
  }
  setSelectedBackend(backend);
  setSelectedModel(model);
  setInitState(ok ? 1 : 2);

  if (ok) {
    setActiveBackend(backend);
    setActiveModel(model);
    setSessionId('');
    if (announce) appendMsg('system', 'connected ' + backendDisplayName(backend) + ' · ' + model);
    return 1;
  }

  setActiveBackend('');
  setActiveModel('');
  setSessionId('');
  setIsStreaming(0);
  appendMsg('system', 'failed to start ' + backendDisplayName(backend) + ' · ' + model);
  return 0;
}

function ensureConnected(announce) {
  var backend = normalizeBackend(selectedBackend);
  var model = trimText(selectedModel);
  if (!backend || !model) {
    appendMsg('system', 'set backend + model first with /use <claude|kimi|local> <model>');
    return '';
  }
  if (initState == 1 && activeBackend == backend && activeModel == model) return backend;
  if (connectBackend(backend, model, announce)) return backend;
  return '';
}

function statusLine() {
  var state = initState == 1 ? 'connected' : initState == 2 ? 'error' : 'idle';
  var selectedModelLabel = modelDisplayLabel(selectedBackend, selectedModel) || 'none';
  var activeModelLabel = modelDisplayLabel(activeBackend, activeModel) || 'none';
  var selected = (selectedBackend ? backendDisplayName(selectedBackend) : 'none') + ' / ' + selectedModelLabel;
  var active = activeBackend ? backendDisplayName(activeBackend) + ' / ' + activeModelLabel : 'none';
  var sid = sessionId || 'n/a';
  return 'state ' + state + ' | selected ' + selected + ' | active ' + active + ' | session ' + sid;
}

function finishTurn(nextCost) {
  setIsStreaming(0);
  _turnsCounter = _turnsCounter + 1;
  setTurnCount(_turnsCounter);
  setTurnText('turns ' + _turnsCounter);
  setTotalCost(nextCost);
  setCostText('$' + nextCost.toFixed(4));
}

function handleClaudeEvent(evt) {
  if (evt.type == 'system') {
    if (evt.model) {
      setSelectedModel(evt.model);
      setActiveModel(evt.model);
    }
    if (evt.session_id) setSessionId(evt.session_id);
    return;
  }

  if (evt.type == 'assistant') {
    var blocks = evt.content || [];
    var i = 0;
    while (i < blocks.length) {
      var b = blocks[i];
      if (b.type == 'text') {
        var t = b.text || '';
        var s = 0;
        while (s < t.length) {
          var cc = t.charCodeAt(s);
          if (cc != 10 && cc != 13 && cc != 32 && cc != 9) break;
          s = s + 1;
        }
        var e = t.length;
        while (e > s) {
          var cc2 = t.charCodeAt(e - 1);
          if (cc2 != 10 && cc2 != 13 && cc2 != 32 && cc2 != 9) break;
          e = e - 1;
        }
        if (e > s) appendToLastAssistant(t.substring(s, e));
      } else if (b.type == 'thinking') {
        appendMsg('thinking', b.thinking);
      } else if (b.type == 'tool_use') {
        appendMsg('tool', b.name + '(' + b.input_json + ')');
      }
      i = i + 1;
    }
    return;
  }

  if (evt.type == 'result') {
    finishTurn(evt.total_cost_usd || 0);
    if (evt.is_error && evt.result) appendMsg('result', 'error: ' + evt.result);
  }
}

function handleKimiEvent(evt) {
  if (evt.type == 'assistant_part') {
    if (evt.part_type == 'text' && evt.text) {
      appendToLastAssistant(evt.text);
    } else if (evt.part_type == 'thinking' && evt.text) {
      appendMsg('thinking', evt.text);
    }
    return;
  }

  if (evt.type == 'tool_call') {
    var toolLine = evt.name || 'tool';
    if (evt.input_json) toolLine = toolLine + '(' + evt.input_json + ')';
    appendMsg('tool', toolLine);
    return;
  }

  if (evt.type == 'tool_result') {
    var resultLine = evt.text || 'tool result';
    appendMsg('result', evt.is_error ? 'error: ' + resultLine : resultLine);
    return;
  }

  if (evt.type == 'status') {
    if (evt.text) appendMsg(evt.is_error ? 'result' : 'system', evt.is_error ? 'error: ' + evt.text : evt.text);
    return;
  }

  if (evt.type == 'result') {
    finishTurn(totalCost || 0);
    if (evt.is_error && evt.result) appendMsg('result', 'error: ' + evt.result);
  }
}

function handleLocalEvent(evt) {
  if (evt.type == 'system') {
    if (evt.model) {
      setSelectedModel(evt.model);
      setActiveModel(evt.model);
    }
    if (evt.session_id) setSessionId(evt.session_id);
    return;
  }

  if (evt.type == 'assistant_part') {
    if (evt.part_type == 'text' && evt.text) appendToLastAssistant(evt.text);
    return;
  }

  if (evt.type == 'status') {
    if (evt.text) appendMsg(evt.is_error ? 'result' : 'system', evt.is_error ? 'error: ' + evt.text : evt.text);
    return;
  }

  if (evt.type == 'result') {
    finishTurn(totalCost || 0);
    if (evt.is_error && evt.result) appendMsg('result', 'error: ' + evt.result);
  }
}

function handleChatCommand(text) {
  var parts = splitWords(text);
  if (parts.length == 0) return;

  var cmd = parts[0].toLowerCase();
  if (cmd == '/use') {
    if (parts.length < 3) {
      appendMsg('system', 'usage: /use <claude|kimi|local> <model>');
      return;
    }
    var backend = normalizeBackend(parts[1]);
    if (!backend) {
      appendMsg('system', 'unknown backend: ' + parts[1]);
      return;
    }
    var model = joinWords(parts, 2);
    setSelectedBackend(backend);
    setSelectedModel(model);
    connectBackend(backend, model, 1);
    return;
  }

  if (cmd == '/backend') {
    if (parts.length < 2) {
      appendMsg('system', 'usage: /backend <claude|kimi|local>');
      return;
    }
    var backend2 = normalizeBackend(parts[1]);
    if (!backend2) {
      appendMsg('system', 'unknown backend: ' + parts[1]);
      return;
    }
    setSelectedBackend(backend2);
    appendMsg('system', 'backend set to ' + backendDisplayName(backend2));
    return;
  }

  if (cmd == '/model') {
    if (parts.length < 2) {
      appendMsg('system', 'usage: /model <model>');
      return;
    }
    var model2 = joinWords(parts, 1);
    setSelectedModel(model2);
    appendMsg('system', 'model set to ' + model2);
    return;
  }

  if (cmd == '/connect') {
    ensureConnected(1);
    return;
  }

  if (cmd == '/disconnect') {
    closeActiveSession(1);
    return;
  }

  if (cmd == '/status') {
    appendMsg('system', statusLine());
    return;
  }

  if (cmd == '/help') {
    appendMsg('system', COMMAND_HELP);
    return;
  }

  appendMsg('system', 'unknown command: ' + cmd);
  appendMsg('system', COMMAND_HELP);
}

function handleChatInput(text) {
  var clean = trimText(text);
  if (!clean) return;

  if (clean.charCodeAt(0) == 47) {
    handleChatCommand(clean);
    __setInputText(0, '');
    return;
  }

  var backend = ensureConnected(1);
  if (!backend) return;

  appendMsg('user', clean);
  var ok = 0;
  if (backend == 'claude') {
    ok = __claude_send(clean);
  } else if (backend == 'kimi') {
    ok = __kimi_send(clean);
  } else if (backend == 'local') {
    ok = __localai_send(clean);
  }
  if (!ok) {
    appendMsg('result', 'error: send failed');
    setIsStreaming(0);
    return;
  }

  __setInputText(0, '');
  setIsStreaming(1);
}

function submitCurrentInput() {
  var text = getInputText(0) || '';
  handleChatInput(text);
}

function primeAction(slot) {
  var idx = slot - 1;
  if (idx < 0 || idx >= ACTIONS.length) return;
  if (slot == 6) {
    __setInputText(0, '');
  }
  setActionFlash(slot);
  setTimeout(function() {
    setActionFlash(0);
  }, 180);
}

function bindHotbarShortcuts() {
  if (_hotbarBound) return;
  _hotbarBound = true;
  useIFTTT('key:ctrl+1', function() { primeAction(1); });
  useIFTTT('key:ctrl+2', function() { primeAction(2); });
  useIFTTT('key:ctrl+3', function() { primeAction(3); });
  useIFTTT('key:ctrl+4', function() { primeAction(4); });
  useIFTTT('key:ctrl+5', function() { primeAction(5); });
  useIFTTT('key:ctrl+6', function() { primeAction(6); });
  useIFTTT('key:enter', function() { submitCurrentInput(); });
}

function maybeBoot() {
  if (_booted) return;
  _booted = true;
  bindHotbarShortcuts();
}

setInterval(function() {
  maybeBoot();

  var sub = __pollInputSubmit();
  if (sub && sub.id == 0 && sub.text && sub.text.length > 0) {
    handleChatInput(sub.text);
  }

  var drained = 0;
  while (drained < 16) {
    var evt = null;
    if (activeBackend == 'claude') {
      evt = __claude_poll();
    } else if (activeBackend == 'kimi') {
      evt = __kimi_poll();
    } else if (activeBackend == 'local') {
      evt = __localai_poll();
    }
    if (!evt) break;
    drained = drained + 1;

    if (activeBackend == 'claude') {
      handleClaudeEvent(evt);
    } else if (activeBackend == 'kimi') {
      handleKimiEvent(evt);
    } else if (activeBackend == 'local') {
      handleLocalEvent(evt);
    }
  }
}, 16);
</script>

export default function App() {
  const [activeTheme, setActiveTheme] = useState(0);
  const nextTheme = (activeTheme + 1) % 4;
  return (
    <C.Root>
      <C.Shell>
        <C.Page>
          <C.SegmentsRow>
            <C.Segment1 />
            <C.Segment2>
              <C.SegmentFlipLabel>{paneLabelText()}</C.SegmentFlipLabel>
            </C.Segment2>
            <C.Segment3 />
          </C.SegmentsRow>
          <C.PageCanvasWrap>
            <Canvas style={{ flexGrow: 1, flexBasis: 0 }} viewX={viewX} viewY={viewY} viewZoom={viewZoom}>
              <Canvas.Node gx={24} gy={24} gw={500} gh={460}>
                <ChatFrame
                  msgCount={msgCount}
                  mk0={mk0} mt0={mt0} mk1={mk1} mt1={mt1}
                  mk2={mk2} mt2={mt2} mk3={mk3} mt3={mt3}
                  mk4={mk4} mt4={mt4} mk5={mk5} mt5={mt5}
                  mk6={mk6} mt6={mt6} mk7={mk7} mt7={mt7}
                  mk8={mk8} mt8={mt8} mk9={mk9} mt9={mt9}
                  mk10={mk10} mt10={mt10} mk11={mk11} mt11={mt11}
                  mk12={mk12} mt12={mt12} mk13={mk13} mt13={mt13}
                  mk14={mk14} mt14={mt14} mk15={mk15} mt15={mt15}
                  mk16={mk16} mt16={mt16} mk17={mk17} mt17={mt17}
                  mk18={mk18} mt18={mt18} mk19={mk19} mt19={mt19}
                  isStreaming={isStreaming}
                  turnText={turnText}
                  costText={costText}
                  backendLabel={backendDisplayName(selectedOrActiveBackend())}
                  backendLetter={backendLetter(selectedOrActiveBackend())}
                  modelLabel={modelDisplayLabel(selectedOrActiveBackend(), selectedOrActiveModel()) || 'no model selected'}
                  spawnStatusText={spawnStatusText()}
                  onSpawnClaudeOpus={() => { spawnPreset('claude', 'claude-opus-4-7', 'claude-0', 274, 254, 1) }}
                  onSpawnClaudeSonnet={() => { spawnPreset('claude', 'claude-sonnet-4-6', 'claude-0', 274, 254, 1) }}
                  onSpawnClaudeHaiku={() => { spawnPreset('claude', 'claude-haiku-4-5', 'claude-0', 274, 254, 1) }}
                  onSpawnKimiK25={() => { spawnPreset('kimi', 'kimi-k2.5', 'kimi-0', 274, 254, 1) }}
                  onSpawnKimiK2={() => { spawnPreset('kimi', 'kimi-k2', 'kimi-0', 274, 254, 1) }}
                  onSpawnKimiThinking={() => { spawnPreset('kimi', 'kimi-k2-thinking', 'kimi-0', 274, 254, 1) }}
                  onSpawnGpt5Codex={() => { announceUnavailable('OpenAI', 'gpt-5-codex') }}
                  onSpawnGpt54={() => { announceUnavailable('OpenAI', 'gpt-5.4') }}
                  onSpawnGpt54Mini={() => { announceUnavailable('OpenAI', 'gpt-5.4-mini') }}
                  onSpawnGeminiPro={() => { announceUnavailable('Gemini', 'gemini-2.5-pro') }}
                  onSpawnGeminiFlash={() => { announceUnavailable('Gemini', 'gemini-2.5-flash') }}
                  onSpawnGeminiFlashLite={() => { announceUnavailable('Gemini', 'gemini-2.5-flash-lite') }}
                  onSpawnCodexLegacy={() => { announceUnavailable('OpenAI', 'codex') }}
                />
              </Canvas.Node>
              <Canvas.Clamp>
                <Box style={{ flexDirection: 'column', width: '100%', height: '100%' }}>
                  <Box style={{ flexDirection: 'row', flexGrow: 1, flexBasis: 0 }}>
                    <C.RaidColumn>
                      <C.RaidHeader>
                        <C.RaidHeaderText>raid · agents</C.RaidHeaderText>
                      </C.RaidHeader>
                      <RaidFrame
                        active={targetAgentId == 'claude-0' ? 1 : 0}
                        online={initState == 1 ? 1 : 0}
                        name={backendDisplayName(selectedOrActiveBackend()) || 'Claude'}
                        meta={selectedOrActiveModel() || 'unassigned'}
                        classLetter={backendLetter(selectedOrActiveBackend())}
                        classColor="#d97757"
                        hpPct={initState == 1 ? 90 : initState == 2 ? 12 : 50}
                        powerPct={isStreaming == 1 ? 100 : 12}
                        role={isStreaming == 1 ? 'streaming' : initState == 1 ? 'ready' : 'idle'}
                        stat={turnText}
                        onPress={() => { setTargetAgentId('claude-0'); setViewX(274); setViewY(254); setViewZoom(1) }}
                      />
                      <RaidFrameEmpty label="summon codex" onPress={() => { announceUnavailable('OpenAI', 'codex') }} />
                      <RaidFrameEmpty label="summon kimi" onPress={() => { spawnPreset('kimi', 'kimi-k2.5', 'kimi-0', 274, 254, 1) }} />
                    </C.RaidColumn>
                    <Box style={{ flexGrow: 1, flexBasis: 0 }} />
                    <C.QuestColumn>
                      <C.QuestHeader>
                        <C.QuestHeaderText>quest log</C.QuestHeaderText>
                      </C.QuestHeader>
                      <QuestCard
                        title="Ship the cockpit QuestLog tile"
                        state={2}
                        doneCount={6}
                        totalSteps={8}
                        partyCount={2}
                        expanded={expandedQuestId == 'quest-log-tile' ? 1 : 0}
                        onPress={() => { setExpandedQuestId(expandedQuestId == 'quest-log-tile' ? '' : 'quest-log-tile') }}
                        s0_state={6} s0_text="Define the sqlite schema"
                        s1_state={6} s1_text="Write the markdown-to-db ingester"
                        s2_state={6} s2_text="Add QuestLog classifiers"
                        s3_state={6} s3_text="Create QuestLog.c.tsz"
                        s4_state={6} s4_text="Wire QuestLog into the cockpit"
                        s5_state={6} s5_text="Add expand/collapse state"
                        s6_state={2} s6_text="Read live data from sqlite"
                        s7_state={1} s7_text="Postflight end-to-end"
                        s8_state={0}  s8_text=""
                        s9_state={0}  s9_text=""
                        s10_state={0} s10_text=""
                        s11_state={0} s11_text=""
                      />
                      <QuestCard
                        title="Wire real audit-gate transitions"
                        state={1}
                        doneCount={0}
                        totalSteps={5}
                        partyCount={0}
                        expanded={expandedQuestId == 'audit-gate-pips' ? 1 : 0}
                        onPress={() => { setExpandedQuestId(expandedQuestId == 'audit-gate-pips' ? '' : 'audit-gate-pips') }}
                        s0_state={1} s0_text="Materialize verify.sh per step"
                        s1_state={1} s1_text="Add a verify-runner daemon hook"
                        s2_state={1} s2_text="Wire planner re-investigation"
                        s3_state={1} s3_text="Surface rejects in the law ticker"
                        s4_state={1} s4_text="Re-render cockpit on state saves"
                        s5_state={0}  s5_text=""
                        s6_state={0}  s6_text=""
                        s7_state={0}  s7_text=""
                        s8_state={0}  s8_text=""
                        s9_state={0}  s9_text=""
                        s10_state={0} s10_text=""
                        s11_state={0} s11_text=""
                      />
                    </C.QuestColumn>
                  </Box>
                  <C.ActionBar>
                    <C.ActionSlot hoverable={1} tooltip="Prime scan prompt to the input" onPress={() => { primeAction(1) }} onHoverEnter={() => { setHoveredAction(1) }} onHoverExit={() => { setHoveredAction(0) }}>
                      {hoveredAction == 1 && <C.ActionSlotFrameHover style={{
                        scaleX: hoveredAction == 1 ? 1.06 : 1,
                        scaleY: hoveredAction == 1 ? 1.06 : 1,
                        shadowColor: 'theme-warning',
                        shadowBlur: hoveredAction == 1 ? 14 : 0,
                        shadowOffsetY: hoveredAction == 1 ? 2 : 0,
                        transition: {
                          scaleX: { duration: 120, easing: 'easeOut' },
                          scaleY: { duration: 120, easing: 'easeOut' },
                          shadowBlur: { duration: 120, easing: 'easeOut' },
                          shadowOffsetY: { duration: 120, easing: 'easeOut' },
                        },
                      }}>
                        {actionFlash == 1 && <C.ActionSlotGlow />}
                        <C.ActionSlotKey>1</C.ActionSlotKey>
                        <C.ActionSlotGlyph>✦</C.ActionSlotGlyph>
                        <C.ActionSlotLabel>scan</C.ActionSlotLabel>
                      </C.ActionSlotFrameHover>}
                      {hoveredAction != 1 && <C.ActionSlotFrame>
                        {actionFlash == 1 && <C.ActionSlotGlow />}
                        <C.ActionSlotKey>1</C.ActionSlotKey>
                        <C.ActionSlotGlyph>✦</C.ActionSlotGlyph>
                        <C.ActionSlotLabel>scan</C.ActionSlotLabel>
                      </C.ActionSlotFrame>}
                    </C.ActionSlot>
                    <C.ActionSlot hoverable={1} tooltip="Prime planning prompt to the input" onPress={() => { primeAction(2) }} onHoverEnter={() => { setHoveredAction(2) }} onHoverExit={() => { setHoveredAction(0) }}>
                      {hoveredAction == 2 && <C.ActionSlotFrameHover style={{
                        scaleX: hoveredAction == 2 ? 1.06 : 1,
                        scaleY: hoveredAction == 2 ? 1.06 : 1,
                        shadowColor: 'theme-warning',
                        shadowBlur: hoveredAction == 2 ? 14 : 0,
                        shadowOffsetY: hoveredAction == 2 ? 2 : 0,
                        transition: {
                          scaleX: { duration: 120, easing: 'easeOut' },
                          scaleY: { duration: 120, easing: 'easeOut' },
                          shadowBlur: { duration: 120, easing: 'easeOut' },
                          shadowOffsetY: { duration: 120, easing: 'easeOut' },
                        },
                      }}>
                        {actionFlash == 2 && <C.ActionSlotGlow />}
                        <C.ActionSlotKey>2</C.ActionSlotKey>
                        <C.ActionSlotGlyph>⌘</C.ActionSlotGlyph>
                        <C.ActionSlotLabel>plan</C.ActionSlotLabel>
                      </C.ActionSlotFrameHover>}
                      {hoveredAction != 2 && <C.ActionSlotFrame>
                        {actionFlash == 2 && <C.ActionSlotGlow />}
                        <C.ActionSlotKey>2</C.ActionSlotKey>
                        <C.ActionSlotGlyph>⌘</C.ActionSlotGlyph>
                        <C.ActionSlotLabel>plan</C.ActionSlotLabel>
                      </C.ActionSlotFrame>}
                    </C.ActionSlot>
                    <C.ActionSlot hoverable={1} tooltip="Prime patch prompt to the input" onPress={() => { primeAction(3) }} onHoverEnter={() => { setHoveredAction(3) }} onHoverExit={() => { setHoveredAction(0) }}>
                      {hoveredAction == 3 && <C.ActionSlotFrameHover style={{
                        scaleX: hoveredAction == 3 ? 1.06 : 1,
                        scaleY: hoveredAction == 3 ? 1.06 : 1,
                        shadowColor: 'theme-warning',
                        shadowBlur: hoveredAction == 3 ? 14 : 0,
                        shadowOffsetY: hoveredAction == 3 ? 2 : 0,
                        transition: {
                          scaleX: { duration: 120, easing: 'easeOut' },
                          scaleY: { duration: 120, easing: 'easeOut' },
                          shadowBlur: { duration: 120, easing: 'easeOut' },
                          shadowOffsetY: { duration: 120, easing: 'easeOut' },
                        },
                      }}>
                        {actionFlash == 3 && <C.ActionSlotGlow />}
                        <C.ActionSlotKey>3</C.ActionSlotKey>
                        <C.ActionSlotGlyph>⌖</C.ActionSlotGlyph>
                        <C.ActionSlotLabel>patch</C.ActionSlotLabel>
                      </C.ActionSlotFrameHover>}
                      {hoveredAction != 3 && <C.ActionSlotFrame>
                        {actionFlash == 3 && <C.ActionSlotGlow />}
                        <C.ActionSlotKey>3</C.ActionSlotKey>
                        <C.ActionSlotGlyph>⌖</C.ActionSlotGlyph>
                        <C.ActionSlotLabel>patch</C.ActionSlotLabel>
                      </C.ActionSlotFrame>}
                    </C.ActionSlot>
                    <C.ActionSlot hoverable={1} tooltip="Prime audit prompt to the input" onPress={() => { primeAction(4) }} onHoverEnter={() => { setHoveredAction(4) }} onHoverExit={() => { setHoveredAction(0) }}>
                      {hoveredAction == 4 && <C.ActionSlotFrameHover style={{
                        scaleX: hoveredAction == 4 ? 1.06 : 1,
                        scaleY: hoveredAction == 4 ? 1.06 : 1,
                        shadowColor: 'theme-warning',
                        shadowBlur: hoveredAction == 4 ? 14 : 0,
                        shadowOffsetY: hoveredAction == 4 ? 2 : 0,
                        transition: {
                          scaleX: { duration: 120, easing: 'easeOut' },
                          scaleY: { duration: 120, easing: 'easeOut' },
                          shadowBlur: { duration: 120, easing: 'easeOut' },
                          shadowOffsetY: { duration: 120, easing: 'easeOut' },
                        },
                      }}>
                        {actionFlash == 4 && <C.ActionSlotGlow />}
                        <C.ActionSlotKey>4</C.ActionSlotKey>
                        <C.ActionSlotGlyph>◈</C.ActionSlotGlyph>
                        <C.ActionSlotLabel>audit</C.ActionSlotLabel>
                      </C.ActionSlotFrameHover>}
                      {hoveredAction != 4 && <C.ActionSlotFrame>
                        {actionFlash == 4 && <C.ActionSlotGlow />}
                        <C.ActionSlotKey>4</C.ActionSlotKey>
                        <C.ActionSlotGlyph>◈</C.ActionSlotGlyph>
                        <C.ActionSlotLabel>audit</C.ActionSlotLabel>
                      </C.ActionSlotFrame>}
                    </C.ActionSlot>
                    <C.ActionSlot hoverable={1} tooltip="Prime ship summary prompt to the input" onPress={() => { primeAction(5) }} onHoverEnter={() => { setHoveredAction(5) }} onHoverExit={() => { setHoveredAction(0) }}>
                      {hoveredAction == 5 && <C.ActionSlotFrameHover style={{
                        scaleX: hoveredAction == 5 ? 1.06 : 1,
                        scaleY: hoveredAction == 5 ? 1.06 : 1,
                        shadowColor: 'theme-warning',
                        shadowBlur: hoveredAction == 5 ? 14 : 0,
                        shadowOffsetY: hoveredAction == 5 ? 2 : 0,
                        transition: {
                          scaleX: { duration: 120, easing: 'easeOut' },
                          scaleY: { duration: 120, easing: 'easeOut' },
                          shadowBlur: { duration: 120, easing: 'easeOut' },
                          shadowOffsetY: { duration: 120, easing: 'easeOut' },
                        },
                      }}>
                        {actionFlash == 5 && <C.ActionSlotGlow />}
                        <C.ActionSlotKey>5</C.ActionSlotKey>
                        <C.ActionSlotGlyph>✧</C.ActionSlotGlyph>
                        <C.ActionSlotLabel>ship</C.ActionSlotLabel>
                      </C.ActionSlotFrameHover>}
                      {hoveredAction != 5 && <C.ActionSlotFrame>
                        {actionFlash == 5 && <C.ActionSlotGlow />}
                        <C.ActionSlotKey>5</C.ActionSlotKey>
                        <C.ActionSlotGlyph>✧</C.ActionSlotGlyph>
                        <C.ActionSlotLabel>ship</C.ActionSlotLabel>
                      </C.ActionSlotFrame>}
                    </C.ActionSlot>
                    <C.ActionSlot hoverable={1} tooltip="Clear the current draft input" onPress={() => { primeAction(6) }} onHoverEnter={() => { setHoveredAction(6) }} onHoverExit={() => { setHoveredAction(0) }}>
                      {hoveredAction == 6 && <C.ActionSlotFrameHover style={{
                        scaleX: hoveredAction == 6 ? 1.06 : 1,
                        scaleY: hoveredAction == 6 ? 1.06 : 1,
                        shadowColor: 'theme-warning',
                        shadowBlur: hoveredAction == 6 ? 14 : 0,
                        shadowOffsetY: hoveredAction == 6 ? 2 : 0,
                        transition: {
                          scaleX: { duration: 120, easing: 'easeOut' },
                          scaleY: { duration: 120, easing: 'easeOut' },
                          shadowBlur: { duration: 120, easing: 'easeOut' },
                          shadowOffsetY: { duration: 120, easing: 'easeOut' },
                        },
                      }}>
                        {actionFlash == 6 && <C.ActionSlotGlow />}
                        <C.ActionSlotKey>6</C.ActionSlotKey>
                        <C.ActionSlotGlyph>⬢</C.ActionSlotGlyph>
                        <C.ActionSlotLabel>clear</C.ActionSlotLabel>
                      </C.ActionSlotFrameHover>}
                      {hoveredAction != 6 && <C.ActionSlotFrame>
                        {actionFlash == 6 && <C.ActionSlotGlow />}
                        <C.ActionSlotKey>6</C.ActionSlotKey>
                        <C.ActionSlotGlyph>⬢</C.ActionSlotGlyph>
                        <C.ActionSlotLabel>clear</C.ActionSlotLabel>
                      </C.ActionSlotFrame>}
                    </C.ActionSlot>
                  </C.ActionBar>
                  <C.TermInputBar>
                    <C.TermInputPrompt>❯</C.TermInputPrompt>
                    <TextInput
                      placeholder={inputPlaceholder()}
                      onSubmit={() => { submitCurrentInput() }}
                      style={{ flexGrow: 1, flexBasis: 0, fontSize: 14, color: '#e2e8f0' }}
                    />
                    <C.ThemeButton onPress={() => { submitCurrentInput() }}>
                      <C.ThemeButtonLabel>send</C.ThemeButtonLabel>
                    </C.ThemeButton>
                  </C.TermInputBar>
                </Box>
              </Canvas.Clamp>
            </Canvas>
          </C.PageCanvasWrap>
        </C.Page>
      </C.Shell>
      <C.BottomBar>
        <C.BarLabel>cockpit</C.BarLabel>
        <C.Spacer />
        <C.BarLabel>{turnText}</C.BarLabel>
        <C.BarLabel>{costText}</C.BarLabel>
        <C.Spacer />
        <C.ThemeButton onPress={() => { setVariant(nextTheme); setActiveTheme(nextTheme) }}>
          <C.ThemeButtonLabel>{THEME_NAMES[activeTheme]}</C.ThemeButtonLabel>
        </C.ThemeButton>
      </C.BottomBar>
    </C.Root>
  );
}
