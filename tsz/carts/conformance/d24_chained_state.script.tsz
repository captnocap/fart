setStep(0);
setName('');
setEmail('');
setPlan(0);
setConfirmed(0);
setError('');

function goNext() {
  if (step === 0 && name === '') { setError('Pick a name first'); return; }
  if (step === 1 && email === '') { setError('Pick an email first'); return; }
  if (step === 2 && plan === 0) { setError('Pick a plan first'); return; }
  setError('');
  setStep(step + 1);
}

function goBack() {
  setError('');
  setStep(step - 1);
}
