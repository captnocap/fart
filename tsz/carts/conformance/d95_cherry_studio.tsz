// CONFORMANCE TEST 95: Cherry Studio Port
//
// Port of: cherryhq/cherry-studio — AI productivity desktop app
// Source: https://github.com/cherryhq/cherry-studio
//
// Cherry Studio is a real production Electron+React+TypeScript app with:
// - Sidebar navigation (conversations, assistants, files, settings)
// - Chat interface with message list, model selector, input area
// - Multi-model support (OpenAI, Gemini, Claude, local models)
// - Assistant management panel with search and categories
// - Settings page with theme toggle, model config, API keys
// - File/document viewer panel
// - Topic/collection organization
// - Notification badges, status indicators, loading states
//
// This is the most realistic test in the suite. It's not a toy —
// it's the actual component structure of a shipping desktop app.
//
// Patterns exercised:
// - Sidebar + main content split layout (every desktop app)
// - Chat message list with sender-based alignment (Slack/Discord/iMessage)
// - Model selector dropdown-like pattern (any multi-option selector)
// - Assistant grid with search filter (any card grid with search)
// - Settings form with sections and toggles (every settings page)
// - File list with type icons (every file manager)
// - Tab switching between major app sections
// - Badge counts on nav items
// - Empty states per section
// - Theme switching affecting entire app
// - Compact/comfortable density toggle
// - Multiple maps with different data shapes on different tabs

const [activeSection, setActiveSection] = useState(0);
const [conversations, setConversations] = useState([{ title: '', model: '', lastMsg: '', time: '', unread: 0, msgCount: 0, tokens: 0, pinned: 0 }]);
const [messages, setMessages] = useState([{ role: 0, content: '', model: '', time: '', tokens: 0 }]);
const [assistants, setAssistants] = useState([{ name: '', desc: '', category: '', icon: '', uses: 0, prompt: '', model: '', temp: 0 }]);
const [files, setFiles] = useState([{ name: '', type: '', size: 0, modified: '' }]);
const [models, setModels] = useState([{ name: '', provider: '', maxTokens: 0, status: 0, rpm: 0 }]);

const [activeConvo, setActiveConvo] = useState(0);
const [activeModel, setActiveModel] = useState(0);
const [activeAssistant, setActiveAssistant] = useState('');
const [assistantSearch, setAssistantSearch] = useState('');
const [assistantFilter, setAssistantFilter] = useState('');

const [theme, setTheme] = useState(0);
const [fontSize, setFontSize] = useState(13);
const [sendOnEnter, setSendOnEnter] = useState(1);
const [streamMode, setStreamMode] = useState(1);
const [showTimestamps, setShowTimestamps] = useState(1);
const [compact, setCompact] = useState(0);
const [dirty, setDirty] = useState(0);

const [totalUnread, setTotalUnread] = useState(0);
const [msgCount, setMsgCount] = useState(0);
const [modelCount, setModelCount] = useState(0);
const [activeModelCount, setActiveModelCount] = useState(0);
const [convoCount, setConvoCount] = useState(0);
const [assistantCount, setAssistantCount] = useState(0);
const [fileCount, setFileCount] = useState(0);
const [notifCount, setNotifCount] = useState(0);
const [notifUnread, setNotifUnread] = useState(0);
const [backupInfo, setBackupInfo] = useState('');
const [lastAction, setLastAction] = useState('');
const [actionCount, setActionCount] = useState(0);

import { cherry_data } from "./d95_cherry_studio.script";

<script>
var convos = [
  { title: 'Code review help', model: 'GPT-4', lastMsg: 'Here is the refactored version...', time: '2m', unread: 2 },
  { title: 'Blog draft', model: 'Claude', lastMsg: 'I have revised the introduction...', time: '1h', unread: 0 },
  { title: 'Debug session', model: 'GPT-4', lastMsg: 'The issue is in the useEffect...', time: '3h', unread: 1 },
  { title: 'Translation', model: 'Gemini', lastMsg: 'Here is the Japanese version...', time: '1d', unread: 0 },
  { title: 'Data analysis', model: 'Claude', lastMsg: 'The CSV has 12,000 rows...', time: '2d', unread: 0 },
  { title: 'API design', model: 'GPT-4', lastMsg: 'REST vs GraphQL tradeoffs...', time: '3d', unread: 3 }
];
setConversations(convos);
var ur = 0;
for (var i = 0; i < convos.length; i++) ur += convos[i].unread;
setTotalUnread(ur);

var msgs = [
  { role: 0, content: 'Can you review this React component for performance issues?', model: '', time: '10:01' },
  { role: 1, content: 'I see several potential improvements. First, the useEffect has missing dependencies which could cause stale closures. Second, the map inside render creates new arrays on every render — consider useMemo. Third, the inline style objects create new references each render.', model: 'GPT-4', time: '10:01' },
  { role: 0, content: 'What about the state management? Is useState enough here?', model: '', time: '10:03' },
  { role: 1, content: 'For this component, useState is fine. The state is local and the update patterns are simple. If you needed to share state between siblings or had complex update logic, I would suggest useReducer or a state library like Zustand.', model: 'GPT-4', time: '10:03' },
  { role: 0, content: 'Can you show me the optimized version?', model: '', time: '10:05' },
  { role: 1, content: 'Here is the refactored version with memoization, proper dependency arrays, and extracted style constants. The key changes are: 1) Moved styles outside component, 2) Added useMemo for the filtered list, 3) Fixed useEffect deps.', model: 'GPT-4', time: '10:06' }
];
setMessages(msgs);
setMsgCount(msgs.length);

var assts = [
  { name: 'Code Reviewer', desc: 'Reviews code for bugs, performance, and style', category: 'dev', icon: 'CR', uses: 1420 },
  { name: 'Translator', desc: 'Translates between 50+ languages', category: 'util', icon: 'TR', uses: 892 },
  { name: 'Blog Writer', desc: 'Writes and edits blog posts and articles', category: 'writing', icon: 'BW', uses: 2100 },
  { name: 'Data Analyst', desc: 'Analyzes CSV, JSON, and database exports', category: 'dev', icon: 'DA', uses: 670 },
  { name: 'Summarizer', desc: 'Condenses long documents into key points', category: 'util', icon: 'SM', uses: 3200 },
  { name: 'SQL Helper', desc: 'Writes and optimizes SQL queries', category: 'dev', icon: 'SQ', uses: 540 },
  { name: 'Email Drafter', desc: 'Composes professional emails', category: 'writing', icon: 'EM', uses: 1800 },
  { name: 'Debugger', desc: 'Helps find and fix code bugs', category: 'dev', icon: 'DB', uses: 950 },
  { name: 'UX Writer', desc: 'Writes UI copy, tooltips, and error messages', category: 'writing', icon: 'UX', uses: 420 },
  { name: 'API Designer', desc: 'Designs RESTful and GraphQL APIs', category: 'dev', icon: 'AP', uses: 380 },
  { name: 'Math Tutor', desc: 'Explains math concepts step by step', category: 'edu', icon: 'MT', uses: 1100 },
  { name: 'Study Guide', desc: 'Creates flashcards and study materials', category: 'edu', icon: 'SG', uses: 780 }
];
setAssistants(assts);

var fls = [
  { name: 'project-spec.md', type: 'md', size: 12400, modified: 'Today' },
  { name: 'api-response.json', type: 'json', size: 89200, modified: 'Today' },
  { name: 'screenshot.png', type: 'img', size: 245000, modified: 'Yesterday' },
  { name: 'report-q2.pdf', type: 'pdf', size: 1200000, modified: '3 days ago' },
  { name: 'data-export.csv', type: 'csv', size: 5400000, modified: 'Last week' }
];
setFiles(fls);

var mods = [
  { name: 'GPT-4', provider: 'OpenAI', status: 1 },
  { name: 'GPT-3.5', provider: 'OpenAI', status: 1 },
  { name: 'Claude 3.5', provider: 'Anthropic', status: 1 },
  { name: 'Gemini Pro', provider: 'Google', status: 1 },
  { name: 'Llama 3', provider: 'Ollama', status: 0 },
  { name: 'Mistral', provider: 'Ollama', status: 0 }
];
setModels(mods);

function act(desc) {
  setLastAction(desc);
  setActionCount(actionCount + 1);
}

function sendMessage(text) {
  msgs.push({ role: 0, content: text, model: '', time: 'now' });
  msgs.push({ role: 1, content: 'This is a simulated AI response to: ' + text.slice(0, 30) + '...', model: mods[activeModel].name, time: 'now' });
  setMessages(msgs);
  setMsgCount(msgs.length);
  act('sent message');
}

function switchConvo(idx) {
  setActiveConvo(idx);
  convos[idx].unread = 0;
  setConversations(convos);
  ur = 0;
  for (var i = 0; i < convos.length; i++) ur += convos[i].unread;
  setTotalUnread(ur);
  act('switched to: ' + convos[idx].title);
}

function filterAssistants(cat) {
  setAssistantFilter(cat);
  if (cat === '') {
    setAssistants(assts);
  } else {
    var result = [];
    for (var i = 0; i < assts.length; i++) {
      if (assts[i].category === cat) result.push(assts[i]);
    }
    setAssistants(result);
  }
  act('filter assistants: ' + (cat === '' ? 'all' : cat));
}

function formatSize(bytes) {
  if (bytes < 1000) return bytes + 'B';
  if (bytes < 1000000) return Math.floor(bytes / 1000) + 'KB';
  return Math.floor(bytes / 1000000) + 'MB';
}
</script>

function NavButton(icon, label, idx, badge) {
  return (
    <Pressable onPress={() => { setActiveSection(idx); act('nav: ' + label) }} style={{ padding: 8, borderRadius: 6, backgroundColor: activeSection == idx ? "#334155" : "transparent", gap: 2, alignItems: "center" }}>
      <Box style={{ flexDirection: "row", gap: 4, alignItems: "center" }}>
        <Text fontSize={14} color={activeSection == idx ? "#3b82f6" : "#64748b"}>{icon}</Text>
        {badge > 0 && <Box style={{ backgroundColor: "#ef4444", borderRadius: 8, paddingLeft: 4, paddingRight: 4, minWidth: 14, alignItems: "center" }}>
          <Text fontSize={7} color="#ffffff">{`${badge}`}</Text>
        </Box>}
      </Box>
      <Text fontSize={8} color={activeSection == idx ? "#e2e8f0" : "#475569"}>{label}</Text>
    </Pressable>
  );
}

function ModelChip(name, provider, isActive, idx) {
  return (
    <Pressable onPress={() => { setActiveModel(idx); act('model: ' + name) }} style={{ padding: 6, borderRadius: 6, backgroundColor: isActive == 1 ? "#1e40af" : "#1e293b", borderWidth: 1, borderColor: isActive == 1 ? "#3b82f6" : "#334155" }}>
      <Text fontSize={9} color={isActive == 1 ? "#ffffff" : "#94a3b8"}>{name}</Text>
      <Text fontSize={7} color={isActive == 1 ? "#93c5fd" : "#475569"}>{provider}</Text>
    </Pressable>
  );
}

function FileIcon(type) {
  return (
    <Box style={{ width: 28, height: 28, borderRadius: 6, alignItems: "center", justifyContent: "center", backgroundColor: type == 'md' ? "#1e293b" : type == 'json' ? "#1e3a1e" : type == 'img' ? "#3a1e3a" : type == 'pdf' ? "#3a1e1e" : "#1e2a3a" }}>
      <Text fontSize={8} color={type == 'md' ? "#94a3b8" : type == 'json' ? "#4ade80" : type == 'img' ? "#c084fc" : type == 'pdf' ? "#f87171" : "#60a5fa"}>{type}</Text>
    </Box>
  );
}

function Toggle(label, value, onToggle) {
  return (
    <Pressable onPress={onToggle} style={{ flexDirection: "row", justifyContent: "spaceBetween", alignItems: "center", padding: 10 }}>
      <Text fontSize={11} color={theme == 0 ? "#e2e8f0" : "#1e293b"}>{label}</Text>
      {value == 1 && <Box style={{ width: 36, height: 20, borderRadius: 10, backgroundColor: "#22c55e", justifyContent: "center", alignItems: "flexEnd", paddingRight: 2 }}>
        <Box style={{ width: 16, height: 16, borderRadius: 8, backgroundColor: "#ffffff" }} />
      </Box>}
      {value == 0 && <Box style={{ width: 36, height: 20, borderRadius: 10, backgroundColor: "#475569", justifyContent: "center", paddingLeft: 2 }}>
        <Box style={{ width: 16, height: 16, borderRadius: 8, backgroundColor: "#94a3b8" }} />
      </Box>}
    </Pressable>
  );
}

function App() {
  return (
    <Box style={{ backgroundColor: theme == 0 ? "#0f172a" : "#f8fafc", width: "100%", height: "100%", flexDirection: "row" }}>

      <Box style={{ width: 56, backgroundColor: theme == 0 ? "#020617" : "#e2e8f0", padding: 6, gap: 4, alignItems: "center", borderColor: theme == 0 ? "#1e293b" : "#cbd5e1", borderWidth: 1 }}>
        <Box style={{ width: 32, height: 32, borderRadius: 8, backgroundColor: "#7c3aed", alignItems: "center", justifyContent: "center", marginBottom: 8 }}>
          <Text fontSize={14} color="#ffffff">🍒</Text>
        </Box>
        <NavButton icon="💬" label="Chat" idx={0} badge={totalUnread} />
        <NavButton icon="🤖" label="Assist" idx={1} badge={0} />
        <NavButton icon="📁" label="Files" idx={2} badge={0} />
        <NavButton icon="⚙" label="Config" idx={3} badge={0} />
        <Box style={{ flexGrow: 1 }} />
        <Text fontSize={7} color="#475569">{`${actionCount}`}</Text>
      </Box>

      {activeSection == 0 && <Box style={{ flexGrow: 1, flexDirection: "row" }}>
        <Box style={{ width: 200, backgroundColor: theme == 0 ? "#1e293b" : "#f1f5f9", borderColor: theme == 0 ? "#334155" : "#e2e8f0", borderWidth: 1, gap: 2 }}>
          <Box style={{ padding: 8, borderColor: theme == 0 ? "#334155" : "#e2e8f0", borderWidth: 1 }}>
            <Text fontSize={11} color={theme == 0 ? "#e2e8f0" : "#1e293b"}>Conversations</Text>
          </Box>
          <ScrollView style={{ flexGrow: 1 }}>
            {conversations.map((c, ci) => (
              <Pressable onPress={() => { switchConvo(ci) }} style={{ padding: 8, gap: 2, backgroundColor: activeConvo == ci ? (theme == 0 ? "#334155" : "#e2e8f0") : "transparent", borderColor: theme == 0 ? "#1e293b" : "#f1f5f9", borderWidth: 1 }}>
                <Box style={{ flexDirection: "row", justifyContent: "spaceBetween", alignItems: "center" }}>
                  <Text fontSize={10} color={theme == 0 ? "#e2e8f0" : "#1e293b"}>{c.title}</Text>
                  {c.unread > 0 && <Box style={{ backgroundColor: "#3b82f6", borderRadius: 8, paddingLeft: 4, paddingRight: 4, minWidth: 14, alignItems: "center" }}>
                    <Text fontSize={7} color="#ffffff">{`${c.unread}`}</Text>
                  </Box>}
                </Box>
                <Text fontSize={8} color="#475569">{c.model}</Text>
                <Text fontSize={8} color="#64748b">{c.lastMsg}</Text>
                <Text fontSize={7} color="#475569">{c.time}</Text>
              </Pressable>
            ))}
          </ScrollView>
        </Box>

        <Box style={{ flexGrow: 1, gap: 0 }}>
          <Box style={{ padding: 8, flexDirection: "row", justifyContent: "spaceBetween", alignItems: "center", backgroundColor: theme == 0 ? "#1e293b" : "#ffffff", borderColor: theme == 0 ? "#334155" : "#e2e8f0", borderWidth: 1 }}>
            <Text fontSize={12} color={theme == 0 ? "#e2e8f0" : "#1e293b"}>{conversations[activeConvo] ? conversations[activeConvo].title : "Chat"}</Text>
            <Box style={{ flexDirection: "row", gap: 4 }}>
              {models.map((m, mi) => (
                <Box>
                  {m.status == 1 && <ModelChip name={m.name} provider={m.provider} isActive={activeModel == mi ? 1 : 0} idx={mi} />}
                </Box>
              ))}
            </Box>
          </Box>

          <ScrollView style={{ flexGrow: 1, padding: 12, gap: 8 }}>
            {messages.map((msg, mi) => (
              <Box style={{ flexDirection: "row", justifyContent: msg.role == 0 ? "flexEnd" : "flexStart", padding: 2 }}>
                <Box style={{ maxWidth: 400, backgroundColor: msg.role == 0 ? "#1e40af" : (theme == 0 ? "#1e293b" : "#ffffff"), borderRadius: 12, padding: 10, gap: 4, borderWidth: msg.role == 1 ? 1 : 0, borderColor: theme == 0 ? "#334155" : "#e2e8f0" }}>
                  {msg.role == 1 && <Box style={{ flexDirection: "row", gap: 4, alignItems: "center" }}>
                    <Box style={{ width: 14, height: 14, borderRadius: 7, backgroundColor: "#7c3aed" }} />
                    <Text fontSize={8} color="#7c3aed">{msg.model}</Text>
                  </Box>}
                  <Text fontSize={fontSize == 13 ? 11 : fontSize == 15 ? 13 : 10} color={msg.role == 0 ? "#ffffff" : (theme == 0 ? "#e2e8f0" : "#1e293b")}>{msg.content}</Text>
                  {showTimestamps == 1 && <Text fontSize={7} color={msg.role == 0 ? "#93c5fd" : "#475569"}>{msg.time}</Text>}
                </Box>
              </Box>
            ))}
          </ScrollView>

          <Box style={{ padding: 8, flexDirection: "row", gap: 8, backgroundColor: theme == 0 ? "#1e293b" : "#ffffff", borderColor: theme == 0 ? "#334155" : "#e2e8f0", borderWidth: 1 }}>
            <Pressable onPress={() => { sendMessage('Tell me more about that last point') }} style={{ flexGrow: 1, padding: 10, backgroundColor: theme == 0 ? "#0f172a" : "#f1f5f9", borderRadius: 8 }}>
              <Text fontSize={10} color="#64748b">Ask a follow-up...</Text>
            </Pressable>
            <Pressable onPress={() => { sendMessage('Can you give me a code example?') }} style={{ padding: 10, backgroundColor: "#3b82f6", borderRadius: 8 }}>
              <Text fontSize={10} color="#ffffff">Send</Text>
            </Pressable>
          </Box>
        </Box>
      </Box>}

      {activeSection == 1 && <Box style={{ flexGrow: 1, padding: 12, gap: 8 }}>
        <Box style={{ flexDirection: "row", justifyContent: "spaceBetween", alignItems: "center" }}>
          <Text fontSize={14} color={theme == 0 ? "#e2e8f0" : "#1e293b"}>Assistants</Text>
          <Text fontSize={9} color="#64748b">{`${assistants.length} available`}</Text>
        </Box>
        <Box style={{ flexDirection: "row", gap: 6 }}>
          <Pressable onPress={() => { filterAssistants('') }} style={{ padding: 6, backgroundColor: assistantFilter == '' ? "#1e40af" : "#334155", borderRadius: 4 }}>
            <Text fontSize={9} color="#e2e8f0">All</Text>
          </Pressable>
          <Pressable onPress={() => { filterAssistants('dev') }} style={{ padding: 6, backgroundColor: assistantFilter == 'dev' ? "#1e40af" : "#334155", borderRadius: 4 }}>
            <Text fontSize={9} color="#e2e8f0">Dev</Text>
          </Pressable>
          <Pressable onPress={() => { filterAssistants('writing') }} style={{ padding: 6, backgroundColor: assistantFilter == 'writing' ? "#1e40af" : "#334155", borderRadius: 4 }}>
            <Text fontSize={9} color="#e2e8f0">Writing</Text>
          </Pressable>
          <Pressable onPress={() => { filterAssistants('util') }} style={{ padding: 6, backgroundColor: assistantFilter == 'util' ? "#1e40af" : "#334155", borderRadius: 4 }}>
            <Text fontSize={9} color="#e2e8f0">Utility</Text>
          </Pressable>
          <Pressable onPress={() => { filterAssistants('edu') }} style={{ padding: 6, backgroundColor: assistantFilter == 'edu' ? "#1e40af" : "#334155", borderRadius: 4 }}>
            <Text fontSize={9} color="#e2e8f0">Education</Text>
          </Pressable>
        </Box>
        <Box style={{ flexDirection: "row", flexWrap: "wrap", gap: 8 }}>
          {assistants.map((a, ai) => (
            <Pressable onPress={() => { setActiveAssistant(a.name); act('assistant: ' + a.name) }} style={{ width: 160, padding: 12, backgroundColor: activeAssistant == a.name ? "#334155" : (theme == 0 ? "#1e293b" : "#ffffff"), borderRadius: 8, borderWidth: 1, borderColor: activeAssistant == a.name ? "#3b82f6" : (theme == 0 ? "#334155" : "#e2e8f0"), gap: 6 }}>
              <Box style={{ flexDirection: "row", gap: 8, alignItems: "center" }}>
                <Box style={{ width: 28, height: 28, borderRadius: 8, backgroundColor: "#7c3aed", alignItems: "center", justifyContent: "center" }}>
                  <Text fontSize={9} color="#ffffff">{a.icon}</Text>
                </Box>
                <Text fontSize={10} color={theme == 0 ? "#e2e8f0" : "#1e293b"}>{a.name}</Text>
              </Box>
              <Text fontSize={8} color="#64748b">{a.desc}</Text>
              <Box style={{ flexDirection: "row", justifyContent: "spaceBetween" }}>
                <Text fontSize={7} color="#475569">{a.category}</Text>
                <Text fontSize={7} color="#475569">{`${a.uses} uses`}</Text>
              </Box>
            </Pressable>
          ))}
        </Box>
      </Box>}

      {activeSection == 2 && <Box style={{ flexGrow: 1, padding: 12, gap: 8 }}>
        <Text fontSize={14} color={theme == 0 ? "#e2e8f0" : "#1e293b"}>Files</Text>
        <Box style={{ gap: 4 }}>
          {files.map((f, fi) => (
            <Pressable onPress={() => { act('file: ' + f.name) }} style={{ flexDirection: "row", gap: 10, padding: 10, backgroundColor: theme == 0 ? "#1e293b" : "#ffffff", borderRadius: 6, alignItems: "center", borderWidth: 1, borderColor: theme == 0 ? "#334155" : "#e2e8f0" }}>
              <FileIcon type={f.type} />
              <Box style={{ flexGrow: 1, gap: 1 }}>
                <Text fontSize={11} color={theme == 0 ? "#e2e8f0" : "#1e293b"}>{f.name}</Text>
                <Text fontSize={8} color="#475569">{f.modified}</Text>
              </Box>
              <Text fontSize={9} color="#64748b">{`${f.size}`}</Text>
            </Pressable>
          ))}
        </Box>
        {files.length == 0 && <Box style={{ padding: 40, alignItems: "center" }}>
          <Text fontSize={12} color="#475569">No files uploaded</Text>
        </Box>}
      </Box>}

      {activeSection == 3 && <Box style={{ flexGrow: 1, padding: 12, gap: 12 }}>
        <Text fontSize={14} color={theme == 0 ? "#e2e8f0" : "#1e293b"}>Settings</Text>

        <Box style={{ backgroundColor: theme == 0 ? "#1e293b" : "#ffffff", borderRadius: 8, borderWidth: 1, borderColor: theme == 0 ? "#334155" : "#e2e8f0" }}>
          <Box style={{ padding: 10, borderColor: theme == 0 ? "#334155" : "#e2e8f0", borderWidth: 1 }}>
            <Text fontSize={11} color="#94a3b8">Appearance</Text>
          </Box>
          <Toggle label="Dark Mode" value={theme == 0 ? 1 : 0} onToggle={() => { setTheme(theme == 0 ? 1 : 0); act('theme toggle') }} />
          <Box style={{ height: 1, backgroundColor: theme == 0 ? "#334155" : "#e2e8f0" }} />
          <Box style={{ flexDirection: "row", justifyContent: "spaceBetween", alignItems: "center", padding: 10 }}>
            <Text fontSize={11} color={theme == 0 ? "#e2e8f0" : "#1e293b"}>{`Font Size: ${fontSize}`}</Text>
            <Box style={{ flexDirection: "row", gap: 4 }}>
              <Pressable onPress={() => { setFontSize(11); act('font: 11') }} style={{ padding: 6, backgroundColor: fontSize == 11 ? "#1e40af" : "#334155", borderRadius: 4 }}>
                <Text fontSize={9} color="#e2e8f0">S</Text>
              </Pressable>
              <Pressable onPress={() => { setFontSize(13); act('font: 13') }} style={{ padding: 6, backgroundColor: fontSize == 13 ? "#1e40af" : "#334155", borderRadius: 4 }}>
                <Text fontSize={9} color="#e2e8f0">M</Text>
              </Pressable>
              <Pressable onPress={() => { setFontSize(15); act('font: 15') }} style={{ padding: 6, backgroundColor: fontSize == 15 ? "#1e40af" : "#334155", borderRadius: 4 }}>
                <Text fontSize={9} color="#e2e8f0">L</Text>
              </Pressable>
            </Box>
          </Box>
        </Box>

        <Box style={{ backgroundColor: theme == 0 ? "#1e293b" : "#ffffff", borderRadius: 8, borderWidth: 1, borderColor: theme == 0 ? "#334155" : "#e2e8f0" }}>
          <Box style={{ padding: 10, borderColor: theme == 0 ? "#334155" : "#e2e8f0", borderWidth: 1 }}>
            <Text fontSize={11} color="#94a3b8">Chat</Text>
          </Box>
          <Toggle label="Send on Enter" value={sendOnEnter} onToggle={() => { setSendOnEnter(sendOnEnter == 0 ? 1 : 0); act('sendOnEnter toggle') }} />
          <Box style={{ height: 1, backgroundColor: theme == 0 ? "#334155" : "#e2e8f0" }} />
          <Toggle label="Stream Response" value={streamMode} onToggle={() => { setStreamMode(streamMode == 0 ? 1 : 0); act('stream toggle') }} />
          <Box style={{ height: 1, backgroundColor: theme == 0 ? "#334155" : "#e2e8f0" }} />
          <Toggle label="Show Timestamps" value={showTimestamps} onToggle={() => { setShowTimestamps(showTimestamps == 0 ? 1 : 0); act('timestamps toggle') }} />
        </Box>

        <Box style={{ backgroundColor: theme == 0 ? "#1e293b" : "#ffffff", borderRadius: 8, borderWidth: 1, borderColor: theme == 0 ? "#334155" : "#e2e8f0" }}>
          <Box style={{ padding: 10, borderColor: theme == 0 ? "#334155" : "#e2e8f0", borderWidth: 1 }}>
            <Text fontSize={11} color="#94a3b8">Models</Text>
          </Box>
          {models.map((m, mi) => (
            <Box style={{ flexDirection: "row", justifyContent: "spaceBetween", alignItems: "center", padding: 10, borderColor: theme == 0 ? "#1e293b" : "#f1f5f9", borderWidth: 1 }}>
              <Box style={{ gap: 1 }}>
                <Text fontSize={10} color={theme == 0 ? "#e2e8f0" : "#1e293b"}>{m.name}</Text>
                <Text fontSize={8} color="#475569">{m.provider}</Text>
              </Box>
              {m.status == 1 && <Box style={{ width: 8, height: 8, borderRadius: 4, backgroundColor: "#22c55e" }} />}
              {m.status == 0 && <Box style={{ width: 8, height: 8, borderRadius: 4, backgroundColor: "#475569" }} />}
            </Box>
          ))}
        </Box>

        <Text fontSize={8} color="#475569">{lastAction}</Text>
      </Box>}
    </Box>
  );
}
