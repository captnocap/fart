export function match(path: string, pattern: string) {
  const keys: string[] = [];
 :

 const regex = new RegExp("^" + pattern.replace(/:([^/]+)/g, (_, k) => {
    keys.push(k);
    return "([^/]+)";
  }) + "$");

  const m = path.match(regex);
  if (!m) return null;

  const params: any = {};
  keys.forEach((k, i) => params[k] = m[i+1]);
  return params;
}

// usage
console.log(match("/users/1", "/users/:id"));
