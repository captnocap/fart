export class Logger {
  constructor(private ctx: any = {}) {}

  log(level: string, msg: string) {
    console.log(JSON.stringify({ level, msg, ...this.ctx }));
  }

  info(msg: string) { this.log("info", msg); }

  child(ctx: any) {
    return new Logger({ ...this.ctx, ...ctx });
  }
}

// usage
const log = new Logger();
log.info("hello");
