export class Model<T extends { id: string }> {
  private data: T[] = [];

  create(obj: T) { this.data.push(obj); return obj; }
  findById(id: string) { return this.data.find(x => x.id === id); }
  findAll() { return [...this.data]; }
  delete(id: string) { this.data = this.data.filter(x => x.id !== id); }
}

// usage
const users = new Model<{id:string,name:string}>();
users.create({id:"1",name:"a"});
