export const delay = (ms: number) => new Promise(r => setTimeout(r, ms));

export function debounce(fn: Function, ms: number) {
  let t: any;
  return (...args: any[]) => {
    clearTimeout(t);
    t = setTimeout(() => fn(...args), ms);
  };
}

// usage
const d = debounce(() => console.log("hi"), 200);
d();
