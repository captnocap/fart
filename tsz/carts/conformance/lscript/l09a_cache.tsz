export class Cache {
  private map = new Map<string, any>();

  set(k: string, v: any) { this.map.set(k, v); }
  get(k: string) { return this.map.get(k); }
  delete(k: string) { this.map.delete(k); }
  clear() { this.map.clear(); }
}

// usage
const c = new Cache();
c.set("a", 1);
console.log(c.get("a"));
