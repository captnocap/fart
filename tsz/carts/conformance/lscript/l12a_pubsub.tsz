export class PubSub {
  private topics = new Map<string, Set<Function>>();

  publish(topic: string, msg: any) {
    this.topics.get(topic)?.forEach(fn => fn(msg));
  }

  subscribe(topic: string, fn: Function) {
    if (!this.topics.has(topic)) this.topics.set(topic, new Set());
    this.topics.get(topic)!.add(fn);
    return () => this.topics.get(topic)!.delete(fn);
  }
}

// usage
const ps = new PubSub();
ps.subscribe("a", console.log);
ps.publish("a", 123);
