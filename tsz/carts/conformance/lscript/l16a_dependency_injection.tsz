export class Container {
  private services = new Map<string, any>();

  register(name: string, val: any) {
    this.services.set(name, val);
  }

  resolve(name: string) {
    return this.services.get(name);
  }
}

// usage
const c = new Container();
c.register("a", 123);
console.log(c.resolve("a"));
