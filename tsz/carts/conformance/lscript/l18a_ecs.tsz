let id = 0;

export class ECS {
  entities = new Map<number, any>();

  create() {
    const eid = ++id;
    this.entities.set(eid, {});
    return eid;
  }

  add(e: number, comp: any) {
    Object.assign(this.entities.get(e), comp);
  }
}

// usage
const ecs = new ECS();
const e = ecs.create();
ecs.add(e, { pos: {x:1,y:2} });
