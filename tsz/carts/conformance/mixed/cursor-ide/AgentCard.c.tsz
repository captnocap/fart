// AgentCard — Individual agent card component

function AgentCard(props) {
  var agent = props.agent || {};
  var active = props.active || 0;
  
  var borderColor = active == 1 ? '#2d62ff' : '#1f2935';
  
  return (
    <Box style={{
      flexDirection: 'column',
      backgroundColor: '#0f141c',
      borderRadius: 12,
      borderWidth: 1,
      borderColor: borderColor,
      padding: 12,
      gap: 10,
    }}>
      {props.children}
    </Box>
  );
}

function AgentCardHeader(props) {
  var agent = props.agent || {};
  var status = agent.status || 'idle';
  var statusColor = '#7ee787';
  
  if (status exact 'running') statusColor = '#ffbd2e';
  else if (status exact 'error') statusColor = '#ff7b72';
  else if (status exact 'paused') statusColor = '#5d6a7c';
  
  return (
    <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 10 }}>
      <Box style={{
        width: 32,
        height: 32,
        borderRadius: 16,
        backgroundColor: '#2d62ff20',
        alignItems: 'center',
        justifyContent: 'center',
      }}>
        <Text fontSize={14} color="#2d62ff">🤖</Text>
      </Box>
      <Box style={{ flexDirection: 'column', flexGrow: 1, flexBasis: 0 }}>
        <Text fontSize={12} color="#eef2f8" bold={true}>{agent.name || 'Agent'}</Text>
        <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 6 }}>
          <Box style={{ width: 6, height: 6, borderRadius: 3, backgroundColor: statusColor }} />
          <Text fontSize={10} color="#7f8a99">{status}</Text>
        </Box>
      </Box>
      {props.actions}
    </Box>
  );
}

function AgentCardProgress(props) {
  var agent = props.agent || {};
  var progress = agent.progress || 0;
  
  return (
    <Box style={{ flexDirection: 'column', gap: 4 }}>
      <Box style={{ flexDirection: 'row', alignItems: 'center', justifyContent: 'space-between' }}>
        <Text fontSize={10} color="#5d6a7c">Progress</Text>
        <Text fontSize={10} color="#79c0ff">{progress}%</Text>
      </Box>
      <Box style={{
        height: 4,
        backgroundColor: '#1f2935',
        borderRadius: 2,
      }}>
        <Box style={{
          width: progress + '%',
          height: 4,
          backgroundColor: '#2d62ff',
          borderRadius: 2,
        }} />
      </Box>
    </Box>
  );
}

function AgentCardMeta(props) {
  return (
    <Box style={{ flexDirection: 'row', gap: 8, flexWrap: 'wrap' }}>
      {props.mode && (
        <Box style={{
          paddingLeft: 6,
          paddingRight: 6,
          paddingTop: 2,
          paddingBottom: 2,
          backgroundColor: '#10151d',
          borderRadius: 4,
          borderWidth: 1,
          borderColor: '#1f2935',
        }}>
          <Text fontSize={9} color="#79c0ff">{props.mode}</Text>
        </Box>
      )}
      {props.model && (
        <Box style={{
          paddingLeft: 6,
          paddingRight: 6,
          paddingTop: 2,
          paddingBottom: 2,
          backgroundColor: '#10151d',
          borderRadius: 4,
          borderWidth: 1,
          borderColor: '#1f2935',
        }}>
          <Text fontSize={9} color="#7ee787">{props.model}</Text>
        </Box>
      )}
      {props.duration && (
        <Box style={{
          paddingLeft: 6,
          paddingRight: 6,
          paddingTop: 2,
          paddingBottom: 2,
          backgroundColor: '#10151d',
          borderRadius: 4,
        }}>
          <Text fontSize={9} color="#5d6a7c">{props.duration}</Text>
        </Box>
      )}
    </Box>
  );
}

function AgentCardActions(props) {
  return (
    <Box style={{ flexDirection: 'row', gap: 6, marginTop: 4 }}>
      {props.children}
    </Box>
  );
}

function AgentActionBtn(props) {
  return (
    <Pressable 
      onPress={props.onPress}
      style={{
        paddingLeft: 10,
        paddingRight: 10,
        paddingTop: 5,
        paddingBottom: 5,
        backgroundColor: props.primary == 1 ? '#2d62ff' : '#10151d',
        borderRadius: 6,
        borderWidth: props.primary == 1 ? 0 : 1,
        borderColor: '#1f2935',
      }}
    >
      <Text fontSize={10} color={props.primary == 1 ? '#ffffff' : '#c9d2df'}>
        {props.label}
      </Text>
    </Pressable>
  );
}

export {
  AgentCard,
  AgentCardHeader,
  AgentCardProgress,
  AgentCardMeta,
  AgentCardActions,
  AgentActionBtn,
};
