// AgentGrid — Grid layout for multiple agent cards

function AgentGrid(props) {
  var columns = props.columns || 2;
  var gap = props.gap || 12;
  
  return (
    <Box style={{
      flexGrow: 1,
      flexBasis: 0,
      flexDirection: 'row',
      flexWrap: 'wrap',
      padding: 14,
      gap: gap,
    }}>
      {props.children}
    </Box>
  );
}

function AgentGridItem(props) {
  var columns = props.columns || 2;
  var gap = props.gap || 12;
  var width = 'calc((100% - ' + ((columns - 1) * gap) + 'px) / ' + columns + ')';
  
  return (
    <Box style={{
      width: width,
      minHeight: 200,
    }}>
      {props.children}
    </Box>
  );
}

function AgentLane(props) {
  return (
    <Box style={{
      flexDirection: 'column',
      padding: 14,
      gap: 10,
    }}>
      {props.children}
    </Box>
  );
}

function AgentLaneHeader(props) {
  return (
    <Box style={{
      flexDirection: 'row',
      alignItems: 'center',
      justifyContent: 'space-between',
    }}>
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
        <Box style={{
          width: 8,
          height: 8,
          borderRadius: 4,
          backgroundColor: props.statusColor || '#7ee787',
        }} />
        <Text fontSize={12} color="#eef2f8" bold={true}>{props.title}</Text>
        {props.count > 0 && <Text fontSize={10} color="#5d6a7c">({props.count})</Text>}
      </Box>
      {props.actions}
    </Box>
  );
}

export {
  AgentGrid,
  AgentGridItem,
  AgentLane,
  AgentLaneHeader,
};
