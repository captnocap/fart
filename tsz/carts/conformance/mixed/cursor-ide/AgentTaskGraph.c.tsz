// AgentTaskGraph — Visual task dependency graph

function AgentTaskGraph(props) {
  return (
    <Box style={{
      flexGrow: 1,
      flexBasis: 0,
      backgroundColor: '#0b0f15',
      flexDirection: 'column',
    }}>
      {props.children}
    </Box>
  );
}

function TaskGraphHeader(props) {
  return (
    <Box style={{
      flexDirection: 'row',
      alignItems: 'center',
      justifyContent: 'space-between',
      padding: 12,
      borderBottomWidth: 1,
      borderColor: '#171d26',
    }}>
      <Text fontSize={12} color="#eef2f8" bold={true}>{props.title || 'Task Graph'}</Text>
      <Box style={{ flexDirection: 'row', gap: 6 }}>
        {props.actions}
      </Box>
    </Box>
  );
}

function TaskGraphCanvas(props) {
  return (
    <Box style={{
      flexGrow: 1,
      flexBasis: 0,
      position: 'relative',
    }}>
      {props.children}
    </Box>
  );
}

function TaskNode(props) {
  var node = props.node || {};
  var status = node.status || 'pending';
  
  var bg = '#0f141c';
  var borderColor = '#1f2935';
  
  if (status exact 'active') {
    bg = '#10213d';
    borderColor = '#2d62ff';
  } else if (status exact 'completed') {
    bg = '#0d2a1a';
    borderColor = '#7ee787';
  } else if (status exact 'error') {
    bg = '#341316';
    borderColor = '#ff7b72';
  }
  
  return (
    <Box style={{
      position: 'absolute',
      left: node.x || 0,
      top: node.y || 0,
      minWidth: 120,
      backgroundColor: bg,
      borderRadius: 8,
      borderWidth: 1,
      borderColor: borderColor,
      padding: 10,
      flexDirection: 'column',
      gap: 6,
    }}>
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 6 }}>
        <Box style={{
          width: 8,
          height: 8,
          borderRadius: 4,
          backgroundColor: status exact 'active' ? '#ffbd2e' : status exact 'completed' ? '#7ee787' : status exact 'error' ? '#ff7b72' : '#5d6a7c',
        }} />
        <Text fontSize={11} color="#eef2f8" bold={true}>{node.name || 'Task'}</Text>
      </Box>
      {node.description && (
        <Text fontSize={10} color="#7f8a99">{node.description}</Text>
      )}
    </Box>
  );
}

function TaskEdge(props) {
  var edge = props.edge || {};
  var from = edge.from || { x: 0, y: 0 };
  var to = edge.to || { x: 100, y: 100 };
  
  return (
    <Box style={{
      position: 'absolute',
      left: Math.min(from.x, to.x),
      top: Math.min(from.y, to.y),
      width: Math.abs(to.x - from.x),
      height: Math.abs(to.y - from.y),
    }}>
      <Box style={{
        position: 'absolute',
        left: 0,
        top: from.y < to.y ? 0 : Math.abs(to.y - from.y),
        width: Math.abs(to.x - from.x),
        height: 2,
        backgroundColor: edge.active == 1 ? '#2d62ff' : '#1f2935',
      }} />
    </Box>
  );
}

function TaskGraphLegend(props) {
  var items = [
    { status: 'pending', color: '#5d6a7c', label: 'Pending' },
    { status: 'active', color: '#ffbd2e', label: 'Active' },
    { status: 'completed', color: '#7ee787', label: 'Completed' },
    { status: 'error', color: '#ff7b72', label: 'Error' },
  ];
  
  return (
    <Box style={{
      flexDirection: 'row',
      gap: 12,
      padding: 10,
      borderTopWidth: 1,
      borderColor: '#171d26',
    }}>
      {items.map(function(item, idx) {
        return (
          <Box key={idx} style={{ flexDirection: 'row', alignItems: 'center', gap: 4 }}>
            <Box style={{ width: 8, height: 8, borderRadius: 4, backgroundColor: item.color }} />
            <Text fontSize={10} color="#5d6a7c">{item.label}</Text>
          </Box>
        );
      })}
    </Box>
  );
}

export {
  AgentTaskGraph,
  TaskGraphHeader,
  TaskGraphCanvas,
  TaskNode,
  TaskEdge,
  TaskGraphLegend,
};
