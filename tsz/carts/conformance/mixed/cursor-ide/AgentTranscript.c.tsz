// AgentTranscript — Agent message transcript panel

function AgentTranscript(props) {
  return (
    <Box style={{
      flexGrow: 1,
      flexBasis: 0,
      flexDirection: 'column',
      backgroundColor: '#0c1016',
    }}>
      {props.children}
    </Box>
  );
}

function TranscriptHeader(props) {
  return (
    <Box style={{
      flexDirection: 'row',
      alignItems: 'center',
      justifyContent: 'space-between',
      padding: 12,
      borderBottomWidth: 1,
      borderColor: '#171d26',
    }}>
      <Text fontSize={12} color="#eef2f8" bold={true}>{props.title || 'Transcript'}</Text>
      <Text fontSize={10} color="#5d6a7c">{props.count || 0} messages</Text>
    </Box>
  );
}

function TranscriptMessages(props) {
  return (
    <ScrollView style={{ flexGrow: 1, flexBasis: 0 }}>
      <Box style={{
        flexDirection: 'column',
        padding: 12,
        gap: 12,
      }}>
        {props.children}
      </Box>
    </ScrollView>
  );
}

function TranscriptMessage(props) {
  var msg = props.message || {};
  var isUser = msg.role exact 'user';
  var isAssistant = msg.role exact 'assistant';
  var isSystem = msg.role exact 'system';
  
  var bg = isUser ? '#10213d' : isSystem ? '#0f141c' : '#10151d';
  var borderColor = isUser ? '#2d62ff40' : '#1f2935';
  
  return (
    <Box style={{
      flexDirection: 'column',
      backgroundColor: bg,
      borderRadius: 10,
      borderWidth: 1,
      borderColor: borderColor,
      padding: 12,
      gap: 8,
    }}>
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
        <Box style={{
          width: 24,
          height: 24,
          borderRadius: 12,
          backgroundColor: isUser ? '#2d62ff' : isSystem ? '#5d6a7c' : '#7ee787',
          alignItems: 'center',
          justifyContent: 'center',
        }}>
          <Text fontSize={10} color="#ffffff">
            {isUser ? 'U' : isSystem ? 'S' : '🤖'}
          </Text>
        </Box>
        <Box style={{ flexDirection: 'column' }}>
          <Text fontSize={11} color="#eef2f8" bold={true}>
            {isUser ? 'You' : isSystem ? 'System' : (msg.model || 'Assistant')}
          </Text>
          {msg.time && <Text fontSize={9} color="#5d6a7c">{msg.time}</Text>}
        </Box>
        {msg.mode && (
          <Box style={{
            marginLeft: 'auto',
            paddingLeft: 6,
            paddingRight: 6,
            paddingTop: 2,
            paddingBottom: 2,
            backgroundColor: '#182510',
            borderRadius: 999,
          }}>
            <Text fontSize={9} color="#7ee787">{msg.mode}</Text>
          </Box>
        )}
      </Box>
      
      <Text fontSize={12} color="#d4dbe7" lineHeight={18}>
        {msg.text}
      </Text>
      
      {msg.attachments && msg.attachments.length > 0 && (
        <Box style={{ flexDirection: 'row', gap: 6, flexWrap: 'wrap' }}>
          {msg.attachments.map(function(att, idx) {
            return (
              <Box key={idx} style={{
                flexDirection: 'row',
                alignItems: 'center',
                gap: 4,
                paddingLeft: 8,
                paddingRight: 8,
                paddingTop: 4,
                paddingBottom: 4,
                backgroundColor: '#0f141c',
                borderRadius: 999,
                borderWidth: 1,
                borderColor: '#1f2935',
              }}>
                <Text fontSize={9} color="#79c0ff">📎 {att.name}</Text>
              </Box>
            );
          })}
        </Box>
      )}
    </Box>
  );
}

function TranscriptToolCall(props) {
  var tool = props.tool || {};
  var expanded = props.expanded || 0;
  
  return (
    <Box style={{
      flexDirection: 'column',
      backgroundColor: '#0f141c',
      borderRadius: 8,
      borderWidth: 1,
      borderColor: '#1f2935',
      padding: 10,
      gap: 6,
      marginLeft: 30,
    }}>
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
        <Text fontSize={10} color="#7ee787">⚡</Text>
        <Text fontSize={11} color="#eef2f8" bold={true}>{tool.name}</Text>
        <Box style={{ flexGrow: 1 }} />
        <Box style={{
          paddingLeft: 6,
          paddingRight: 6,
          paddingTop: 2,
          paddingBottom: 2,
          backgroundColor: tool.status exact 'completed' ? '#0d2a1a' : tool.status exact 'error' ? '#341316' : '#10213d',
          borderRadius: 4,
        }}>
          <Text fontSize={9} color={tool.status exact 'completed' ? '#7ee787' : tool.status exact 'error' ? '#ff7b72' : '#79c0ff'}>
            {tool.status}
          </Text>
        </Box>
      </Box>
      
      {tool.input && (
        <Text fontSize={10} color="#5d6a7c">{tool.input}</Text>
      )}
      
      {tool.result && expanded == 1 && (
        <Box style={{
          backgroundColor: '#0b0f15',
          borderRadius: 6,
          padding: 8,
        }}>
          <Text fontSize={10} color="#9db1c9" fontFamily="monospace">
            {tool.result}
          </Text>
        </Box>
      )}
    </Box>
  );
}

export {
  AgentTranscript,
  TranscriptHeader,
  TranscriptMessages,
  TranscriptMessage,
  TranscriptToolCall,
};
