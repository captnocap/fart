// ChatPanel — agent console that shares workspace, git, and editor context

import {
  XIcon, BotIcon, UserRoundIcon, FileCodeIcon, AtSignIcon, GitBranchIcon, ChevronDownIcon,
  HashIcon, PlusIcon, GlobeIcon, TerminalIcon, SparklesIcon, SendIcon, AlertTriangleIcon,
  BadgeInfoIcon, RefreshCcwIcon
} from './Icon.c';

function ToolCallCard(props) {
  var exec = props.exec;

  return (
    <C.ToolCallCard>
      <C.ToolCallHeader>
        <C.ToolCallName>{exec.name}</C.ToolCallName>
        <C.ToolCallInput>{exec.input}</C.ToolCallInput>
        <C.ToolCallStatus style={{ color: exec.status == 'completed' ? '#7ee787' : exec.status == 'error' ? '#ff7b72' : '#79c0ff' }}>{exec.status}</C.ToolCallStatus>
      </C.ToolCallHeader>
      <C.ToolCallOutput>
        <C.ToolCallOutputText>{exec.result}</C.ToolCallOutputText>
      </C.ToolCallOutput>
    </C.ToolCallCard>
  );
}

function AgentSessionBanner() {
  var isStreaming = agentStatusText == 'streaming';
  var isExecuting = agentStatusText == 'executing';
  var hasAgent = activeAgentId.length > 0;
  var isActive = 0;
  if (isStreaming || isExecuting || hasAgent) isActive = 1;
  if (isActive != 1) return null;

  return (
    <C.SessionBanner>
      {isStreaming == 1 && <C.SessionBannerDot style={{ backgroundColor: '#2d62ff' }} />}
      {isStreaming != 1 && isExecuting == 1 && <C.SessionBannerDot style={{ backgroundColor: '#e6b450' }} />}
      {isStreaming != 1 && isExecuting != 1 && hasAgent && <C.SessionBannerDot style={{ backgroundColor: '#7ee787' }} />}
      {isStreaming == 1 && <C.SessionBannerText>streaming response</C.SessionBannerText>}
      {isStreaming != 1 && isExecuting == 1 && <C.SessionBannerText>running tools</C.SessionBannerText>}
      {isStreaming != 1 && isExecuting != 1 && hasAgent && <C.SessionBannerText>background agent active</C.SessionBannerText>}
      {hasAgent && (
        <C.SessionBannerStop onPress={function() { stopBackgroundAgent(); }}>
          <C.SessionBannerStopText>Stop</C.SessionBannerStopText>
        </C.SessionBannerStop>
      )}
    </C.SessionBanner>
  );
}

function ContextStrip(props) {
  var compactBand = 0;
  var minimumBand = 0;
  var showViewChip = 1;
  var showFocusChip = 1;
  var focusLabel = props.currentFilePath == '__landing__' ? props.workspaceName : props.currentFilePath == '__settings__' ? 'Settings' : props.currentFilePath;
  var dirtyCountText = props.changedCount;

  if (props.widthBand == 'narrow' || props.widthBand == 'widget' || props.widthBand == 'minimum') {
    compactBand = 1;
    showViewChip = 0;
  }
  if (props.widthBand == 'minimum') {
    minimumBand = 1;
    showFocusChip = 0;
  }

  if (compactBand == 1 && props.currentFilePath != '__landing__' && props.currentFilePath != '__settings__') {
    var parts = props.currentFilePath.split('/');
    focusLabel = parts[parts.length - 1];
  }

  return (
    <C.ChatContextStrip style={compactBand == 1 ? { paddingLeft: 10, paddingRight: 10, paddingTop: 8, paddingBottom: 8, gap: 6 } : {}}>
      {showViewChip == 1 && <C.ChatContextChip>
        <C.ChatContextChipLabel>view</C.ChatContextChipLabel>
        <C.ChatContextChipValue>{props.activeView}</C.ChatContextChipValue>
      </C.ChatContextChip>}
      <C.ChatContextChip>
        <C.ChatContextChipLabel>branch</C.ChatContextChipLabel>
        <C.ChatContextChipValue>{props.gitBranch}</C.ChatContextChipValue>
      </C.ChatContextChip>
      {showFocusChip == 1 && <C.ChatContextChip>
        <C.ChatContextChipLabel>focus</C.ChatContextChipLabel>
        <C.ChatContextChipValue>{focusLabel}</C.ChatContextChipValue>
      </C.ChatContextChip>}
      <C.ChatContextChip>
        <C.ChatContextChipLabel>dirty</C.ChatContextChipLabel>
        <C.ChatContextChipValue>{dirtyCountText}</C.ChatContextChipValue>
      </C.ChatContextChip>
    </C.ChatContextStrip>
  );
}

function BubbleContent(props) {
  var msg = props.msg;
  var showAttachments = 0;
  var showTools = 0;

  if (msg.attachments && msg.attachments.length > 0) showAttachments = 1;
  if (msg.toolSnapshot && msg.toolSnapshot.length > 0) showTools = 1;

  return (
    <Box style={{ flexDirection: 'column', gap: 8 }}>
      <C.MessageText>{msg.text}</C.MessageText>

      {showAttachments == 1 && <C.ContextBar>
        {msg.attachments.map(function(a, i) {
          return (
            <C.ContextChip key={i}>
              <C.ContextChipFile>{a.name}</C.ContextChipFile>
            </C.ContextChip>
          );
        })}
      </C.ContextBar>}

      {showTools == 1 && <C.MessageToolList>
        {msg.toolSnapshot.map(function(exec, idx) {
          return <ToolCallCard key={idx} exec={exec} />;
        })}
      </C.MessageToolList>}
    </Box>
  );
}

function Message(props) {
  var msg = props.msg;
  var isUser = msg.role == 'user';
  var showMode = 0;
  var showModel = 0;
  var authorLabel = isUser == 1 ? 'You' : 'Agent';

  if (msg.mode) showMode = 1;
  if (msg.model) showModel = 1;

  return (
    <C.Message>
      <C.MessageHeader>
        {isUser == 1 && <C.MessageAvatar style={{ backgroundColor: '#17345d' }}><UserRoundIcon size={11} /></C.MessageAvatar>}
        {isUser != 1 && <C.MessageAvatar style={{ backgroundColor: '#143120' }}><BotIcon size={11} /></C.MessageAvatar>}
        {isUser == 1 && <C.MessageAuthor>You</C.MessageAuthor>}
        {isUser != 1 && <C.MessageAuthor>Agent</C.MessageAuthor>}
        <C.MessageTime>{msg.time}</C.MessageTime>
        {showMode == 1 && <C.MessageModeBadge><C.MessageModeText>{msg.mode}</C.MessageModeText></C.MessageModeBadge>}
        {showModel == 1 && <C.MessageModelBadge><C.MessageModelText>{msg.model}</C.MessageModelText></C.MessageModelBadge>}
      </C.MessageHeader>

      {isUser == 1 && <C.MessageBubble style={{ backgroundColor: '#101827', borderColor: '#20324f' }}><BubbleContent msg={msg} /></C.MessageBubble>}
      {isUser != 1 && <C.MessageBubble style={{ backgroundColor: '#10141c', borderColor: '#1c2531' }}><BubbleContent msg={msg} /></C.MessageBubble>}
    </C.Message>
  );
}

function ThinkingIndicator() {
  var activeLabel = 'thinking';
  for (var ti = 0; ti < toolExecutions.length; ti++) {
    if (toolExecutions[ti].status == 'running') activeLabel = 'running ' + toolExecutions[ti].name;
  }

  return (
    <C.ThinkingRow>
      <C.ThinkingAvatar>
        <BotIcon size={11} />
      </C.ThinkingAvatar>
      <C.ThinkingBubble>
        <C.ThinkingDot />
        <C.ThinkingDot />
        <C.ThinkingDot />
      </C.ThinkingBubble>
      <C.ThinkingLabel>{activeLabel}</C.ThinkingLabel>
    </C.ThinkingRow>
  );
}

function ModePillBar() {
  return (
    <C.ModePillBar>
      <C.ModePill onPress={function() { setAgentMode('ask'); }} style={agentMode == 'ask' ? { backgroundColor: '#10213d', borderColor: '#2d62ff' } : {}}>
        <C.ModePillLabel style={agentMode == 'ask' ? { color: '#79c0ff' } : {}}>Ask</C.ModePillLabel>
      </C.ModePill>
      <C.ModePill onPress={function() { setAgentMode('plan'); }} style={agentMode == 'plan' ? { backgroundColor: '#10213d', borderColor: '#2d62ff' } : {}}>
        <C.ModePillLabel style={agentMode == 'plan' ? { color: '#79c0ff' } : {}}>Plan</C.ModePillLabel>
      </C.ModePill>
      <C.ModePill onPress={function() { setAgentMode('task'); }} style={agentMode == 'task' ? { backgroundColor: '#182510', borderColor: '#7ee787' } : {}}>
        <C.ModePillLabel style={agentMode == 'task' ? { color: '#7ee787' } : {}}>Task</C.ModePillLabel>
      </C.ModePill>
      <C.ModePill onPress={function() { setAgentMode('agent'); }} style={agentMode == 'agent' ? { backgroundColor: '#26180f', borderColor: '#ffa657' } : {}}>
        <C.ModePillLabel style={agentMode == 'agent' ? { color: '#ffa657' } : {}}>Agent</C.ModePillLabel>
      </C.ModePill>
    </C.ModePillBar>
  );
}

function AttachBadge(props) {
  var a = props.attachment;

  return (
    <C.AttachBadge>
      {a.type == 'symbol' && <AtSignIcon size={10} />}
      {a.type == 'git' && <GitBranchIcon size={10} />}
      {a.type != 'symbol' && a.type != 'git' && <FileCodeIcon size={10} />}
      <C.AttachBadgeName>{a.name}</C.AttachBadgeName>
      <C.AttachBadgeRemove onPress={function() { removeAttachment(a.id); }}>
        <XIcon size={9} />
      </C.AttachBadgeRemove>
    </C.AttachBadge>
  );
}

function AttachmentBar() {
  if (attachments.length == 0) return null;

  return (
    <C.AttachmentBar>
      <C.AttachmentList>
        {attachments.map(function(a, idx) {
          return <AttachBadge key={idx} attachment={a} />;
        })}
      </C.AttachmentList>
      <C.AttachClearAll onPress={function() { clearAttachments(); }}>
        <C.AttachClearLabel>Clear</C.AttachClearLabel>
      </C.AttachClearAll>
    </C.AttachmentBar>
  );
}

function ToolToggle(props) {
  return (
    <C.InputToolToggle onPress={props.onToggle} style={props.active == 1 ? { backgroundColor: '#10213d', borderColor: '#2d62ff' } : props.iconOnly == 1 ? { paddingLeft: 6, paddingRight: 6 } : {}}>
      <Box style={{ width: 10, alignItems: 'center', justifyContent: 'center' }}>
        {props.children}
      </Box>
      {props.iconOnly != 1 && <C.InputToolToggleLabel style={props.active == 1 ? { color: '#79c0ff' } : {}}>{props.label}</C.InputToolToggleLabel>}
    </C.InputToolToggle>
  );
}

function ModelPicker(props) {
  var showLabel = 1;
  if (props.widthBand == 'minimum') showLabel = 0;

  return (
    <C.ModelPickerBtn onPress={function() { cycleModel(); }}>
      <C.ModelPickerDot style={{ backgroundColor: '#ff7b72' }} />
      {showLabel == 1 && <C.ModelPickerLabel>{modelDisplayName}</C.ModelPickerLabel>}
      <ChevronDownIcon size={9} />
    </C.ModelPickerBtn>
  );
}

function TokenCountBadge() {
  var tokenText = inputTokenEstimate + ' tkns';
  if (inputTokenEstimate == 0) return null;

  return (
    <C.TokenCount>
      <C.TokenCountText style={{ color: inputTokenEstimate > 16000 ? '#ff7b72' : inputTokenEstimate > 8000 ? '#e6b450' : '#4a4a4a' }}>{tokenText}</C.TokenCountText>
    </C.TokenCount>
  );
}

function SlashHints() {
  var cmds = [
    { cmd: '/fix', desc: 'Fix current file' },
    { cmd: '/review', desc: 'Review recent changes' },
    { cmd: '/plan', desc: 'Plan the next edit' },
    { cmd: '/docs', desc: 'Draft docs' },
    { cmd: '/commit', desc: 'Draft commit message' },
  ];
  var filtered = [];

  for (var i = 0; i < cmds.length; i++) {
    if (currentInput == '/' || cmds[i].cmd.indexOf(currentInput) == 0) filtered.push(cmds[i]);
  }

  if (filtered.length == 0) return null;

  return (
    <C.SlashHints>
      {filtered.map(function(c, idx) {
        return (
          <C.SlashHint key={idx} onPress={function() { selectSlashCommand(c.cmd); }}>
            <C.SlashHintCmd>{c.cmd}</C.SlashHintCmd>
            <C.SlashHintDesc>{c.desc}</C.SlashHintDesc>
          </C.SlashHint>
        );
      })}
    </C.SlashHints>
  );
}

function ChatInput(props) {
  var compactBand = 0;
  var minimumBand = 0;
  var iconOnly = 0;
  var showComposerMeta = 1;
  var showDivider = 1;
  var showSendLabel = 1;
  var composerContextText = currentFilePath == '__landing__' ? workspaceName : currentFilePath == '__settings__' ? 'Settings' : currentFilePath;
  var composerMetaText = gitBranch + ' / ' + gitRemote;

  if (props.widthBand == 'narrow' || props.widthBand == 'widget' || props.widthBand == 'minimum') compactBand = 1;
  if (props.widthBand == 'minimum') {
    minimumBand = 1;
    iconOnly = 1;
    showComposerMeta = 0;
    showDivider = 0;
    showSendLabel = 0;
  }

  return (
    <C.ChatInputArea style={compactBand == 1 ? { padding: 10, gap: 6 } : {}}>
      <ModePillBar />

      {currentInput.indexOf('/') == 0 && <SlashHints />}

      <C.ChatInputBox>
        <C.ChatComposerSummary>
          <C.ChatComposerContext>{composerContextText}</C.ChatComposerContext>
          {showComposerMeta == 1 && <C.ChatComposerMeta>{composerMetaText}</C.ChatComposerMeta>}
        </C.ChatComposerSummary>

        <AttachmentBar />

        <C.ChatInputField
          value={currentInput}
          onChange={function(v) { setCurrentInput(v); }}
          multiline={true}
        />

        <C.ChatInputToolbar>
          <C.ChatInputToolsLeft>
            <C.ChatToolBtnCompact onPress={function() { triggerFileMention(); }}>
              <HashIcon size={11} />
            </C.ChatToolBtnCompact>
            <C.ChatToolBtnCompact onPress={function() { triggerSymbolMention(); }}>
              <AtSignIcon size={11} />
            </C.ChatToolBtnCompact>
            <C.ChatToolBtnCompact onPress={function() { attachGitContext(); }}>
              <GitBranchIcon size={11} />
            </C.ChatToolBtnCompact>
            <C.ChatToolBtnCompact onPress={function() { attachCurrentFile(); }}>
              <PlusIcon size={11} />
            </C.ChatToolBtnCompact>
            {showDivider == 1 && <C.InputToolDivider />}
            <ToolToggle label="Web" iconOnly={iconOnly} active={webSearch} onToggle={function() { toggleWebSearch(); }}><GlobeIcon size={10} /></ToolToggle>
            <ToolToggle label="Term" iconOnly={iconOnly} active={termAccess} onToggle={function() { toggleTermAccess(); }}><TerminalIcon size={10} /></ToolToggle>
            <ToolToggle label="Auto" iconOnly={iconOnly} active={autoApply} onToggle={function() { toggleAutoApply(); }}><SparklesIcon size={10} /></ToolToggle>
          </C.ChatInputToolsLeft>

          <C.ChatInputToolsRight>
            <TokenCountBadge />
            <ModelPicker widthBand={props.widthBand} />
            <C.ChatSendBtn onPress={function() { sendMessage(); }}>
              <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 7 }}>
                <SendIcon size={11} />
                {showSendLabel == 1 && agentMode == 'agent' && <C.ChatSendLabel>Launch</C.ChatSendLabel>}
                {showSendLabel == 1 && agentMode == 'task' && <C.ChatSendLabel>Run Task</C.ChatSendLabel>}
                {showSendLabel == 1 && agentMode == 'plan' && <C.ChatSendLabel>Plan</C.ChatSendLabel>}
                {showSendLabel == 1 && agentMode != 'agent' && agentMode != 'task' && agentMode != 'plan' && <C.ChatSendLabel>Send</C.ChatSendLabel>}
              </Box>
            </C.ChatSendBtn>
          </C.ChatInputToolsRight>
        </C.ChatInputToolbar>
      </C.ChatInputBox>

      {agentMode == 'task' && (
        <C.TaskModeHint>
          <AlertTriangleIcon size={11} />
          <C.TaskModeHintText>Task mode can read the workspace, inspect git, and use the terminal.</C.TaskModeHintText>
        </C.TaskModeHint>
      )}

      {agentMode == 'plan' && (
        <C.PlanModeHint>
          <BadgeInfoIcon size={11} />
          <C.PlanModeHintText>Plan mode stays descriptive first, edit second.</C.PlanModeHintText>
        </C.PlanModeHint>
      )}
    </C.ChatInputArea>
  );
}

function ToolFeed() {
  if (toolExecutions.length == 0) return null;

  return (
    <C.ToolFeed>
      <C.ToolFeedLabel>Live tool calls</C.ToolFeedLabel>
      {toolExecutions.map(function(exec, idx) {
        return <ToolCallCard key={idx} exec={exec} />;
      })}
    </C.ToolFeed>
  );
}

function ChatPanel(props) {
  var compactBand = 0;
  var minimumBand = 0;
  var showModelLabel = 1;
  var showActionLabels = 1;
  var showWelcome = 1;
  var welcomeTitle = props.workspaceName + ' agent session';
  var welcomeText = props.gitBranch + ' / ' + props.gitRemote + ' / ' + props.changedCount + ' dirty paths';

  if (props.widthBand == 'narrow' || props.widthBand == 'widget' || props.widthBand == 'minimum') compactBand = 1;
  if (props.widthBand == 'minimum') {
    minimumBand = 1;
    showModelLabel = 0;
    showActionLabels = 0;
    showWelcome = 0;
  }

  return (
    <C.ChatPanel style={props.style}>
      <C.ChatHeader style={compactBand == 1 ? { paddingLeft: 10, paddingRight: 10, paddingTop: 10, paddingBottom: 10 } : {}}>
        <C.ChatHeaderLeft>
          <C.ChatTitle>Agent Console</C.ChatTitle>
          <C.ChatModelBadge>
            <C.ChatModelDot />
            {showModelLabel == 1 && <C.ChatModelLabel>{selectedModel}</C.ChatModelLabel>}
          </C.ChatModelBadge>
        </C.ChatHeaderLeft>
        <C.ChatActions>
          <C.ChatActionBtn onPress={function() { startNewConversation(); }}>
            <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 6 }}>
              <PlusIcon size={10} />
              {showActionLabels == 1 && <C.ChatActionLabel>New</C.ChatActionLabel>}
            </Box>
          </C.ChatActionBtn>
          <C.ChatActionBtn onPress={function() { indexProject('.'); }}>
            <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 6 }}>
              <RefreshCcwIcon size={10} />
              {showActionLabels == 1 && <C.ChatActionLabel>Index</C.ChatActionLabel>}
            </Box>
          </C.ChatActionBtn>
        </C.ChatActions>
      </C.ChatHeader>

      <ContextStrip
        activeView={props.activeView}
        currentFilePath={props.currentFilePath}
        workspaceName={props.workspaceName}
        gitBranch={props.gitBranch}
        gitRemote={props.gitRemote}
        changedCount={props.changedCount}
        widthBand={props.widthBand}
      />

      <AgentSessionBanner />

      <C.ChatMessages>
        <C.ChatStack>
          {showWelcome == 1 && <C.ChatWelcome>
            <C.ChatWelcomeTitle>{welcomeTitle}</C.ChatWelcomeTitle>
            <C.ChatWelcomeText>{welcomeText}</C.ChatWelcomeText>
          </C.ChatWelcome>}

          {props.messages.map(function(msg, idx) {
            return <Message key={idx} msg={msg} />;
          })}

          {props.isGenerating == 1 && <ToolFeed />}
          {props.isGenerating == 1 && <ThinkingIndicator />}
        </C.ChatStack>
      </C.ChatMessages>

      <ChatInput widthBand={props.widthBand} />
    </C.ChatPanel>
  );
}

export { ChatPanel };
