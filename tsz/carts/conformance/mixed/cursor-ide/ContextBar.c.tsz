// ContextBar — Context attachment bar

function ContextBar(props) {
  var items = props.items || [];
  
  return (
    <C.ChatContextStrip>
      {items.map(function(item, idx) {
        return (
          <ContextChip 
            key={idx} 
            item={item}
            onRemove={function() { if (props.onRemove) props.onRemove(item.id); }}
          />
        );
      })}
      <Pressable onPress={props.onAdd}>
        <Box style={{
          flexDirection: 'row',
          alignItems: 'center',
          gap: 4,
          paddingLeft: 8,
          paddingRight: 8,
          paddingTop: 4,
          paddingBottom: 4,
          backgroundColor: '#10151d',
          borderRadius: 999,
          borderWidth: 1,
          borderColor: '#1f2935',
          borderStyle: 'dashed',
        }}>
          <Text fontSize={9} color="#79c0ff">+</Text>
          <Text fontSize={10} color="#79c0ff">Add</Text>
        </Box>
      </Pressable>
    </C.ChatContextStrip>
  );
}

function ContextChip(props) {
  var item = props.item || {};
  var typeColors = {
    file: '#79c0ff',
    folder: '#7ee787',
    git: '#ff7b72',
    symbol: '#d2a8ff',
    workspace: '#ffbd2e',
    web: '#79c0ff',
    image: '#ffa657',
  };
  
  var color = typeColors[item.type] || '#c9d2df';
  
  return (
    <C.ChatContextChip>
      <Text fontSize={9} color={color}>{item.type}</Text>
      <C.ChatContextChipValue>{item.name}</C.ChatContextChipValue>
      {props.onRemove && (
        <Pressable onPress={props.onRemove}>
          <Text fontSize={9} color="#5d6a7c">×</Text>
        </Pressable>
      )}
    </C.ChatContextChip>
  );
}

export {
  ContextBar,
  ContextChip,
};
