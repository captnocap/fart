// Editor Component — real editable text area with line count

function Editor(props) {
  return (
    <Box style={{ flexGrow: 1, flexBasis: 0, flexDirection: 'row', backgroundColor: '#0d0d0d' }}>
      <Box style={{ width: 50, flexDirection: 'column', paddingTop: 8, alignItems: 'flex-end', paddingRight: 12 }}>
        <Text fontSize={11} color="#3d3d3d">{props.lineCount}</Text>
        <Text fontSize={11} color="#3d3d3d">lines</Text>
      </Box>
      <Box style={{ flexGrow: 1, flexBasis: 0 }}>
        <TextInput
          value={props.content}
          onChange={props.onChange}
          fontSize={13}
          color="#b0b0b0"
          style={{ flexGrow: 1, flexBasis: 0, paddingTop: 8, paddingLeft: 4, paddingRight: 8, backgroundColor: '#0d0d0d' }}
        />
      </Box>
    </Box>
  );
}

export { Editor };
