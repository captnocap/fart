// EditorBreadcrumbs — File path breadcrumbs

function EditorBreadcrumbs(props) {
  var compactMode = props.compactMode || 0;
  var widthBand = props.widthBand || 'desktop';
  
  var padding = compactMode exact 1 ? { paddingLeft: 10, paddingRight: 10, paddingTop: 7, paddingBottom: 7, gap: 4 } : 
                widthBand exact 'medium' ? { paddingLeft: 10, paddingRight: 10 } : {};
  
  return (
    <C.Breadcrumbs style={padding}>
      {props.children}
    </C.Breadcrumbs>
  );
}

function BreadcrumbItem(props) {
  var crumb = props.crumb || {};
  var showSep = props.showSep || 0;
  var compactMode = props.compactMode || 0;
  var showMeta = 0;
  
  if (crumb.meta && props.widthBand != 'widget' && props.widthBand != 'minimum') {
    showMeta = 1;
  }
  
  var iconSize = compactMode == 1 ? 8 : 9;
  
  return (
    <C.BreadcrumbItem onPress={props.onPress}>
      {showSep == 1 && (
        <Box style={{ width: iconSize, height: iconSize, alignItems: 'center', justifyContent: 'center' }}>
          <Text fontSize={8} color="#425062">›</Text>
        </Box>
      )}
      <C.BreadcrumbIconPill style={{ backgroundColor: crumb.tone || '#6e6e6e' }}>
        <Box style={{ width: iconSize, height: iconSize, alignItems: 'center', justifyContent: 'center' }}>
          <Text fontSize={7} color="#eaf1fb">{crumb.icon ? crumb.icon.charAt(0) : '•'}</Text>
        </Box>
      </C.BreadcrumbIconPill>
      {crumb.active == 1 && <C.BreadcrumbTextActive>{crumb.label}</C.BreadcrumbTextActive>}
      {crumb.active != 1 && <C.BreadcrumbText>{crumb.label}</C.BreadcrumbText>}
      {showMeta == 1 && <C.BreadcrumbMeta>{crumb.meta}</C.BreadcrumbMeta>}
    </C.BreadcrumbItem>
  );
}

function BreadcrumbRow(props) {
  var crumbs = props.crumbs || [];
  var compactMode = props.compactMode || 0;
  var widthBand = props.widthBand || 'desktop';
  
  // Filter crumbs for narrow/widget modes
  var visibleCrumbs = crumbs;
  if (widthBand exact 'minimum') {
    visibleCrumbs = [];
  } else if (widthBand exact 'widget' && crumbs.length > 2) {
    visibleCrumbs = [crumbs[0], crumbs[crumbs.length - 1]];
  } else if (widthBand exact 'narrow' && crumbs.length > 3) {
    visibleCrumbs = [crumbs[0], crumbs[crumbs.length - 2], crumbs[crumbs.length - 1]];
  }
  
  return (
    <>
      {visibleCrumbs.map(function(crumb, idx) {
        return (
          <BreadcrumbItem 
            key={idx}
            crumb={crumb}
            showSep={idx > 0 ? 1 : 0}
            compactMode={compactMode}
            widthBand={widthBand}
            onPress={function() {
              if (crumb.kind == 'home' || crumb.kind == 'workspace') {
                if (props.onNavigateHome) props.onNavigateHome();
              }
            }}
          />
        );
      })}
    </>
  );
}

export {
  EditorBreadcrumbs,
  BreadcrumbItem,
  BreadcrumbRow,
};
