// EditorHeader — Editor header with file info and actions

function EditorHeader(props) {
  var compactBand = props.compactBand || 0;
  var padding = compactBand == 1 ? { paddingLeft: 10, paddingRight: 10, paddingTop: 8, paddingBottom: 8 } : {};
  
  return (
    <C.EditorHeaderBar style={padding}>
      {props.children}
    </C.EditorHeaderBar>
  );
}

function EditorHeaderLeft(props) {
  return (
    <C.EditorHeaderLeft>
      {props.children}
    </C.EditorHeaderLeft>
  );
}

function EditorHeaderTitle(props) {
  return (
    <C.EditorHeaderTitle>
      {props.children}
    </C.EditorHeaderTitle>
  );
}

function EditorHeaderMeta(props) {
  return (
    <C.EditorHeaderMeta>
      {props.children}
    </C.EditorHeaderMeta>
  );
}

function EditorHeaderRight(props) {
  return (
    <C.EditorHeaderRight>
      {props.children}
    </C.EditorHeaderRight>
  );
}

function EditorHeaderBadge(props) {
  var color = props.color || '#7f8a99';
  var bg = props.backgroundColor || '#10151d';
  
  return (
    <C.EditorHeaderBadge style={{ backgroundColor: bg }}>
      <C.EditorHeaderBadgeText style={{ color: color }}>
        {props.children}
      </C.EditorHeaderBadgeText>
    </C.EditorHeaderBadge>
  );
}

function EditorPathBreadcrumbs(props) {
  var crumbs = props.crumbs || [];
  
  return (
    <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 6 }}>
      {crumbs.map(function(crumb, idx) {
        return (
          <Box key={idx} style={{ flexDirection: 'row', alignItems: 'center', gap: 6 }}>
            {idx > 0 && <Text fontSize={10} color="#425062">›</Text>}
            <Text fontSize={11} color={crumb.active == 1 ? '#eef2f8' : '#7f8a99'} bold={crumb.active == 1}>
              {crumb.label}
            </Text>
          </Box>
        );
      })}
    </Box>
  );
}

export {
  EditorHeader,
  EditorHeaderLeft,
  EditorHeaderTitle,
  EditorHeaderMeta,
  EditorHeaderRight,
  EditorHeaderBadge,
  EditorPathBreadcrumbs,
};
