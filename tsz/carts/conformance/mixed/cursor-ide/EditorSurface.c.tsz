// EditorSurface — Main editor shell container

function EditorSurface(props) {
  return (
    <C.EditorViewportShell>
      {props.children}
    </C.EditorViewportShell>
  );
}

function EditorPane(props) {
  return (
    <C.Editor style={props.style}>
      {props.children}
    </C.Editor>
  );
}

function EditorContent(props) {
  var compactBand = props.compactBand || 0;
  
  return (
    <C.EditorViewport>
      {props.children}
    </C.EditorViewport>
  );
}

export {
  EditorSurface,
  EditorPane,
  EditorContent,
};
