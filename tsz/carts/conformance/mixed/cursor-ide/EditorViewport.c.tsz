// EditorViewport — Main code editing area

function EditorViewport(props) {
  return (
    <C.EditorViewport>
      {props.children}
    </C.EditorViewport>
  );
}

function EditorCodeScroll(props) {
  return (
    <C.EditorCodeScroll>
      {props.children}
    </C.EditorCodeScroll>
  );
}

function EditorCodeStack(props) {
  return (
    <C.EditorCodeStack>
      {props.children}
    </C.EditorCodeStack>
  );
}

function EditorRow(props) {
  var row = props.row || {};
  var isActive = row.line == props.cursorLine;
  var bg = isActive ? '#111b2d' : row.line % 2 == 0 ? '#0f1218' : '#0d1015';
  var rowHeight = props.compactBand == 1 ? 20 : 22;
  
  return (
    <Box style={{ flexDirection: 'row', minHeight: rowHeight, backgroundColor: bg }}>
      {props.children}
    </Box>
  );
}

function EditorEmptyState(props) {
  return (
    <Box style={{
      flexGrow: 1,
      flexBasis: 0,
      alignItems: 'center',
      justifyContent: 'center',
      padding: 40,
    }}>
      <Text fontSize={14} color="#5d6a7c" bold={true}>{props.title || 'No file open'}</Text>
      <Text fontSize={12} color="#5d6a7c" style={{ marginTop: 8 }}>{props.message || 'Select a file from the sidebar'}</Text>
    </Box>
  );
}

export {
  EditorViewport,
  EditorCodeScroll,
  EditorCodeStack,
  EditorRow,
  EditorEmptyState,
};
