// ExtensionDetail — VS Code extension detail view

function ExtensionDetail(props) {
  return (
    <Box style={{
      flexGrow: 1,
      flexBasis: 0,
      flexDirection: 'column',
      backgroundColor: '#0d1015',
    }}>
      {props.children}
    </Box>
  );
}

function ExtensionDetailHeader(props) {
  var ext = props.extension || {};
  var installed = ext.installed || 0;
  var enabled = ext.enabled || 0;
  
  return (
    <Box style={{
      flexDirection: 'column',
      gap: 14,
      padding: 16,
      borderBottomWidth: 1,
      borderColor: '#171d26',
    }}>
      <Box style={{ flexDirection: 'row', gap: 14 }}>
        <Box style={{
          width: 80,
          height: 80,
          borderRadius: 12,
          backgroundColor: ext.tone || '#79c0ff' + '20',
          alignItems: 'center',
          justifyContent: 'center',
        }}>
          <Text fontSize={36} color={ext.tone || '#79c0ff'}>{ext.icon || '📦'}</Text>
        </Box>
        
        <Box style={{ flexDirection: 'column', flexGrow: 1, flexBasis: 0, gap: 6 }}>
          <Text fontSize={18} color="#eef2f8" bold={true}>{ext.name}</Text>
          <Text fontSize={12} color="#5d6a7c">{ext.publisher}</Text>
          <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8, flexWrap: 'wrap' }}>
            {ext.rating > 0 && (
              <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 4 }}>
                <Text fontSize={12} color="#ffbd2e">★ {ext.rating}</Text>
              </Box>
            )}
            <Text fontSize={11} color="#5d6a7c">{ext.downloads} downloads</Text>
            <Text fontSize={11} color="#5d6a7c">v{ext.version}</Text>
          </Box>
        </Box>
      </Box>
      
      <Box style={{ flexDirection: 'row', gap: 8 }}>
        {installed == 1 ? (
          <>
            <Pressable 
              onPress={props.onToggle}
              style={{
                paddingLeft: 16,
                paddingRight: 16,
                paddingTop: 8,
                paddingBottom: 8,
                backgroundColor: enabled == 1 ? '#341316' : '#0d2a1a',
                borderRadius: 8,
              }}
            >
              <Text fontSize={12} color={enabled == 1 ? '#ff7b72' : '#7ee787'} bold={true}>
                {enabled == 1 ? 'Disable' : 'Enable'}
              </Text>
            </Pressable>
            <Pressable 
              onPress={props.onUninstall}
              style={{
                paddingLeft: 16,
                paddingRight: 16,
                paddingTop: 8,
                paddingBottom: 8,
                backgroundColor: '#10151d',
                borderRadius: 8,
                borderWidth: 1,
                borderColor: '#1f2935',
              }}
            >
              <Text fontSize={12} color="#c9d2df">Uninstall</Text>
            </Pressable>
          </>
        ) : (
          <Pressable 
            onPress={props.onInstall}
            style={{
              paddingLeft: 20,
              paddingRight: 20,
              paddingTop: 10,
              paddingBottom: 10,
              backgroundColor: '#2d62ff',
              borderRadius: 8,
            }}
          >
            <Text fontSize={13} color="#ffffff" bold={true}>Install</Text>
          </Pressable>
        )}
      </Box>
    </Box>
  );
}

function ExtensionDetailContent(props) {
  return (
    <ScrollView style={{ flexGrow: 1, flexBasis: 0 }}>
      <Box style={{ padding: 16, flexDirection: 'column', gap: 16 }}>
        {props.children}
      </Box>
    </ScrollView>
  );
}

function ExtensionDetailSection(props) {
  return (
    <Box style={{ flexDirection: 'column', gap: 10 }}>
      <Text fontSize={13} color="#eef2f8" bold={true}>{props.title}</Text>
      {props.children}
    </Box>
  );
}

function ExtensionDetailReadme(props) {
  return (
    <Text fontSize={12} color="#c9d2df" lineHeight={20}>
      {props.children}
    </Text>
  );
}

export {
  ExtensionDetail,
  ExtensionDetailHeader,
  ExtensionDetailContent,
  ExtensionDetailSection,
  ExtensionDetailReadme,
};
