// MarketplaceCard — Grid card for marketplace items

function MarketplaceCard(props) {
  var item = props.item || {};
  
  return (
    <Pressable 
      onPress={props.onPress}
      style={{
        width: props.width || 200,
        padding: 12,
        backgroundColor: '#0f141c',
        borderRadius: 10,
        borderWidth: 1,
        borderColor: '#1f2935',
        flexDirection: 'column',
        gap: 8,
      }}
    >
      <Box style={{
        width: 48,
        height: 48,
        borderRadius: 10,
        backgroundColor: item.tone || '#79c0ff' + '20',
        alignItems: 'center',
        justifyContent: 'center',
      }}>
        <Text fontSize={24} color={item.tone || '#79c0ff'}>{item.icon || '📦'}</Text>
      </Box>
      
      <Box style={{ flexDirection: 'column', gap: 2 }}>
        <Text fontSize={12} color="#eef2f8" bold={true} numberOfLines={1}>{item.name}</Text>
        <Text fontSize={10} color="#5d6a7c">{item.publisher}</Text>
      </Box>
      
      <Text fontSize={10} color="#7f8a99" numberOfLines={2} lineHeight={14}>
        {item.description}
      </Text>
      
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 6, marginTop: 'auto' }}>
        <Text fontSize={9} color="#5d6a7c">{item.downloads}</Text>
        {item.rating > 0 && (
          <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 2 }}>
            <Text fontSize={9} color="#ffbd2e">★</Text>
            <Text fontSize={9} color="#5d6a7c">{item.rating}</Text>
          </Box>
        )}
      </Box>
    </Pressable>
  );
}

function MarketplaceCardGrid(props) {
  return (
    <Box style={{
      flexDirection: 'row',
      flexWrap: 'wrap',
      gap: 10,
      padding: 12,
    }}>
      {props.children}
    </Box>
  );
}

export {
  MarketplaceCard,
  MarketplaceCardGrid,
};
