// MarketplaceList — List of marketplace items

function MarketplaceList(props) {
  return (
    <ScrollView style={{ flexGrow: 1, flexBasis: 0 }}>
      <Box style={{
        flexDirection: 'column',
        padding: 12,
        gap: 10,
      }}>
        {props.children}
      </Box>
    </ScrollView>
  );
}

function MarketplaceCategory(props) {
  return (
    <Box style={{ flexDirection: 'column', gap: 8 }}>
      <Text fontSize={11} color="#5d6a7c" letterSpacing={0.5}>{props.title}</Text>
      <Box style={{ flexDirection: 'column', gap: 8 }}>
        {props.children}
      </Box>
    </Box>
  );
}

function MarketplaceItemRow(props) {
  var item = props.item || {};
  var installed = item.installed || 0;
  var enabled = item.enabled || 0;
  
  return (
    <Pressable 
      onPress={props.onPress}
      style={{
        flexDirection: 'row',
        alignItems: 'center',
        gap: 10,
        padding: 12,
        backgroundColor: '#0f141c',
        borderRadius: 10,
        borderWidth: 1,
        borderColor: '#1f2935',
      }}
    >
      <Box style={{
        width: 40,
        height: 40,
        borderRadius: 8,
        backgroundColor: item.tone || '#79c0ff' + '20',
        alignItems: 'center',
        justifyContent: 'center',
      }}>
        <Text fontSize={18} color={item.tone || '#79c0ff'}>{item.icon || '📦'}</Text>
      </Box>
      
      <Box style={{ flexDirection: 'column', flexGrow: 1, flexBasis: 0, gap: 2 }}>
        <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 6 }}>
          <Text fontSize={12} color="#eef2f8" bold={true}>{item.name}</Text>
          <Text fontSize={10} color="#5d6a7c">v{item.version}</Text>
        </Box>
        <Text fontSize={10} color="#7f8a99" numberOfLines={1}>{item.description}</Text>
        <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8, marginTop: 2 }}>
          <Text fontSize={9} color="#5d6a7c">{item.publisher}</Text>
          <Text fontSize={9} color="#5d6a7c">•</Text>
          <Text fontSize={9} color="#5d6a7c">{item.downloads} downloads</Text>
          {item.rating > 0 && (
            <>
              <Text fontSize={9} color="#5d6a7c">•</Text>
              <Text fontSize={9} color="#ffbd2e">★ {item.rating}</Text>
            </>
          )}
        </Box>
      </Box>
      
      {installed == 1 ? (
        <Box style={{
          paddingLeft: 10,
          paddingRight: 10,
          paddingTop: 5,
          paddingBottom: 5,
          backgroundColor: enabled == 1 ? '#0d2a1a' : '#341316',
          borderRadius: 6,
        }}>
          <Text fontSize={10} color={enabled == 1 ? '#7ee787' : '#ff7b72'}>
            {enabled == 1 ? 'Enabled' : 'Disabled'}
          </Text>
        </Box>
      ) : (
        <Pressable 
          onPress={props.onInstall}
          style={{
            paddingLeft: 12,
            paddingRight: 12,
            paddingTop: 6,
            paddingBottom: 6,
            backgroundColor: '#2d62ff',
            borderRadius: 6,
          }}
        >
          <Text fontSize={11} color="#ffffff" bold={true}>Install</Text>
        </Pressable>
      )}
    </Pressable>
  );
}

export {
  MarketplaceList,
  MarketplaceCategory,
  MarketplaceItemRow,
};
