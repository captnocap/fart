// MemoryInspector — Detailed memory entry inspector

function MemoryInspector(props) {
  var entry = props.entry || {};
  
  return (
    <Box style={{
      flexGrow: 1,
      flexBasis: 0,
      flexDirection: 'column',
      backgroundColor: '#0d1015',
    }}>
      {props.children}
    </Box>
  );
}

function MemoryInspectorHeader(props) {
  return (
    <Box style={{
      flexDirection: 'row',
      alignItems: 'center',
      justifyContent: 'space-between',
      padding: 14,
      borderBottomWidth: 1,
      borderColor: '#171d26',
    }}>
      <Text fontSize={13} color="#eef2f8" bold={true}>Memory Inspector</Text>
      <Pressable onPress={props.onClose}>
        <Text fontSize={14} color="#5d6a7c">×</Text>
      </Pressable>
    </Box>
  );
}

function MemoryInspectorContent(props) {
  return (
    <ScrollView style={{ flexGrow: 1, flexBasis: 0 }}>
      <Box style={{ padding: 14, flexDirection: 'column', gap: 14 }}>
        {props.children}
      </Box>
    </ScrollView>
  );
}

function MemoryEntryHeader(props) {
  var entry = props.entry || {};
  
  return (
    <Box style={{
      flexDirection: 'column',
      gap: 8,
      padding: 12,
      backgroundColor: '#0f141c',
      borderRadius: 10,
      borderWidth: 1,
      borderColor: '#1f2935',
    }}>
      <Text fontSize={14} color="#eef2f8" bold={true}>{entry.title || 'Untitled'}</Text>
      <Box style={{ flexDirection: 'row', gap: 10, flexWrap: 'wrap' }}>
        <MemoryMeta label="Source" value={entry.source} />
        <MemoryMeta label="Type" value={entry.type} />
        <MemoryMeta label="Created" value={entry.created} />
        <MemoryMeta label="Relevance" value={entry.relevance + '%'} />
      </Box>
    </Box>
  );
}

function MemoryMeta(props) {
  return (
    <Box style={{ flexDirection: 'column', gap: 2 }}>
      <Text fontSize={9} color="#5d6a7c">{props.label}</Text>
      <Text fontSize={11} color="#c9d2df">{props.value}</Text>
    </Box>
  );
}

function MemoryEntryContent(props) {
  return (
    <Box style={{
      padding: 12,
      backgroundColor: '#0b0f15',
      borderRadius: 8,
      borderWidth: 1,
      borderColor: '#1f2935',
    }}>
      <Text fontSize={12} color="#c9d2df" lineHeight={20}>
        {props.children}
      </Text>
    </Box>
  );
}

function MemoryEntryTags(props) {
  var tags = props.tags || [];
  
  return (
    <Box style={{ flexDirection: 'row', gap: 6, flexWrap: 'wrap' }}>
      {tags.map(function(tag, idx) {
        return (
          <Box key={idx} style={{
            paddingLeft: 8,
            paddingRight: 8,
            paddingTop: 4,
            paddingBottom: 4,
            backgroundColor: '#10151d',
            borderRadius: 999,
            borderWidth: 1,
            borderColor: '#1f2935',
          }}>
            <Text fontSize={10} color="#d2a8ff">{tag}</Text>
          </Box>
        );
      })}
    </Box>
  );
}

export {
  MemoryInspector,
  MemoryInspectorHeader,
  MemoryInspectorContent,
  MemoryEntryHeader,
  MemoryMeta,
  MemoryEntryContent,
  MemoryEntryTags,
};
