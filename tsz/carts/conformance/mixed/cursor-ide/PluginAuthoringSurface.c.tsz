// PluginAuthoringSurface — Plugin development interface

function PluginAuthoringSurface(props) {
  return (
    <Box style={{
      flexGrow: 1,
      flexBasis: 0,
      flexDirection: 'column',
      backgroundColor: '#0d1015',
    }}>
      {props.children}
    </Box>
  );
}

function PluginAuthoringHeader(props) {
  return (
    <Box style={{
      flexDirection: 'row',
      alignItems: 'center',
      justifyContent: 'space-between',
      padding: 14,
      borderBottomWidth: 1,
      borderColor: '#171d26',
    }}>
      <Text fontSize={13} color="#eef2f8" bold={true}>Plugin Authoring</Text>
      <Box style={{ flexDirection: 'row', gap: 6 }}>
        {props.actions}
      </Box>
    </Box>
  );
}

function PluginAuthoringWorkspace(props) {
  return (
    <Box style={{
      flexGrow: 1,
      flexBasis: 0,
      flexDirection: 'row',
    }}>
      {props.children}
    </Box>
  );
}

function PluginFileTree(props) {
  return (
    <Box style={{
      width: 200,
      backgroundColor: '#0c1016',
      borderRightWidth: 1,
      borderColor: '#171d26',
      flexDirection: 'column',
    }}>
      {props.children}
    </Box>
  );
}

function PluginFileTreeHeader(props) {
  return (
    <Box style={{
      flexDirection: 'row',
      alignItems: 'center',
      justifyContent: 'space-between',
      padding: 10,
      borderBottomWidth: 1,
      borderColor: '#171d26',
    }}>
      <Text fontSize={11} color="#5d6a7c">Files</Text>
      <Pressable onPress={props.onNewFile}>
        <Text fontSize={12} color="#79c0ff">+</Text>
      </Pressable>
    </Box>
  );
}

function PluginFileTreeItem(props) {
  var file = props.file || {};
  var indent = file.indent || 0;
  
  return (
    <Pressable 
      onPress={props.onPress}
      style={{
        flexDirection: 'row',
        alignItems: 'center',
        gap: 6,
        padding: 8,
        paddingLeft: 10 + indent * 12,
        backgroundColor: props.selected == 1 ? '#10213d' : 'transparent',
      }}
    >
      <Text fontSize={10} color="#79c0ff">{file.icon || '📄'}</Text>
      <Text fontSize={11} color={props.selected == 1 ? '#eef2f8' : '#c9d2df'}>
        {file.name}
      </Text>
    </Pressable>
  );
}

function PluginEditor(props) {
  return (
    <Box style={{
      flexGrow: 1,
      flexBasis: 0,
      flexDirection: 'column',
    }}>
      {props.children}
    </Box>
  );
}

function PluginEditorTabs(props) {
  return (
    <Box style={{
      flexDirection: 'row',
      height: 36,
      backgroundColor: '#0a0d12',
      borderBottomWidth: 1,
      borderColor: '#171d26',
    }}>
      {props.children}
    </Box>
  );
}

function PluginEditorTab(props) {
  return (
    <Pressable 
      onPress={props.onPress}
      style={{
        flexDirection: 'row',
        alignItems: 'center',
        gap: 6,
        paddingLeft: 12,
        paddingRight: 12,
        backgroundColor: props.active == 1 ? '#0d1015' : 'transparent',
        borderBottomWidth: props.active == 1 ? 2 : 0,
        borderBottomColor: '#2d62ff',
      }}
    >
      <Text fontSize={11} color={props.active == 1 ? '#eef2f8' : '#7f8a99'}>{props.label}</Text>
      {props.modified == 1 && <Box style={{ width: 4, height: 4, borderRadius: 2, backgroundColor: '#e6b450' }} />}
    </Pressable>
  );
}

function PluginEditorContent(props) {
  return (
    <Box style={{
      flexGrow: 1,
      flexBasis: 0,
      padding: 14,
    }}>
      {props.children}
    </Box>
  );
}

export {
  PluginAuthoringSurface,
  PluginAuthoringHeader,
  PluginAuthoringWorkspace,
  PluginFileTree,
  PluginFileTreeHeader,
  PluginFileTreeItem,
  PluginEditor,
  PluginEditorTabs,
  PluginEditorTab,
  PluginEditorContent,
};
