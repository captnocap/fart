// PluginPermissionsPanel — Permission management panel

function PluginPermissionsPanel(props) {
  return (
    <Box style={{
      width: props.width || 320,
      backgroundColor: '#0c1016',
      borderLeftWidth: 1,
      borderColor: '#171d26',
      flexDirection: 'column',
    }}>
      {props.children}
    </Box>
  );
}

function PluginPermissionsHeader(props) {
  return (
    <Box style={{
      flexDirection: 'row',
      alignItems: 'center',
      justifyContent: 'space-between',
      padding: 12,
      borderBottomWidth: 1,
      borderColor: '#171d26',
    }}>
      <Text fontSize={12} color="#eef2f8" bold={true}>Permissions</Text>
      <Box style={{
        paddingLeft: 8,
        paddingRight: 8,
        paddingTop: 3,
        paddingBottom: 3,
        backgroundColor: props.allGranted == 1 ? '#0d2a1a' : '#341316',
        borderRadius: 999,
      }}>
        <Text fontSize={9} color={props.allGranted == 1 ? '#7ee787' : '#ff7b72'}>
          {props.grantedCount}/{props.totalCount}
        </Text>
      </Box>
    </Box>
  );
}

function PluginPermissionsContent(props) {
  return (
    <ScrollView style={{ flexGrow: 1, flexBasis: 0 }}>
      <Box style={{ padding: 12, flexDirection: 'column', gap: 10 }}>
        {props.children}
      </Box>
    </ScrollView>
  );
}

function PermissionItem(props) {
  var perm = props.permission || {};
  
  return (
    <Box style={{
      flexDirection: 'column',
      gap: 8,
      padding: 12,
      backgroundColor: perm.granted == 1 ? '#0d2a1a20' : '#34131620',
      borderRadius: 8,
      borderWidth: 1,
      borderColor: perm.granted == 1 ? '#0d2a1a' : '#341316',
    }}>
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
        <Text fontSize={14} color={perm.granted == 1 ? '#7ee787' : '#ff7b72'}>
          {perm.granted == 1 ? '✓' : '⚠'}
        </Text>
        <Text fontSize={12} color="#eef2f8" bold={true} style={{ flexGrow: 1 }}>{perm.name}</Text>
      </Box>
      
      <Text fontSize={10} color="#7f8a99" lineHeight={16}>{perm.description}</Text>
      
      {perm.risk && (
        <Box style={{
          padding: 8,
          backgroundColor: '#341316',
          borderRadius: 6,
        }}>
          <Text fontSize={10} color="#ff7b72">Risk: {perm.risk}</Text>
        </Box>
      )}
      
      <Pressable 
        onPress={function() { if (props.onToggle) props.onToggle(perm.id); }}
        style={{
          alignSelf: 'flex-start',
          paddingLeft: 12,
          paddingRight: 12,
          paddingTop: 6,
          paddingBottom: 6,
          backgroundColor: perm.granted == 1 ? '#341316' : '#0d2a1a',
          borderRadius: 6,
        }}
      >
        <Text fontSize={11} color={perm.granted == 1 ? '#ff7b72' : '#7ee787'}>
          {perm.granted == 1 ? 'Revoke' : 'Grant'}
        </Text>
      </Pressable>
    </Box>
  );
}

function PermissionCategory(props) {
  return (
    <Box style={{ flexDirection: 'column', gap: 8 }}>
      <Text fontSize={10} color="#5d6a7c" letterSpacing={0.5}>{props.title}</Text>
      <Box style={{ flexDirection: 'column', gap: 8 }}>
        {props.children}
      </Box>
    </Box>
  );
}

export {
  PluginPermissionsPanel,
  PluginPermissionsHeader,
  PluginPermissionsContent,
  PermissionItem,
  PermissionCategory,
};
