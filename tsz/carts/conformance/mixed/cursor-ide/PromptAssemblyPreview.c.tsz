// PromptAssemblyPreview — Preview of assembled prompt

function PromptAssemblyPreview(props) {
  return (
    <Box style={{
      flexGrow: 1,
      flexBasis: 0,
      flexDirection: 'column',
      backgroundColor: '#0b0f15',
    }}>
      {props.children}
    </Box>
  );
}

function AssemblyPreviewHeader(props) {
  return (
    <Box style={{
      flexDirection: 'row',
      alignItems: 'center',
      justifyContent: 'space-between',
      padding: 12,
      borderBottomWidth: 1,
      borderColor: '#171d26',
    }}>
      <Text fontSize={12} color="#eef2f8" bold={true}>Prompt Preview</Text>
      <Box style={{ flexDirection: 'row', gap: 6 }}>
        <Text fontSize={10} color="#5d6a7c">{props.tokenCount || 0} tokens</Text>
      </Box>
    </Box>
  );
}

function AssemblyPreviewContent(props) {
  return (
    <ScrollView style={{ flexGrow: 1, flexBasis: 0 }}>
      <Box style={{ padding: 14, flexDirection: 'column', gap: 12 }}>
        {props.children}
      </Box>
    </ScrollView>
  );
}

function AssemblySectionPreview(props) {
  var section = props.section || {};
  
  return (
    <Box style={{
      flexDirection: 'column',
      gap: 6,
      padding: 10,
      backgroundColor: '#0f141c',
      borderRadius: 8,
      borderWidth: 1,
      borderColor: '#1f2935',
    }}>
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
        <Box style={{
          width: 6,
          height: 6,
          borderRadius: 3,
          backgroundColor: section.tone || '#79c0ff',
        }} />
        <Text fontSize={10} color="#5d6a7c" bold={true}>{section.name}</Text>
        <Box style={{ flexGrow: 1 }} />
        <Text fontSize={9} color="#5d6a7c">{section.tokens || 0} tokens</Text>
      </Box>
      <Text fontSize={11} color="#c9d2df" fontFamily="monospace" lineHeight={16}>
        {section.content}
      </Text>
    </Box>
  );
}

function AssemblyPreviewEmpty(props) {
  return (
    <Box style={{
      flexGrow: 1,
      alignItems: 'center',
      justifyContent: 'center',
      padding: 40,
    }}>
      <Text fontSize={12} color="#5d6a7c">Select a configuration to preview</Text>
    </Box>
  );
}

export {
  PromptAssemblyPreview,
  AssemblyPreviewHeader,
  AssemblyPreviewContent,
  AssemblySectionPreview,
  AssemblyPreviewEmpty,
};
