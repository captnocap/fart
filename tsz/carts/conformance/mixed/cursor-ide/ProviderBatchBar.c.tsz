// ProviderBatchBar — Batch operations toolbar

function ProviderBatchBar(props) {
  var selectedCount = props.selectedCount || 0;
  
  if (selectedCount == 0) return null;
  
  return (
    <Box style={{
      flexDirection: 'row',
      alignItems: 'center',
      gap: 10,
      padding: 10,
      backgroundColor: '#10213d',
      borderRadius: 8,
      borderWidth: 1,
      borderColor: '#2d62ff',
    }}>
      <Box style={{
        width: 24,
        height: 24,
        borderRadius: 12,
        backgroundColor: '#2d62ff',
        alignItems: 'center',
        justifyContent: 'center',
      }}>
        <Text fontSize={11} color="#ffffff" bold={true}>{selectedCount}</Text>
      </Box>
      <Text fontSize={11} color="#eef2f8" style={{ flexGrow: 1 }}>selected</Text>
      {props.children}
    </Box>
  );
}

function BatchActionBtn(props) {
  return (
    <Pressable 
      onPress={props.onPress}
      style={{
        paddingLeft: 12,
        paddingRight: 12,
        paddingTop: 6,
        paddingBottom: 6,
        backgroundColor: props.primary == 1 ? '#2d62ff' : '#0f141c',
        borderRadius: 6,
        borderWidth: props.primary == 1 ? 0 : 1,
        borderColor: '#1f2935',
      }}
    >
      <Text fontSize={11} color={props.primary == 1 ? '#ffffff' : '#c9d2df'}>
        {props.label}
      </Text>
    </Pressable>
  );
}

function BatchSelectAll(props) {
  return (
    <Pressable 
      onPress={props.onPress}
      style={{
        flexDirection: 'row',
        alignItems: 'center',
        gap: 6,
      }}
    >
      <Box style={{
        width: 16,
        height: 16,
        borderRadius: 4,
        borderWidth: 1,
        borderColor: props.checked == 1 ? '#2d62ff' : '#1f2935',
        backgroundColor: props.checked == 1 ? '#2d62ff' : 'transparent',
        alignItems: 'center',
        justifyContent: 'center',
      }}>
        {props.checked == 1 && <Text fontSize={10} color="#ffffff">✓</Text>}
      </Box>
      <Text fontSize={11} color="#c9d2df">Select all</Text>
    </Pressable>
  );
}

export {
  ProviderBatchBar,
  BatchActionBtn,
  BatchSelectAll,
};
