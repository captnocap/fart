// ProviderEndpointForm — Endpoint and routing configuration

function ProviderEndpointForm(props) {
  var endpoints = props.endpoints || [];
  
  return (
    <Box style={{
      flexDirection: 'column',
      gap: 12,
      padding: 14,
      backgroundColor: '#0f141c',
      borderRadius: 10,
      borderWidth: 1,
      borderColor: '#1f2935',
    }}>
      <Text fontSize={12} color="#eef2f8" bold={true}>Endpoints</Text>
      
      {endpoints.map(function(endpoint, idx) {
        return <EndpointRow key={idx} endpoint={endpoint} />;
      })}
      
      <Pressable 
        onPress={props.onAdd}
        style={{
          flexDirection: 'row',
          alignItems: 'center',
          gap: 6,
          padding: 10,
          backgroundColor: '#10151d',
          borderRadius: 8,
          borderWidth: 1,
          borderColor: '#1f2935',
          borderStyle: 'dashed',
        }}
      >
        <Text fontSize={12} color="#79c0ff">+</Text>
        <Text fontSize={11} color="#79c0ff">Add Endpoint</Text>
      </Pressable>
    </Box>
  );
}

function EndpointRow(props) {
  var endpoint = props.endpoint || {};
  
  return (
    <Box style={{
      flexDirection: 'column',
      gap: 8,
      padding: 10,
      backgroundColor: '#10151d',
      borderRadius: 8,
      borderWidth: 1,
      borderColor: endpoint.active == 1 ? '#2d62ff' : '#1f2935',
    }}>
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
        <Box style={{
          width: 8,
          height: 8,
          borderRadius: 4,
          backgroundColor: endpoint.active == 1 ? '#7ee787' : '#5d6a7c',
        }} />
        <Text fontSize={11} color="#eef2f8" bold={true} style={{ flexGrow: 1 }}>{endpoint.name}</Text>
        <Pressable onPress={props.onEdit}>
          <Text fontSize={10} color="#5d6a7c">Edit</Text>
        </Pressable>
        <Pressable onPress={props.onDelete}>
          <Text fontSize={10} color="#ff7b72">Delete</Text>
        </Pressable>
      </Box>
      
      <Text fontSize={10} color="#79c0ff">{endpoint.url}</Text>
      
      <Box style={{ flexDirection: 'row', gap: 6, flexWrap: 'wrap' }}>
        {endpoint.models && endpoint.models.map(function(model, idx) {
          return (
            <Box key={idx} style={{
              paddingLeft: 6,
              paddingRight: 6,
              paddingTop: 2,
              paddingBottom: 2,
              backgroundColor: '#0f141c',
              borderRadius: 4,
            }}>
              <Text fontSize={9} color="#7f8a99">{model}</Text>
            </Box>
          );
        })}
      </Box>
    </Box>
  );
}

export {
  ProviderEndpointForm,
  EndpointRow,
};
