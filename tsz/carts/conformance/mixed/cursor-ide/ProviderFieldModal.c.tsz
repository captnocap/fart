// ProviderFieldModal — Modal for editing provider fields

function ProviderFieldModal(props) {
  var visible = props.visible || 0;
  
  if (visible != 1) return null;
  
  return (
    <Box style={{
      position: 'absolute',
      top: 0,
      left: 0,
      right: 0,
      bottom: 0,
      backgroundColor: '#00000080',
      alignItems: 'center',
      justifyContent: 'center',
      zIndex: 1000,
    }}>
      <Box style={{
        width: 480,
        backgroundColor: '#0d1015',
        borderRadius: 12,
        borderWidth: 1,
        borderColor: '#171d26',
        flexDirection: 'column',
      }}>
        {props.children}
      </Box>
    </Box>
  );
}

function FieldModalHeader(props) {
  return (
    <Box style={{
      flexDirection: 'row',
      alignItems: 'center',
      justifyContent: 'space-between',
      padding: 14,
      borderBottomWidth: 1,
      borderColor: '#171d26',
    }}>
      <Text fontSize={13} color="#eef2f8" bold={true}>{props.title}</Text>
      <Pressable onPress={props.onClose}>
        <Text fontSize={16} color="#5d6a7c">×</Text>
      </Pressable>
    </Box>
  );
}

function FieldModalBody(props) {
  return (
    <Box style={{
      padding: 14,
      flexDirection: 'column',
      gap: 12,
    }}>
      {props.children}
    </Box>
  );
}

function FieldModalFooter(props) {
  return (
    <Box style={{
      flexDirection: 'row',
      alignItems: 'center',
      justifyContent: 'flex-end',
      gap: 10,
      padding: 14,
      borderTopWidth: 1,
      borderColor: '#171d26',
    }}>
      {props.children}
    </Box>
  );
}

function ModalField(props) {
  return (
    <Box style={{ flexDirection: 'column', gap: 6 }}>
      <Text fontSize={11} color="#eef2f8">{props.label}</Text>
      <TextInput
        value={props.value}
        onChange={props.onChange}
        placeholder={props.placeholder}
        fontSize={12}
        color="#c9d2df"
        style={{
          padding: 10,
          backgroundColor: '#10151d',
          borderRadius: 6,
          borderWidth: 1,
          borderColor: '#1f2935',
          height: 40,
        }}
      />
    </Box>
  );
}

function ModalSelect(props) {
  return (
    <Box style={{ flexDirection: 'column', gap: 6 }}>
      <Text fontSize={11} color="#eef2f8">{props.label}</Text>
      <Box style={{
        padding: 10,
        backgroundColor: '#10151d',
        borderRadius: 6,
        borderWidth: 1,
        borderColor: '#1f2935',
      }}>
        {props.children}
      </Box>
    </Box>
  );
}

function ModalActionBtn(props) {
  return (
    <Pressable 
      onPress={props.onPress}
      style={{
        paddingLeft: 16,
        paddingRight: 16,
        paddingTop: 8,
        paddingBottom: 8,
        backgroundColor: props.primary == 1 ? '#2d62ff' : '#10151d',
        borderRadius: 8,
        borderWidth: props.primary == 1 ? 0 : 1,
        borderColor: '#1f2935',
      }}
    >
      <Text fontSize={11} color={props.primary == 1 ? '#ffffff' : '#c9d2df'}>
        {props.label}
      </Text>
    </Pressable>
  );
}

export {
  ProviderFieldModal,
  FieldModalHeader,
  FieldModalBody,
  FieldModalFooter,
  ModalField,
  ModalSelect,
  ModalActionBtn,
};
