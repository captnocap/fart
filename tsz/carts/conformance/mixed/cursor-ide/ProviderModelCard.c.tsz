// ProviderModelCard — Detailed model information card

function ProviderModelCard(props) {
  var model = props.model || {};
  
  return (
    <Box style={{
      flexDirection: 'column',
      gap: 12,
      padding: 14,
      backgroundColor: '#0f141c',
      borderRadius: 10,
      borderWidth: 1,
      borderColor: '#1f2935',
    }}>
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 10 }}>
        <Box style={{
          width: 40,
          height: 40,
          borderRadius: 20,
          backgroundColor: '#2d62ff20',
          alignItems: 'center',
          justifyContent: 'center',
        }}>
          <Text fontSize={16} color="#2d62ff">🤖</Text>
        </Box>
        <Box style={{ flexDirection: 'column', flexGrow: 1, flexBasis: 0 }}>
          <Text fontSize={14} color="#eef2f8" bold={true}>{model.name || 'Model'}</Text>
          <Text fontSize={10} color="#5d6a7c">{model.id || ''}</Text>
        </Box>
        <Box style={{
          paddingLeft: 8,
          paddingRight: 8,
          paddingTop: 3,
          paddingBottom: 3,
          backgroundColor: model.available == 1 ? '#0d2a1a' : '#341316',
          borderRadius: 999,
        }}>
          <Text fontSize={9} color={model.available == 1 ? '#7ee787' : '#ff7b72'}>
            {model.available == 1 ? 'Available' : 'Unavailable'}
          </Text>
        </Box>
      </Box>
      
      {model.description && (
        <Text fontSize={11} color="#c9d2df" lineHeight={18}>{model.description}</Text>
      )}
      
      <Box style={{ flexDirection: 'row', gap: 10, flexWrap: 'wrap' }}>
        {model.contextWindow && (
          <ModelSpec label="Context" value={model.contextWindow} />
        )}
        {model.maxTokens && (
          <ModelSpec label="Max Tokens" value={model.maxTokens} />
        )}
        {model.inputPrice && (
          <ModelSpec label="Input" value={model.inputPrice} />
        )}
        {model.outputPrice && (
          <ModelSpec label="Output" value={model.outputPrice} />
        )}
      </Box>
      
      {model.features && model.features.length > 0 && (
        <Box style={{ flexDirection: 'row', gap: 6, flexWrap: 'wrap' }}>
          {model.features.map(function(feature, idx) {
            return (
              <Box key={idx} style={{
                paddingLeft: 8,
                paddingRight: 8,
                paddingTop: 4,
                paddingBottom: 4,
                backgroundColor: '#10151d',
                borderRadius: 999,
                borderWidth: 1,
                borderColor: '#1f2935',
              }}>
                <Text fontSize={9} color="#79c0ff">{feature}</Text>
              </Box>
            );
          })}
        </Box>
      )}
    </Box>
  );
}

function ModelSpec(props) {
  return (
    <Box style={{
      padding: 8,
      backgroundColor: '#10151d',
      borderRadius: 6,
      minWidth: 80,
    }}>
      <Text fontSize={9} color="#5d6a7c">{props.label}</Text>
      <Text fontSize={11} color="#eef2f8" bold={true}>{props.value}</Text>
    </Box>
  );
}

export {
  ProviderModelCard,
  ModelSpec,
};
