// ProviderModelGrid — Model selection grid

function ProviderModelGrid(props) {
  var models = props.models || [];
  
  return (
    <Box style={{
      flexDirection: 'column',
      gap: 12,
    }}>
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
        <Text fontSize={12} color="#eef2f8" bold={true}>Available Models</Text>
        <Box style={{
          paddingLeft: 6,
          paddingRight: 6,
          paddingTop: 2,
          paddingBottom: 2,
          backgroundColor: '#10151d',
          borderRadius: 999,
        }}>
          <Text fontSize={9} color="#79c0ff">{models.length}</Text>
        </Box>
      </Box>
      
      <Box style={{
        flexDirection: 'row',
        gap: 10,
        flexWrap: 'wrap',
      }}>
        {models.map(function(model, idx) {
          return (
            <ModelCard 
              key={idx} 
              model={model} 
              selected={model.id == props.selected}
              onSelect={props.onSelect}
            />
          );
        })}
      </Box>
    </Box>
  );
}

function ModelCard(props) {
  var model = props.model || {};
  var selected = props.selected || 0;
  
  return (
    <Pressable 
      onPress={function() { if (props.onSelect) props.onSelect(model.id); }}
      style={{
        width: 140,
        padding: 12,
        backgroundColor: selected == 1 ? '#10213d' : '#0f141c',
        borderRadius: 10,
        borderWidth: 1,
        borderColor: selected == 1 ? '#2d62ff' : '#1f2935',
        flexDirection: 'column',
        gap: 6,
      }}
    >
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 6 }}>
        <Box style={{
          width: 8,
          height: 8,
          borderRadius: 4,
          backgroundColor: model.available == 1 ? '#7ee787' : '#5d6a7c',
        }} />
        <Text fontSize={11} color="#eef2f8" bold={true} numberOfLines={1}>{model.name}</Text>
      </Box>
      
      <Text fontSize={9} color="#5d6a7c">{model.id}</Text>
      
      <Box style={{ flexDirection: 'row', gap: 4, flexWrap: 'wrap', marginTop: 4 }}>
        {model.features && model.features.map(function(feature, idx) {
          return (
            <Box key={idx} style={{
              paddingLeft: 4,
              paddingRight: 4,
              paddingTop: 1,
              paddingBottom: 1,
              backgroundColor: '#10151d',
              borderRadius: 3,
            }}>
              <Text fontSize={8} color="#79c0ff">{feature}</Text>
            </Box>
          );
        })}
      </Box>
      
      {model.contextWindow && (
        <Text fontSize={9} color="#7f8a99" style={{ marginTop: 4 }}>
          {model.contextWindow} ctx
        </Text>
      )}
    </Pressable>
  );
}

export {
  ProviderModelGrid,
  ModelCard,
};
