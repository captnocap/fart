// SearchPanel — repo search with click-through results and workspace scope

import { XIcon, SearchIcon, RefreshCcwIcon } from './Icon.c';

function SearchResult(props) {
  var result = props.result;

  return (
    <C.SearchResult onPress={function() { props.onOpenResult(result.file, result.line); }}>
      <C.SearchResultHeader>
        <C.SearchResultFile>{result.file}</C.SearchResultFile>
        <C.SearchResultLine>:{result.line}</C.SearchResultLine>
        <Box style={{ flexGrow: 1 }} />
        <C.SearchResultBadge>{result.matches}</C.SearchResultBadge>
      </C.SearchResultHeader>
      <C.SearchResultText>{result.text}</C.SearchResultText>
    </C.SearchResult>
  );
}

function SearchPanel(props) {
  var compactBand = 0;
  var minimumBand = 0;
  var searchScopeText = props.workspaceName + ' / ' + props.gitBranch;

  if (props.widthBand == 'narrow' || props.widthBand == 'widget' || props.widthBand == 'minimum') compactBand = 1;
  if (props.widthBand == 'minimum') minimumBand = 1;

  return (
    <C.SearchPanel style={props.style}>
      <C.SearchHeader style={compactBand == 1 ? { padding: 12, gap: 8 } : {}}>
        <C.SearchTopRow>
          <C.SearchTitle>Project Search</C.SearchTitle>
          {minimumBand != 1 && <C.SearchScope>{searchScopeText}</C.SearchScope>}
          <Pressable onPress={props.onClose ? props.onClose : function() { setShowSearch(0); }} style={{ paddingLeft: 6, paddingRight: 6, paddingTop: 2, paddingBottom: 2 }}>
            <Box style={{ width: 11, height: 11, alignItems: 'center', justifyContent: 'center' }}>
              <XIcon size={11} />
            </Box>
          </Pressable>
        </C.SearchTopRow>

        <C.SearchInputBox>
          <Box style={{ width: 11, height: 11, alignItems: 'center', justifyContent: 'center' }}>
            <SearchIcon size={11} />
          </Box>
          <C.SearchInput value={searchQuery} onChange={function(v) { searchProject(v); }} />
        </C.SearchInputBox>

        {minimumBand != 1 && <C.SearchOptions>
          <C.SearchOption><Text fontSize={10} color="#79c0ff">repo</Text></C.SearchOption>
          <C.SearchOption><Text fontSize={10} color="#6e6e6e">case</Text></C.SearchOption>
          <C.SearchOption><Text fontSize={10} color="#6e6e6e">regex</Text></C.SearchOption>
        </C.SearchOptions>}
      </C.SearchHeader>

      <C.SearchResults>
        <C.SearchResultsStack>
          {props.results.map(function(result, idx) {
            return <SearchResult key={idx} result={result} onOpenResult={props.onOpenResult} />;
          })}
        </C.SearchResultsStack>
      </C.SearchResults>

      {minimumBand != 1 && <C.SearchFooter>
        <C.SearchFooterText>results in workspace</C.SearchFooterText>
        <C.SearchActionBtn onPress={function() { searchProject(searchQuery); }}>
          <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 6 }}>
            <Box style={{ width: 10, height: 10, alignItems: 'center', justifyContent: 'center' }}>
              <RefreshCcwIcon size={10} />
            </Box>
            <Text fontSize={10} color="#9db1c9">Refresh</Text>
          </Box>
        </C.SearchActionBtn>
      </C.SearchFooter>}
    </C.SearchPanel>
  );
}

export { SearchPanel };
