// SettingsGeneralPage — General settings page

function SettingsGeneralPage(props) {
  return (
    <Box style={{
      flexDirection: 'column',
      gap: 14,
      flexGrow: 1,
      flexBasis: 0,
    }}>
      <SettingsPagePanel title="Editor" icon="file-code" meta="Code editing preferences">
        {props.editorSettings}
      </SettingsPagePanel>
      
      <SettingsPagePanel title="Appearance" icon="palette" meta="Theme and visual settings">
        {props.appearanceSettings}
      </SettingsPagePanel>
      
      <SettingsPagePanel title="Keybindings" icon="keyboard" meta="Keyboard shortcuts">
        {props.keybindingSettings}
      </SettingsPagePanel>
    </Box>
  );
}

function SettingsPagePanel(props) {
  return (
    <Box style={{
      padding: 14,
      borderRadius: 14,
      borderWidth: 1,
      borderColor: '#1f2935',
      backgroundColor: '#10151d',
      gap: 12,
    }}>
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 9, justifyContent: 'space-between' }}>
        <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 9, flexGrow: 1, flexBasis: 0 }}>
          <Box style={{ width: 13, height: 13, alignItems: 'center', justifyContent: 'center' }}>
            <Text fontSize={12} color="#79c0ff">{props.icon}</Text>
          </Box>
          <Box style={{ flexDirection: 'column', gap: 3, flexGrow: 1, flexBasis: 0 }}>
            <Text fontSize={13} color="#eef2f8" bold={true}>{props.title}</Text>
            <Text fontSize={10} color="#5d6a7c">{props.meta}</Text>
          </Box>
        </Box>
      </Box>
      {props.children}
    </Box>
  );
}

function SettingsToggleRow(props) {
  return (
    <Box style={{
      flexDirection: 'row',
      alignItems: 'center',
      justifyContent: 'space-between',
      padding: 10,
      backgroundColor: '#0f141c',
      borderRadius: 8,
    }}>
      <Box style={{ flexDirection: 'column', gap: 2 }}>
        <Text fontSize={11} color="#eef2f8">{props.label}</Text>
        {props.description && <Text fontSize={10} color="#5d6a7c">{props.description}</Text>}
      </Box>
      <SettingsToggle active={props.active} onPress={props.onPress} />
    </Box>
  );
}

function SettingsToggle(props) {
  var active = props.active || 0;
  
  return (
    <Pressable onPress={props.onPress}>
      <Box style={{
        width: 36,
        height: 20,
        borderRadius: 10,
        backgroundColor: active == 1 ? '#2d62ff' : '#1f2935',
        padding: 2,
      }}>
        <Box style={{
          width: 16,
          height: 16,
          borderRadius: 8,
          backgroundColor: '#ffffff',
          marginLeft: active == 1 ? 16 : 0,
        }} />
      </Box>
    </Pressable>
  );
}

export {
  SettingsGeneralPage,
  SettingsPagePanel,
  SettingsToggleRow,
  SettingsToggle,
};
