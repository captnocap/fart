// SettingsMemoryPage — Memory configuration page

function SettingsMemoryPage(props) {
  var rows = props.memoryRows || [];
  
  return (
    <Box style={{
      flexDirection: 'column',
      gap: 14,
      flexGrow: 1,
      flexBasis: 0,
    }}>
      <Box style={{
        padding: 14,
        borderRadius: 14,
        borderWidth: 1,
        borderColor: '#1f2935',
        backgroundColor: '#10151d',
        gap: 12,
      }}>
        <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 9 }}>
          <Box style={{ width: 13, height: 13, alignItems: 'center', justifyContent: 'center' }}>
            <Text fontSize={12} color="#d2a8ff">🤖</Text>
          </Box>
          <Text fontSize={13} color="#eef2f8" bold={true}>Memory Orchestration</Text>
          <Box style={{ flexGrow: 1 }} />
          <Box style={{
            paddingLeft: 8,
            paddingRight: 8,
            paddingTop: 3,
            paddingBottom: 3,
            backgroundColor: '#10151d',
            borderRadius: 999,
            borderWidth: 1,
            borderColor: '#1f2935',
          }}>
            <Text fontSize={10} color="#d2a8ff">{rows.length} banks</Text>
          </Box>
        </Box>
        
        <Box style={{ flexDirection: 'column', gap: 10 }}>
          {rows.map(function(item, idx) {
            return <MemoryRow key={idx} item={item} />;
          })}
        </Box>
      </Box>
    </Box>
  );
}

function MemoryRow(props) {
  var item = props.item || {};
  
  return (
    <Box style={{
      flexDirection: 'row',
      alignItems: 'flex-start',
      gap: 10,
      padding: 12,
      borderRadius: 12,
      borderWidth: 1,
      borderColor: '#1f2935',
      backgroundColor: '#0f141c',
    }}>
      <Box style={{ width: 8, height: 8, borderRadius: 4, backgroundColor: item.tone || '#79c0ff', marginTop: 5 }} />
      <Box style={{ flexDirection: 'column', gap: 5, flexGrow: 1, flexBasis: 0 }}>
        <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8, flexWrap: 'wrap' }}>
          <Text fontSize={12} color="#eef2f8" bold={true}>{item.name}</Text>
          <Box style={{
            paddingLeft: 6,
            paddingRight: 6,
            paddingTop: 2,
            paddingBottom: 2,
            borderRadius: 999,
            borderWidth: 1,
            borderColor: '#1f2935',
            backgroundColor: '#10151d',
          }}>
            <Text fontSize={10} color="#c9d2df">{item.backend || item.runtime || item.status}</Text>
          </Box>
          {item.scope && (
            <Box style={{
              paddingLeft: 6,
              paddingRight: 6,
              paddingTop: 2,
              paddingBottom: 2,
              borderRadius: 999,
              borderWidth: 1,
              borderColor: '#1f2935',
              backgroundColor: '#10151d',
            }}>
              <Text fontSize={10} color="#79c0ff">{item.scope}</Text>
            </Box>
          )}
          {item.retention && (
            <Box style={{
              paddingLeft: 6,
              paddingRight: 6,
              paddingTop: 2,
              paddingBottom: 2,
              borderRadius: 999,
              borderWidth: 1,
              borderColor: '#1f2935',
              backgroundColor: '#10151d',
            }}>
              <Text fontSize={10} color="#d2a8ff">{item.retention}</Text>
            </Box>
          )}
        </Box>
        {item.source && <Text fontSize={10} color="#5d6a7c">{item.source}</Text>}
        {item.summary && <Text fontSize={11} color="#c9d2df" lineHeight={17}>{item.summary}</Text>}
        {item.stress && <Text fontSize={10} color="#ffb86b">stress: {item.stress}</Text>}
        {item.output && <Text fontSize={10} color="#79c0ff">output: {item.output}</Text>}
        {item.risk && <Text fontSize={10} color="#ff7b72">risk: {item.risk}</Text>}
      </Box>
    </Box>
  );
}

export {
  SettingsMemoryPage,
  MemoryRow,
};
