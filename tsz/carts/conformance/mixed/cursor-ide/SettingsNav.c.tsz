// SettingsNav — Settings navigation rail

function SettingsNav(props) {
  var width = props.width || 240;
  var stacked = props.stacked || 0;
  
  if (stacked == 1) {
    return (
      <Box style={{
        flexDirection: 'column',
        gap: 10,
      }}>
        {props.children}
      </Box>
    );
  }
  
  return (
    <Box style={{
      width: width,
      flexDirection: 'column',
      gap: 10,
    }}>
      {props.children}
    </Box>
  );
}

function SettingsSectionRow(props) {
  var section = props.section || {};
  var active = props.active || 0;
  
  var borderColor = active == 1 ? section.tone || '#2d62ff' : '#1f2935';
  var bg = active == 1 ? '#121a24' : '#0f141c';
  
  return (
    <Pressable 
      onPress={function() { if (props.onSelect) props.onSelect(section.id); }}
      style={{
        padding: 12,
        borderRadius: 12,
        borderWidth: 1,
        borderColor: borderColor,
        backgroundColor: bg,
        gap: 4,
      }}
    >
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
        <Box style={{ width: 12, height: 12, alignItems: 'center', justifyContent: 'center' }}>
          <Text fontSize={10} color={section.tone || '#79c0ff'}>{section.icon || '•'}</Text>
        </Box>
        <Text fontSize={12} color={active == 1 ? '#eef2f8' : '#c9d2df'} bold={true}>{section.label}</Text>
        <Box style={{ flexGrow: 1 }} />
        {section.count && <Text fontSize={10} color={section.tone || '#79c0ff'}>{section.count}</Text>}
      </Box>
      <Text fontSize={10} color="#5d6a7c">{section.meta}</Text>
    </Pressable>
  );
}

function SettingsNavFooter(props) {
  return (
    <Box style={{
      padding: 12,
      borderRadius: 12,
      borderWidth: 1,
      borderColor: '#1f2935',
      backgroundColor: '#0f141c',
      gap: 6,
    }}>
      {props.children}
    </Box>
  );
}

export {
  SettingsNav,
  SettingsSectionRow,
  SettingsNavFooter,
};
