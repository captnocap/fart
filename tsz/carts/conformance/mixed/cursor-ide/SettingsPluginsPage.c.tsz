// SettingsPluginsPage — Plugin management page

function SettingsPluginsPage(props) {
  var rows = props.pluginRows || [];
  
  return (
    <Box style={{
      flexDirection: 'column',
      gap: 14,
      flexGrow: 1,
      flexBasis: 0,
    }}>
      <Box style={{
        padding: 14,
        borderRadius: 14,
        borderWidth: 1,
        borderColor: '#1f2935',
        backgroundColor: '#10151d',
        gap: 12,
      }}>
        <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 9 }}>
          <Box style={{ width: 13, height: 13, alignItems: 'center', justifyContent: 'center' }}>
            <Text fontSize={12} color="#ffa657">🎨</Text>
          </Box>
          <Text fontSize={13} color="#eef2f8" bold={true}>Plugin Runtimes</Text>
          <Box style={{ flexGrow: 1 }} />
          <Box style={{
            paddingLeft: 8,
            paddingRight: 8,
            paddingTop: 3,
            paddingBottom: 3,
            backgroundColor: '#10151d',
            borderRadius: 999,
            borderWidth: 1,
            borderColor: '#1f2935',
          }}>
            <Text fontSize={10} color="#ffa657">{rows.length} runtimes</Text>
          </Box>
        </Box>
        
        <Box style={{ flexDirection: 'column', gap: 10 }}>
          {rows.map(function(item, idx) {
            return <PluginRow key={idx} item={item} />;
          })}
        </Box>
      </Box>
    </Box>
  );
}

function PluginRow(props) {
  var item = props.item || {};
  
  return (
    <Box style={{
      flexDirection: 'row',
      alignItems: 'flex-start',
      gap: 10,
      padding: 12,
      borderRadius: 12,
      borderWidth: 1,
      borderColor: '#1f2935',
      backgroundColor: '#0f141c',
    }}>
      <Box style={{ width: 8, height: 8, borderRadius: 4, backgroundColor: item.tone || '#79c0ff', marginTop: 5 }} />
      <Box style={{ flexDirection: 'column', gap: 5, flexGrow: 1, flexBasis: 0 }}>
        <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8, flexWrap: 'wrap' }}>
          <Text fontSize={12} color="#eef2f8" bold={true}>{item.name}</Text>
          <Box style={{
            paddingLeft: 6,
            paddingRight: 6,
            paddingTop: 2,
            paddingBottom: 2,
            borderRadius: 999,
            borderWidth: 1,
            borderColor: '#1f2935',
            backgroundColor: '#10151d',
          }}>
            <Text fontSize={10} color="#c9d2df">{item.runtime || item.status}</Text>
          </Box>
        </Box>
        {item.summary && <Text fontSize={11} color="#c9d2df" lineHeight={17}>{item.summary}</Text>}
        {item.stress && <Text fontSize={10} color="#ffb86b">stress: {item.stress}</Text>}
      </Box>
    </Box>
  );
}

export {
  SettingsPluginsPage,
  PluginRow,
};
