// SettingsPromptAssemblyPage — Prompt assembly configuration

function SettingsPromptAssemblyPage(props) {
  return (
    <Box style={{
      flexDirection: 'column',
      gap: 14,
      flexGrow: 1,
      flexBasis: 0,
    }}>
      <Box style={{
        padding: 14,
        borderRadius: 14,
        borderWidth: 1,
        borderColor: '#1f2935',
        backgroundColor: '#10151d',
        gap: 12,
      }}>
        <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 9 }}>
          <Box style={{ width: 13, height: 13, alignItems: 'center', justifyContent: 'center' }}>
            <Text fontSize={12} color="#79c0ff">📝</Text>
          </Box>
          <Text fontSize={13} color="#eef2f8" bold={true}>Prompt Assembly</Text>
        </Box>
        
        <Text fontSize={11} color="#c9d2df" lineHeight={18}>
          Configure how context is assembled for model requests. Control token allocation, 
          context prioritization, and memory injection.
        </Text>
        
        <Box style={{ flexDirection: 'column', gap: 10 }}>
          <AssemblySection title="Context Priority" description="Order of context inclusion when token budget is limited">
            <AssemblyPriorityList items={props.priorityItems || []} />
          </AssemblySection>
          
          <AssemblySection title="Token Allocation" description="Maximum tokens per context type">
            <AssemblyTokenBudgets budgets={props.budgets || []} />
          </AssemblySection>
          
          <AssemblySection title="Memory Injection" description="When to include memory in prompts">
            <AssemblyToggleList items={props.injectionSettings || []} />
          </AssemblySection>
        </Box>
      </Box>
    </Box>
  );
}

function AssemblySection(props) {
  return (
    <Box style={{
      flexDirection: 'column',
      gap: 8,
      padding: 12,
      backgroundColor: '#0f141c',
      borderRadius: 10,
      borderWidth: 1,
      borderColor: '#1f2935',
    }}>
      <Text fontSize={12} color="#eef2f8" bold={true}>{props.title}</Text>
      <Text fontSize={10} color="#5d6a7c">{props.description}</Text>
      {props.children}
    </Box>
  );
}

function AssemblyPriorityList(props) {
  var items = props.items || [];
  
  return (
    <Box style={{ flexDirection: 'column', gap: 6 }}>
      {items.map(function(item, idx) {
        return (
          <Box key={idx} style={{
            flexDirection: 'row',
            alignItems: 'center',
            gap: 8,
            padding: 8,
            backgroundColor: '#10151d',
            borderRadius: 6,
          }}>
            <Text fontSize={10} color="#5d6a7c">{idx + 1}</Text>
            <Text fontSize={11} color="#c9d2df" style={{ flexGrow: 1 }}>{item.name}</Text>
            <Box style={{ flexDirection: 'row', gap: 4 }}>
              <Pressable>
                <Text fontSize={10} color="#5d6a7c">↑</Text>
              </Pressable>
              <Pressable>
                <Text fontSize={10} color="#5d6a7c">↓</Text>
              </Pressable>
            </Box>
          </Box>
        );
      })}
    </Box>
  );
}

function AssemblyTokenBudgets(props) {
  var budgets = props.budgets || [];
  
  return (
    <Box style={{ flexDirection: 'column', gap: 8 }}>
      {budgets.map(function(budget, idx) {
        return (
          <Box key={idx} style={{
            flexDirection: 'row',
            alignItems: 'center',
            gap: 10,
          }}>
            <Text fontSize={11} color="#c9d2df" style={{ width: 100 }}>{budget.name}</Text>
            <Box style={{
              flexGrow: 1,
              height: 6,
              backgroundColor: '#1f2935',
              borderRadius: 3,
            }}>
              <Box style={{
                width: (budget.used / budget.max * 100) + '%',
                height: 6,
                backgroundColor: budget.used > budget.max * 0.8 ? '#ff7b72' : '#2d62ff',
                borderRadius: 3,
              }} />
            </Box>
            <Text fontSize={10} color="#5d6a7c">{budget.used}/{budget.max}</Text>
          </Box>
        );
      })}
    </Box>
  );
}

function AssemblyToggleList(props) {
  var items = props.items || [];
  
  return (
    <Box style={{ flexDirection: 'column', gap: 6 }}>
      {items.map(function(item, idx) {
        return (
          <Box key={idx} style={{
            flexDirection: 'row',
            alignItems: 'center',
            justifyContent: 'space-between',
            padding: 8,
            backgroundColor: '#10151d',
            borderRadius: 6,
          }}>
            <Text fontSize={11} color="#c9d2df">{item.name}</Text>
            <Box style={{
              width: 32,
              height: 18,
              borderRadius: 9,
              backgroundColor: item.active == 1 ? '#2d62ff' : '#1f2935',
              padding: 2,
            }}>
              <Box style={{
                width: 14,
                height: 14,
                borderRadius: 7,
                backgroundColor: '#ffffff',
                marginLeft: item.active == 1 ? 14 : 0,
              }} />
            </Box>
          </Box>
        );
      })}
    </Box>
  );
}

export {
  SettingsPromptAssemblyPage,
  AssemblySection,
  AssemblyPriorityList,
  AssemblyTokenBudgets,
  AssemblyToggleList,
};
