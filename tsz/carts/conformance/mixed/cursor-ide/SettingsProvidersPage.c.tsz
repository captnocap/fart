// SettingsProvidersPage — Provider configuration page

function SettingsProvidersPage(props) {
  var providers = props.providers || [];
  var selectedId = props.selectedProviderId || '';
  
  var selected = providers[0] || {};
  for (var i = 0; i < providers.length; i++) {
    if (providers[i].id == selectedId) {
      selected = providers[i];
    }
  }
  
  return (
    <Box style={{
      flexDirection: 'column',
      gap: 14,
      flexGrow: 1,
      flexBasis: 0,
    }}>
      <Box style={{
        padding: 14,
        borderRadius: 14,
        borderWidth: 1,
        borderColor: '#1f2935',
        backgroundColor: '#10151d',
        gap: 12,
      }}>
        <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 9 }}>
          <Box style={{ width: 13, height: 13, alignItems: 'center', justifyContent: 'center' }}>
            <Text fontSize={12} color="#79c0ff">📦</Text>
          </Box>
          <Text fontSize={13} color="#eef2f8" bold={true}>Model Providers</Text>
          <Box style={{ flexGrow: 1 }} />
          <Box style={{
            paddingLeft: 8,
            paddingRight: 8,
            paddingTop: 3,
            paddingBottom: 3,
            backgroundColor: '#10151d',
            borderRadius: 999,
            borderWidth: 1,
            borderColor: '#1f2935',
          }}>
            <Text fontSize={10} color="#79c0ff">{providers.length} providers</Text>
          </Box>
        </Box>
        
        <Box style={{ flexDirection: 'column', gap: 10 }}>
          {providers.map(function(provider, idx) {
            return (
              <ProviderRow 
                key={idx}
                provider={provider}
                active={provider.id == selectedId ? 1 : 0}
                onSelect={props.onSelectProvider}
              />
            );
          })}
        </Box>
      </Box>
      
      <Box style={{
        padding: 14,
        borderRadius: 14,
        borderWidth: 1,
        borderColor: selected.tone || '#1f2935',
        backgroundColor: '#10151d',
        gap: 12,
      }}>
        <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 9 }}>
          <Box style={{ width: 13, height: 13, alignItems: 'center', justifyContent: 'center' }}>
            <Text fontSize={12} color={selected.tone || '#79c0ff'}>🌐</Text>
          </Box>
          <Box style={{ flexDirection: 'column', gap: 3, flexGrow: 1, flexBasis: 0 }}>
            <Text fontSize={13} color="#eef2f8" bold={true}>{selected.name || 'Provider'} Routing</Text>
            <Text fontSize={10} color="#5d6a7c">{selected.summary || ''}</Text>
          </Box>
          <Box style={{
            paddingLeft: 8,
            paddingRight: 8,
            paddingTop: 3,
            paddingBottom: 3,
            backgroundColor: '#11161f',
            borderRadius: 999,
            borderWidth: 1,
            borderColor: selected.tone || '#1f2935',
          }}>
            <Text fontSize={10} color={selected.tone || '#79c0ff'}>{selected.status || 'planned'}</Text>
          </Box>
        </Box>
        
        {selected.capabilities && selected.capabilities.length > 0 && (
          <Box style={{ flexDirection: 'row', gap: 8, flexWrap: 'wrap' }}>
            {selected.capabilities.map(function(cap, idx) {
              return (
                <Box key={idx} style={{
                  paddingLeft: 9,
                  paddingRight: 9,
                  paddingTop: 5,
                  paddingBottom: 5,
                  borderRadius: 999,
                  borderWidth: 1,
                  borderColor: selected.tone || '#1f2935',
                  backgroundColor: '#11161f',
                }}>
                  <Text fontSize={10} color={selected.tone || '#79c0ff'}>{cap}</Text>
                </Box>
              );
            })}
          </Box>
        )}
      </Box>
    </Box>
  );
}

function ProviderRow(props) {
  var provider = props.provider || {};
  var active = props.active || 0;
  
  return (
    <Pressable 
      onPress={function() { if (props.onSelect) props.onSelect(provider.id); }}
      style={{
        padding: 12,
        borderRadius: 12,
        borderWidth: 1,
        borderColor: active == 1 ? provider.tone || '#2d62ff' : '#1f2935',
        backgroundColor: active == 1 ? '#121a24' : '#0f141c',
        gap: 8,
      }}
    >
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
        <Box style={{
          paddingLeft: 6,
          paddingRight: 6,
          paddingTop: 3,
          paddingBottom: 3,
          borderRadius: 4,
          borderWidth: 1,
          borderColor: provider.tone || '#1f2935',
          backgroundColor: '#0f141c',
        }}>
          <Text fontSize={10} color={provider.tone || '#79c0ff'}>{provider.short || provider.id}</Text>
        </Box>
        <Box style={{ flexDirection: 'column', gap: 2, flexGrow: 1, flexBasis: 0 }}>
          <Text fontSize={12} color="#eef2f8" bold={true}>{provider.name}</Text>
          <Text fontSize={10} color="#5d6a7c">{provider.driver || ''}</Text>
        </Box>
        <Box style={{
          paddingLeft: 8,
          paddingRight: 8,
          paddingTop: 3,
          paddingBottom: 3,
          borderRadius: 999,
          borderWidth: 1,
          borderColor: provider.tone || '#1f2935',
          backgroundColor: '#11161f',
        }}>
          <Text fontSize={10} color={provider.tone || '#79c0ff'}>{provider.status}</Text>
        </Box>
      </Box>
      
      <Box style={{ flexDirection: 'row', gap: 6, flexWrap: 'wrap' }}>
        {provider.route && (
          <Box style={{
            paddingLeft: 8,
            paddingRight: 8,
            paddingTop: 4,
            paddingBottom: 4,
            borderRadius: 999,
            borderWidth: 1,
            borderColor: '#1f2935',
            backgroundColor: '#10151d',
          }}>
            <Text fontSize={10} color="#c9d2df">{provider.route}</Text>
          </Box>
        )}
        {provider.defaultModel && (
          <Box style={{
            paddingLeft: 8,
            paddingRight: 8,
            paddingTop: 4,
            paddingBottom: 4,
            borderRadius: 999,
            borderWidth: 1,
            borderColor: '#1f2935',
            backgroundColor: '#10151d',
          }}>
            <Text fontSize={10} color="#79c0ff">{provider.defaultModel}</Text>
          </Box>
        )}
        {provider.env && (
          <Box style={{
            paddingLeft: 8,
            paddingRight: 8,
            paddingTop: 4,
            paddingBottom: 4,
            borderRadius: 999,
            borderWidth: 1,
            borderColor: '#1f2935',
            backgroundColor: '#10151d',
          }}>
            <Text fontSize={10} color="#7ee787">{provider.env}</Text>
          </Box>
        )}
      </Box>
      
      <Text fontSize={11} color="#c9d2df" lineHeight={17}>{provider.summary || ''}</Text>
    </Pressable>
  );
}

export {
  SettingsProvidersPage,
  ProviderRow,
};
