// SettingsShortcutsPage — Keyboard shortcuts configuration

function SettingsShortcutsPage(props) {
  var shortcuts = props.shortcuts || [];
  
  return (
    <Box style={{
      flexDirection: 'column',
      gap: 14,
      flexGrow: 1,
      flexBasis: 0,
    }}>
      <Box style={{
        padding: 14,
        borderRadius: 14,
        borderWidth: 1,
        borderColor: '#1f2935',
        backgroundColor: '#10151d',
        gap: 12,
      }}>
        <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 9 }}>
          <Box style={{ width: 13, height: 13, alignItems: 'center', justifyContent: 'center' }}>
            <Text fontSize={12} color="#7ee787">⌨</Text>
          </Box>
          <Text fontSize={13} color="#eef2f8" bold={true}>Keyboard Shortcuts</Text>
        </Box>
        
        <Text fontSize={11} color="#c9d2df" lineHeight={18}>
          Customize keyboard shortcuts for common actions. Click on a shortcut to edit.
        </Text>
        
        <Box style={{ flexDirection: 'column', gap: 8 }}>
          {shortcuts.map(function(category, idx) {
            return <ShortcutCategory key={idx} category={category} />;
          })}
        </Box>
      </Box>
    </Box>
  );
}

function ShortcutCategory(props) {
  var category = props.category || {};
  
  return (
    <Box style={{
      flexDirection: 'column',
      gap: 6,
    }}>
      <Text fontSize={11} color="#5d6a7c" letterSpacing={0.5}>{category.name}</Text>
      <Box style={{
        flexDirection: 'column',
        gap: 2,
        backgroundColor: '#0f141c',
        borderRadius: 8,
        borderWidth: 1,
        borderColor: '#1f2935',
      }}>
        {category.items.map(function(item, idx) {
          return <ShortcutRow key={idx} item={item} />;
        })}
      </Box>
    </Box>
  );
}

function ShortcutRow(props) {
  var item = props.item || {};
  
  return (
    <Pressable 
      onPress={props.onPress}
      style={{
        flexDirection: 'row',
        alignItems: 'center',
        justifyContent: 'space-between',
        padding: 10,
        borderBottomWidth: 1,
        borderColor: '#1f2935',
      }}
    >
      <Text fontSize={11} color="#c9d2df">{item.name}</Text>
      <Box style={{
        flexDirection: 'row',
        alignItems: 'center',
        gap: 4,
      }}>
        {item.keys.map(function(key, kidx) {
          return (
            <Box key={kidx} style={{
              paddingLeft: 6,
              paddingRight: 6,
              paddingTop: 3,
              paddingBottom: 3,
              backgroundColor: '#10151d',
              borderRadius: 4,
              borderWidth: 1,
              borderColor: '#1f2935',
            }}>
              <Text fontSize={10} color="#79c0ff">{key}</Text>
            </Box>
          );
        })}
      </Box>
    </Pressable>
  );
}

export {
  SettingsShortcutsPage,
  ShortcutCategory,
  ShortcutRow,
};
