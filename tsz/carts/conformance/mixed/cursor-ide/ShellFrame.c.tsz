// ShellFrame — Root window frame with resize handles

function ShellFrame(props) {
  return (
    <C.WindowFrame>
      {props.children}
    </C.WindowFrame>
  );
}

function ShellFrameMiddle(props) {
  return (
    <C.WindowFrameMiddle>
      {props.children}
    </C.WindowFrameMiddle>
  );
}

function WindowResizeHandles() {
  return (
    <>
      <C.WindowResizeTop />
      <C.WindowResizeBottom />
    </>
  );
}

function WindowResizeSides() {
  return (
    <>
      <C.WindowResizeLeft />
      <C.WindowResizeRight />
    </>
  );
}

function ShellContent(props) {
  return (
    <C.Shell style={props.style}>
      {props.children}
    </C.Shell>
  );
}

function Workspace(props) {
  var compactMode = props.compactMode || 0;
  
  return (
    <C.Workspace style={compactMode == 1 ? { flexDirection: 'column' } : {}}>
      {props.children}
    </C.Workspace>
  );
}

export {
  ShellFrame,
  ShellFrameMiddle,
  WindowResizeHandles,
  WindowResizeSides,
  ShellContent,
  Workspace,
};
