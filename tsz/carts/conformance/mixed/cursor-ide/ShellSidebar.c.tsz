// ShellSidebar — Main sidebar shell container

function ShellSidebar(props) {
  var width = props.width || 312;
  var collapsed = props.collapsed || 0;
  
  if (collapsed == 1) {
    return (
      <C.Sidebar style={{ width: 48 }}>
        {props.children}
      </C.Sidebar>
    );
  }
  
  return (
    <C.Sidebar style={{ width: width }}>
      {props.children}
    </C.Sidebar>
  );
}

function SidebarHeader(props) {
  return (
    <C.SidebarHeader>
      {props.children}
    </C.SidebarHeader>
  );
}

function SidebarTitle(props) {
  return (
    <C.SidebarTitle>
      {props.children}
    </C.SidebarTitle>
  );
}

function SidebarActions(props) {
  return (
    <C.SidebarActions>
      {props.children}
    </C.SidebarActions>
  );
}

function SidebarActionBtn(props) {
  return (
    <C.SidebarActionBtn onPress={props.onPress}>
      {props.children}
    </C.SidebarActionBtn>
  );
}

function SidebarSection(props) {
  return (
    <C.SidebarSection>
      {props.children}
    </C.SidebarSection>
  );
}

function SidebarSectionHeader(props) {
  return (
    <C.SidebarSectionHeader>
      {props.children}
    </C.SidebarSectionHeader>
  );
}

function SidebarSectionTitle(props) {
  return (
    <C.SidebarSectionTitle>
      {props.children}
    </C.SidebarSectionTitle>
  );
}

export {
  ShellSidebar,
  SidebarHeader,
  SidebarTitle,
  SidebarActions,
  SidebarActionBtn,
  SidebarSection,
  SidebarSectionHeader,
  SidebarSectionTitle,
};
