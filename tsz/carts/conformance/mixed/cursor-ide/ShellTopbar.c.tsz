// ShellTopbar — Main top bar with window controls and workspace info

function ShellTopbar(props) {
  var compactMode = props.compactMode || 0;
  var minimumMode = props.minimumMode || 0;
  
  var height = minimumMode == 1 ? 40 : compactMode == 1 ? 42 : 46;
  var padding = minimumMode == 1 ? 10 : 14;
  
  return (
    <C.TopBar style={{ height: height, paddingLeft: padding, paddingRight: padding }}>
      {props.children}
    </C.TopBar>
  );
}

function TopbarLeft(props) {
  return (
    <C.TopBarLeft>
      {props.children}
    </C.TopBarLeft>
  );
}

function TopbarTrafficLights(props) {
  return (
    <C.TopBarTraffic>
      <C.TopBarTrafficBtn onPress={props.onClose}>
        <C.TopBarTrafficDot style={{ backgroundColor: '#ff5f56' }} />
      </C.TopBarTrafficBtn>
      <C.TopBarTrafficBtn onPress={props.onMinimize}>
        <C.TopBarTrafficDot style={{ backgroundColor: '#ffbd2e' }} />
      </C.TopBarTrafficBtn>
      <C.TopBarTrafficBtn onPress={props.onMaximize}>
        <C.TopBarTrafficDot style={{ backgroundColor: '#27c93f' }} />
      </C.TopBarTrafficBtn>
    </C.TopBarTraffic>
  );
}

function TopbarWorkspaceBtn(props) {
  return (
    <C.TopBarWorkspaceBtn onPress={props.onPress}>
      <C.TopBarWorkspaceGlyph>⌘</C.TopBarWorkspaceGlyph>
      <C.TopBarWorkspaceText>{props.name}</C.TopBarWorkspaceText>
    </C.TopBarWorkspaceBtn>
  );
}

function TopbarCommandBar(props) {
  return (
    <C.TopBarCommandBar onPress={props.onPress}>
      <C.TopBarCommandHint>{props.hint || 'Search or command...'}</C.TopBarCommandHint>
      {props.label && <C.TopBarCommandLabel>{props.label}</C.TopBarCommandLabel>}
    </C.TopBarCommandBar>
  );
}

function TopbarRight(props) {
  return (
    <C.TopBarRight>
      {props.children}
    </C.TopBarRight>
  );
}

function TopbarGitChip(props) {
  return (
    <C.TopBarGitChip>
      <C.TopBarGitDot style={{ backgroundColor: props.statusColor || '#7ee787' }} />
      <C.TopBarGitText>{props.branch}</C.TopBarGitText>
      {props.meta && <C.TopBarGitMeta>{props.meta}</C.TopBarGitMeta>}
    </C.TopBarGitChip>
  );
}

function TopbarAction(props) {
  return (
    <C.TopBarAction onPress={props.onPress}>
      {props.label && <C.TopBarActionLabel>{props.label}</C.TopBarActionLabel>}
      {props.meta && <C.TopBarActionMeta>{props.meta}</C.TopBarActionMeta>}
      {props.children}
    </C.TopBarAction>
  );
}

export {
  ShellTopbar,
  TopbarLeft,
  TopbarTrafficLights,
  TopbarWorkspaceBtn,
  TopbarCommandBar,
  TopbarRight,
  TopbarGitChip,
  TopbarAction,
};
