// Sidebar Component — File explorer with type icons

function Sidebar(props) {
  return (
    <C.Sidebar>
      <C.SidebarHeader>
        <C.SidebarTitle>EXPLORER</C.SidebarTitle>
        <C.SidebarActions>
          <C.SidebarActionBtn>
            <C.SidebarActionIcon>+</C.SidebarActionIcon>
          </C.SidebarActionBtn>
        </C.SidebarActions>
      </C.SidebarHeader>

      <C.FileTree>
        <C.FileTreeStack>
          {props.files.map(function(file, idx) {
            return (
              <Pressable onPress={function() { props.onSelectFile(idx); }} style={{ flexDirection: 'row', alignItems: 'center', gap: 6, paddingLeft: 12 + file.indent * 12, paddingRight: 12, paddingTop: 3, paddingBottom: 3, backgroundColor: file.selected == 1 ? '#1f1f1f' : '#00000000' }}>
                {file.type == 'dir' && <Text fontSize={10} color="#6e6e6e">{file.expanded == 1 ? 'v' : '>'}</Text>}
                {file.type == 'tsx' && <Text fontSize={9} color="#3b82f6">TS</Text>}
                {file.type == 'ts' && <Text fontSize={9} color="#3b82f6">TS</Text>}
                {file.type == 'js' && <Text fontSize={9} color="#eab308">JS</Text>}
                {file.type == 'css' && <Text fontSize={9} color="#a855f7">CS</Text>}
                {file.type == 'json' && <Text fontSize={9} color="#22c55e">{ }</Text>}
                {file.type == 'md' && <Text fontSize={9} color="#6e6e6e">MD</Text>}
                <Text fontSize={12} color={file.selected == 1 ? '#ffffff' : '#9ca3af'}>{file.name}</Text>
              </Pressable>
            );
          })}
        </C.FileTreeStack>
      </C.FileTree>
    </C.Sidebar>
  );
}

export { Sidebar };
