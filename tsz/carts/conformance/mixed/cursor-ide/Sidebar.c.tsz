// Sidebar Component — File explorer with type icons

function FileIcon(props) {
  var t = props.type;
  // Directories get chevron
  if (t == 'dir') {
    return <Text fontSize={10} color="#6e6e6e">{props.expanded == 1 ? 'v' : '>'}</Text>;
  }
  // File type badges
  if (t == 'tsx') return <Text fontSize={9} color="#3b82f6">TS</Text>;
  if (t == 'ts') return <Text fontSize={9} color="#3b82f6">TS</Text>;
  if (t == 'js') return <Text fontSize={9} color="#eab308">JS</Text>;
  if (t == 'css') return <Text fontSize={9} color="#a855f7">CS</Text>;
  if (t == 'json') return <Text fontSize={9} color="#22c55e">{ }</Text>;
  if (t == 'md') return <Text fontSize={9} color="#6e6e6e">MD</Text>;
  return <Text fontSize={9} color="#6e6e6e">--</Text>;
}

function FileRow(props) {
  var file = props.file;
  var isSelected = file.selected == 1;
  var nameColor = isSelected ? '#ffffff' : (file.type == 'dir' ? '#b0b0b0' : '#9ca3af');
  var bgColor = isSelected ? '#1f1f1f' : '#00000000';

  return (
    <Pressable onPress={props.onPress} style={{ flexDirection: 'row', alignItems: 'center', gap: 6, paddingLeft: 12 + file.indent * 12, paddingRight: 12, paddingTop: 3, paddingBottom: 3, backgroundColor: bgColor }}>
      <FileIcon type={file.type} expanded={file.expanded} />
      <Text fontSize={12} color={nameColor}>{file.name}</Text>
    </Pressable>
  );
}

function Sidebar(props) {
  return (
    <C.Sidebar>
      <C.SidebarHeader>
        <C.SidebarTitle>EXPLORER</C.SidebarTitle>
        <C.SidebarActions>
          <C.SidebarActionBtn>
            <C.SidebarActionIcon>+</C.SidebarActionIcon>
          </C.SidebarActionBtn>
        </C.SidebarActions>
      </C.SidebarHeader>

      <C.FileTree>
        <C.FileTreeStack>
          {props.files.map(function(file, idx) {
            return (
              <FileRow
                file={file}
                onPress={function() { props.onSelectFile(idx); }}
              />
            );
          })}
        </C.FileTreeStack>
      </C.FileTree>
    </C.Sidebar>
  );
}

export { Sidebar };
