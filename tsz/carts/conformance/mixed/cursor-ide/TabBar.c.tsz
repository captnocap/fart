// TabBar — tabs with file type color dots, modified indicator, close button

function Tab(props) {
  var tab = props.tab;
  var isActive = props.isActive;

  // File type dot color
  var dotColor = '#6e6e6e';
  if (tab.type == 'tsx' || tab.type == 'ts') dotColor = '#3b82f6';
  if (tab.type == 'js') dotColor = '#eab308';
  if (tab.type == 'css') dotColor = '#a855f7';
  if (tab.type == 'json') dotColor = '#22c55e';

  if (isActive == 1) {
    return (
      <C.TabActive onPress={function() { activateTab(tab.id); }}>
        <Box style={{ width: 6, height: 6, borderRadius: 3, backgroundColor: dotColor }} />
        <C.TabNameActive>{tab.name}</C.TabNameActive>
        {tab.modified == 1 && <C.TabModified />}
        <C.TabClose onPress={function() { closeTab(tab.id); }}>
          <C.TabCloseIcon>x</C.TabCloseIcon>
        </C.TabClose>
      </C.TabActive>
    );
  }

  return (
    <C.Tab onPress={function() { activateTab(tab.id); }}>
      <Box style={{ width: 6, height: 6, borderRadius: 3, backgroundColor: dotColor }} />
      <C.TabName>{tab.name}</C.TabName>
      {tab.modified == 1 && <C.TabModified />}
      <C.TabClose onPress={function() { closeTab(tab.id); }}>
        <C.TabCloseIcon>x</C.TabCloseIcon>
      </C.TabClose>
    </C.Tab>
  );
}

function TabBar(props) {
  return (
    <C.TabBar>
      {props.tabs.map(function(tab, idx) {
        return (
          <Tab tab={tab} isActive={tab.id == props.activeId ? 1 : 0} />
        );
      })}
    </C.TabBar>
  );
}

export { TabBar };
