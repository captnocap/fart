// Terminal panel — same chrome as editor and chat, real PTY underneath

import { XIcon } from './Icon.c';

function TerminalPanel(props) {
  var compactBand = 0;
  if (props.widthBand == 'narrow' || props.widthBand == 'widget' || props.widthBand == 'minimum') compactBand = 1;

  return (
    <C.TerminalPanel style={props.style}>
      <C.TerminalHeader style={compactBand == 1 ? { paddingLeft: 10, paddingRight: 10, paddingTop: 8, paddingBottom: 8 } : {}}>
        <C.TerminalHeaderMain>
          <C.TerminalTitle>Terminal</C.TerminalTitle>
          <C.TerminalMeta>{props.gitBranch}</C.TerminalMeta>
          {compactBand != 1 && <C.TerminalMeta>{props.workDir}</C.TerminalMeta>}
        </C.TerminalHeaderMain>
        <C.TerminalActions>
          {props.onClose && <C.TerminalActionBtn onPress={props.onClose}>
            <XIcon size={10} />
          </C.TerminalActionBtn>}
        </C.TerminalActions>
      </C.TerminalHeader>

      <C.TerminalBody>
        <Terminal style={{ flexGrow: 1, flexBasis: 0 }} fontSize={compactBand == 1 ? 12 : 13} />
      </C.TerminalBody>

      {compactBand != 1 && <C.TerminalFooter>
        <C.TerminalFooterText>pty attached to workspace shell</C.TerminalFooterText>
      </C.TerminalFooter>}
    </C.TerminalPanel>
  );
}

export { TerminalPanel };
