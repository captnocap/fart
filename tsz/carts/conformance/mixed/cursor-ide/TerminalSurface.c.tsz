// TerminalSurface — Terminal panel

function TerminalSurface(props) {
  var compactMode = props.compactMode || 0;
  
  if (compactMode == 1) {
    return (
      <C.TerminalPanel style={{ flexGrow: 1, flexBasis: 0, minHeight: 0, borderTopWidth: 0 }}>
        {props.children}
      </C.TerminalPanel>
    );
  }
  
  return (
    <C.TerminalPanel style={props.style}>
      {props.children}
    </C.TerminalPanel>
  );
}

function TerminalHeader(props) {
  return (
    <C.TerminalHeader>
      <C.TerminalHeaderMain>
        <C.TerminalTitle>{props.title || 'Terminal'}</C.TerminalTitle>
        {props.meta && <C.TerminalMeta>{props.meta}</C.TerminalMeta>}
      </C.TerminalHeaderMain>
      <C.TerminalActions>
        {props.actions}
      </C.TerminalActions>
    </C.TerminalHeader>
  );
}

function TerminalBody(props) {
  return (
    <C.TerminalBody>
      {props.children}
    </C.TerminalBody>
  );
}

function TerminalFooter(props) {
  return (
    <C.TerminalFooter>
      <C.TerminalFooterText>{props.children}</C.TerminalFooterText>
    </C.TerminalFooter>
  );
}

function TerminalLine(props) {
  var line = props.line || {};
  var type = line.type || 'output';
  
  var color = '#c9d2df';
  if (type exact 'command') color = '#79c0ff';
  else if (type exact 'error') color = '#ff7b72';
  else if (type exact 'info') color = '#7ee787';
  else if (type exact 'prompt') color = '#d2a8ff';
  
  return (
    <Text fontSize={11} color={color} fontFamily="monospace">
      {line.text}
    </Text>
  );
}

function TerminalInput(props) {
  return (
    <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
      <Text fontSize={11} color="#d2a8ff" fontFamily="monospace">$</Text>
      <TextInput
        value={props.value}
        onChange={props.onChange}
        onSubmit={props.onSubmit}
        fontSize={11}
        color="#c9d2df"
        fontFamily="monospace"
        style={{ flexGrow: 1, height: 24, borderWidth: 0, backgroundColor: 'transparent' }}
        placeholder="Type a command..."
      />
    </Box>
  );
}

function TerminalActionBtn(props) {
  return (
    <C.TerminalActionBtn onPress={props.onPress}>
      <C.TerminalActionLabel>{props.label}</C.TerminalActionLabel>
    </C.TerminalActionBtn>
  );
}

export {
  TerminalSurface,
  TerminalHeader,
  TerminalBody,
  TerminalFooter,
  TerminalLine,
  TerminalInput,
  TerminalActionBtn,
};
