// ToolExecutionPanel — Tool execution progress and results

function ToolExecutionPanel(props) {
  var executions = props.executions || [];
  
  if (executions.length == 0) return null;
  
  return (
    <Box style={{
      backgroundColor: '#0f141c',
      borderTopWidth: 1,
      borderColor: '#171d26',
      flexDirection: 'column',
      maxHeight: 200,
    }}>
      {props.children}
    </Box>
  );
}

function ToolExecutionHeader(props) {
  return (
    <Box style={{
      flexDirection: 'row',
      alignItems: 'center',
      justifyContent: 'space-between',
      padding: 10,
      borderBottomWidth: 1,
      borderColor: '#171d26',
    }}>
      <Text fontSize={11} color="#eef2f8" bold={true}>Tool Execution</Text>
      <Text fontSize={10} color="#5d6a7c">{props.count} active</Text>
    </Box>
  );
}

function ToolExecutionItem(props) {
  var exec = props.exec || {};
  var statusColor = '#7ee787';
  
  if (exec.status exact 'running') statusColor = '#ffbd2e';
  else if (exec.status exact 'error') statusColor = '#ff7b72';
  else if (exec.status exact 'pending') statusColor = '#5d6a7c';
  
  return (
    <Box style={{
      flexDirection: 'column',
      padding: 10,
      borderBottomWidth: 1,
      borderColor: '#171d26',
      gap: 6,
    }}>
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
        <Box style={{ width: 8, height: 8, borderRadius: 4, backgroundColor: statusColor }} />
        <Text fontSize={11} color="#eef2f8" bold={true}>{exec.name}</Text>
        <Box style={{ flexGrow: 1 }} />
        <Text fontSize={10} color="#5d6a7c">{exec.status}</Text>
      </Box>
      
      {exec.input && (
        <Text fontSize={10} color="#7f8a99">{exec.input}</Text>
      )}
      
      {exec.status exact 'running' && (
        <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
          <Box style={{ flexGrow: 1, height: 4, backgroundColor: '#1f2935', borderRadius: 2 }}>
            <Box style={{
              width: exec.percent + '%',
              height: 4,
              backgroundColor: '#2d62ff',
              borderRadius: 2,
            }} />
          </Box>
          <Text fontSize={10} color="#5d6a7c">{exec.percent}%</Text>
        </Box>
      )}
      
      {exec.result && exec.result.length > 0 && (
        <Box style={{
          backgroundColor: '#0b0f15',
          borderRadius: 6,
          padding: 8,
        }}>
          <Text fontSize={10} color="#9db1c9" fontFamily="monospace">
            {exec.result}
          </Text>
        </Box>
      )}
    </Box>
  );
}

function ToolExecutionList(props) {
  var executions = props.executions || [];
  
  return (
    <ScrollView style={{ maxHeight: 160 }}>
      {executions.map(function(exec, idx) {
        return <ToolExecutionItem key={idx} exec={exec} />;
      })}
    </ScrollView>
  );
}

export {
  ToolExecutionPanel,
  ToolExecutionHeader,
  ToolExecutionItem,
  ToolExecutionList,
};
