// TopBar Component

function TopBar(props) {
  return (
    <C.TopBar>
      <C.TopBarLeft>
        <C.WindowTitle>{props.title}</C.WindowTitle>
      </C.TopBarLeft>
      <C.TopBarRight>
        <Pressable onPress={props.onToggleSearch} style={{ paddingLeft: 10, paddingRight: 10, paddingTop: 5, paddingBottom: 5, borderRadius: 4 }}>
          <Text fontSize={11} color="#b0b0b0">Search</Text>
        </Pressable>
        <Pressable onPress={props.onToggleTerminal} style={{ paddingLeft: 10, paddingRight: 10, paddingTop: 5, paddingBottom: 5, borderRadius: 4 }}>
          <Text fontSize={11} color="#b0b0b0">Terminal</Text>
        </Pressable>
        <Pressable onPress={props.onToggleChat} style={{ paddingLeft: 10, paddingRight: 10, paddingTop: 5, paddingBottom: 5, borderRadius: 4 }}>
          <Text fontSize={11} color="#b0b0b0">Chat</Text>
        </Pressable>
      </C.TopBarRight>
    </C.TopBar>
  );
}

export { TopBar };
