// Cursor IDE — Icon registry and helpers

// === ICON GLYPHS ===

var ICONS = {
  // Navigation
  house: '⌂',
  package: '⬡',
  folder: '▶',
  'folder-open': '▼',
  'panel-left': '◧',
  'panel-right': '◨',
  search: '🔍',
  terminal: '$',
  'message-square': '☰',
  
  // File types
  'file-code': '◈',
  'file-json': '{ }',
  'file-text': '📄',
  'file-image': '🖼',
  palette: '◐',
  braces: '{ }',
  'file-plus': '+',
  
  // Actions
  plus: '+',
  minus: '−',
  x: '×',
  check: '✓',
  refresh: '↻',
  'chevron-right': '›',
  'chevron-down': '⌄',
  'chevron-left': '‹',
  'chevron-up': '⌃',
  
  // Git
  'git-branch': '⎇',
  'git-commit': '●',
  'git-compare': '⇄',
  'git-merge': '⫯',
  'git-pull-request': '⫰',
  
  // Agent
  bot: '🤖',
  sparkles: '✨',
  'zap': '⚡',
  'play': '▶',
  'pause': '⏸',
  'stop': '⏹',
  
  // Settings
  globe: '🌐',
  'badge-info': 'ⓘ',
  'alert-triangle': '⚠',
  'alert-circle': '⚠',
  settings: '⚙',
  keyboard: '⌨',
  
  // Misc
  more: '⋯',
  link: '🔗',
  copy: '⎘',
  trash: '🗑',
  edit: '✎',
  save: '💾',
  download: '↓',
  upload: '↑',
  'external-link': '↗',
  menu: '☰',
  filter: '▽',
  sort: '⇅',
  pin: '⌖',
  'pin-off': '○',
  maximize: '□',
  minimize: '▁',
  'corner-down-left': '↵',
  'corner-up-right': '↷',
  ellipsis: '⋯',
  history: '↺',
  bookmark: '🔖',
  star: '★',
  'star-off': '☆',
  lock: '🔒',
  unlock: '🔓',
  eye: '👁',
  'eye-off': '○',
  send: '➤',
  mic: '🎤',
  paperclip: '⌗',
  'more-vertical': '⋮',
  grip: '⫶',
};

// === ICON SIZES ===

var ICON_SIZES = {
  xs: 8,
  sm: 10,
  md: 12,
  lg: 14,
  xl: 16,
};

// === ICON HELPERS ===

function getIcon(name) {
  return ICONS[name] || ICONS.ellipsis;
}

function getIconSize(size) {
  return ICON_SIZES[size] || ICON_SIZES.md;
}

function iconForFileType(type) {
  var map = {
    workspace: 'package',
    home: 'house',
    dir: 'folder',
    component: 'braces',
    cls: 'palette',
    script: 'file-code',
    mod: 'package',
    app: 'panel-left',
    tsz: 'braces',
    ts: 'file-code',
    tsx: 'file-code',
    js: 'file-code',
    jsx: 'file-code',
    zig: 'braces',
    md: 'file-text',
    json: 'file-json',
    css: 'palette',
    sh: 'terminal',
    settings: 'palette',
  };
  return map[type] || 'file-text';
}

function iconForProvider(id) {
  var map = {
    anthropic: 'bot',
    openai: 'sparkles',
    'lua-local': 'braces',
    'qjs-plugin': 'zap',
  };
  return map[id] || 'globe';
}

function iconForSettingsSection(id) {
  var map = {
    providers: 'globe',
    context: 'folder',
    memory: 'bot',
    plugins: 'palette',
    automations: 'sparkles',
    capabilities: 'braces',
    general: 'settings',
    shortcuts: 'keyboard',
  };
  return map[id] || 'badge-info';
}

function iconForAgentStatus(status) {
  var map = {
    idle: '●',
    running: '⏵',
    paused: '⏸',
    completed: '✓',
    error: '⚠',
    waiting: '◐',
  };
  return map[status] || '○';
}

function iconForGitStatus(code) {
  if (!code || code.length == 0) return '';
  if (code.indexOf('D') >= 0) return '−';
  if (code.indexOf('A') >= 0) return '+';
  if (code == '??' || code == 'new') return '?';
  if (code.indexOf('M') >= 0) return '●';
  return '○';
}

function iconForAction(action) {
  var map = {
    save: '💾',
    refresh: '↻',
    close: '×',
    new: '+',
    search: '🔍',
    send: '➤',
    attach: '⌗',
    remove: '−',
    expand: '▼',
    collapse: '▶',
    settings: '⚙',
    home: '⌂',
  };
  return map[action] || '•';
}

// === ICON COMPONENTS ===

function Icon(props) {
  var name = props.name || 'ellipsis';
  var size = props.size || 'md';
  var color = props.color || '#c9d2df';
  
  return (
    <Text fontSize={getIconSize(size)} color={color}>
      {getIcon(name)}
    </Text>
  );
}

function FileIcon(props) {
  var type = props.type || 'file';
  var size = props.size || 'sm';
  var color = props.color || '#c9d2df';
  
  return (
    <Icon name={iconForFileType(type)} size={size} color={color} />
  );
}

function ProviderIcon(props) {
  var id = props.id || 'default';
  var size = props.size || 'md';
  var color = props.color || '#79c0ff';
  
  return (
    <Icon name={iconForProvider(id)} size={size} color={color} />
  );
}

function ActionIcon(props) {
  var action = props.action || 'default';
  var size = props.size || 'sm';
  var color = props.color || '#c9d2df';
  
  return (
    <Icon name={iconForAction(action)} size={size} color={color} />
  );
}

function StatusIcon(props) {
  var status = props.status || 'default';
  var size = props.size || 'sm';
  var color = props.color || '#7ee787';
  
  return (
    <Text fontSize={getIconSize(size)} color={color}>
      {iconForAgentStatus(status)}
    </Text>
  );
}

export {
  ICONS,
  ICON_SIZES,
  getIcon,
  getIconSize,
  iconForFileType,
  iconForProvider,
  iconForSettingsSection,
  iconForAgentStatus,
  iconForGitStatus,
  iconForAction,
  Icon,
  FileIcon,
  ProviderIcon,
  ActionIcon,
  StatusIcon,
};
