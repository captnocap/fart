          </Box>
        </Box>

        <Box style={{ width: 200, backgroundColor: '#1e293b', borderRadius: 16, padding: 14, gap: 8 }}>
          <Text fontSize={13} color="#94a3b8">E: Fill + 2px fill-color stroke</Text>
