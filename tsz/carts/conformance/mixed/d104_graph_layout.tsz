            <Graph style={{ width: 140, height: 140 }} viewX={0} viewY={0} viewZoom={0.88}>
              <Graph.Path d="M 0,-72 L 62,-36 L 62,36 L 0,72 L -62,36 L -62,-36 Z" fill="#f97316" stroke="#f97316" strokeWidth={2} />
