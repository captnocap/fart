// CONFORMANCE TEST 129: Message Type Dispatcher
//
// Ported from: Claude Code Message.tsx + SystemTextMessage.tsx
//
// A chat message renderer where each message has a type field (0-7) and
// each type renders completely different JSX — different components, different
// props, different layouts. Mimics the switch(message.type) pattern from
// Claude Code's Message component which has 94 React Compiler cache slots.
//
// Patterns tested:
// - 8-way conditional dispatch (if-chain on numeric type field)
// - Each branch renders a DIFFERENT component with different props
// - Map over messages with per-item type dispatch
// - Sub-dispatch within a type (error messages have sub-types)
// - Conditional margin/spacing based on adjacent message types
// - Component used once vs component used in every branch (timestamp)
// - Mixed content: text, code blocks, images, tool results, thinking
// - Verbose mode toggles additional detail rendering per type

const [messages, setMessages] = useState([{ type: 0, content: '', sender: '', time: '', toolName: '', toolStatus: 0, thinkingText: '', errorCode: 0, attachmentName: '', verbose: 0 }]);
const [verboseMode, setVerboseMode] = useState(0);
const [selectedMsg, setSelectedMsg] = useState(0);
const [typeFilter, setTypeFilter] = useState(8);
const [msgCounts, setMsgCounts] = useState([0, 0, 0, 0, 0, 0, 0, 0]);

<script>
var msgs = [
  { type: 0, content: 'Hello, how can I help you today?', sender: 'assistant', time: '10:01', toolName: '', toolStatus: 0, thinkingText: '', errorCode: 0, attachmentName: '', verbose: 0 },
  { type: 1, content: 'Can you fix the auth bug?', sender: 'user', time: '10:02', toolName: '', toolStatus: 0, thinkingText: '', errorCode: 0, attachmentName: '', verbose: 0 },
  { type: 2, content: 'Let me look at the auth module...', sender: 'assistant', time: '10:02', toolName: '', toolStatus: 0, thinkingText: 'The user wants me to fix an auth bug. I should check the auth middleware first, then the session handling.', errorCode: 0, attachmentName: '', verbose: 0 },
  { type: 3, content: 'cat src/auth/middleware.ts', sender: 'assistant', time: '10:03', toolName: 'Bash', toolStatus: 1, thinkingText: '', errorCode: 0, attachmentName: '', verbose: 0 },
  { type: 4, content: 'export function authMiddleware(req, res, next) {\n  const token = req.headers.authorization;\n  if (!token) return res.status(401).json({ error: "No token" });\n  next();\n}', sender: 'tool', time: '10:03', toolName: 'Bash', toolStatus: 1, thinkingText: '', errorCode: 0, attachmentName: '', verbose: 0 },
  { type: 3, content: 'src/auth/middleware.ts line 3', sender: 'assistant', time: '10:04', toolName: 'Edit', toolStatus: 1, thinkingText: '', errorCode: 0, attachmentName: '', verbose: 0 },
  { type: 5, content: '', sender: 'system', time: '10:04', toolName: '', toolStatus: 0, thinkingText: '', errorCode: 0, attachmentName: 'screenshot.png', verbose: 0 },
  { type: 6, content: 'Rate limit exceeded', sender: 'system', time: '10:05', toolName: '', toolStatus: 0, thinkingText: '', errorCode: 429, attachmentName: '', verbose: 0 },
  { type: 0, content: 'I found the issue. The token validation was missing the Bearer prefix check. I have fixed it.', sender: 'assistant', time: '10:06', toolName: '', toolStatus: 0, thinkingText: '', errorCode: 0, attachmentName: '', verbose: 0 },
  { type: 7, content: 'Turn completed in 4.2s · 3 tool calls · 1,247 tokens', sender: 'system', time: '10:06', toolName: '', toolStatus: 0, thinkingText: '', errorCode: 0, attachmentName: '', verbose: 0 },
  { type: 1, content: 'Great, can you also add rate limiting?', sender: 'user', time: '10:07', toolName: '', toolStatus: 0, thinkingText: '', errorCode: 0, attachmentName: '', verbose: 0 },
  { type: 6, content: 'Connection reset', sender: 'system', time: '10:07', toolName: '', toolStatus: 0, thinkingText: '', errorCode: 500, attachmentName: '', verbose: 0 }
];
setMessages(msgs);

var counts = [0, 0, 0, 0, 0, 0, 0, 0];
for (var i = 0; i < msgs.length; i++) {
  counts[msgs[i].type]++;
}
setMsgCounts(counts);
</script>

function Timestamp(time) {
  return (
    <Text fontSize={7} color="#475569">{time}</Text>
  );
}

function AssistantMsg(m) {
  return (
    <Box style={{ gap: 4, padding: 8, backgroundColor: "#1e293b", borderRadius: 8 }}>
      <Box style={{ flexDirection: "row", gap: 6, alignItems: "center" }}>
        <Box style={{ width: 6, height: 6, borderRadius: 3, backgroundColor: "#a855f7" }} />
        <Text fontSize={9} color="#a855f7">Assistant</Text>
        <Timestamp time={m.time} />
      </Box>
      <Text fontSize={10} color="#e2e8f0">{m.content}</Text>
    </Box>
  );
}

function UserMsg(m) {
  return (
    <Box style={{ gap: 4, padding: 8, backgroundColor: "#0f172a", borderRadius: 8, borderWidth: 1, borderColor: "#334155" }}>
      <Box style={{ flexDirection: "row", gap: 6, alignItems: "center" }}>
        <Box style={{ width: 6, height: 6, borderRadius: 3, backgroundColor: "#3b82f6" }} />
        <Text fontSize={9} color="#3b82f6">User</Text>
        <Timestamp time={m.time} />
      </Box>
      <Text fontSize={10} color="#e2e8f0">{m.content}</Text>
    </Box>
  );
}

function ThinkingMsg(m) {
  return (
    <Box style={{ gap: 4, padding: 8, backgroundColor: "#1a1a2e", borderRadius: 8, borderWidth: 1, borderColor: "#4a1d96" }}>
      <Box style={{ flexDirection: "row", gap: 6, alignItems: "center" }}>
        <Text fontSize={9} color="#7c3aed">Thinking</Text>
        <Timestamp time={m.time} />
      </Box>
      <Text fontSize={10} color="#94a3b8">{m.content}</Text>
      {verboseMode == 1 && <Box style={{ padding: 6, backgroundColor: "#0f0f1a", borderRadius: 4 }}>
        <Text fontSize={8} color="#6b21a8">{m.thinkingText}</Text>
      </Box>}
    </Box>
  );
}

function ToolUseMsg(m) {
  return (
    <Box style={{ gap: 4, padding: 8, backgroundColor: "#0c1929", borderRadius: 8 }}>
      <Box style={{ flexDirection: "row", gap: 6, alignItems: "center" }}>
        <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 1, paddingBottom: 1, backgroundColor: "#1e40af", borderRadius: 3 }}>
          <Text fontSize={7} color="#ffffff">{m.toolName}</Text>
        </Box>
        <Box style={{ width: 6, height: 6, borderRadius: 3, backgroundColor: m.toolStatus == 1 ? "#22c55e" : m.toolStatus == 2 ? "#ef4444" : "#f59e0b" }} />
        <Timestamp time={m.time} />
      </Box>
      <Text fontSize={9} color="#64748b">{m.content}</Text>
    </Box>
  );
}

function ToolResultMsg(m) {
  return (
    <Box style={{ gap: 4, padding: 8, backgroundColor: "#0a1628", borderRadius: 8, borderWidth: 1, borderColor: "#1e3a5f" }}>
      <Box style={{ flexDirection: "row", gap: 6, alignItems: "center" }}>
        <Text fontSize={8} color="#475569">{`${m.toolName} result`}</Text>
        <Timestamp time={m.time} />
      </Box>
      <Box style={{ padding: 6, backgroundColor: "#0f172a", borderRadius: 4 }}>
        <Text fontSize={9} color="#94a3b8">{m.content}</Text>
      </Box>
      {verboseMode == 1 && <Text fontSize={7} color="#334155">{`${m.content.length} chars`}</Text>}
    </Box>
  );
}

function AttachmentMsg(m) {
  return (
    <Box style={{ flexDirection: "row", gap: 8, padding: 8, backgroundColor: "#1e293b", borderRadius: 8, alignItems: "center" }}>
      <Box style={{ width: 32, height: 32, borderRadius: 4, backgroundColor: "#334155", alignItems: "center", justifyContent: "center" }}>
        <Text fontSize={12} color="#64748b">IMG</Text>
      </Box>
      <Box style={{ gap: 2 }}>
        <Text fontSize={10} color="#e2e8f0">{m.attachmentName}</Text>
        <Timestamp time={m.time} />
      </Box>
    </Box>
  );
}

function ErrorMsg(m) {
  return (
    <Box style={{ gap: 4, padding: 8, backgroundColor: m.errorCode == 429 ? "#451a03" : "#450a0a", borderRadius: 8, borderWidth: 1, borderColor: m.errorCode == 429 ? "#92400e" : "#dc2626" }}>
      <Box style={{ flexDirection: "row", gap: 6, alignItems: "center" }}>
        <Text fontSize={9} color={m.errorCode == 429 ? "#f59e0b" : "#ef4444"}>Error</Text>
        <Text fontSize={8} color="#475569">{`code: ${m.errorCode}`}</Text>
        <Timestamp time={m.time} />
      </Box>
      <Text fontSize={10} color={m.errorCode == 429 ? "#fbbf24" : "#fca5a5"}>{m.content}</Text>
      {m.errorCode == 429 && <Text fontSize={8} color="#92400e">Rate limited — will retry</Text>}
      {m.errorCode == 500 && <Text fontSize={8} color="#dc2626">Server error — check connection</Text>}
    </Box>
  );
}

function DurationMsg(m) {
  return (
    <Box style={{ flexDirection: "row", gap: 6, padding: 4, alignItems: "center" }}>
      <Box style={{ flexGrow: 1, height: 1, backgroundColor: "#1e293b" }} />
      <Text fontSize={7} color="#475569">{m.content}</Text>
      <Box style={{ flexGrow: 1, height: 1, backgroundColor: "#1e293b" }} />
    </Box>
  );
}

function App() {
  return (
    <Box style={{ backgroundColor: "#0f172a", padding: 16, width: "100%", height: "100%", flexDirection: "column", gap: 10 }}>
      <Box style={{ flexDirection: "row", justifyContent: "spaceBetween", alignItems: "center" }}>
        <Text fontSize={16} color="#e2e8f0">Message Dispatcher</Text>
        <Pressable onPress={() => { setVerboseMode(verboseMode == 0 ? 1 : 0) }} style={{ padding: 4, backgroundColor: verboseMode == 1 ? "#7c3aed" : "#334155", borderRadius: 4 }}>
          <Text fontSize={8} color="#ffffff">{verboseMode == 1 ? "Verbose" : "Normal"}</Text>
        </Pressable>
      </Box>

      <Box style={{ flexDirection: "row", gap: 4, flexWrap: "wrap" }}>
        <Pressable onPress={() => { setTypeFilter(8) }} style={{ padding: 3, backgroundColor: typeFilter == 8 ? "#1e40af" : "#1e293b", borderRadius: 3 }}>
          <Text fontSize={7} color="#e2e8f0">All</Text>
        </Pressable>
        <Pressable onPress={() => { setTypeFilter(0) }} style={{ padding: 3, backgroundColor: typeFilter == 0 ? "#1e40af" : "#1e293b", borderRadius: 3 }}>
          <Text fontSize={7} color="#a855f7">{`Asst (${msgCounts[0]})`}</Text>
        </Pressable>
        <Pressable onPress={() => { setTypeFilter(1) }} style={{ padding: 3, backgroundColor: typeFilter == 1 ? "#1e40af" : "#1e293b", borderRadius: 3 }}>
          <Text fontSize={7} color="#3b82f6">{`User (${msgCounts[1]})`}</Text>
        </Pressable>
        <Pressable onPress={() => { setTypeFilter(3) }} style={{ padding: 3, backgroundColor: typeFilter == 3 ? "#1e40af" : "#1e293b", borderRadius: 3 }}>
          <Text fontSize={7} color="#1e40af">{`Tool (${msgCounts[3]})`}</Text>
        </Pressable>
        <Pressable onPress={() => { setTypeFilter(6) }} style={{ padding: 3, backgroundColor: typeFilter == 6 ? "#1e40af" : "#1e293b", borderRadius: 3 }}>
          <Text fontSize={7} color="#ef4444">{`Error (${msgCounts[6]})`}</Text>
        </Pressable>
      </Box>

      <ScrollView style={{ flexGrow: 1, gap: 4 }}>
        {messages.map((m, i) => (
          <Box>
            {(typeFilter == 8 || typeFilter == m.type) && <Pressable onPress={() => { setSelectedMsg(i) }} style={{ borderWidth: selectedMsg == i ? 1 : 0, borderColor: "#3b82f6", borderRadius: 8 }}>
              {m.type == 0 && <AssistantMsg m={m} />}
              {m.type == 1 && <UserMsg m={m} />}
              {m.type == 2 && <ThinkingMsg m={m} />}
              {m.type == 3 && <ToolUseMsg m={m} />}
              {m.type == 4 && <ToolResultMsg m={m} />}
              {m.type == 5 && <AttachmentMsg m={m} />}
              {m.type == 6 && <ErrorMsg m={m} />}
              {m.type == 7 && <DurationMsg m={m} />}
            </Pressable>}
          </Box>
        ))}
      </ScrollView>

      <Text fontSize={8} color="#475569">{`${messages.length} messages · selected: ${selectedMsg} · verbose: ${verboseMode}`}</Text>
    </Box>
  );
}
