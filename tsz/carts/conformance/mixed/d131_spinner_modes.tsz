// CONFORMANCE TEST 131: Multi-Mode Spinner / Status Display
//
// Ported from: Claude Code Spinner.tsx + SpinnerAnimationRow.tsx
//
// A status display component with 6 modes: idle, thinking, searching,
// writing, stalled, error. Each mode has different visual treatment —
// different colors, different text, different sub-components visible.
// Includes a simulated elapsed timer, token counter, and task list
// that conditionally renders based on mode and verbosity.
//
// Patterns tested:
// - 6-mode conditional rendering (each mode = different JSX subtree)
// - Timer-derived state: elapsed time changes stall detection color
// - Nested conditional: stall mode has 3 severity levels based on elapsed
// - Task list with per-task status dots rendered inside spinner
// - Verbose mode shows token counts, model name, effort level
// - Template literals with computed values (formatDuration, token counts)
// - Mode transition handlers that reset/update multiple state vars

const [mode, setMode] = useState(0);
const [elapsed, setElapsed] = useState(0);
const [tokens, setTokens] = useState(0);
const [taskCount, setTaskCount] = useState(0);
const [tasks, setTasks] = useState([{ name: '', status: 0 }]);
const [verbose, setVerbose] = useState(0);
const [modelName, setModelName] = useState('');
const [effort, setEffort] = useState(0);
const [stallLevel, setStallLevel] = useState(0);
const [spinnerFrame, setSpinnerFrame] = useState(0);
const [verb, setVerb] = useState('');

<script>
var spinnerChars = ['⠋', '⠙', '⠹', '⠸', '⠼', '⠴', '⠦', '⠧', '⠇', '⠏'];
var modeNames = ['idle', 'thinking', 'searching', 'writing', 'stalled', 'error'];
var modeVerbs = ['Waiting', 'Thinking', 'Searching', 'Writing', 'Processing', 'Error'];
var modeColors = ['#475569', '#a855f7', '#3b82f6', '#22c55e', '#f59e0b', '#ef4444'];

setModelName('claude-opus-4-6');
setVerb(modeVerbs[0]);

var taskList = [
  { name: 'Read auth module', status: 2 },
  { name: 'Search for token usage', status: 2 },
  { name: 'Edit middleware', status: 1 },
  { name: 'Run tests', status: 0 },
  { name: 'Update docs', status: 0 }
];
setTasks(taskList);
setTaskCount(taskList.length);

function switchMode(m) {
  setMode(m);
  setVerb(modeVerbs[m]);
  setElapsed(0);
  setStallLevel(0);
  if (m === 5) {
    setTokens(0);
  }
}

function advanceTime() {
  var newElapsed = elapsed + 1;
  setElapsed(newElapsed);
  setTokens(tokens + 47);
  setSpinnerFrame((spinnerFrame + 1) % 10);

  // Stall detection
  if (mode === 1 || mode === 2 || mode === 3) {
    if (newElapsed > 30) {
      setStallLevel(2);
    } else if (newElapsed > 15) {
      setStallLevel(1);
    } else {
      setStallLevel(0);
    }
  }
}

function advanceTask() {
  for (var i = 0; i < taskList.length; i++) {
    if (taskList[i].status === 1) {
      taskList[i].status = 2;
      if (i + 1 < taskList.length) {
        taskList[i + 1].status = 1;
      }
      setTasks(taskList);
      return;
    }
  }
  // If no in-progress task, start first pending
  for (var j = 0; j < taskList.length; j++) {
    if (taskList[j].status === 0) {
      taskList[j].status = 1;
      setTasks(taskList);
      return;
    }
  }
}

function setEffortLevel(e) {
  setEffort(e);
}
</script>

function SpinnerDot(m) {
  return (
    <Text fontSize={12} color={m == 0 ? "#475569" : m == 1 ? "#a855f7" : m == 2 ? "#3b82f6" : m == 3 ? "#22c55e" : m == 4 ? "#f59e0b" : "#ef4444"}>{spinnerChars[spinnerFrame]}</Text>
  );
}

function TaskRow(t) {
  return (
    <Box style={{ flexDirection: "row", gap: 6, alignItems: "center", paddingLeft: 16 }}>
      <Box style={{ width: 6, height: 6, borderRadius: 3, backgroundColor: t.status == 0 ? "#334155" : t.status == 1 ? "#3b82f6" : "#22c55e" }} />
      <Text fontSize={8} color={t.status == 2 ? "#475569" : t.status == 1 ? "#e2e8f0" : "#64748b"}>{t.name}</Text>
      {t.status == 1 && <Text fontSize={7} color="#3b82f6">in progress</Text>}
      {t.status == 2 && <Text fontSize={7} color="#22c55e">done</Text>}
    </Box>
  );
}

function App() {
  return (
    <Box style={{ backgroundColor: "#0f172a", padding: 16, width: "100%", height: "100%", flexDirection: "column", gap: 12 }}>
      <Text fontSize={16} color="#e2e8f0">Spinner Modes</Text>

      <Box style={{ flexDirection: "row", gap: 4 }}>
        <Pressable onPress={() => { switchMode(0) }} style={{ padding: 4, backgroundColor: mode == 0 ? "#475569" : "#1e293b", borderRadius: 4 }}>
          <Text fontSize={8} color="#e2e8f0">Idle</Text>
        </Pressable>
        <Pressable onPress={() => { switchMode(1) }} style={{ padding: 4, backgroundColor: mode == 1 ? "#7c3aed" : "#1e293b", borderRadius: 4 }}>
          <Text fontSize={8} color="#e2e8f0">Think</Text>
        </Pressable>
        <Pressable onPress={() => { switchMode(2) }} style={{ padding: 4, backgroundColor: mode == 2 ? "#1e40af" : "#1e293b", borderRadius: 4 }}>
          <Text fontSize={8} color="#e2e8f0">Search</Text>
        </Pressable>
        <Pressable onPress={() => { switchMode(3) }} style={{ padding: 4, backgroundColor: mode == 3 ? "#166534" : "#1e293b", borderRadius: 4 }}>
          <Text fontSize={8} color="#e2e8f0">Write</Text>
        </Pressable>
        <Pressable onPress={() => { switchMode(4) }} style={{ padding: 4, backgroundColor: mode == 4 ? "#92400e" : "#1e293b", borderRadius: 4 }}>
          <Text fontSize={8} color="#e2e8f0">Stall</Text>
        </Pressable>
        <Pressable onPress={() => { switchMode(5) }} style={{ padding: 4, backgroundColor: mode == 5 ? "#dc2626" : "#1e293b", borderRadius: 4 }}>
          <Text fontSize={8} color="#e2e8f0">Error</Text>
        </Pressable>
      </Box>

      <Box style={{ padding: 12, backgroundColor: "#1e293b", borderRadius: 8, gap: 8 }}>
        <Box style={{ flexDirection: "row", gap: 8, alignItems: "center" }}>
          {mode !== 0 && mode !== 5 && <SpinnerDot m={mode} />}
          {mode == 5 && <Text fontSize={12} color="#ef4444">✕</Text>}
          <Text fontSize={12} color={stallLevel == 2 ? "#ef4444" : stallLevel == 1 ? "#f59e0b" : mode == 0 ? "#475569" : mode == 1 ? "#a855f7" : mode == 2 ? "#3b82f6" : mode == 3 ? "#22c55e" : mode == 4 ? "#f59e0b" : "#ef4444"}>{verb}</Text>
          {elapsed > 0 && <Text fontSize={9} color="#475569">{`${elapsed}s`}</Text>}
        </Box>

        {stallLevel == 1 && <Text fontSize={8} color="#f59e0b">Taking longer than expected...</Text>}
        {stallLevel == 2 && <Text fontSize={8} color="#ef4444">This is taking unusually long. Consider cancelling.</Text>}

        {mode == 5 && <Box style={{ padding: 6, backgroundColor: "#450a0a", borderRadius: 4 }}>
          <Text fontSize={9} color="#fca5a5">Connection error. Check your API key and network.</Text>
        </Box>}

        {verbose == 1 && mode !== 0 && <Box style={{ flexDirection: "row", gap: 12 }}>
          <Text fontSize={8} color="#475569">{`${tokens} tokens`}</Text>
          <Text fontSize={8} color="#475569">{modelName}</Text>
          <Text fontSize={8} color="#475569">{effort == 0 ? "auto" : effort == 1 ? "low" : effort == 2 ? "medium" : "high"}</Text>
        </Box>}

        {(mode == 1 || mode == 2 || mode == 3) && <Box style={{ gap: 3 }}>
          {tasks.map((t, ti) => (
            <TaskRow t={t} />
          ))}
        </Box>}
      </Box>

      <Box style={{ flexDirection: "row", gap: 6 }}>
        <Pressable onPress={() => { advanceTime() }} style={{ padding: 4, backgroundColor: "#334155", borderRadius: 4 }}>
          <Text fontSize={8} color="#94a3b8">+1s</Text>
        </Pressable>
        <Pressable onPress={() => { advanceTask() }} style={{ padding: 4, backgroundColor: "#334155", borderRadius: 4 }}>
          <Text fontSize={8} color="#94a3b8">Advance Task</Text>
        </Pressable>
        <Pressable onPress={() => { setVerbose(verbose == 0 ? 1 : 0) }} style={{ padding: 4, backgroundColor: verbose == 1 ? "#7c3aed" : "#334155", borderRadius: 4 }}>
          <Text fontSize={8} color="#ffffff">{verbose == 1 ? "Verbose" : "Normal"}</Text>
        </Pressable>
        <Pressable onPress={() => { setEffortLevel((effort + 1) % 4) }} style={{ padding: 4, backgroundColor: "#334155", borderRadius: 4 }}>
          <Text fontSize={8} color="#94a3b8">{effort == 0 ? "auto" : effort == 1 ? "low" : effort == 2 ? "med" : "high"}</Text>
        </Pressable>
      </Box>

      <Box style={{ flexDirection: "row", gap: 8, padding: 8, backgroundColor: "#1e293b", borderRadius: 6 }}>
        <Box style={{ flexDirection: "row", gap: 4, alignItems: "center" }}>
          <Text fontSize={8} color="#475569">Effort:</Text>
          <Box style={{ width: 40, height: 4, backgroundColor: "#0f172a", borderRadius: 2 }}>
            <Box style={{ height: 4, borderRadius: 2, backgroundColor: effort == 0 ? "#475569" : effort == 1 ? "#22c55e" : effort == 2 ? "#f59e0b" : "#ef4444", width: effort == 0 ? 10 : effort == 1 ? 15 : effort == 2 ? 28 : 40 }} />
          </Box>
        </Box>
        <Text fontSize={8} color="#475569">{`frame: ${spinnerFrame}`}</Text>
        <Text fontSize={8} color="#475569">{`stall: ${stallLevel}`}</Text>
      </Box>
    </Box>
  );
}
