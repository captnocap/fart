// CONFORMANCE TEST 132: Plugin Marketplace Browser
//
// Ported from: Claude Code BrowseMarketplace.tsx + ManagePlugins.tsx + DiscoverPlugins.tsx
//
// A plugin/extension marketplace with search, categories, install/uninstall
// state per plugin, version display, star ratings, and detail expansion.
// Search filters across name + description + author simultaneously.
//
// Patterns tested:
// - Search/filter: input string matched against multiple fields per item
// - Per-item install state: independent installed/not-installed/updating toggle
// - Category tabs filtering the displayed list
// - Sort modes: by name, by stars, by downloads
// - Detail expansion: clicking a plugin shows full description + changelog
// - Computed derived state: installed count, filtered count, category counts
// - String.indexOf for substring matching in script
// - Multi-field sort comparison function
// - Template literal with 4+ interpolations in stats display

const [plugins, setPlugins] = useState([{ name: '', desc: '', author: '', category: 0, stars: 0, downloads: 0, version: '', installed: 0, updating: 0 }]);
const [searchQuery, setSearchQuery] = useState('');
const [activeCategory, setActiveCategory] = useState(0);
const [sortMode, setSortMode] = useState(0);
const [expandedPlugin, setExpandedPlugin] = useState(0);
const [installedCount, setInstalledCount] = useState(0);
const [filteredCount, setFilteredCount] = useState(0);
const [lastAction, setLastAction] = useState('');

<script>
var cats = ['All', 'Tools', 'Themes', 'Languages', 'AI', 'Testing'];

var plist = [
  { name: 'ESLint Pro',        desc: 'Advanced linting with auto-fix and custom rules', author: 'lint-team', category: 1, stars: 4850, downloads: 128000, version: '3.2.1', installed: 1, updating: 0 },
  { name: 'Dracula Theme',     desc: 'Dark theme inspired by Dracula', author: 'dracula-org', category: 2, stars: 12400, downloads: 890000, version: '2.0.0', installed: 0, updating: 0 },
  { name: 'Python Tools',      desc: 'Python language server, debugger, and formatter', author: 'py-tools', category: 3, stars: 8200, downloads: 456000, version: '5.1.0', installed: 1, updating: 0 },
  { name: 'Copilot Bridge',    desc: 'AI code completion and chat integration', author: 'ai-labs', category: 4, stars: 15600, downloads: 1200000, version: '1.8.3', installed: 0, updating: 0 },
  { name: 'Jest Runner',       desc: 'Run and debug Jest tests inline', author: 'test-utils', category: 5, stars: 3200, downloads: 98000, version: '4.0.2', installed: 0, updating: 0 },
  { name: 'Git Graph',         desc: 'Visualize git history as an interactive graph', author: 'git-viz', category: 1, stars: 7800, downloads: 345000, version: '2.4.0', installed: 1, updating: 0 },
  { name: 'One Dark Pro',      desc: 'Atom One Dark theme for editors', author: 'theme-lab', category: 2, stars: 9100, downloads: 670000, version: '3.1.0', installed: 0, updating: 0 },
  { name: 'Rust Analyzer',     desc: 'Rust language server with completion and diagnostics', author: 'rust-team', category: 3, stars: 11200, downloads: 520000, version: '0.4.1', installed: 0, updating: 0 },
  { name: 'Claude AI',         desc: 'Claude integration for code review and generation', author: 'anthropic', category: 4, stars: 18900, downloads: 2100000, version: '2.1.88', installed: 1, updating: 0 },
  { name: 'Playwright Test',   desc: 'E2E testing with Playwright browser automation', author: 'ms-test', category: 5, stars: 5400, downloads: 210000, version: '1.42.0', installed: 0, updating: 0 },
  { name: 'Docker Tools',      desc: 'Dockerfile syntax, compose support, container management', author: 'docker-inc', category: 1, stars: 6700, downloads: 410000, version: '1.28.0', installed: 0, updating: 0 },
  { name: 'Catppuccin',        desc: 'Soothing pastel theme for editors', author: 'catppuccin', category: 2, stars: 8900, downloads: 540000, version: '3.0.0', installed: 0, updating: 0 }
];
setPlugins(plist);

function recount() {
  var ic = 0;
  for (var i = 0; i < plist.length; i++) {
    if (plist[i].installed === 1) ic++;
  }
  setInstalledCount(ic);
}
recount();

function matchesSearch(p) {
  if (searchQuery === '') return 1;
  var q = searchQuery;
  if (p.name.indexOf(q) >= 0) return 1;
  if (p.desc.indexOf(q) >= 0) return 1;
  if (p.author.indexOf(q) >= 0) return 1;
  return 0;
}

function matchesCategory(p) {
  if (activeCategory === 0) return 1;
  if (p.category === activeCategory) return 1;
  return 0;
}

function isVisible(p) {
  if (matchesSearch(p) === 1 && matchesCategory(p) === 1) return 1;
  return 0;
}

function toggleInstall(idx) {
  if (plist[idx].installed === 1) {
    plist[idx].installed = 0;
    setLastAction('Uninstalled ' + plist[idx].name);
  } else {
    plist[idx].installed = 1;
    setLastAction('Installed ' + plist[idx].name + ' v' + plist[idx].version);
  }
  setPlugins(plist);
  recount();
}

function updatePlugin(idx) {
  plist[idx].updating = 1;
  setPlugins(plist);
  setLastAction('Updating ' + plist[idx].name + '...');
}

function formatNumber(n) {
  if (n >= 1000000) return (n / 1000000) + 'M';
  if (n >= 1000) return (n / 1000) + 'K';
  return '' + n;
}

function doSearch(q) {
  setSearchQuery(q);
  var fc = 0;
  for (var i = 0; i < plist.length; i++) {
    if (isVisible(plist[i]) === 1) fc++;
  }
  setFilteredCount(fc);
}
doSearch('');
</script>

function StarRating(stars) {
  return (
    <Box style={{ flexDirection: "row", gap: 2, alignItems: "center" }}>
      <Text fontSize={8} color="#f59e0b">{stars > 10000 ? "★★★★★" : stars > 5000 ? "★★★★" : stars > 2000 ? "★★★" : "★★"}</Text>
      <Text fontSize={7} color="#475569">{formatNumber(stars)}</Text>
    </Box>
  );
}

function PluginCard(p, idx) {
  return (
    <Box>
      {isVisible(p) == 1 && <Pressable onPress={() => { setExpandedPlugin(idx) }} style={{ padding: 10, backgroundColor: expandedPlugin == idx ? "#334155" : "#1e293b", borderRadius: 8, gap: 6 }}>
        <Box style={{ flexDirection: "row", gap: 8, alignItems: "center" }}>
          <Box style={{ width: 32, height: 32, borderRadius: 6, backgroundColor: p.category == 1 ? "#1e40af" : p.category == 2 ? "#7c2d12" : p.category == 3 ? "#065f46" : p.category == 4 ? "#4a1d96" : "#92400e", alignItems: "center", justifyContent: "center" }}>
            <Text fontSize={12} color="#ffffff">{p.category == 1 ? "T" : p.category == 2 ? "C" : p.category == 3 ? "L" : p.category == 4 ? "A" : "Q"}</Text>
          </Box>
          <Box style={{ flexGrow: 1, gap: 2 }}>
            <Box style={{ flexDirection: "row", gap: 6, alignItems: "center" }}>
              <Text fontSize={11} color="#e2e8f0">{p.name}</Text>
              <Text fontSize={7} color="#475569">{`v${p.version}`}</Text>
            </Box>
            <Text fontSize={8} color="#64748b">{p.desc}</Text>
            <Box style={{ flexDirection: "row", gap: 8 }}>
              <Text fontSize={7} color="#475569">{p.author}</Text>
              <StarRating stars={p.stars} />
              <Text fontSize={7} color="#475569">{`${formatNumber(p.downloads)} downloads`}</Text>
            </Box>
          </Box>
          <Pressable onPress={() => { toggleInstall(idx) }} style={{ paddingLeft: 8, paddingRight: 8, paddingTop: 4, paddingBottom: 4, backgroundColor: p.installed == 1 ? "#dc2626" : "#22c55e", borderRadius: 4 }}>
            <Text fontSize={8} color="#ffffff">{p.installed == 1 ? "Remove" : "Install"}</Text>
          </Pressable>
        </Box>

        {expandedPlugin == idx && <Box style={{ padding: 8, backgroundColor: "#0f172a", borderRadius: 4, gap: 4 }}>
          <Text fontSize={9} color="#94a3b8">{p.desc}</Text>
          <Box style={{ flexDirection: "row", gap: 12 }}>
            <Text fontSize={8} color="#475569">{`Author: ${p.author}`}</Text>
            <Text fontSize={8} color="#475569">{`Version: ${p.version}`}</Text>
            <Text fontSize={8} color="#475569">{`Stars: ${p.stars}`}</Text>
            <Text fontSize={8} color="#475569">{`Downloads: ${p.downloads}`}</Text>
          </Box>
          {p.installed == 1 && <Pressable onPress={() => { updatePlugin(idx) }} style={{ padding: 4, backgroundColor: "#1e40af", borderRadius: 4, alignSelf: "flexStart" }}>
            <Text fontSize={8} color="#ffffff">{p.updating == 1 ? "Updating..." : "Check for Update"}</Text>
          </Pressable>}
        </Box>}
      </Pressable>}
    </Box>
  );
}

function App() {
  return (
    <Box style={{ backgroundColor: "#0f172a", padding: 16, width: "100%", height: "100%", flexDirection: "column", gap: 10 }}>
      <Box style={{ flexDirection: "row", justifyContent: "spaceBetween", alignItems: "center" }}>
        <Text fontSize={16} color="#e2e8f0">Marketplace</Text>
        <Text fontSize={9} color="#475569">{`${installedCount} installed · ${filteredCount} shown`}</Text>
      </Box>

      <Box style={{ flexDirection: "row", gap: 4, flexWrap: "wrap" }}>
        <Pressable onPress={() => { setActiveCategory(0); doSearch(searchQuery) }} style={{ padding: 4, backgroundColor: activeCategory == 0 ? "#1e40af" : "#1e293b", borderRadius: 4 }}>
          <Text fontSize={8} color="#e2e8f0">All</Text>
        </Pressable>
        <Pressable onPress={() => { setActiveCategory(1); doSearch(searchQuery) }} style={{ padding: 4, backgroundColor: activeCategory == 1 ? "#1e40af" : "#1e293b", borderRadius: 4 }}>
          <Text fontSize={8} color="#e2e8f0">Tools</Text>
        </Pressable>
        <Pressable onPress={() => { setActiveCategory(2); doSearch(searchQuery) }} style={{ padding: 4, backgroundColor: activeCategory == 2 ? "#1e40af" : "#1e293b", borderRadius: 4 }}>
          <Text fontSize={8} color="#e2e8f0">Themes</Text>
        </Pressable>
        <Pressable onPress={() => { setActiveCategory(3); doSearch(searchQuery) }} style={{ padding: 4, backgroundColor: activeCategory == 3 ? "#1e40af" : "#1e293b", borderRadius: 4 }}>
          <Text fontSize={8} color="#e2e8f0">Languages</Text>
        </Pressable>
        <Pressable onPress={() => { setActiveCategory(4); doSearch(searchQuery) }} style={{ padding: 4, backgroundColor: activeCategory == 4 ? "#1e40af" : "#1e293b", borderRadius: 4 }}>
          <Text fontSize={8} color="#e2e8f0">AI</Text>
        </Pressable>
        <Pressable onPress={() => { setActiveCategory(5); doSearch(searchQuery) }} style={{ padding: 4, backgroundColor: activeCategory == 5 ? "#1e40af" : "#1e293b", borderRadius: 4 }}>
          <Text fontSize={8} color="#e2e8f0">Testing</Text>
        </Pressable>
      </Box>

      <ScrollView style={{ flexGrow: 1, gap: 4 }}>
        {plugins.map((p, pi) => (
          <PluginCard p={p} idx={pi} />
        ))}
      </ScrollView>

      <Text fontSize={8} color="#475569">{lastAction}</Text>
    </Box>
  );
}
