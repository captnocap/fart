// CONFORMANCE TEST 157: Component prop expressions should evaluate, not literalize
// Pattern from cursor-ide SettingsPanel PanelHeader props:
//   title={selected.name + ' Routing'}
//   meta={selected.summary}
//   trailing={providers.length + ' providers'}

const [providers, setProviders] = useState([
  { name: 'Anthropic', summary: 'Policy aware provider surface' },
  { name: 'OpenAI', summary: 'Tool heavy provider surface' },
]);
const [activeIndex, setActiveIndex] = useState(0);

function Header(props) {
  return (
    <Box style={{ padding: 12, borderRadius: 10, borderWidth: 1, borderColor: "#374151", backgroundColor: "#111827", gap: 6 }}>
      <Text fontSize={13} color="#f9fafb">{props.title}</Text>
      <Text fontSize={10} color="#94a3b8">{props.meta}</Text>
      <Text fontSize={10} color="#60a5fa">{props.trailing}</Text>
    </Box>
  );
}

function App() {
  var selected = providers[activeIndex];

  return (
    <Box style={{ width: "100%", height: "100%", backgroundColor: "#020617", padding: 20, gap: 12 }}>
      <Text fontSize={16} color="#f8fafc">Component Prop Expressions</Text>
      <Text fontSize={10} color="#94a3b8">Computed props should arrive at child components as values, not source text.</Text>

      <Header title={selected.name + ' Routing'} meta={selected.summary} trailing={providers.length + ' providers'} />

      <Box style={{ flexDirection: "row", gap: 8 }}>
        <Pressable onPress={() => { setActiveIndex(0) }} style={{ padding: 10, borderRadius: 8, backgroundColor: activeIndex == 0 ? "#1d4ed8" : "#334155" }}>
          <Text fontSize={11} color="#ffffff">Anthropic</Text>
        </Pressable>
        <Pressable onPress={() => { setActiveIndex(1) }} style={{ padding: 10, borderRadius: 8, backgroundColor: activeIndex == 1 ? "#1d4ed8" : "#334155" }}>
          <Text fontSize={11} color="#ffffff">OpenAI</Text>
        </Pressable>
      </Box>
    </Box>
  );
}
