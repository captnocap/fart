// CONFORMANCE TEST 158: Top-level var object arrays through component props with nested maps
// Pattern from cursor-ide SettingsPanel provider data: a top-level var array of provider objects
// with nested capability arrays passed into a child component that selects and maps them.

var providerRows = [
  {
    id: 'anthropic',
    name: 'Anthropic',
    summary: 'Policy aware provider surface',
    capabilities: ['stream text', 'tool use', 'background agent spawn'],
  },
  {
    id: 'openai',
    name: 'OpenAI',
    summary: 'Tool heavy provider surface',
    capabilities: ['tool calling', 'vision', 'formatting assistant'],
  },
];

const [selectedProviderId, setSelectedProviderId] = useState('anthropic');

function ProviderDetails(props) {
  var selected = props.providers[0];
  for (var pi = 0; pi < props.providers.length; pi++) {
    if (props.providers[pi].id == props.selectedProviderId) selected = props.providers[pi];
  }

  return (
    <Box style={{ padding: 12, borderRadius: 10, borderWidth: 1, borderColor: "#374151", backgroundColor: "#111827", gap: 8 }}>
      <Text fontSize={13} color="#f9fafb">{selected.name}</Text>
      <Text fontSize={10} color="#94a3b8">{selected.summary}</Text>
      <Box style={{ flexDirection: "row", gap: 6, flexWrap: "wrap" }}>
        {selected.capabilities.map(function(capability, idx) {
          return (
            <Box key={idx} style={{ paddingLeft: 8, paddingRight: 8, paddingTop: 5, paddingBottom: 5, borderRadius: 999, borderWidth: 1, borderColor: "#4b5563", backgroundColor: "#0f172a" }}>
              <Text fontSize={10} color="#e5e7eb">{capability}</Text>
            </Box>
          );
        })}
      </Box>
    </Box>
  );
}

function App() {
  return (
    <Box style={{ width: "100%", height: "100%", backgroundColor: "#030712", padding: 20, gap: 12 }}>
      <Text fontSize={16} color="#f9fafb">Top-level Var Nested Props</Text>
      <Text fontSize={10} color="#94a3b8">Child components should be able to select from top-level var rows and map nested arrays.</Text>

      <Box style={{ flexDirection: "row", gap: 8 }}>
        <Pressable onPress={() => { setSelectedProviderId('anthropic') }} style={{ padding: 10, borderRadius: 8, backgroundColor: selectedProviderId == 'anthropic' ? "#1d4ed8" : "#334155" }}>
          <Text fontSize={11} color="#ffffff">Select Anthropic</Text>
        </Pressable>
        <Pressable onPress={() => { setSelectedProviderId('openai') }} style={{ padding: 10, borderRadius: 8, backgroundColor: selectedProviderId == 'openai' ? "#1d4ed8" : "#334155" }}>
          <Text fontSize={11} color="#ffffff">Select OpenAI</Text>
        </Pressable>
      </Box>

      <ProviderDetails providers={providerRows} selectedProviderId={selectedProviderId} />
    </Box>
  );
}
