var list = [
  { name: 'README.md', size: 12, starred: 1 },
  { name: 'package.json', size: 3, starred: 0 },
  { name: 'index.tsx', size: 48, starred: 0 },
  { name: 'styles.css', size: 22, starred: 1 },
  { name: 'config.yaml', size: 8, starred: 0 }
];
setFiles(list);

function toggleStar(idx) {
  var f = files[idx];
  f.starred = f.starred === 1 ? 0 : 1;
  setFiles(files);
  setLastAction((f.starred === 1 ? 'star ' : 'unstar ') + f.name);
}
