  { name: 'Blog Writer', desc: 'Writes and edits blog posts and articles', category: 'writing', icon: 'BW', uses: 2100, prompt: 'You are an experienced content writer...', model: 'GPT-4o', temp: 0.7 },
  { name: 'Data Analyst', desc: 'Analyzes CSV, JSON, and database exports', category: 'dev', icon: 'DA', uses: 670, prompt: 'You are a data analysis expert...', model: 'Claude 3.5 Sonnet', temp: 0.1 },
