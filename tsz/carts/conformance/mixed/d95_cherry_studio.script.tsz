// ConversationService
// ──────────────────────────────────────────────────────
var allConvos = [
  { title: 'Code review: auth module', model: 'GPT-4o', lastMsg: 'Here is the refactored version...', time: '2m', unread: 2, msgCount: 14, tokens: 4200, pinned: 1 },
  { title: 'Blog draft: TS patterns', model: 'Claude 3.5 Sonnet', lastMsg: 'I have revised the intro...', time: '1h', unread: 0, msgCount: 8, tokens: 3100, pinned: 0 },
  { title: 'Debug: useEffect loop', model: 'GPT-4', lastMsg: 'The dependency array is...', time: '3h', unread: 1, msgCount: 22, tokens: 6800, pinned: 0 },
  { title: 'Translate: docs to JP', model: 'Gemini Pro', lastMsg: 'Here is the Japanese...', time: '1d', unread: 0, msgCount: 6, tokens: 2400, pinned: 0 },
  { title: 'Data: Q2 analysis', model: 'Claude 3.5 Sonnet', lastMsg: 'The CSV has 12K rows...', time: '2d', unread: 0, msgCount: 10, tokens: 8900, pinned: 1 },
  { title: 'API: REST design', model: 'GPT-4o', lastMsg: 'REST vs GraphQL depends on...', time: '3d', unread: 3, msgCount: 18, tokens: 5600, pinned: 0 }
];
setConversations(allConvos);
setConvoCount(allConvos.length);

var ur = 0;
for (var ci = 0; ci < allConvos.length; ci++) ur += allConvos[ci].unread;
setTotalUnread(ur);

function switchConvo(idx) {
  setActiveConvo(idx);
  allConvos[idx].unread = 0;
  setConversations(allConvos);
  recalcUnread();
  act('convo: ' + allConvos[idx].title);
}

function recalcUnread() {
  ur = 0;
  for (var i = 0; i < allConvos.length; i++) ur += allConvos[i].unread;
  setTotalUnread(ur);
}

function createConvo(title, model) {
  allConvos.push({ title: title, model: model, lastMsg: '', time: 'now', unread: 0, msgCount: 0, tokens: 0, pinned: 0 });
  setConversations(allConvos);
  setConvoCount(allConvos.length);
  setActiveConvo(allConvos.length - 1);
  act('new convo: ' + title);
}

function deleteConvo(idx) {
  var result = [];
  for (var i = 0; i < allConvos.length; i++) {
    if (i !== idx) result.push(allConvos[i]);
  }
  allConvos = result;
  setConversations(allConvos);
  setConvoCount(allConvos.length);
  if (activeConvo >= allConvos.length) setActiveConvo(0);
  recalcUnread();
  act('deleted convo');
}

function togglePin(idx) {
  allConvos[idx].pinned = allConvos[idx].pinned === 1 ? 0 : 1;
  setConversations(allConvos);
  act('pin toggle: ' + allConvos[idx].title);
}

function getTotalTokens() {
  var total = 0;
  for (var i = 0; i < allConvos.length; i++) total += allConvos[i].tokens;
  return total;
}

// ──────────────────────────────────────────────────────
// MessagesService
// ──────────────────────────────────────────────────────
var allMsgs = [
  { role: 0, content: 'Can you review this React component for performance issues?', model: '', time: '10:01', tokens: 12 },
  { role: 1, content: 'I see several potential improvements. First, the useEffect has missing dependencies. Second, the map creates new arrays on every render. Third, inline style objects create new refs.', model: 'GPT-4o', time: '10:01', tokens: 48 },
  { role: 0, content: 'What about the state management?', model: '', time: '10:03', tokens: 8 },
  { role: 1, content: 'For this component, useState is fine. The state is local and updates are simple. For shared state or complex logic, consider useReducer or Zustand.', model: 'GPT-4o', time: '10:03', tokens: 36 },
  { role: 0, content: 'Show me the optimized version', model: '', time: '10:05', tokens: 6 },
  { role: 1, content: 'Here is the refactored version with memoization, proper dep arrays, and extracted style constants.', model: 'GPT-4o', time: '10:06', tokens: 42 }
];
setMessages(allMsgs);
setMsgCount(allMsgs.length);

function sendMessage(text) {
  allMsgs.push({ role: 0, content: text, model: '', time: 'now', tokens: Math.floor(text.length / 4) });

  // Simulate AI response
  var activeModelName = allModels[activeModel].name;
  var response = 'Response from ' + activeModelName + ': ';
  if (text.indexOf('code') >= 0 || text.indexOf('bug') >= 0) {
    response = response + 'Let me analyze the code. I see a few issues...';
  } else if (text.indexOf('explain') >= 0 || text.indexOf('what') >= 0) {
    response = response + 'Great question. Here is the explanation...';
  } else {
    response = response + 'I understand. Let me help with that...';
  }

  allMsgs.push({ role: 1, content: response, model: activeModelName, time: 'now', tokens: Math.floor(response.length / 4) });
  setMessages(allMsgs);
  setMsgCount(allMsgs.length);

  // Update conversation metadata
  if (activeConvo < allConvos.length) {
    allConvos[activeConvo].lastMsg = response.slice(0, 40) + '...';
    allConvos[activeConvo].time = 'now';
    allConvos[activeConvo].msgCount += 2;
    allConvos[activeConvo].tokens += Math.floor(text.length / 4) + Math.floor(response.length / 4);
    setConversations(allConvos);
  }
  act('sent: ' + text.slice(0, 20));
}

function deleteMessage(idx) {
  var result = [];
  for (var i = 0; i < allMsgs.length; i++) {
    if (i !== idx) result.push(allMsgs[i]);
  }
  allMsgs = result;
  setMessages(allMsgs);
  setMsgCount(allMsgs.length);
  act('deleted message');
}

function getMessageTokenCount() {
  var total = 0;
  for (var i = 0; i < allMsgs.length; i++) total += allMsgs[i].tokens;
  return total;
}

