  { name: 'Email Drafter', desc: 'Composes professional emails', category: 'writing', icon: 'EM', uses: 1800, prompt: 'You draft professional emails...', model: 'GPT-3.5', temp: 0.5 },
  { name: 'Debugger', desc: 'Helps find and fix code bugs', category: 'dev', icon: 'DB', uses: 950, prompt: 'You are a debugging expert...', model: 'GPT-4o', temp: 0.2 },
  { name: 'UX Writer', desc: 'Writes UI copy, tooltips, error messages', category: 'writing', icon: 'UX', uses: 420, prompt: 'You write clear UI copy...', model: 'Claude 3.5 Sonnet', temp: 0.4 },
  { name: 'API Designer', desc: 'Designs RESTful and GraphQL APIs', category: 'dev', icon: 'AP', uses: 380, prompt: 'You design clean APIs...', model: 'GPT-4', temp: 0.3 },
  { name: 'Math Tutor', desc: 'Explains math concepts step by step', category: 'edu', icon: 'MT', uses: 1100, prompt: 'You teach math clearly...', model: 'GPT-4o', temp: 0.2 },
  { name: 'Study Guide', desc: 'Creates flashcards and study materials', category: 'edu', icon: 'SG', uses: 780, prompt: 'You create study materials...', model: 'Claude 3 Haiku', temp: 0.4 }
];
setAssistants(allAssistants);

function searchAssistants(query) {
  if (query === '') {
    setAssistants(allAssistants);
    setAssistantCount(allAssistants.length);
    return;
  }
  var lower = query.toLowerCase !== undefined ? query.toLowerCase() : query;
  var result = [];
  for (var i = 0; i < allAssistants.length; i++) {
    var nameLower = allAssistants[i].name.toLowerCase !== undefined ? allAssistants[i].name.toLowerCase() : allAssistants[i].name;
    var descLower = allAssistants[i].desc.toLowerCase !== undefined ? allAssistants[i].desc.toLowerCase() : allAssistants[i].desc;
    if (nameLower.indexOf(lower) >= 0 || descLower.indexOf(lower) >= 0) {
      result.push(allAssistants[i]);
    }
  }
  setAssistants(result);
  setAssistantCount(result.length);
  act('search assistants: ' + query + ' (' + result.length + ')');
}

function filterAssistantsByCategory(cat) {
  setAssistantFilter(cat);
  if (cat === '') {
    setAssistants(allAssistants);
    setAssistantCount(allAssistants.length);
  } else {
    var result = [];
    for (var i = 0; i < allAssistants.length; i++) {
      if (allAssistants[i].category === cat) result.push(allAssistants[i]);
    }
    setAssistants(result);
    setAssistantCount(result.length);
  }
  act('filter: ' + (cat === '' ? 'all' : cat));
}

function useAssistant(name) {
  for (var i = 0; i < allAssistants.length; i++) {
    if (allAssistants[i].name === name) {
      allAssistants[i].uses++;
      setAssistants(allAssistants);
      setActiveAssistant(name);
      act('using assistant: ' + name);
      return;
    }
  }
}

function getTopAssistants(n) {
  var sorted = allAssistants.slice();
  for (var i = 0; i < sorted.length; i++) {
    for (var j = i + 1; j < sorted.length; j++) {
      if (sorted[j].uses > sorted[i].uses) {
        var tmp = sorted[i]; sorted[i] = sorted[j]; sorted[j] = tmp;
      }
    }
  }
  var result = [];
  for (var k = 0; k < n && k < sorted.length; k++) {
    result.push(sorted[k]);
  }
  return result;
}

