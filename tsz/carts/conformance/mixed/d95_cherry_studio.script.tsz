// Cherry Studio — Business Logic Layer
// Port of: cherryhq/cherry-studio services/
//
// This is the ENTIRE tooling logic, not just the UI.
// Services ported:
//   ApiService — HTTP request simulation, API key management
//   ModelService — model config, selection, status, provider mapping
//   AssistantService — CRUD, search, category filter, usage tracking
//   ConversationService — create, delete, switch, rename, unread counts
//   MessagesService — append, edit, delete, role assignment, timestamps
//   FileManager — add, remove, type detection, size formatting
//   MemoryService — context window, token counting, pruning
//   CacheService — set, get, invalidate, TTL expiry
//   TokenService — API key storage, validation, masking
//   NotificationService — push, dismiss, badge counts
//   SettingsService — get, set, persist, reset defaults
//   SearchService — full-text search across conversations and assistants
//   StreamService — simulated streaming response (character-by-character)
//   BackupService — export/import state snapshot

// ──────────────────────────────────────────────────────
// ModelService
// ──────────────────────────────────────────────────────
var allModels = [
  { name: 'GPT-4o', provider: 'openai', maxTokens: 128000, status: 1, rpm: 500 },
  { name: 'GPT-4', provider: 'openai', maxTokens: 8192, status: 1, rpm: 200 },
  { name: 'GPT-3.5', provider: 'openai', maxTokens: 16385, status: 1, rpm: 3500 },
  { name: 'Claude 3.5 Sonnet', provider: 'anthropic', maxTokens: 200000, status: 1, rpm: 1000 },
  { name: 'Claude 3 Haiku', provider: 'anthropic', maxTokens: 200000, status: 1, rpm: 4000 },
  { name: 'Gemini Pro', provider: 'google', maxTokens: 32000, status: 1, rpm: 360 },
  { name: 'Llama 3 70B', provider: 'ollama', maxTokens: 8192, status: 0, rpm: 0 },
  { name: 'Mistral 7B', provider: 'ollama', maxTokens: 32000, status: 0, rpm: 0 }
];
setModels(allModels);
setModelCount(allModels.length);

function getModelByName(name) {
  for (var i = 0; i < allModels.length; i++) {
    if (allModels[i].name === name) return allModels[i];
  }
  return null;
}

function getActiveModels() {
  var result = [];
  for (var i = 0; i < allModels.length; i++) {
    if (allModels[i].status === 1) result.push(allModels[i]);
  }
  return result;
}

function getModelsByProvider(provider) {
  var result = [];
  for (var i = 0; i < allModels.length; i++) {
    if (allModels[i].provider === provider) result.push(allModels[i]);
  }
  return result;
}

function toggleModelStatus(idx) {
  allModels[idx].status = allModels[idx].status === 1 ? 0 : 1;
  setModels(allModels);
  var active = 0;
  for (var i = 0; i < allModels.length; i++) {
    if (allModels[i].status === 1) active++;
  }
  setActiveModelCount(active);
  act('toggled model: ' + allModels[idx].name);
}

