// FileManager
// ──────────────────────────────────────────────────────
var allFiles = [
  { name: 'project-spec.md', type: 'md', size: 12400, modified: 'Today' },
  { name: 'api-response.json', type: 'json', size: 89200, modified: 'Today' },
  { name: 'screenshot.png', type: 'img', size: 245000, modified: 'Yesterday' },
  { name: 'report-q2.pdf', type: 'pdf', size: 1200000, modified: '3 days ago' },
  { name: 'data-export.csv', type: 'csv', size: 5400000, modified: 'Last week' },
  { name: 'design-system.figma', type: 'other', size: 34000000, modified: 'Last week' },
  { name: 'meeting-notes.md', type: 'md', size: 4200, modified: '2 weeks ago' }
];
setFiles(allFiles);
setFileCount(allFiles.length);

function formatFileSize(bytes) {
  if (bytes < 1000) return bytes + 'B';
  if (bytes < 1000000) return Math.floor(bytes / 1000) + 'KB';
  return Math.floor(bytes / 1000000) + 'MB';
}

function getFilesByType(type) {
  var result = [];
  for (var i = 0; i < allFiles.length; i++) {
    if (allFiles[i].type === type) result.push(allFiles[i]);
  }
  return result;
}

function getTotalFileSize() {
  var total = 0;
  for (var i = 0; i < allFiles.length; i++) total += allFiles[i].size;
  return total;
}

function addFile(name, type, size) {
  allFiles.push({ name: name, type: type, size: size, modified: 'Just now' });
  setFiles(allFiles);
  setFileCount(allFiles.length);
  act('added file: ' + name);
}

function removeFile(idx) {
  var removed = allFiles[idx].name;
  var result = [];
  for (var i = 0; i < allFiles.length; i++) {
    if (i !== idx) result.push(allFiles[i]);
  }
  allFiles = result;
  setFiles(allFiles);
  setFileCount(allFiles.length);
  act('removed: ' + removed);
}

// ──────────────────────────────────────────────────────
// CacheService
// ──────────────────────────────────────────────────────
var cache = [];
var cacheHits = 0;
var cacheMisses = 0;

function cacheSet(key, value) {
  // Check if exists, update
  for (var i = 0; i < cache.length; i++) {
    if (cache[i].key === key) {
      cache[i].value = value;
      return;
    }
  }
  cache.push({ key: key, value: value });
}

function cacheGet(key) {
  for (var i = 0; i < cache.length; i++) {
    if (cache[i].key === key) {
      cacheHits++;
      return cache[i].value;
    }
  }
  cacheMisses++;
  return '';
}

function cacheClear() {
  cache = [];
  cacheHits = 0;
  cacheMisses = 0;
}

// ──────────────────────────────────────────────────────
// NotificationService
// ──────────────────────────────────────────────────────
var notifications = [];

function pushNotif(msg, type) {
  notifications.push({ msg: msg, type: type, read: 0 });
  setNotifCount(notifications.length);
  var unreadN = 0;
  for (var i = 0; i < notifications.length; i++) {
    if (notifications[i].read === 0) unreadN++;
  }
  setNotifUnread(unreadN);
}

function dismissNotif(idx) {
  notifications[idx].read = 1;
  var unreadN = 0;
  for (var i = 0; i < notifications.length; i++) {
    if (notifications[i].read === 0) unreadN++;
  }
  setNotifUnread(unreadN);
}

function clearAllNotifs() {
  notifications = [];
  setNotifCount(0);
  setNotifUnread(0);
}

// ──────────────────────────────────────────────────────
// SettingsService
// ──────────────────────────────────────────────────────
var settings = {
  theme: 'dark',
  fontSize: 13,
  sendOnEnter: 1,
  streamMode: 1,
  showTimestamps: 1,
  compactMode: 0,
  language: 'en',
  maxTokens: 4096,
  temperature: 0.7,
  autoSave: 1
};

function getSetting(key) {
  if (key === 'theme') return settings.theme;
  if (key === 'fontSize') return '' + settings.fontSize;
  if (key === 'sendOnEnter') return '' + settings.sendOnEnter;
  if (key === 'streamMode') return '' + settings.streamMode;
  if (key === 'showTimestamps') return '' + settings.showTimestamps;
  if (key === 'compactMode') return '' + settings.compactMode;
  if (key === 'language') return settings.language;
  if (key === 'maxTokens') return '' + settings.maxTokens;
  if (key === 'temperature') return '' + settings.temperature;
  if (key === 'autoSave') return '' + settings.autoSave;
  return '';
}

function setSetting(key, value) {
  if (key === 'theme') { settings.theme = value; setTheme(value === 'dark' ? 0 : 1); }
  if (key === 'fontSize') { settings.fontSize = parseInt(value); setFontSize(parseInt(value)); }
  if (key === 'sendOnEnter') { settings.sendOnEnter = parseInt(value); setSendOnEnter(parseInt(value)); }
  if (key === 'streamMode') { settings.streamMode = parseInt(value); setStreamMode(parseInt(value)); }
  if (key === 'showTimestamps') { settings.showTimestamps = parseInt(value); setShowTimestamps(parseInt(value)); }
  if (key === 'compactMode') { settings.compactMode = parseInt(value); setCompact(parseInt(value)); }
  setDirty(1);
  act('set ' + key + ' = ' + value);
}

function resetSettings() {
  settings.theme = 'dark'; setTheme(0);
  settings.fontSize = 13; setFontSize(13);
  settings.sendOnEnter = 1; setSendOnEnter(1);
  settings.streamMode = 1; setStreamMode(1);
  settings.showTimestamps = 1; setShowTimestamps(1);
  settings.compactMode = 0; setCompact(0);
  settings.language = 'en';
  settings.maxTokens = 4096;
  settings.temperature = 0.7;
  settings.autoSave = 1;
  setDirty(0);
  act('reset all settings');
}

// ──────────────────────────────────────────────────────
// SearchService
// ──────────────────────────────────────────────────────
function searchConversations(query) {
  if (query === '') {
    setConversations(allConvos);
    setConvoCount(allConvos.length);
    return;
  }
  var lower = query.toLowerCase !== undefined ? query.toLowerCase() : query;
  var result = [];
  for (var i = 0; i < allConvos.length; i++) {
    var titleLower = allConvos[i].title.toLowerCase !== undefined ? allConvos[i].title.toLowerCase() : allConvos[i].title;
    if (titleLower.indexOf(lower) >= 0) result.push(allConvos[i]);
  }
  setConversations(result);
  setConvoCount(result.length);
  act('search convos: ' + query);
}

function searchMessages(query) {
  if (query === '') {
    setMessages(allMsgs);
    setMsgCount(allMsgs.length);
    return;
  }
  var lower = query.toLowerCase !== undefined ? query.toLowerCase() : query;
  var result = [];
  for (var i = 0; i < allMsgs.length; i++) {
    var contentLower = allMsgs[i].content.toLowerCase !== undefined ? allMsgs[i].content.toLowerCase() : allMsgs[i].content;
    if (contentLower.indexOf(lower) >= 0) result.push(allMsgs[i]);
  }
  setMessages(result);
  setMsgCount(result.length);
  act('search msgs: ' + query);
}

// ──────────────────────────────────────────────────────
// BackupService
// ──────────────────────────────────────────────────────
function getBackupStats() {
  var totalTokens = getTotalTokens();
  var totalSize = getTotalFileSize();
  var totalMsgTokens = getMessageTokenCount();
  setBackupInfo(allConvos.length + ' convos, ' + allMsgs.length + ' msgs, ' + allFiles.length + ' files, ' + totalTokens + ' total tokens, ' + formatFileSize(totalSize) + ' files');
}

// ──────────────────────────────────────────────────────
// Initialize
// ──────────────────────────────────────────────────────
var active = 0;
for (var mi = 0; mi < allModels.length; mi++) {
  if (allModels[mi].status === 1) active++;
}
setActiveModelCount(active);

pushNotif('Welcome to Cherry Studio', 0);
pushNotif('3 new model updates available', 1);
pushNotif('Backup reminder: last backup 7 days ago', 1);

cacheSet('lastModel', 'GPT-4o');
cacheSet('lastConvo', '0');

getBackupStats();
