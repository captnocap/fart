  ToolBtnLabel: { type: 'Text', fontSize: 10, color: '#c9d1d9' },
  ModalShell: { type: 'Box', style: { position: 'absolute', left: 0, top: 0, right: 0, bottom: 0, alignItems: 'center', justifyContent: 'center' } },
  ModalDimmer: { type: 'Pressable', style: { position: 'absolute', left: 0, top: 0, right: 0, bottom: 0, backgroundColor: '#000000aa' } },
  ModalBackdrop: { type: 'Pressable', style: { position: 'absolute', left: 0, top: 0, right: 0, bottom: 0, backgroundColor: '#000000aa', alignItems: 'center', justifyContent: 'center' } },
  ModalPanel: { type: 'Box', style: { width: 420, maxHeight: 280, backgroundColor: '#161b22', borderRadius: 10, borderWidth: 1, borderColor: '#30363d', padding: 10, flexDirection: 'column', gap: 4 } },
  ModalTitle: { type: 'Text', fontSize: 12, color: '#f0f6fc', bold: true },
  ModalRow: { type: 'Pressable', style: { flexDirection: 'row', alignItems: 'center', justifyContent: 'space-between', paddingLeft: 10, paddingRight: 10, paddingTop: 8, paddingBottom: 8, borderRadius: 6, backgroundColor: '#0d1117' } },
  ModalRowOn: { type: 'Pressable', style: { flexDirection: 'row', alignItems: 'center', justifyContent: 'space-between', paddingLeft: 10, paddingRight: 10, paddingTop: 8, paddingBottom: 8, borderRadius: 6, backgroundColor: '#1c2a3a' } },
  ModalPath: { type: 'Text', fontSize: 11, color: '#c9d1d9' },
