  VaultChipLabel: { type: 'Text', fontSize: 11, color: '#58a6ff', bold: true },
  VaultChipMeta: { type: 'Text', fontSize: 10, color: '#6e7681' },
  BodyRow: { type: 'Box', style: { flexDirection: 'row', flexGrow: 1, flexBasis: 0, overflow: 'hidden' } },
