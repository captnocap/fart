  PinnedRow: { type: 'Pressable', style: { flexDirection: 'row', alignItems: 'center', gap: 8, marginLeft: 8, marginRight: 8, marginBottom: 4, paddingLeft: 8, paddingRight: 8, paddingTop: 6, paddingBottom: 6, borderRadius: 6, backgroundColor: '#161b22' } },
  PinnedLabel: { type: 'Text', fontSize: 11, color: '#c9d1d9' },
