  TabBar: { type: 'Box', style: { flexDirection: 'row', borderBottomWidth: 1, borderColor: '#21262d', backgroundColor: '#010409' } },
  TabRow: { type: 'Pressable', style: { flexDirection: 'row', alignItems: 'center', gap: 8, paddingLeft: 12, paddingRight: 10, paddingTop: 8, paddingBottom: 8, borderRightWidth: 1, borderColor: '#21262d' } },
