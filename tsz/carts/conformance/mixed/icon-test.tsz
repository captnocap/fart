// Icon rendering test — isolated box-path icon centering

function App() {
  return (
    <Box style={{ width: '100%', height: '100%', backgroundColor: '#1a1a2e', flexDirection: 'column', alignItems: 'center', justifyContent: 'center', gap: 20 }}>
      <Text fontSize={14} color="#ffffff">Icon Path Test</Text>

      <Box style={{ flexDirection: 'row', gap: 20, alignItems: 'center' }}>
        <Box style={{ flexDirection: 'column', alignItems: 'center', gap: 4 }}>
          <Box style={{ width: 48, height: 48, backgroundColor: '#333' }} d="M 18 6 L 6 18 M 6 6 L 18 18" stroke="#ff0000" strokeWidth={2} />
          <Text fontSize={10} color="#888">X direct 48</Text>
        </Box>

        <Box style={{ flexDirection: 'column', alignItems: 'center', gap: 4 }}>
          <Box style={{ width: 24, height: 24, backgroundColor: '#333' }} d="M 18 6 L 6 18 M 6 6 L 18 18" stroke="#00ff00" strokeWidth={2} />
          <Text fontSize={10} color="#888">X direct 24</Text>
        </Box>

        <Box style={{ flexDirection: 'column', alignItems: 'center', gap: 4 }}>
          <Box style={{ width: 12, height: 12, backgroundColor: '#333' }} d="M 18 6 L 6 18 M 6 6 L 18 18" stroke="#4488ff" strokeWidth={2} />
          <Text fontSize={10} color="#888">X direct 12</Text>
        </Box>
      </Box>

      <Box style={{ flexDirection: 'row', gap: 20, alignItems: 'center' }}>
        <Box style={{ flexDirection: 'column', alignItems: 'center', gap: 4 }}>
          <Box style={{ width: 24, height: 24, backgroundColor: '#333' }} d="M 9 18 L 15 12 L 9 6" stroke="#ff0000" strokeWidth={2} />
          <Text fontSize={10} color="#888">Chev direct</Text>
        </Box>

        <Box style={{ flexDirection: 'column', alignItems: 'center', gap: 4 }}>
          <Box style={{ width: 24, height: 24, backgroundColor: '#333' }} d="M 12 19 L 20 19 M 4 17 L 10 11 L 4 5" stroke="#00ff00" strokeWidth={2} />
          <Text fontSize={10} color="#888">Term direct</Text>
        </Box>

        <Box style={{ flexDirection: 'column', alignItems: 'center', gap: 4 }}>
          <Box style={{ width: 24, height: 24, backgroundColor: '#333' }}>
            <Box style={{ flexGrow: 1, flexBasis: 0 }} d="M 18 6 L 6 18 M 6 6 L 18 18" stroke="#ffff00" strokeWidth={2} />
          </Box>
          <Text fontSize={10} color="#888">X child flex</Text>
        </Box>
      </Box>

      <Text fontSize={10} color="#555">Top row: path on same Box. Bottom-right: path on flex child.</Text>
    </Box>
  );
}
