// Live Sweatshop cockpit feed.
// Prefer supervisor.db when it is open; fall back to the existing hook session
// JSON files under /run/user/$UID/claude-sessions/reactjit/.

import {
  isOpen as dbIsOpen,
  queryListWorkers,
  queryListSessions,
  queryListMessages,
} from './database.mod';

const FALLBACK_UID = '1000';
const SESSIONS_ROOT_PREFIX = '/run/user/';
const SESSIONS_ROOT_SUFFIX = '/claude-sessions/reactjit';
const DEFAULT_LIMIT = 6;
const HOOK_MODEL = 'claude-code';

function toText(value, fallback) {
  if (value === undefined || value === null) return fallback;
  return String(value);
}

function toInt(value, fallback) {
  if (value === undefined || value === null) return fallback;
  if (typeof value === 'number' && Number.isFinite(value)) return value;
  var parsed = parseInt(String(value), 10);
  if (Number.isNaN(parsed)) return fallback;
  return parsed;
}

function asRows(result) {
  if (!result || result.ok === 0) return [];
  if (result.rows && result.rows.length !== undefined) return result.rows;
  if (result.data && result.data.length !== undefined) return result.data;
  return [];
}

function trimText(value, maxLen) {
  var text = toText(value, '');
  if (text.length <= maxLen) return text;
  return text.substring(0, maxLen - 3) + '...';
}

function resolveUid() {
  if (typeof __getenv === 'function') {
    var uid = toText(__getenv('UID'), '');
    if (uid.length > 0) return uid;
    var alt = toText(__getenv('UID_NUMBER'), '');
    if (alt.length > 0) return alt;
  }
  return FALLBACK_UID;
}

function sessionsRoot() {
  return SESSIONS_ROOT_PREFIX + resolveUid() + SESSIONS_ROOT_SUFFIX;
}

function pad2(value) {
  var n = toInt(value, 0);
  if (n < 10) return '0' + String(n);
  return String(n);
}

function stampFromEpoch(epochSeconds) {
  var raw = toInt(epochSeconds, 0);
  if (raw <= 0) return '';
  var date = new Date(raw * 1000);
  return pad2(date.getHours()) + ':' + pad2(date.getMinutes());
}

function isoFromEpoch(epochSeconds) {
  var raw = toInt(epochSeconds, 0);
  if (raw <= 0) return '';
  return new Date(raw * 1000).toISOString();
}

function stampFromIso(isoText) {
  var text = toText(isoText, '');
  if (text.length === 0) return '';
  var parsed = Date.parse(text);
  if (Number.isNaN(parsed)) return '';
  var date = new Date(parsed);
  return pad2(date.getHours()) + ':' + pad2(date.getMinutes());
}

function lastPathSegment(path) {
  var text = toText(path, '');
  if (text.length === 0) return '';
  var pieces = text.split('/');
  if (pieces.length === 0) return text;
  return pieces[pieces.length - 1];
}

function listHookSessionPaths(limit) {
  if (typeof __exec !== 'function') return [];

  var raw = '';
  try {
    raw = __exec('ls ' + sessionsRoot() + '/*.json 2>/dev/null');
  } catch (err) {
    return [];
  }

  if (!raw || raw.length === 0) return [];

  var lines = raw.split('\n');
  var out = [];
  var i = 0;
  while (i < lines.length && out.length < limit) {
    var line = toText(lines[i], '').trim();
    if (line.length > 0 && line.indexOf('.json') >= 0) out.push(line);
    i = i + 1;
  }
  return out;
}

function readHookRecord(path) {
  if (typeof __fs_readfile !== 'function') return null;

  var raw = '';
  try {
    raw = __fs_readfile(path);
  } catch (err) {
    return null;
  }

  if (!raw || raw.length === 0) return null;

  try {
    var parsed = JSON.parse(raw);
    return {
      sid: toText(parsed.sid, ''),
      short: toText(parsed.short, ''),
      ping: toInt(parsed.ping, 0),
      file: toText(parsed.file, ''),
      tool: toText(parsed.tool, ''),
      status: toText(parsed.status, 'idle'),
      recent: Array.isArray(parsed.recent) ? parsed.recent : [],
    };
  } catch (err) {
    return null;
  }
}

function displayNameFromHook(record, fallback) {
  if (record && record.short) return record.short;
  if (record && record.file) {
    var base = lastPathSegment(record.file);
    if (base.length > 0) return base;
  }
  return fallback;
}

function transcriptFromHook(record) {
  var out = [];
  var recent = record && record.recent ? record.recent : [];
  var start = recent.length > DEFAULT_LIMIT ? recent.length - DEFAULT_LIMIT : 0;
  var i = start;
  while (i < recent.length) {
    var item = recent[i] || {};
    var summary = trimText(item.summary || item.file || '', 160);
    if (summary.length > 0) {
      out.push({
        id: toText(record.sid, 'hook') + '-recent-' + String(i),
        sessionId: toText(record.sid, ''),
        type: 'assistant_output',
        content: summary,
        timestamp: stampFromEpoch(item.time),
      });
    }
    i = i + 1;
  }

  if (out.length === 0) {
    var toolLabel = toText(record.tool, '');
    var fileLabel = toText(record.file, '');
    var text = '';
    if (toolLabel.length > 0) text = toolLabel;
    if (fileLabel.length > 0) {
      if (text.length > 0) text = text + ' · ';
      text = text + fileLabel;
    }
    if (text.length > 0) {
      out.push({
        id: toText(record.sid, 'hook') + '-status',
        sessionId: toText(record.sid, ''),
        type: 'system_message',
        content: text,
        timestamp: stampFromEpoch(record.ping),
      });
    }
  }

  return out;
}

function promptFromHook(record) {
  if (!record || record.status !== 'blocked') return null;
  var tool = toText(record.tool, '');
  return {
    id: toText(record.sid, 'hook') + '-prompt',
    sessionId: toText(record.sid, ''),
    type: 'confirmation',
    message: tool.length > 0 ? ('Awaiting approval for ' + tool) : 'Awaiting operator approval',
    options: ['approve', 'reject'],
    default: 'approve',
    timestamp: stampFromEpoch(record.ping),
  };
}

function sessionStatusFromHook(record) {
  if (!record) return 'stopped';
  if (record.status === 'blocked') return 'waiting_input';
  if (record.status === 'active') return 'running';
  return 'stopped';
}

function modeFromHook(record) {
  if (!record) return 'idle';
  if (record.status === 'blocked') return 'permission';
  if (record.status === 'active' && record.tool.length > 0) return 'tool-use';
  if (record.status === 'active') return 'streaming';
  return 'idle';
}

function mapMessageRole(role) {
  var text = toText(role, '');
  if (text === 'user') return 'user_input';
  if (text === 'assistant') return 'assistant_output';
  if (text === 'tool') return 'tool_result';
  if (text === 'function') return 'tool_result';
  return 'system_message';
}

function mapMessageEntry(sessionId, row, index) {
  return {
    id: toText(sessionId, 'db') + '-msg-' + String(index),
    sessionId: toText(sessionId, ''),
    type: mapMessageRole(row.role),
    content: trimText(row.content, 180),
    timestamp: stampFromIso(row.timestamp),
  };
}

function reverseCopy(list) {
  var out = [];
  var i = list.length - 1;
  while (i >= 0) {
    out.push(list[i]);
    i = i - 1;
  }
  return out;
}

function sessionStatusFromWorker(status, hookRecord) {
  var text = toText(status, '');
  if (hookRecord && hookRecord.status === 'blocked') return 'waiting_input';
  if (text === 'active') return 'running';
  if (text === 'stuck') return 'paused';
  return 'stopped';
}

function modeFromWorker(status, hookRecord) {
  var text = toText(status, '');
  if (hookRecord && hookRecord.status === 'blocked') return 'permission';
  if (text === 'active' && hookRecord && hookRecord.tool.length > 0) return 'tool-use';
  if (text === 'active') return 'streaming';
  if (text === 'stuck') return 'stuck';
  return 'idle';
}

function hookRecordIndex(records) {
  var out = {};
  var i = 0;
  while (i < records.length) {
    var record = records[i];
    if (record && record.sid) out[record.sid] = record;
    i = i + 1;
  }
  return out;
}

function loadHookRecords(limit) {
  var paths = listHookSessionPaths(limit);
  var out = [];
  var i = 0;
  while (i < paths.length) {
    var record = readHookRecord(paths[i]);
    if (record) out.push(record);
    i = i + 1;
  }

  out.sort(function(left, right) {
    return toInt(right.ping, 0) - toInt(left.ping, 0);
  });

  return out;
}

function hookSessionsFromRecords(records, limit) {
  var out = [];
  var i = 0;
  while (i < records.length && out.length < limit) {
    var record = records[i];
    var name = displayNameFromHook(record, 'session-' + String(i + 1));
    out.push({
      id: toText(record.sid, 'hook-' + String(i)),
      projectPath: toText(record.file, 'session/' + name),
      status: sessionStatusFromHook(record),
      createdAt: isoFromEpoch(record.ping),
      updatedAt: isoFromEpoch(record.ping),
      name: name,
      model: HOOK_MODEL,
      mode: modeFromHook(record),
      entries: transcriptFromHook(record),
      currentPrompt: promptFromHook(record),
    });
    i = i + 1;
  }
  return out;
}

function dbSessionsFromRecords(limit, hookIndex) {
  if (typeof dbIsOpen !== 'function' || dbIsOpen() === 0) return [];

  var workersRes = queryListWorkers(null, limit, null);
  var workerRows = asRows(workersRes);
  if (workerRows.length === 0) return [];

  var out = [];
  var i = 0;
  while (i < workerRows.length && out.length < limit) {
    var worker = workerRows[i];
    var hookRecord = hookIndex[toText(worker.session_id, '')];
    var sessionRows = asRows(queryListSessions(null, worker.id, 1, null));
    var sessionRow = sessionRows.length > 0 ? sessionRows[0] : null;
    var messageRows = [];
    if (sessionRow && toInt(sessionRow.id, 0) > 0) {
      messageRows = asRows(queryListMessages(sessionRow.id, null, DEFAULT_LIMIT, null));
      messageRows = reverseCopy(messageRows);
    }

    var name = displayNameFromHook(hookRecord, 'pane-' + String(toInt(worker.pane_id, i + 1)));
    var entries = [];
    if (messageRows.length > 0) {
      var j = 0;
      while (j < messageRows.length) {
        entries.push(mapMessageEntry(worker.session_id || sessionRow.id, messageRows[j], j));
        j = j + 1;
      }
    } else if (hookRecord) {
      entries = transcriptFromHook(hookRecord);
    }

    out.push({
      id: toText(worker.session_id, '') || ('worker-' + String(worker.id)),
      projectPath: sessionRow ? toText(sessionRow.jsonl_path, '') : toText(hookRecord && hookRecord.file, ''),
      status: sessionStatusFromWorker(worker.status, hookRecord),
      createdAt: sessionRow ? toText(sessionRow.started_at, '') : toText(worker.registered_at, ''),
      updatedAt: toText(worker.last_seen_at, sessionRow ? toText(sessionRow.ended_at, '') : ''),
      name: name,
      model: HOOK_MODEL,
      mode: modeFromWorker(worker.status, hookRecord),
      entries: entries,
      currentPrompt: promptFromHook(hookRecord),
    });
    i = i + 1;
  }

  return out;
}

function mergeSessions(primary, fallback, limit) {
  var out = [];
  var seen = {};
  var i = 0;

  while (i < primary.length && out.length < limit) {
    var item = primary[i];
    if (item && !seen[item.id]) {
      out.push(item);
      seen[item.id] = 1;
    }
    i = i + 1;
  }

  i = 0;
  while (i < fallback.length && out.length < limit) {
    var next = fallback[i];
    if (next && !seen[next.id]) {
      out.push(next);
      seen[next.id] = 1;
    }
    i = i + 1;
  }

  return out;
}

function loadCockpitWorkerSessions(limit) {
  var maxRows = toInt(limit, DEFAULT_LIMIT);
  if (maxRows <= 0) maxRows = DEFAULT_LIMIT;

  var hookRecords = loadHookRecords(maxRows);
  var hookSessions = hookSessionsFromRecords(hookRecords, maxRows);
  var dbSessions = dbSessionsFromRecords(maxRows, hookRecordIndex(hookRecords));

  return mergeSessions(dbSessions, hookSessions, maxRows);
}

export {
  loadCockpitWorkerSessions,
};
