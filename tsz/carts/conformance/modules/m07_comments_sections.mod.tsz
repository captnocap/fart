// m07: Comments preserved, section comments in functions
// Proves: comments pass through, multi-function blocks with comment separators

<module cache>
  <types>
    Entry: {
      key: string,
      value: i32 = 0,
      ttl: u32 = 0,
      alive: bool = true
    }
  </types>

  <state>
    entries: Entry[16]
    count: u8 = 0
  </state>

  <functions>
    // ── Writes ──

    put(key: string, value: i32, ttl: u32): void
      count >= 16 ? stop : go
      entries[count] = { key: key, value: value, ttl: ttl, alive: true }
      count = count + 1

    // ── Reads ──

    get(key: string): i32
      for entries[0..count] as e:
        e.alive == true and e.key == key
          ? return e.value
          : continue
      return -1

    // ── Lifecycle ──

    evict(idx: u8): void
      entries[idx].alive = false
      entries[idx].value = 0
  </functions>
</module>
