// m16: String concatenation → std.fmt.bufPrint
// Proves: 'literal' + var + 'literal' becomes bufPrint with format string

<module msg>
  <state>
    buf: u8[512]
  </state>

  <functions>
    greet(name: string): string
      return 'Hello, ' + name + '!'

    status(code: i32, text: string): string
      return 'HTTP ' + code + ' ' + text
  </functions>
</module>
