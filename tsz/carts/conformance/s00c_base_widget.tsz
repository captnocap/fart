<widget name=clock>
  <var>
    hour is time.hour
    minute is time.minute
    greeting is hour < 12 ? 'Good morning' : hour < 18 ? 'Good afternoon' : 'Good evening'
    user is sys.user
  </var>

  <functions>
    timestamp:
      hour + ':' + minute

    title:
      greeting + ', ' + user
  </functions>

  return(
    <C.Card>
      <C.Title>{title}</C.Title>
      <C.Value>{timestamp}</C.Value>
    </C.Card>
  )
</widget>
