// AgentInputBar — Shared input bar for agents

function AgentInputBar(props) {
  return (
    <C.ChatInputArea>
      {props.children}
    </C.ChatInputArea>
  );
}

function AgentModePills(props) {
  var modes = props.modes || ['ask', 'plan', 'task', 'agent'];
  var current = props.current || 'ask';
  
  return (
    <C.ModePillBar>
      {modes.map(function(mode, idx) {
        var active = mode == current ? 1 : 0;
        return (
          <C.ModePill 
            key={idx}
            onPress={function() { if (props.onChange) props.onChange(mode); }}
            style={active == 1 ? { borderColor: '#2d62ff', backgroundColor: '#10213d' } : {}}
          >
            <C.ModePillLabel style={active == 1 ? { color: '#79c0ff' } : {}}>
              {mode}
            </C.ModePillLabel>
          </C.ModePill>
        );
      })}
    </C.ModePillBar>
  );
}

function AgentInputBox(props) {
  return (
    <C.ChatInputBox>
      {props.children}
    </C.ChatInputBox>
  );
}

function AgentInputField(props) {
  return (
    <C.ChatInputField
      value={props.value}
      onChange={props.onChange}
      placeholder={props.placeholder || 'Ask anything...'}
      multiline={1}
    />
  );
}

function AgentInputToolbar(props) {
  return (
    <C.ChatInputToolbar>
      {props.children}
    </C.ChatInputToolbar>
  );
}

function AgentInputToolsLeft(props) {
  return (
    <C.ChatInputToolsLeft>
      {props.children}
    </C.ChatInputToolsLeft>
  );
}

function AgentInputToolsRight(props) {
  return (
    <C.ChatInputToolsRight>
      {props.children}
    </C.ChatInputToolsRight>
  );
}

function AgentToolBtn(props) {
  var active = props.active || 0;
  
  return (
    <C.ChatToolBtnCompact 
      onPress={props.onPress}
      style={active == 1 ? { borderColor: '#2d62ff' } : {}}
    >
      <C.ChatToolIconCompact style={active == 1 ? { color: '#79c0ff' } : {}}>
        {props.icon}
      </C.ChatToolIconCompact>
    </C.ChatToolBtnCompact>
  );
}

function AgentSendBtn(props) {
  return (
    <C.ChatSendBtn onPress={props.onPress}>
      <C.ChatSendLabel>{props.label || 'Send'}</C.ChatSendLabel>
    </C.ChatSendBtn>
  );
}

function AgentAttachmentBar(props) {
  var attachments = props.attachments || [];
  
  if (attachments.length == 0) return null;
  
  return (
    <C.AttachmentBar>
      <C.AttachmentList>
        {attachments.map(function(att, idx) {
          return (
            <C.AttachBadge key={idx}>
              <C.AttachBadgeIcon>📎</C.AttachBadgeIcon>
              <C.AttachBadgeName>{att.name}</C.AttachBadgeName>
              <C.AttachBadgeRemove onPress={function() { if (props.onRemove) props.onRemove(att.id); }}>
                <C.AttachBadgeRemoveIcon>×</C.AttachBadgeRemoveIcon>
              </C.AttachBadgeRemove>
            </C.AttachBadge>
          );
        })}
      </C.AttachmentList>
      <C.AttachClearAll onPress={props.onClearAll}>
        <C.AttachClearLabel>Clear</C.AttachClearLabel>
      </C.AttachClearAll>
    </C.AttachmentBar>
  );
}

export {
  AgentInputBar,
  AgentModePills,
  AgentInputBox,
  AgentInputField,
  AgentInputToolbar,
  AgentInputToolsLeft,
  AgentInputToolsRight,
  AgentToolBtn,
  AgentSendBtn,
  AgentAttachmentBar,
};
