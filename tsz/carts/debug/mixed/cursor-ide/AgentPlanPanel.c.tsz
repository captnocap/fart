// AgentPlanPanel — Agent planning and task breakdown

function AgentPlanPanel(props) {
  return (
    <Box style={{
      width: props.width || 300,
      backgroundColor: '#0c1016',
      borderLeftWidth: 1,
      borderColor: '#171d26',
      flexDirection: 'column',
    }}>
      {props.children}
    </Box>
  );
}

function PlanPanelHeader(props) {
  return (
    <Box style={{
      flexDirection: 'row',
      alignItems: 'center',
      justifyContent: 'space-between',
      padding: 12,
      borderBottomWidth: 1,
      borderColor: '#171d26',
    }}>
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
        <Text fontSize={12} color="#eef2f8" bold={true}>{props.title || 'Plan'}</Text>
        {props.stepCount > 0 && (
          <Box style={{
            paddingLeft: 6,
            paddingRight: 6,
            paddingTop: 2,
            paddingBottom: 2,
            backgroundColor: '#10151d',
            borderRadius: 999,
          }}>
            <Text fontSize={9} color="#79c0ff">{props.completedSteps}/{props.stepCount}</Text>
          </Box>
        )}
      </Box>
      {props.actions}
    </Box>
  );
}

function PlanSteps(props) {
  return (
    <ScrollView style={{ flexGrow: 1, flexBasis: 0 }}>
      <Box style={{ flexDirection: 'column', padding: 12, gap: 8 }}>
        {props.children}
      </Box>
    </ScrollView>
  );
}

function PlanStep(props) {
  var step = props.step || {};
  var status = step.status || 'pending';
  var number = props.number || 1;
  
  var statusIcon = '○';
  var statusColor = '#5d6a7c';
  
  if (status exact 'completed') {
    statusIcon = '✓';
    statusColor = '#7ee787';
  } else if (status exact 'active') {
    statusIcon = '◐';
    statusColor = '#ffbd2e';
  } else if (status exact 'error') {
    statusIcon = '⚠';
    statusColor = '#ff7b72';
  }
  
  return (
    <Pressable onPress={props.onPress}>
      <Box style={{
        flexDirection: 'row',
        alignItems: 'flex-start',
        gap: 10,
        padding: 10,
        backgroundColor: status exact 'active' ? '#10213d' : '#0f141c',
        borderRadius: 8,
        borderWidth: 1,
        borderColor: status exact 'active' ? '#2d62ff' : '#1f2935',
      }}>
        <Box style={{
          width: 20,
          height: 20,
          borderRadius: 10,
          backgroundColor: status exact 'completed' ? '#0d2a1a' : status exact 'active' ? '#2d62ff20' : '#10151d',
          alignItems: 'center',
          justifyContent: 'center',
        }}>
          <Text fontSize={10} color={statusColor}>{statusIcon}</Text>
        </Box>
        <Box style={{ flexDirection: 'column', flexGrow: 1, flexBasis: 0, gap: 4 }}>
          <Text fontSize={11} color="#eef2f8" bold={true}>{step.title || 'Step ' + number}</Text>
          {step.description && (
            <Text fontSize={10} color="#7f8a99">{step.description}</Text>
          )}
          {step.result && status exact 'completed' && (
            <Text fontSize={10} color="#7ee787">{step.result}</Text>
          )}
        </Box>
      </Box>
    </Pressable>
  );
}

function PlanProgressBar(props) {
  var percent = props.percent || 0;
  
  return (
    <Box style={{ padding: 12 }}>
      <Box style={{
        height: 6,
        backgroundColor: '#1f2935',
        borderRadius: 3,
      }}>
        <Box style={{
          width: percent + '%',
          height: 6,
          backgroundColor: '#2d62ff',
          borderRadius: 3,
        }} />
      </Box>
    </Box>
  );
}

export {
  AgentPlanPanel,
  PlanPanelHeader,
  PlanSteps,
  PlanStep,
  PlanProgressBar,
};
