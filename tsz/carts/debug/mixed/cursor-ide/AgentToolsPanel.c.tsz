// AgentToolsPanel — Available tools and capabilities

function AgentToolsPanel(props) {
  return (
    <Box style={{
      width: props.width || 260,
      backgroundColor: '#0c1016',
      borderLeftWidth: 1,
      borderColor: '#171d26',
      flexDirection: 'column',
    }}>
      {props.children}
    </Box>
  );
}

function AgentToolsHeader(props) {
  return (
    <Box style={{
      flexDirection: 'row',
      alignItems: 'center',
      justifyContent: 'space-between',
      padding: 12,
      borderBottomWidth: 1,
      borderColor: '#171d26',
    }}>
      <Text fontSize={12} color="#eef2f8" bold={true}>{props.title || 'Tools'}</Text>
      <Text fontSize={10} color="#5d6a7c">{props.count || 0}</Text>
    </Box>
  );
}

function AgentToolsContent(props) {
  return (
    <ScrollView style={{ flexGrow: 1, flexBasis: 0 }}>
      <Box style={{ flexDirection: 'column', padding: 12, gap: 16 }}>
        {props.children}
      </Box>
    </ScrollView>
  );
}

function AgentToolSection(props) {
  return (
    <Box style={{ flexDirection: 'column', gap: 8 }}>
      <Text fontSize={10} color="#5d6a7c" letterSpacing={0.5}>{props.title}</Text>
      {props.children}
    </Box>
  );
}

function AgentToolButton(props) {
  return (
    <Pressable 
      onPress={props.onPress}
      style={{
        flexDirection: 'row',
        alignItems: 'center',
        gap: 8,
        padding: 8,
        backgroundColor: '#0f141c',
        borderRadius: 8,
        borderWidth: 1,
        borderColor: '#1f2935',
      }}
    >
      <Text fontSize={12} color="#79c0ff">{props.icon || '⚡'}</Text>
      <Text fontSize={11} color="#c9d2df">{props.label}</Text>
    </Pressable>
  );
}

function AgentToolGrid(props) {
  return (
    <Box style={{ flexDirection: 'row', gap: 6, flexWrap: 'wrap' }}>
      {props.children}
    </Box>
  );
}

function AgentLog(props) {
  var entries = props.entries || [];
  
  return (
    <Box style={{ flexDirection: 'column', gap: 6 }}>
      {entries.map(function(entry, idx) {
        var color = '#c9d2df';
        if (entry.level exact 'error') color = '#ff7b72';
        else if (entry.level exact 'warn') color = '#ffbd2e';
        else if (entry.level exact 'info') color = '#79c0ff';
        else if (entry.level exact 'success') color = '#7ee787';
        
        return (
          <Box key={idx} style={{ flexDirection: 'row', gap: 8 }}>
            <Text fontSize={10} color="#5d6a7c">{entry.time}</Text>
            <Text fontSize={10} color={color}>{entry.level}</Text>
            <Text fontSize={10} color="#c9d2df" style={{ flexGrow: 1, flexBasis: 0 }}>{entry.message}</Text>
          </Box>
        );
      })}
    </Box>
  );
}

export {
  AgentToolsPanel,
  AgentToolsHeader,
  AgentToolsContent,
  AgentToolSection,
  AgentToolButton,
  AgentToolGrid,
  AgentLog,
};
