// ArtifactPanel — Generated artifact viewer

function ArtifactPanel(props) {
  return (
    <Box style={{
      width: props.width || 360,
      backgroundColor: '#0c1016',
      borderLeftWidth: 1,
      borderColor: '#171d26',
      flexDirection: 'column',
    }}>
      {props.children}
    </Box>
  );
}

function ArtifactHeader(props) {
  return (
    <Box style={{
      flexDirection: 'row',
      alignItems: 'center',
      justifyContent: 'space-between',
      padding: 14,
      borderBottomWidth: 1,
      borderColor: '#171d26',
    }}>
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
        <Text fontSize={13} color="#eef2f8" bold={true}>{props.title || 'Artifact'}</Text>
        {props.type && (
          <Box style={{
            paddingLeft: 6,
            paddingRight: 6,
            paddingTop: 2,
            paddingBottom: 2,
            backgroundColor: '#10151d',
            borderRadius: 4,
            borderWidth: 1,
            borderColor: '#1f2935',
          }}>
            <Text fontSize={9} color="#79c0ff">{props.type}</Text>
          </Box>
        )}
      </Box>
      <Box style={{ flexDirection: 'row', gap: 6 }}>
        {props.actions}
      </Box>
    </Box>
  );
}

function ArtifactBody(props) {
  return (
    <ScrollView style={{ flexGrow: 1, flexBasis: 0 }}>
      <Box style={{ padding: 14 }}>
        {props.children}
      </Box>
    </ScrollView>
  );
}

function ArtifactCodeBlock(props) {
  return (
    <Box style={{
      backgroundColor: '#0b0f15',
      borderRadius: 8,
      borderWidth: 1,
      borderColor: '#1f2935',
      padding: 12,
      marginBottom: 10,
    }}>
      <Box style={{ flexDirection: 'row', alignItems: 'center', justifyContent: 'space-between', marginBottom: 8 }}>
        {props.language && <Text fontSize={10} color="#5d6a7c">{props.language}</Text>}
        <Pressable onPress={props.onCopy}>
          <Text fontSize={10} color="#79c0ff">Copy</Text>
        </Pressable>
      </Box>
      <Text fontSize={11} color="#c9d2df" fontFamily="monospace">
        {props.children}
      </Text>
    </Box>
  );
}

function ArtifactTextBlock(props) {
  return (
    <Box style={{ marginBottom: 10 }}>
      <Text fontSize={12} color="#c9d2df" lineHeight={18}>
        {props.children}
      </Text>
    </Box>
  );
}

function ArtifactImagePreview(props) {
  return (
    <Box style={{
      backgroundColor: '#0b0f15',
      borderRadius: 8,
      borderWidth: 1,
      borderColor: '#1f2935',
      padding: 12,
      marginBottom: 10,
      alignItems: 'center',
    }}>
      <Box style={{
        width: props.width || 200,
        height: props.height || 150,
        backgroundColor: '#10151d',
        borderRadius: 4,
        alignItems: 'center',
        justifyContent: 'center',
      }}>
        <Text fontSize={24} color="#5d6a7c">🖼</Text>
        <Text fontSize={10} color="#5d6a7c" style={{ marginTop: 8 }}>{props.fileName || 'image.png'}</Text>
      </Box>
    </Box>
  );
}

function ArtifactActionBtn(props) {
  return (
    <Pressable 
      onPress={props.onPress}
      style={{
        paddingLeft: 10,
        paddingRight: 10,
        paddingTop: 5,
        paddingBottom: 5,
        backgroundColor: props.primary == 1 ? '#2d62ff' : '#10151d',
        borderRadius: 6,
        borderWidth: props.primary == 1 ? 0 : 1,
        borderColor: '#1f2935',
      }}
    >
      <Text fontSize={10} color={props.primary == 1 ? '#ffffff' : '#c9d2df'}>
        {props.label}
      </Text>
    </Pressable>
  );
}

export {
  ArtifactPanel,
  ArtifactHeader,
  ArtifactBody,
  ArtifactCodeBlock,
  ArtifactTextBlock,
  ArtifactImagePreview,
  ArtifactActionBtn,
};
