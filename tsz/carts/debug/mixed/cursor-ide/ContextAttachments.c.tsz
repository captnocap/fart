// ContextAttachments — Attachment list and picker

function ContextAttachments(props) {
  return (
    <Box style={{
      flexDirection: 'column',
      gap: 8,
      padding: 12,
    }}>
      {props.children}
    </Box>
  );
}

function AttachmentSection(props) {
  return (
    <Box style={{ flexDirection: 'column', gap: 6 }}>
      <Text fontSize={10} color="#5d6a7c" letterSpacing={0.5}>{props.title}</Text>
      {props.children}
    </Box>
  );
}

function AttachmentItem(props) {
  var item = props.item || {};
  
  return (
    <Pressable 
      onPress={props.onPress}
      onRemove={props.onRemove}
      style={{
        flexDirection: 'row',
        alignItems: 'center',
        gap: 8,
        padding: 8,
        backgroundColor: props.selected == 1 ? '#10213d' : '#0f141c',
        borderRadius: 6,
        borderWidth: 1,
        borderColor: props.selected == 1 ? '#2d62ff' : '#1f2935',
      }}
    >
      <Text fontSize={12} color={item.tone || '#79c0ff'}>{item.icon || '📎'}</Text>
      <Box style={{ flexDirection: 'column', flexGrow: 1, flexBasis: 0 }}>
        <Text fontSize={11} color="#c9d2df" numberOfLines={1}>{item.name}</Text>
        <Text fontSize={9} color="#5d6a7c">{item.path}</Text>
      </Box>
      {props.onRemove && (
        <Pressable onPress={props.onRemove}>
          <Text fontSize={12} color="#5d6a7c">×</Text>
        </Pressable>
      )}
    </Pressable>
  );
}

function AttachmentPicker(props) {
  return (
    <Box style={{
      padding: 12,
      backgroundColor: '#0f141c',
      borderRadius: 8,
      borderWidth: 1,
      borderColor: '#1f2935',
      borderStyle: 'dashed',
      alignItems: 'center',
      gap: 8,
    }}>
      <Text fontSize={20} color="#5d6a7c">📎</Text>
      <Text fontSize={11} color="#5d6a7c">Drop files here or click to browse</Text>
      <Pressable onPress={props.onBrowse}>
        <Box style={{
          paddingLeft: 12,
          paddingRight: 12,
          paddingTop: 6,
          paddingBottom: 6,
          backgroundColor: '#10151d',
          borderRadius: 6,
          borderWidth: 1,
          borderColor: '#1f2935',
        }}>
          <Text fontSize={11} color="#79c0ff">Browse</Text>
        </Box>
      </Pressable>
    </Box>
  );
}

export {
  ContextAttachments,
  AttachmentSection,
  AttachmentItem,
  AttachmentPicker,
};
