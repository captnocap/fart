// EditorGutter — Line numbers and gutter markers

function EditorGutter(props) {
  var width = props.compactBand == 1 ? 52 : 64;
  var padding = props.compactBand == 1 ? 10 : 12;
  
  return (
    <Box style={{
      width: width,
      flexDirection: 'row',
      alignItems: 'center',
      justifyContent: 'flex-end',
      gap: 8,
      paddingRight: padding,
    }}>
      {props.children}
    </Box>
  );
}

function GutterMarker(props) {
  var marker = props.marker || '';
  var color = '#2a3440';
  
  if (marker == 'todo') color = '#ff7b72';
  else if (marker == 'symbol') color = '#2d62ff';
  else if (marker == 'tool') color = '#7ee787';
  else if (marker == 'flow') color = '#d2a8ff';
  else if (marker == 'breakpoint') color = '#ff5f56';
  
  return (
    <Box style={{ width: 6, height: 6, borderRadius: 3, backgroundColor: color }} />
  );
}

function GutterLineNumber(props) {
  var line = props.line || 0;
  var isActive = props.active || 0;
  
  return (
    <Text fontSize={11} color={isActive == 1 ? '#79c0ff' : '#4f5b6b'}>
      {'' + line}
    </Text>
  );
}

function GutterFoldControl(props) {
  var expanded = props.expanded || 0;
  
  return (
    <Pressable onPress={props.onPress}>
      <Text fontSize={9} color="#5d6a7c">
        {expanded == 1 ? '▼' : '▶'}
      </Text>
    </Pressable>
  );
}

export {
  EditorGutter,
  GutterMarker,
  GutterLineNumber,
  GutterFoldControl,
};
