// EditorInlineActions — Inline code actions and quick fixes

function EditorInlineActions(props) {
  var visible = props.visible || 0;
  var line = props.line || 0;
  
  if (visible != 1) return null;
  
  return (
    <Box style={{
      position: 'absolute',
      right: 20,
      top: (line - 1) * 22,
      flexDirection: 'row',
      alignItems: 'center',
      gap: 4,
      backgroundColor: '#0d1015',
      borderRadius: 6,
      borderWidth: 1,
      borderColor: '#1f2935',
      padding: 4,
      zIndex: 10,
    }}>
      {props.children}
    </Box>
  );
}

function InlineActionBtn(props) {
  return (
    <Pressable 
      onPress={props.onPress}
      style={{
        paddingLeft: 8,
        paddingRight: 8,
        paddingTop: 4,
        paddingBottom: 4,
        borderRadius: 4,
        backgroundColor: props.highlight == 1 ? '#2d62ff20' : 'transparent',
      }}
    >
      <Text fontSize={10} color={props.highlight == 1 ? '#79c0ff' : '#c9d2df'}>
        {props.label}
      </Text>
    </Pressable>
  );
}

function InlineActionGroup(props) {
  return (
    <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 2 }}>
      {props.children}
    </Box>
  );
}

function InlineActionSeparator() {
  return (
    <Box style={{ width: 1, height: 14, backgroundColor: '#1f2935', marginLeft: 4, marginRight: 4 }} />
  );
}

export {
  EditorInlineActions,
  InlineActionBtn,
  InlineActionGroup,
  InlineActionSeparator,
};
