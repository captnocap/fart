// EditorMinimap — Code minimap preview

function EditorMinimap(props) {
  var visible = props.visible || 0;
  
  if (visible != 1) return null;
  
  return (
    <C.EditorMinimap>
      <C.EditorMinimapHeader />
      <C.EditorMinimapScroll>
        <C.EditorMinimapStack>
          {props.children}
        </C.EditorMinimapStack>
      </C.EditorMinimapScroll>
    </C.EditorMinimap>
  );
}

function MinimapLine(props) {
  var row = props.row || {};
  var cursorLine = props.cursorLine || 0;
  
  var color = '#2a3440';
  var width = row.previewWidth || 20 + ((row.textLength || 0) * 3) % 80;
  
  if (row.marker == 'todo') color = '#ff7b72';
  else if (row.marker == 'tool') color = '#7ee787';
  else if (row.line == cursorLine) color = '#2d62ff';
  
  return (
    <Box style={{ height: 3, marginBottom: 2, flexDirection: 'row' }}>
      <Box style={{ height: 3, borderRadius: 2, width: width, backgroundColor: color }} />
    </Box>
  );
}

function MinimapViewport(props) {
  var top = props.top || 0;
  var height = props.height || 100;
  
  return (
    <Box style={{
      position: 'absolute',
      top: top,
      left: 0,
      right: 0,
      height: height,
      backgroundColor: '#ffffff10',
      borderWidth: 1,
      borderColor: '#ffffff20',
    }} />
  );
}

export {
  EditorMinimap,
  MinimapLine,
  MinimapViewport,
};
