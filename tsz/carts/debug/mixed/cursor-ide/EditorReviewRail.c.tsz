// EditorReviewRail — Review comments and suggestions rail

function EditorReviewRail(props) {
  return (
    <Box style={{
      width: 280,
      backgroundColor: '#0b0f15',
      borderLeftWidth: 1,
      borderColor: '#171d26',
      flexDirection: 'column',
    }}>
      {props.children}
    </Box>
  );
}

function ReviewRailHeader(props) {
  return (
    <Box style={{
      flexDirection: 'row',
      alignItems: 'center',
      justifyContent: 'space-between',
      padding: 12,
      borderBottomWidth: 1,
      borderColor: '#171d26',
    }}>
      <Text fontSize={12} color="#eef2f8" bold={true}>{props.title || 'Review'}</Text>
      <Text fontSize={10} color="#5d6a7c">{props.count || 0}</Text>
    </Box>
  );
}

function ReviewThread(props) {
  return (
    <Box style={{
      flexDirection: 'column',
      padding: 12,
      borderBottomWidth: 1,
      borderColor: '#171d26',
      gap: 8,
    }}>
      {props.children}
    </Box>
  );
}

function ReviewThreadHeader(props) {
  return (
    <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
      <Box style={{
        width: 20,
        height: 20,
        borderRadius: 10,
        backgroundColor: props.avatarColor || '#2d62ff',
        alignItems: 'center',
        justifyContent: 'center',
      }}>
        <Text fontSize={9} color="#ffffff">{props.initials || '?'}</Text>
      </Box>
      <Text fontSize={11} color="#eef2f8" bold={true}>{props.author}</Text>
      <Text fontSize={10} color="#5d6a7c">{props.time}</Text>
      <Box style={{ flexGrow: 1 }} />
      <Text fontSize={10} color="#5d6a7c">Line {props.line}</Text>
    </Box>
  );
}

function ReviewComment(props) {
  return (
    <Text fontSize={11} color="#c9d2df" lineHeight={16}>
      {props.children}
    </Text>
  );
}

function ReviewSuggestion(props) {
  return (
    <Box style={{
      backgroundColor: '#10151d',
      borderRadius: 8,
      borderWidth: 1,
      borderColor: '#1f2935',
      padding: 10,
      flexDirection: 'column',
      gap: 6,
    }}>
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 6 }}>
        <Text fontSize={9} color="#7ee787">+</Text>
        <Text fontSize={10} color="#7f8a99">Suggested change</Text>
      </Box>
      <Box style={{ backgroundColor: '#0d2a1a', borderRadius: 4, padding: 8 }}>
        <Text fontSize={10} color="#7ee787" fontFamily="monospace">
          {props.addition}
        </Text>
      </Box>
      {props.removal && (
        <Box style={{ backgroundColor: '#341316', borderRadius: 4, padding: 8 }}>
          <Text fontSize={10} color="#ff7b72" fontFamily="monospace">
            {props.removal}
          </Text>
        </Box>
      )}
    </Box>
  );
}

function ReviewActions(props) {
  return (
    <Box style={{ flexDirection: 'row', gap: 8, marginTop: 4 }}>
      {props.children}
    </Box>
  );
}

function ReviewActionBtn(props) {
  return (
    <Pressable 
      onPress={props.onPress}
      style={{
        paddingLeft: 10,
        paddingRight: 10,
        paddingTop: 5,
        paddingBottom: 5,
        backgroundColor: props.primary == 1 ? '#2d62ff' : '#10151d',
        borderRadius: 6,
        borderWidth: props.primary == 1 ? 0 : 1,
        borderColor: '#1f2935',
      }}
    >
      <Text fontSize={10} color={props.primary == 1 ? '#ffffff' : '#c9d2df'}>
        {props.label}
      </Text>
    </Pressable>
  );
}

export {
  EditorReviewRail,
  ReviewRailHeader,
  ReviewThread,
  ReviewThreadHeader,
  ReviewComment,
  ReviewSuggestion,
  ReviewActions,
  ReviewActionBtn,
};
