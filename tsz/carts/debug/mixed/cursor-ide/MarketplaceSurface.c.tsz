// MarketplaceSurface — Plugin/extension marketplace container

function MarketplaceSurface(props) {
  return (
    <Box style={{
      flexGrow: 1,
      flexBasis: 0,
      flexDirection: 'column',
      backgroundColor: '#0d1015',
    }}>
      {props.children}
    </Box>
  );
}

function MarketplaceHeader(props) {
  return (
    <Box style={{
      flexDirection: 'row',
      alignItems: 'center',
      justifyContent: 'space-between',
      padding: 14,
      borderBottomWidth: 1,
      borderColor: '#171d26',
    }}>
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 10 }}>
        <Text fontSize={13} color="#eef2f8" bold={true}>Marketplace</Text>
        <Box style={{
          paddingLeft: 8,
          paddingRight: 8,
          paddingTop: 3,
          paddingBottom: 3,
          backgroundColor: '#10151d',
          borderRadius: 999,
          borderWidth: 1,
          borderColor: '#1f2935',
        }}>
          <Text fontSize={10} color="#79c0ff">{props.count || 0}</Text>
        </Box>
      </Box>
      <Box style={{ flexDirection: 'row', gap: 6 }}>
        {props.actions}
      </Box>
    </Box>
  );
}

function MarketplaceSearch(props) {
  return (
    <Box style={{
      padding: 12,
      borderBottomWidth: 1,
      borderColor: '#171d26',
    }}>
      <Box style={{
        flexDirection: 'row',
        alignItems: 'center',
        gap: 8,
        padding: 10,
        backgroundColor: '#0f141c',
        borderRadius: 8,
        borderWidth: 1,
        borderColor: '#1f2935',
      }}>
        <Text fontSize={12} color="#5d6a7c">🔍</Text>
        <TextInput
          value={props.value}
          onChange={props.onChange}
          placeholder={props.placeholder || 'Search extensions...'}
          fontSize={12}
          color="#c9d2df"
          style={{ flexGrow: 1, height: 20, borderWidth: 0, backgroundColor: 'transparent' }}
        />
      </Box>
    </Box>
  );
}

function MarketplaceContent(props) {
  return (
    <Box style={{
      flexGrow: 1,
      flexBasis: 0,
      flexDirection: props.layout || 'column',
    }}>
      {props.children}
    </Box>
  );
}

function MarketplaceTabs(props) {
  var tabs = props.tabs || ['all', 'installed', 'recommended'];
  var active = props.active || 'all';
  
  return (
    <Box style={{
      flexDirection: 'row',
      gap: 2,
      padding: 12,
      borderBottomWidth: 1,
      borderColor: '#171d26',
    }}>
      {tabs.map(function(tab, idx) {
        var isActive = tab == active;
        return (
          <Pressable 
            key={idx}
            onPress={function() { if (props.onChange) props.onChange(tab); }}
            style={{
              paddingLeft: 12,
              paddingRight: 12,
              paddingTop: 6,
              paddingBottom: 6,
              backgroundColor: isActive ? '#10213d' : 'transparent',
              borderRadius: 6,
            }}
          >
            <Text fontSize={11} color={isActive ? '#79c0ff' : '#c9d2df'}>
              {tab.charAt(0).toUpperCase() + tab.slice(1)}
            </Text>
          </Pressable>
        );
      })}
    </Box>
  );
}

export {
  MarketplaceSurface,
  MarketplaceHeader,
  MarketplaceSearch,
  MarketplaceContent,
  MarketplaceTabs,
};
