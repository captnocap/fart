// MemoryFilters — Memory search and filtering

function MemoryFilters(props) {
  return (
    <Box style={{
      flexDirection: 'column',
      gap: 10,
      padding: 12,
      borderBottomWidth: 1,
      borderColor: '#171d26',
    }}>
      {props.children}
    </Box>
  );
}

function MemorySearchInput(props) {
  return (
    <Box style={{
      flexDirection: 'row',
      alignItems: 'center',
      gap: 8,
      padding: 10,
      backgroundColor: '#0f141c',
      borderRadius: 8,
      borderWidth: 1,
      borderColor: '#1f2935',
    }}>
      <Text fontSize={12} color="#5d6a7c">🔍</Text>
      <TextInput
        value={props.value}
        onChange={props.onChange}
        placeholder={props.placeholder || 'Search memory...'}
        fontSize={12}
        color="#c9d2df"
        style={{ flexGrow: 1, height: 20, borderWidth: 0, backgroundColor: 'transparent' }}
      />
    </Box>
  );
}

function MemoryFilterChips(props) {
  return (
    <Box style={{ flexDirection: 'row', gap: 6, flexWrap: 'wrap' }}>
      {props.children}
    </Box>
  );
}

function MemoryFilterChip(props) {
  var active = props.active || 0;
  
  return (
    <Pressable onPress={props.onPress}>
      <Box style={{
        paddingLeft: 8,
        paddingRight: 8,
        paddingTop: 4,
        paddingBottom: 4,
        backgroundColor: active == 1 ? '#10213d' : '#10151d',
        borderRadius: 999,
        borderWidth: 1,
        borderColor: active == 1 ? '#2d62ff' : '#1f2935',
      }}>
        <Text fontSize={10} color={active == 1 ? '#79c0ff' : '#c9d2df'}>{props.label}</Text>
      </Box>
    </Pressable>
  );
}

function MemoryTypeFilter(props) {
  var types = props.types || ['all', 'conversation', 'file', 'web', 'user'];
  var selected = props.selected || 'all';
  
  return (
    <Box style={{ flexDirection: 'row', gap: 6 }}>
      {types.map(function(type, idx) {
        return (
          <MemoryFilterChip 
            key={idx}
            label={type}
            active={type == selected ? 1 : 0}
            onPress={function() { if (props.onSelect) props.onSelect(type); }}
          />
        );
      })}
    </Box>
  );
}

export {
  MemoryFilters,
  MemorySearchInput,
  MemoryFilterChips,
  MemoryFilterChip,
  MemoryTypeFilter,
};
