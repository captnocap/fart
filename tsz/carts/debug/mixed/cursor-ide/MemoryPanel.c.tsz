// MemoryPanel — Memory bank panel

function MemoryPanel(props) {
  return (
    <Box style={{
      width: props.width || 320,
      backgroundColor: '#0c1016',
      borderLeftWidth: 1,
      borderColor: '#171d26',
      flexDirection: 'column',
    }}>
      {props.children}
    </Box>
  );
}

function MemoryPanelHeader(props) {
  return (
    <Box style={{
      flexDirection: 'row',
      alignItems: 'center',
      justifyContent: 'space-between',
      padding: 12,
      borderBottomWidth: 1,
      borderColor: '#171d26',
    }}>
      <Text fontSize={12} color="#eef2f8" bold={true}>Memory</Text>
      <Box style={{ flexDirection: 'row', gap: 6 }}>
        {props.actions}
      </Box>
    </Box>
  );
}

function MemoryPanelContent(props) {
  return (
    <ScrollView style={{ flexGrow: 1, flexBasis: 0 }}>
      <Box style={{ padding: 12, flexDirection: 'column', gap: 10 }}>
        {props.children}
      </Box>
    </ScrollView>
  );
}

function MemoryBankSection(props) {
  var bank = props.bank || {};
  
  return (
    <Box style={{
      flexDirection: 'column',
      gap: 8,
      padding: 10,
      backgroundColor: '#0f141c',
      borderRadius: 8,
      borderWidth: 1,
      borderColor: '#1f2935',
    }}>
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
        <Box style={{
          width: 8,
          height: 8,
          borderRadius: 4,
          backgroundColor: bank.tone || '#d2a8ff',
        }} />
        <Text fontSize={11} color="#eef2f8" bold={true}>{bank.name}</Text>
        <Box style={{ flexGrow: 1 }} />
        <Text fontSize={9} color="#5d6a7c">{bank.scope}</Text>
      </Box>
      
      <Text fontSize={10} color="#5d6a7c">{bank.summary}</Text>
      
      {bank.entries && (
        <Box style={{ flexDirection: 'column', gap: 4 }}>
          {bank.entries.map(function(entry, idx) {
            return (
              <MemoryEntry key={idx} entry={entry} />
            );
          })}
        </Box>
      )}
    </Box>
  );
}

function MemoryEntry(props) {
  var entry = props.entry || {};
  
  return (
    <Pressable 
      onPress={props.onPress}
      style={{
        flexDirection: 'row',
        alignItems: 'center',
        gap: 8,
        padding: 8,
        backgroundColor: '#10151d',
        borderRadius: 6,
      }}
    >
      <Text fontSize={10} color="#79c0ff">•</Text>
      <Box style={{ flexDirection: 'column', flexGrow: 1, flexBasis: 0 }}>
        <Text fontSize={10} color="#c9d2df" numberOfLines={1}>{entry.title || 'Entry'}</Text>
        <Text fontSize={9} color="#5d6a7c">{entry.timestamp}</Text>
      </Box>
    </Pressable>
  );
}

export {
  MemoryPanel,
  MemoryPanelHeader,
  MemoryPanelContent,
  MemoryBankSection,
  MemoryEntry,
};
