// MemoryTimeline — Timeline view of memory entries

function MemoryTimeline(props) {
  return (
    <Box style={{
      flexDirection: 'column',
      padding: 12,
    }}>
      {props.children}
    </Box>
  );
}

function MemoryTimelineSection(props) {
  return (
    <Box style={{ flexDirection: 'column', gap: 8 }}>
      <Text fontSize={10} color="#5d6a7c" letterSpacing={0.5}>{props.date}</Text>
      <Box style={{ flexDirection: 'column', gap: 6, paddingLeft: 12 }}>
        {props.children}
      </Box>
    </Box>
  );
}

function MemoryTimelineItem(props) {
  var entry = props.entry || {};
  
  return (
    <Pressable 
      onPress={props.onPress}
      style={{
        flexDirection: 'row',
        alignItems: 'flex-start',
        gap: 10,
      }}
    >
      <Box style={{
        width: 8,
        height: 8,
        borderRadius: 4,
        backgroundColor: entry.tone || '#d2a8ff',
        marginTop: 4,
      }} />
      <Box style={{
        flexDirection: 'column',
        flexGrow: 1,
        flexBasis: 0,
        paddingBottom: 12,
        borderLeftWidth: 1,
        borderColor: '#1f2935',
        paddingLeft: 12,
      }}>
        <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 6 }}>
          <Text fontSize={11} color="#eef2f8">{entry.title}</Text>
          <Text fontSize={9} color="#5d6a7c">{entry.time}</Text>
        </Box>
        <Text fontSize={10} color="#7f8a99" numberOfLines={2}>{entry.summary}</Text>
      </Box>
    </Pressable>
  );
}

export {
  MemoryTimeline,
  MemoryTimelineSection,
  MemoryTimelineItem,
};
