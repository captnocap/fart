// PluginDetail — Cursor plugin detail view

function PluginDetail(props) {
  return (
    <Box style={{
      flexGrow: 1,
      flexBasis: 0,
      flexDirection: 'column',
      backgroundColor: '#0d1015',
    }}>
      {props.children}
    </Box>
  );
}

function PluginDetailHeader(props) {
  var plugin = props.plugin || {};
  
  return (
    <Box style={{
      flexDirection: 'column',
      gap: 14,
      padding: 16,
      borderBottomWidth: 1,
      borderColor: '#171d26',
    }}>
      <Box style={{ flexDirection: 'row', gap: 14 }}>
        <Box style={{
          width: 80,
          height: 80,
          borderRadius: 12,
          backgroundColor: plugin.tone || '#ffa657' + '20',
          alignItems: 'center',
          justifyContent: 'center',
        }}>
          <Text fontSize={36} color={plugin.tone || '#ffa657'}>{plugin.icon || '🎨'}</Text>
        </Box>
        
        <Box style={{ flexDirection: 'column', flexGrow: 1, flexBasis: 0, gap: 6 }}>
          <Text fontSize={18} color="#eef2f8" bold={true}>{plugin.name}</Text>
          <Text fontSize={12} color="#5d6a7c">{plugin.runtime || 'lua'} runtime</Text>
          <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8, flexWrap: 'wrap' }}>
            <Box style={{
              paddingLeft: 8,
              paddingRight: 8,
              paddingTop: 3,
              paddingBottom: 3,
              backgroundColor: plugin.enabled == 1 ? '#0d2a1a' : '#341316',
              borderRadius: 4,
            }}>
              <Text fontSize={10} color={plugin.enabled == 1 ? '#7ee787' : '#ff7b72'}>
                {plugin.enabled == 1 ? 'Enabled' : 'Disabled'}
              </Text>
            </Box>
            <Text fontSize={11} color="#5d6a7c">v{plugin.version}</Text>
          </Box>
        </Box>
      </Box>
      
      <Box style={{ flexDirection: 'row', gap: 8 }}>
        {plugin.enabled == 1 ? (
          <Pressable 
            onPress={props.onDisable}
            style={{
              paddingLeft: 16,
              paddingRight: 16,
              paddingTop: 8,
              paddingBottom: 8,
              backgroundColor: '#341316',
              borderRadius: 8,
            }}
          >
            <Text fontSize={12} color="#ff7b72" bold={true}>Disable</Text>
          </Pressable>
        ) : (
          <Pressable 
            onPress={props.onEnable}
            style={{
              paddingLeft: 16,
              paddingRight: 16,
              paddingTop: 8,
              paddingBottom: 8,
              backgroundColor: '#0d2a1a',
              borderRadius: 8,
            }}
          >
            <Text fontSize={12} color="#7ee787" bold={true}>Enable</Text>
          </Pressable>
        )}
        <Pressable 
          onPress={props.onConfigure}
          style={{
            paddingLeft: 16,
            paddingRight: 16,
            paddingTop: 8,
            paddingBottom: 8,
            backgroundColor: '#10151d',
            borderRadius: 8,
            borderWidth: 1,
            borderColor: '#1f2935',
          }}
        >
          <Text fontSize={12} color="#c9d2df">Configure</Text>
        </Pressable>
        <Pressable 
          onPress={props.onUninstall}
          style={{
            paddingLeft: 16,
            paddingRight: 16,
            paddingTop: 8,
            paddingBottom: 8,
            backgroundColor: '#10151d',
            borderRadius: 8,
            borderWidth: 1,
            borderColor: '#1f2935',
          }}
        >
          <Text fontSize={12} color="#ff7b72">Uninstall</Text>
        </Pressable>
      </Box>
    </Box>
  );
}

function PluginCapabilities(props) {
  var plugin = props.plugin || {};
  
  return (
    <Box style={{ flexDirection: 'column', gap: 10 }}>
      <Text fontSize={13} color="#eef2f8" bold={true}>Capabilities</Text>
      
      {plugin.hooks && plugin.hooks.length > 0 && (
        <CapabilitySection title="Hooks" items={plugin.hooks} />
      )}
      {plugin.commands && plugin.commands.length > 0 && (
        <CapabilitySection title="Commands" items={plugin.commands} />
      )}
      {plugin.skills && plugin.skills.length > 0 && (
        <CapabilitySection title="Skills" items={plugin.skills} />
      )}
      {plugin.agents && plugin.agents.length > 0 && (
        <CapabilitySection title="Agents" items={plugin.agents} />
      )}
    </Box>
  );
}

function CapabilitySection(props) {
  return (
    <Box style={{ flexDirection: 'column', gap: 6 }}>
      <Text fontSize={10} color="#5d6a7c" letterSpacing={0.5}>{props.title}</Text>
      <Box style={{ flexDirection: 'row', gap: 6, flexWrap: 'wrap' }}>
        {props.items.map(function(item, idx) {
          return (
            <Box key={idx} style={{
              paddingLeft: 8,
              paddingRight: 8,
              paddingTop: 4,
              paddingBottom: 4,
              backgroundColor: '#10151d',
              borderRadius: 6,
              borderWidth: 1,
              borderColor: '#1f2935',
            }}>
              <Text fontSize={10} color="#79c0ff">{item}</Text>
            </Box>
          );
        })}
      </Box>
    </Box>
  );
}

function PluginPermissions(props) {
  var plugin = props.plugin || {};
  
  return (
    <Box style={{ flexDirection: 'column', gap: 10 }}>
      <Text fontSize={13} color="#eef2f8" bold={true}>Permissions</Text>
      <Box style={{ flexDirection: 'column', gap: 8 }}>
        {plugin.permissions && plugin.permissions.map(function(perm, idx) {
          return (
            <Box key={idx} style={{
              flexDirection: 'row',
              alignItems: 'center',
              gap: 8,
              padding: 10,
              backgroundColor: '#0f141c',
              borderRadius: 8,
            }}>
              <Text fontSize={12} color={perm.granted == 1 ? '#7ee787' : '#ffbd2e'}>
                {perm.granted == 1 ? '✓' : '⚠'}
              </Text>
              <Box style={{ flexDirection: 'column', flexGrow: 1, flexBasis: 0 }}>
                <Text fontSize={11} color="#c9d2df">{perm.name}</Text>
                <Text fontSize={9} color="#5d6a7c">{perm.description}</Text>
              </Box>
            </Box>
          );
        })}
      </Box>
    </Box>
  );
}

export {
  PluginDetail,
  PluginDetailHeader,
  PluginCapabilities,
  CapabilitySection,
  PluginPermissions,
};
