// PluginRegistryPanel — Installed plugin registry

function PluginRegistryPanel(props) {
  return (
    <Box style={{
      width: props.width || 280,
      backgroundColor: '#0c1016',
      borderRightWidth: 1,
      borderColor: '#171d26',
      flexDirection: 'column',
    }}>
      {props.children}
    </Box>
  );
}

function PluginRegistryHeader(props) {
  return (
    <Box style={{
      flexDirection: 'row',
      alignItems: 'center',
      justifyContent: 'space-between',
      padding: 12,
      borderBottomWidth: 1,
      borderColor: '#171d26',
    }}>
      <Text fontSize={12} color="#eef2f8" bold={true}>Installed</Text>
      <Text fontSize={10} color="#5d6a7c">{props.count || 0}</Text>
    </Box>
  );
}

function PluginRegistryContent(props) {
  return (
    <ScrollView style={{ flexGrow: 1, flexBasis: 0 }}>
      <Box style={{ padding: 8, flexDirection: 'column', gap: 6 }}>
        {props.children}
      </Box>
    </ScrollView>
  );
}

function PluginRegistryItem(props) {
  var plugin = props.plugin || {};
  
  return (
    <Pressable 
      onPress={props.onPress}
      style={{
        flexDirection: 'row',
        alignItems: 'center',
        gap: 10,
        padding: 10,
        backgroundColor: props.selected == 1 ? '#10213d' : 'transparent',
        borderRadius: 8,
        borderWidth: 1,
        borderColor: props.selected == 1 ? '#2d62ff' : 'transparent',
      }}
    >
      <Box style={{
        width: 32,
        height: 32,
        borderRadius: 8,
        backgroundColor: plugin.tone || '#ffa657' + '20',
        alignItems: 'center',
        justifyContent: 'center',
      }}>
        <Text fontSize={14} color={plugin.tone || '#ffa657'}>{plugin.icon || '🎨'}</Text>
      </Box>
      
      <Box style={{ flexDirection: 'column', flexGrow: 1, flexBasis: 0 }}>
        <Text fontSize={11} color="#c9d2df" bold={true} numberOfLines={1}>{plugin.name}</Text>
        <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 6 }}>
          <Box style={{
            width: 6,
            height: 6,
            borderRadius: 3,
            backgroundColor: plugin.enabled == 1 ? '#7ee787' : '#5d6a7c',
          }} />
          <Text fontSize={9} color="#5d6a7c">{plugin.enabled == 1 ? 'Enabled' : 'Disabled'}</Text>
        </Box>
      </Box>
    </Pressable>
  );
}

export {
  PluginRegistryPanel,
  PluginRegistryHeader,
  PluginRegistryContent,
  PluginRegistryItem,
};
