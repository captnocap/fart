// PromptAssemblyList — List of prompt assembly configurations

function PromptAssemblyList(props) {
  return (
    <Box style={{
      flexDirection: 'column',
      gap: 8,
      padding: 12,
    }}>
      {props.children}
    </Box>
  );
}

function AssemblyConfigItem(props) {
  var config = props.config || {};
  
  return (
    <Pressable 
      onPress={props.onPress}
      style={{
        flexDirection: 'column',
        gap: 8,
        padding: 12,
        backgroundColor: props.active == 1 ? '#10213d' : '#0f141c',
        borderRadius: 10,
        borderWidth: 1,
        borderColor: props.active == 1 ? '#2d62ff' : '#1f2935',
      }}
    >
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
        <Text fontSize={12} color="#eef2f8" bold={true}>{config.name || 'Configuration'}</Text>
        <Box style={{ flexGrow: 1 }} />
        {config.default == 1 && (
          <Box style={{
            paddingLeft: 6,
            paddingRight: 6,
            paddingTop: 2,
            paddingBottom: 2,
            backgroundColor: '#0d2a1a',
            borderRadius: 4,
          }}>
            <Text fontSize={9} color="#7ee787">Default</Text>
          </Box>
        )}
      </Box>
      
      <Text fontSize={10} color="#5d6a7c">{config.description || ''}</Text>
      
      <Box style={{ flexDirection: 'row', gap: 6, flexWrap: 'wrap' }}>
        {config.contextTypes && config.contextTypes.map(function(type, idx) {
          return (
            <Box key={idx} style={{
              paddingLeft: 6,
              paddingRight: 6,
              paddingTop: 2,
              paddingBottom: 2,
              backgroundColor: '#10151d',
              borderRadius: 4,
            }}>
              <Text fontSize={9} color="#79c0ff">{type}</Text>
            </Box>
          );
        })}
      </Box>
    </Pressable>
  );
}

function AssemblyAddButton(props) {
  return (
    <Pressable 
      onPress={props.onPress}
      style={{
        flexDirection: 'row',
        alignItems: 'center',
        gap: 6,
        padding: 12,
        backgroundColor: '#0f141c',
        borderRadius: 10,
        borderWidth: 1,
        borderColor: '#1f2935',
        borderStyle: 'dashed',
      }}
    >
      <Text fontSize={14} color="#79c0ff">+</Text>
      <Text fontSize={11} color="#79c0ff">New Assembly</Text>
    </Pressable>
  );
}

export {
  PromptAssemblyList,
  AssemblyConfigItem,
  AssemblyAddButton,
};
