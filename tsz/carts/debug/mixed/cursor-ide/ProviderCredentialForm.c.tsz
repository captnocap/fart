// ProviderCredentialForm — API key and credential management

function ProviderCredentialForm(props) {
  var provider = props.provider || {};
  
  return (
    <Box style={{
      flexDirection: 'column',
      gap: 12,
      padding: 14,
      backgroundColor: '#0f141c',
      borderRadius: 10,
      borderWidth: 1,
      borderColor: '#1f2935',
    }}>
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
        <Text fontSize={12} color="#eef2f8" bold={true}>API Credentials</Text>
        <Box style={{
          paddingLeft: 6,
          paddingRight: 6,
          paddingTop: 2,
          paddingBottom: 2,
          backgroundColor: provider.hasCredentials == 1 ? '#0d2a1a' : '#341316',
          borderRadius: 4,
        }}>
          <Text fontSize={9} color={provider.hasCredentials == 1 ? '#7ee787' : '#ff7b72'}>
            {provider.hasCredentials == 1 ? 'Configured' : 'Missing'}
          </Text>
        </Box>
      </Box>
      
      <CredentialField 
        label="API Key"
        placeholder={provider.env || 'Enter API key...'}
        secure={1}
        value={props.apiKey}
        onChange={props.onApiKeyChange}
      />
      
      {props.children}
    </Box>
  );
}

function CredentialField(props) {
  var secure = props.secure || 0;
  var revealed = props.revealed || 0;
  
  return (
    <Box style={{ flexDirection: 'column', gap: 6 }}>
      <Text fontSize={10} color="#5d6a7c">{props.label}</Text>
      <Box style={{
        flexDirection: 'row',
        alignItems: 'center',
        gap: 8,
        padding: 10,
        backgroundColor: '#10151d',
        borderRadius: 8,
        borderWidth: 1,
        borderColor: '#1f2935',
      }}>
        <TextInput
          value={props.value}
          onChange={props.onChange}
          placeholder={props.placeholder}
          secureTextEntry={secure == 1 && revealed != 1}
          fontSize={12}
          color="#c9d2df"
          style={{ flexGrow: 1, height: 20, borderWidth: 0, backgroundColor: 'transparent' }}
        />
        {secure == 1 && (
          <Pressable onPress={props.onToggleReveal}>
            <Text fontSize={10} color="#5d6a7c">{revealed == 1 ? '🙈' : '👁'}</Text>
          </Pressable>
        )}
      </Box>
    </Box>
  );
}

function CredentialActions(props) {
  return (
    <Box style={{ flexDirection: 'row', gap: 8, marginTop: 8 }}>
      {props.children}
    </Box>
  );
}

function CredentialSaveBtn(props) {
  return (
    <Pressable 
      onPress={props.onPress}
      style={{
        paddingLeft: 14,
        paddingRight: 14,
        paddingTop: 8,
        paddingBottom: 8,
        backgroundColor: '#2d62ff',
        borderRadius: 8,
      }}
    >
      <Text fontSize={11} color="#ffffff" bold={true}>{props.label || 'Save'}</Text>
    </Pressable>
  );
}

function CredentialTestBtn(props) {
  return (
    <Pressable 
      onPress={props.onPress}
      style={{
        paddingLeft: 14,
        paddingRight: 14,
        paddingTop: 8,
        paddingBottom: 8,
        backgroundColor: '#10151d',
        borderRadius: 8,
        borderWidth: 1,
        borderColor: '#1f2935',
      }}
    >
      <Text fontSize={11} color="#c9d2df">{props.label || 'Test'}</Text>
    </Pressable>
  );
}

export {
  ProviderCredentialForm,
  CredentialField,
  CredentialActions,
  CredentialSaveBtn,
  CredentialTestBtn,
};
