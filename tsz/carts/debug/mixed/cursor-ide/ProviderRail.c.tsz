// ProviderRail — Provider icon rail for quick switching

function ProviderRail(props) {
  var providers = props.providers || [];
  var selected = props.selected || '';
  
  return (
    <Box style={{
      width: 48,
      backgroundColor: '#0c1016',
      borderRightWidth: 1,
      borderColor: '#171d26',
      flexDirection: 'column',
      alignItems: 'center',
      paddingTop: 12,
      gap: 8,
    }}>
      {providers.map(function(provider, idx) {
        var isSelected = provider.id == selected;
        return (
          <Pressable 
            key={idx}
            onPress={function() { if (props.onSelect) props.onSelect(provider.id); }}
          >
            <Box style={{
              width: 36,
              height: 36,
              borderRadius: 8,
              backgroundColor: isSelected ? '#10213d' : 'transparent',
              borderWidth: 1,
              borderColor: isSelected ? provider.tone || '#2d62ff' : 'transparent',
              alignItems: 'center',
              justifyContent: 'center',
            }}>
              <Text fontSize={14} color={provider.tone || '#79c0ff'}>
                {provider.icon || '●'}
              </Text>
            </Box>
          </Pressable>
        );
      })}
    </Box>
  );
}

function ProviderRailItem(props) {
  var provider = props.provider || {};
  var active = props.active || 0;
  
  return (
    <Pressable 
      onPress={props.onPress}
      style={{
        width: 36,
        height: 36,
        borderRadius: 8,
        backgroundColor: active == 1 ? '#10213d' : 'transparent',
        borderWidth: 1,
        borderColor: active == 1 ? provider.tone || '#2d62ff' : 'transparent',
        alignItems: 'center',
        justifyContent: 'center',
      }}
    >
      <Text fontSize={14} color={provider.tone || '#79c0ff'}>
        {provider.icon || '●'}
      </Text>
    </Pressable>
  );
}

export {
  ProviderRail,
  ProviderRailItem,
};
