// SearchSurface — Unified search panel

function SearchSurface(props) {
  var width = props.width || 390;
  var compactMode = props.compactMode || 0;
  
  if (compactMode == 1) {
    return (
      <C.SearchPanel style={{ width: '100%', borderLeftWidth: 0, flexGrow: 1, flexBasis: 0 }}>
        {props.children}
      </C.SearchPanel>
    );
  }
  
  return (
    <C.SearchPanel style={{ width: width }}>
      {props.children}
    </C.SearchPanel>
  );
}

function SearchHeader(props) {
  return (
    <C.SearchHeader>
      {props.children}
    </C.SearchHeader>
  );
}

function SearchTitle(props) {
  return (
    <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 8 }}>
      <C.SearchTitle>{props.children}</C.SearchTitle>
      <C.SearchScope>{props.scope}</C.SearchScope>
    </Box>
  );
}

function SearchInputBox(props) {
  return (
    <C.SearchInputBox>
      <C.SearchInputIcon>🔍</C.SearchInputIcon>
      <C.SearchInput 
        value={props.value}
        onChange={props.onChange}
        placeholder={props.placeholder || 'Search files...'}
      />
    </C.SearchInputBox>
  );
}

function SearchOptions(props) {
  return (
    <C.SearchOptions>
      {props.children}
    </C.SearchOptions>
  );
}

function SearchOption(props) {
  var active = props.active || 0;
  
  return (
    <C.SearchOption style={active == 1 ? { borderColor: '#2d62ff' } : {}}>
      <Pressable onPress={props.onPress}>
        <Text fontSize={10} color={active == 1 ? '#79c0ff' : '#7f8a99'}>
          {props.label}
        </Text>
      </Pressable>
    </C.SearchOption>
  );
}

function SearchResults(props) {
  return (
    <C.SearchResults>
      <C.SearchResultsStack>
        {props.children}
      </C.SearchResultsStack>
    </C.SearchResults>
  );
}

function SearchResult(props) {
  var result = props.result || {};
  
  return (
    <C.SearchResult onPress={function() { if (props.onOpen) props.onOpen(result.file, result.line); }}>
      <C.SearchResultHeader>
        <C.SearchResultFile>{result.file}</C.SearchResultFile>
        {result.line > 0 && <C.SearchResultLine>:{result.line}</C.SearchResultLine>}
      </C.SearchResultHeader>
      <C.SearchResultText>{result.text}</C.SearchResultText>
      {result.matches > 1 && <C.SearchResultBadge>{result.matches} matches</C.SearchResultBadge>}
    </C.SearchResult>
  );
}

function SearchFooter(props) {
  return (
    <C.SearchFooter>
      <C.SearchFooterText>{props.status}</C.SearchFooterText>
      <C.SearchActionBtn onPress={props.onClose}>
        <Text fontSize={10} color="#c9d2df">Close</Text>
      </C.SearchActionBtn>
    </C.SearchFooter>
  );
}

export {
  SearchSurface,
  SearchHeader,
  SearchTitle,
  SearchInputBox,
  SearchOptions,
  SearchOption,
  SearchResults,
  SearchResult,
  SearchFooter,
};
