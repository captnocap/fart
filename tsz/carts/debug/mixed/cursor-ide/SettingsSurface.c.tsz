// SettingsSurface — Main settings shell

function SettingsSurface(props) {
  return (
    <C.LandingPage style={{ flexGrow: 1, flexBasis: 0, backgroundColor: '#0d1015' }}>
      {props.children}
    </C.LandingPage>
  );
}

function SettingsLayout(props) {
  var stacked = props.stacked || 0;
  
  return (
    <Box style={{
      flexDirection: stacked == 1 ? 'column' : 'row',
      gap: 14,
      alignItems: stacked == 1 ? 'stretch' : 'flex-start',
      padding: stacked == 1 ? 12 : 18,
    }}>
      {props.children}
    </Box>
  );
}

function SettingsHero(props) {
  var stacked = props.stacked || 0;
  
  return (
    <Box style={{
      padding: stacked == 1 ? 14 : 18,
      borderRadius: 16,
      borderWidth: 1,
      borderColor: '#1f2935',
      backgroundColor: '#10151d',
      gap: 10,
    }}>
      <Text fontSize={10} color="#79c0ff" letterSpacing={0.8}>SETTINGS SURFACE</Text>
      <Text fontSize={stacked == 1 ? 20 : 24} color="#eef2f8" bold={true}>{props.title}</Text>
      <Text fontSize={11} color="#c9d2df" lineHeight={18}>{props.description}</Text>
      {props.children}
    </Box>
  );
}

function SettingsHeroChips(props) {
  return (
    <Box style={{
      flexDirection: 'row',
      gap: 8,
      flexWrap: 'wrap',
      paddingTop: 6,
    }}>
      {props.children}
    </Box>
  );
}

function SettingsDenseChip(props) {
  return (
    <Box style={{
      paddingLeft: 9,
      paddingRight: 9,
      paddingTop: 5,
      paddingBottom: 5,
      borderRadius: 999,
      borderWidth: 1,
      borderColor: props.borderColor || '#1f2935',
      backgroundColor: props.backgroundColor || '#10151d',
    }}>
      <Text fontSize={10} color={props.color || '#c9d2df'}>{props.label}</Text>
    </Box>
  );
}

export {
  SettingsSurface,
  SettingsLayout,
  SettingsHero,
  SettingsHeroChips,
  SettingsDenseChip,
};
