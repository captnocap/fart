// ShellCommandPalette — Command palette overlay

function ShellCommandPalette(props) {
  var visible = props.visible || 0;
  
  if (visible != 1) return null;
  
  return (
    <Box style={{
      position: 'absolute',
      top: 60,
      left: '50%',
      marginLeft: -300,
      width: 600,
      backgroundColor: '#0d1015',
      borderRadius: 12,
      borderWidth: 1,
      borderColor: '#171d26',
      flexDirection: 'column',
      zIndex: 1001,
      shadowColor: '#000000',
      shadowOffset: { width: 0, height: 8 },
      shadowBlur: 32,
    }}>
      {props.children}
    </Box>
  );
}

function CommandPaletteInput(props) {
  return (
    <Box style={{
      flexDirection: 'row',
      alignItems: 'center',
      gap: 10,
      padding: 14,
      borderBottomWidth: 1,
      borderColor: '#171d26',
    }}>
      <Text fontSize={16} color="#5d6a7c">⌘</Text>
      <TextInput
        value={props.value}
        onChange={props.onChange}
        placeholder={props.placeholder || 'Type a command...'}
        fontSize={14}
        color="#eef2f8"
        style={{ flexGrow: 1, height: 32, borderWidth: 0, backgroundColor: 'transparent' }}
        autoFocus={true}
      />
    </Box>
  );
}

function CommandPaletteSection(props) {
  return (
    <Box style={{ flexDirection: 'column' }}>
      <Box style={{ paddingLeft: 14, paddingRight: 14, paddingTop: 10, paddingBottom: 6 }}>
        <Text fontSize={10} color="#5d6a7c" letterSpacing={0.5}>{props.title}</Text>
      </Box>
      {props.children}
    </Box>
  );
}

function CommandPaletteItem(props) {
  var selected = props.selected || 0;
  
  return (
    <Pressable 
      onPress={props.onPress}
      style={{
        flexDirection: 'row',
        alignItems: 'center',
        gap: 10,
        paddingLeft: 14,
        paddingRight: 14,
        paddingTop: 8,
        paddingBottom: 8,
        backgroundColor: selected == 1 ? '#182235' : 'transparent',
      }}
    >
      {props.icon && (
        <Box style={{ width: 20, alignItems: 'center' }}>
          <Text fontSize={12} color="#79c0ff">{props.icon}</Text>
        </Box>
      )}
      <Box style={{ flexDirection: 'column', flexGrow: 1, flexBasis: 0 }}>
        <Text fontSize={12} color="#eef2f8">{props.label}</Text>
        {props.meta && <Text fontSize={10} color="#5d6a7c">{props.meta}</Text>}
      </Box>
      {props.shortcut && (
        <Box style={{ flexDirection: 'row', gap: 4 }}>
          <Text fontSize={10} color="#5d6a7c">{props.shortcut}</Text>
        </Box>
      )}
    </Pressable>
  );
}

function CommandPaletteEmpty(props) {
  return (
    <Box style={{ padding: 24, alignItems: 'center' }}>
      <Text fontSize={12} color="#5d6a7c">{props.message || 'No commands found'}</Text>
    </Box>
  );
}

export {
  ShellCommandPalette,
  CommandPaletteInput,
  CommandPaletteSection,
  CommandPaletteItem,
  CommandPaletteEmpty,
};
