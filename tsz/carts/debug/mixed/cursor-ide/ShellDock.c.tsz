// ShellDock — Bottom dock for terminal and tool panels

function ShellDock(props) {
  var visible = props.visible || 0;
  var height = props.height || 200;
  
  if (visible != 1) return null;
  
  return (
    <C.TerminalPanel style={{ height: height }}>
      {props.children}
    </C.TerminalPanel>
  );
}

function DockHeader(props) {
  return (
    <C.TerminalHeader>
      <C.TerminalHeaderMain>
        <C.TerminalTitle>{props.title}</C.TerminalTitle>
        {props.meta && <C.TerminalMeta>{props.meta}</C.TerminalMeta>}
      </C.TerminalHeaderMain>
      <C.TerminalActions>
        {props.actions}
      </C.TerminalActions>
    </C.TerminalHeader>
  );
}

function DockBody(props) {
  return (
    <C.TerminalBody>
      {props.children}
    </C.TerminalBody>
  );
}

function DockFooter(props) {
  return (
    <C.TerminalFooter>
      <C.TerminalFooterText>{props.children}</C.TerminalFooterText>
    </C.TerminalFooter>
  );
}

function DockActionBtn(props) {
  return (
    <C.TerminalActionBtn onPress={props.onPress}>
      <C.TerminalActionLabel>{props.label}</C.TerminalActionLabel>
    </C.TerminalActionBtn>
  );
}

export {
  ShellDock,
  DockHeader,
  DockBody,
  DockFooter,
  DockActionBtn,
};
