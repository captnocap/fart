// ShellStatusbar — Bottom status bar with context info

function ShellStatusbar(props) {
  var compactMode = props.compactMode || 0;
  var height = compactMode == 1 ? 26 : 28;
  
  return (
    <C.StatusBar style={{ height: height }}>
      {props.children}
    </C.StatusBar>
  );
}

function StatusbarLeft(props) {
  return (
    <C.StatusLeft>
      {props.children}
    </C.StatusLeft>
  );
}

function StatusbarRight(props) {
  return (
    <C.StatusRight>
      {props.children}
    </C.StatusRight>
  );
}

function StatusItem(props) {
  return (
    <C.StatusItem>
      {props.highlight == 1 && <C.StatusTextHighlight>{props.children}</C.StatusTextHighlight>}
      {props.highlight != 1 && <C.StatusText>{props.children}</C.StatusText>}
    </C.StatusItem>
  );
}

function StatusSeparator() {
  return <C.StatusSeparator />;
}

function StatusBranch(props) {
  return (
    <C.StatusBranch>
      <C.StatusText>⎇ {props.branch}</C.StatusText>
    </C.StatusBranch>
  );
}

function StatusGitSummary(props) {
  var parts = [];
  if (props.changed > 0) parts.push(props.changed + 'M');
  if (props.staged > 0) parts.push(props.staged + 'A');
  if (parts.length == 0) parts.push('clean');
  
  return (
    <C.StatusItem>
      <C.StatusText>{parts.join(' ')}</C.StatusText>
    </C.StatusItem>
  );
}

function StatusCursorPosition(props) {
  return (
    <C.StatusItem>
      <C.StatusText>Ln {props.line}, Col {props.column}</C.StatusText>
    </C.StatusItem>
  );
}

function StatusLanguage(props) {
  return (
    <C.StatusItem>
      <C.StatusText>{props.language}</C.StatusText>
    </C.StatusItem>
  );
}

function StatusModel(props) {
  return (
    <C.StatusItem>
      <C.StatusTextHighlight>{props.name}</C.StatusTextHighlight>
    </C.StatusItem>
  );
}

function StatusAgentState(props) {
  var color = props.status exact 'idle' ? '#7ee787' : props.status exact 'streaming' ? '#ffbd2e' : '#ff5f56';
  
  return (
    <C.StatusItem>
      <Box style={{ flexDirection: 'row', alignItems: 'center', gap: 4 }}>
        <Box style={{ width: 6, height: 6, borderRadius: 3, backgroundColor: color }} />
        <C.StatusText>{props.status}</C.StatusText>
      </Box>
    </C.StatusItem>
  );
}

export {
  ShellStatusbar,
  StatusbarLeft,
  StatusbarRight,
  StatusItem,
  StatusSeparator,
  StatusBranch,
  StatusGitSummary,
  StatusCursorPosition,
  StatusLanguage,
  StatusModel,
  StatusAgentState,
};
