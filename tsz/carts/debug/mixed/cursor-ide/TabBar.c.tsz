// TabBar — project landing, file tabs, git badges, and dirty markers

import { HouseIcon, PackageIcon, FileCodeIcon, FileTextIcon, PaletteIcon, BracesIcon, PanelLeftIcon, XIcon } from './Icon.c';

function TabIcon(props) {
  var type = props.type;

  if (type == 'home') return <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#0d2040' }}><HouseIcon size={9} /></Box>;
  if (type == 'component') return <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#10213d' }}><BracesIcon size={9} /></Box>;
  if (type == 'cls' || type == 'css') return <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#241233' }}><PaletteIcon size={9} /></Box>;
  if (type == 'script') return <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#102214' }}><FileCodeIcon size={9} /></Box>;
  if (type == 'settings') return <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#241233' }}><PaletteIcon size={9} /></Box>;
  if (type == 'mod') return <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#331608' }}><PackageIcon size={9} /></Box>;
  if (type == 'app') return <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#341316' }}><PanelLeftIcon size={9} /></Box>;
  if (type == 'tsz') return <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#112016' }}><BracesIcon size={9} /></Box>;
  if (type == 'ts' || type == 'tsx') return <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#0d2040' }}><FileCodeIcon size={9} /></Box>;
  if (type == 'js' || type == 'jsx') return <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#332600' }}><FileCodeIcon size={9} /></Box>;
  if (type == 'md') return <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#102214' }}><FileTextIcon size={9} /></Box>;
  if (type == 'zig') return <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#331608' }}><BracesIcon size={9} /></Box>;
  return <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#1d2330' }}><FileTextIcon size={9} /></Box>;
}

function Tab(props) {
  var tab = props.tab;
  var isActive = props.isActive;
  var compact = props.compactMode == 1;

  return (
    <Pressable onPress={function() { activateTab(tab.id); }} style={isActive == 1 ? { flexDirection: 'row', alignItems: 'center', gap: compact == 1 ? 6 : 8, paddingLeft: compact == 1 ? 10 : 12, paddingRight: compact == 1 ? 8 : 10, paddingTop: compact == 1 ? 7 : 8, paddingBottom: compact == 1 ? 7 : 8, backgroundColor: '#11161f', borderRightWidth: 1, borderColor: '#18202b', borderTopWidth: 2, borderTopColor: '#2d62ff' } : { flexDirection: 'row', alignItems: 'center', gap: compact == 1 ? 6 : 8, paddingLeft: compact == 1 ? 10 : 12, paddingRight: compact == 1 ? 8 : 10, paddingTop: compact == 1 ? 7 : 8, paddingBottom: compact == 1 ? 7 : 8, backgroundColor: '#0b0e13', borderRightWidth: 1, borderColor: '#18202b' }}>
      {tab.type == 'home' && <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#0d2040' }}><HouseIcon size={9} /></Box>}
      {tab.type == 'component' && <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#10213d' }}><BracesIcon size={9} /></Box>}
      {(tab.type == 'cls' || tab.type == 'css') && <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#241233' }}><PaletteIcon size={9} /></Box>}
      {tab.type == 'script' && <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#102214' }}><FileCodeIcon size={9} /></Box>}
      {tab.type == 'settings' && <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#241233' }}><PaletteIcon size={9} /></Box>}
      {tab.type == 'mod' && <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#331608' }}><PackageIcon size={9} /></Box>}
      {tab.type == 'app' && <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#341316' }}><PanelLeftIcon size={9} /></Box>}
      {tab.type == 'tsz' && <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#112016' }}><BracesIcon size={9} /></Box>}
      {(tab.type == 'ts' || tab.type == 'tsx') && <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#0d2040' }}><FileCodeIcon size={9} /></Box>}
      {(tab.type == 'js' || tab.type == 'jsx') && <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#332600' }}><FileCodeIcon size={9} /></Box>}
      {tab.type == 'md' && <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#102214' }}><FileTextIcon size={9} /></Box>}
      {tab.type == 'zig' && <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#331608' }}><BracesIcon size={9} /></Box>}
      {tab.type != 'home' && tab.type != 'component' && tab.type != 'cls' && tab.type != 'css' && tab.type != 'script' && tab.type != 'settings' && tab.type != 'mod' && tab.type != 'app' && tab.type != 'tsz' && tab.type != 'ts' && tab.type != 'tsx' && tab.type != 'js' && tab.type != 'jsx' && tab.type != 'md' && tab.type != 'zig' && <Box style={{ paddingLeft: 4, paddingRight: 4, paddingTop: 2, paddingBottom: 2, borderRadius: 4, backgroundColor: '#1d2330' }}><FileTextIcon size={9} /></Box>}
      {isActive == 1 && <C.TabNameActive>{tab.name}</C.TabNameActive>}
      {isActive != 1 && <C.TabName>{tab.name}</C.TabName>}
      {compact != 1 && tab.git && <C.TabGitBadge>{tab.git}</C.TabGitBadge>}
      {tab.modified == 1 && <C.TabModified />}
      <Box style={{ flexGrow: 1 }} />
      {compact != 1 && tab.pinned != 1 && (
        <C.TabClose onPress={function() { closeTab(tab.id); }}>
          <XIcon size={10} />
        </C.TabClose>
      )}
    </Pressable>
  );
}

function TabBar(props) {
  return (
    <C.TabBar style={props.compactMode == 1 ? { height: 34 } : {}}>
      {props.tabs.map(function(tab, idx) {
        return <Tab key={idx} tab={tab} isActive={tab.id == props.activeId ? 1 : 0} compactMode={props.compactMode} />;
      })}
    </C.TabBar>
  );
}

export { TabBar };
