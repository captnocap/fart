function shortPathLabel(path) {
  if (!path || path == '__landing__') return 'Project landing';
  if (path == '__settings__') return 'Settings';
  var parts = path.split('/');
  return parts[parts.length - 1];
}

function primaryMainView() {
  if (activeView == 'landing' || currentFilePath == '__landing__') return 'landing';
  if (activeView == 'settings' || currentFilePath == '__settings__') return 'settings';
  return 'editor';
}

