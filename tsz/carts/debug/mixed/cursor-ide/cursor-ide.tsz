function limitList(list, limit) {
  if (limit <= 0 || list.length <= limit) return list;
  var out = [];
  var start = list.length - limit;
  if (start < 0) start = 0;
  for (var i = start; i < list.length; i++) out.push(list[i]);
  return out;
}

function takeList(list, limit) {
  if (limit <= 0 || list.length <= limit) return list;
  var out = [];
  for (var i = 0; i < list.length && i < limit; i++) out.push(list[i]);
  return out;
}

function visibleTabs(list, activeId, limit) {
  if (limit <= 0 || list.length <= limit) return list;

  var out = limitList(list, limit);
  var hasHome = 0;
  var hasActive = 0;
  for (var i = 0; i < out.length; i++) {
    if (out[i].id == 'home') hasHome = 1;
    if (out[i].id == activeId) hasActive = 1;
  }

  if (hasActive == 0) {
    for (var ai = 0; ai < list.length; ai++) {
      if (list[ai].id == activeId) {
        out.shift();
        out.push(list[ai]);
        break;
      }
    }
  }

  if (hasHome == 0) {
    out.unshift(list[0]);
    if (out.length > limit) out.pop();
  }

  return out;
}

function visibleBreadcrumbs(list, band) {
  if (band == 'minimum') return [];
  if (band == 'widget' && list.length > 2) return [list[0], list[list.length - 1]];
  if (band == 'narrow' && list.length > 3) return [list[0], list[list.length - 2], list[list.length - 1]];
  return list;
}

function CompactSurfaceButton(props) {
  return (
    <C.CompactSurfaceBtn onPress={props.onPress} style={props.active == 1 ? { backgroundColor: '#10213d', borderColor: '#2d62ff' } : {}}>
      <Box style={{ width: 10, height: 10, alignItems: 'center', justifyContent: 'center' }}>
        {props.children}
      </Box>
      {props.showLabel == 1 && <C.CompactSurfaceLabel style={props.active == 1 ? { color: '#79c0ff' } : {}}>{props.label}</C.CompactSurfaceLabel>}
    </C.CompactSurfaceBtn>
  );
}

function BreadcrumbRow(props) {
  var crumb = props.crumb;
  var showMeta = 0;
  if (crumb.meta && props.widthBand != 'widget' && props.widthBand != 'minimum') showMeta = 1;

  return (
    <C.BreadcrumbItem onPress={crumb.kind == 'home' || crumb.kind == 'workspace' ? function() { openLandingPage(); } : function() {}}>
      {props.showSep == 1 && <Box style={{ width: props.compactMode == 1 ? 8 : 9, height: props.compactMode == 1 ? 8 : 9, alignItems: 'center', justifyContent: 'center' }}><ChevronRightIcon size={props.compactMode == 1 ? 8 : 9} /></Box>}
      <C.BreadcrumbIconPill style={{ backgroundColor: crumb.tone }}>
        <Box style={{ width: props.compactMode == 1 ? 8 : 9, height: props.compactMode == 1 ? 8 : 9, alignItems: 'center', justifyContent: 'center' }}>
          {crumb.icon == 'house' && <HouseIcon size={props.compactMode == 1 ? 8 : 9} />}
          {crumb.icon == 'package' && <PackageIcon size={props.compactMode == 1 ? 8 : 9} />}
          {crumb.icon == 'folder' && <FolderIcon size={props.compactMode == 1 ? 8 : 9} />}
          {crumb.icon == 'panel-left' && <PanelLeftIcon size={props.compactMode == 1 ? 8 : 9} />}
          {crumb.icon == 'terminal' && <TerminalIcon size={props.compactMode == 1 ? 8 : 9} />}
          {crumb.icon == 'palette' && <PaletteIcon size={props.compactMode == 1 ? 8 : 9} />}
          {crumb.icon == 'braces' && <BracesIcon size={props.compactMode == 1 ? 8 : 9} />}
          {crumb.icon == 'file-json' && <FileJsonIcon size={props.compactMode == 1 ? 8 : 9} />}
          {crumb.icon == 'file-code' && <FileCodeIcon size={props.compactMode == 1 ? 8 : 9} />}
          {crumb.icon != 'house' && crumb.icon != 'package' && crumb.icon != 'folder' && crumb.icon != 'panel-left' && crumb.icon != 'terminal' && crumb.icon != 'palette' && crumb.icon != 'braces' && crumb.icon != 'file-json' && crumb.icon != 'file-code' && <FileTextIcon size={props.compactMode == 1 ? 8 : 9} />}
        </Box>
      </C.BreadcrumbIconPill>
      {crumb.active == 1 && <C.BreadcrumbTextActive>{crumb.label}</C.BreadcrumbTextActive>}
      {crumb.active != 1 && <C.BreadcrumbText>{crumb.label}</C.BreadcrumbText>}
      {showMeta == 1 && <C.BreadcrumbMeta>{crumb.meta}</C.BreadcrumbMeta>}
    </C.BreadcrumbItem>
  );
}

function SurfaceTabBar(props) {
  if (props.widthBand == 'minimum') return null;

  return <TabBar tabs={props.tabs} activeId={props.activeTabId} compactMode={props.compactMode} widthBand={props.widthBand} />;
}

function MainSurfacePane(props) {
  var compactMode = 0;
  if (props.widthBand == 'narrow' || props.widthBand == 'widget' || props.widthBand == 'minimum') compactMode = 1;

  return (
    <C.Editor style={props.shellStyle}>
      <SurfaceTabBar tabs={props.tabs} activeTabId={props.activeTabId} compactMode={compactMode} widthBand={props.widthBand} />

      {props.crumbs.length > 0 && <C.Breadcrumbs style={compactMode == 1 ? { paddingLeft: 10, paddingRight: 10, paddingTop: 7, paddingBottom: 7, gap: 4 } : props.widthBand == 'medium' ? { paddingLeft: 10, paddingRight: 10 } : {}}>
        {props.crumbs.map(function(crumb, idx) {
          return <BreadcrumbRow key={idx} crumb={crumb} showSep={idx > 0 ? 1 : 0} compactMode={compactMode} widthBand={props.widthBand} />;
        })}
      </C.Breadcrumbs>}

      {props.activeView == 'landing' && <ProjectLanding
        workspaceName={workspaceName}
        workspaceTagline={workspaceTagline}
        workDir={workDir}
        gitBranch={gitBranch}
        gitRemote={gitRemote}
        branchAhead={branchAhead}
        branchBehind={branchBehind}
        changedCount={changedCount}
        stagedCount={stagedCount}
        widthBand={props.widthBand}
        stats={props.landingStats}
        projects={props.landingProjects}
        recentFiles={props.landingRecent}
        connections={props.landingConnections}
        onOpenPath={function(path) { openFileByPath(path); }}
        onIndexWorkspace={function() { indexProject('.'); }}
        onOpenSettings={function() { openSettingsSurface(); }}
      />}

      {props.activeView == 'settings' && <SettingsPanel
        activeSection={settingsSection}
        selectedProviderId={selectedProviderId}
        selectedModelName={modelDisplayName}
        workspaceName={workspaceName}
        gitBranch={gitBranch}
        agentStatusText={agentStatusText}
        workDir={workDir}
        widthBand={props.widthBand}
        sections={[
          { id: 'providers', label: 'Providers', meta: 'model routing + auth + components', tone: '#79c0ff', icon: 'globe', count: '' + settingsProviders.length },
          { id: 'context', label: 'Context', meta: 'workspace + git + external sources', tone: '#7ee787', icon: 'folder', count: '' + settingsContextRows.length },
          { id: 'memory', label: 'Memory', meta: 'session + sqlite + transcript stores', tone: '#d2a8ff', icon: 'bot', count: '' + settingsMemoryRows.length },
          { id: 'plugins', label: 'Plugins', meta: 'lua + qjs + marketplace parity', tone: '#ffa657', icon: 'palette', count: '' + settingsPluginRows.length },
          { id: 'automations', label: 'Automations', meta: 'ifttt rules + build hooks', tone: '#ff7b72', icon: 'sparkles', count: '' + settingsAutomationRows.length },
          { id: 'capabilities', label: 'Capabilities', meta: 'existing runtime references to bake in', tone: '#ffb86b', icon: 'braces', count: '' + settingsCapabilityRows.length },
        ]}
        providers={settingsProviders}
        contextRows={settingsContextRows}
        memoryRows={settingsMemoryRows}
        pluginRows={settingsPluginRows}
        automationRows={settingsAutomationRows}
        capabilityRows={settingsCapabilityRows}
        onSelectSection={function(sectionId) { setSettingsSection(sectionId); }}
        onSelectProvider={function(providerId) { setSelectedProviderId(providerId); }}
      />}

      {props.activeView == 'editor' && <Editor
        content={editorContent}
        editorRows={editorRows}
        lineNumbers={lineNumbers}
        totalLines={totalLines}
        cursorLine={cursorPosition.line}
        modified={editorModified}
        currentFilePath={currentFilePath}
        widthBand={props.widthBand}
        windowHeight={windowHeight}
      />}

      {props.showTerminal == 1 && <TerminalPanel
        workDir={workDir}
        gitBranch={gitBranch}
        widthBand={props.widthBand}
        style={props.terminalStyle}
      />}
    </C.Editor>
  );
}

// Initialize on first render
if (ready == 0) {
  initData();
  setReady(1);
}

function App() {
  var mainSurface = primaryMainView();
  var compactMode = 0;
  var widgetMode = 0;
  var minimumMode = 0;
  var mediumMode = 0;
  var rightRail = showSearch == 1 ? 'search' : showChat == 1 ? 'agent' : '';
  var tabsForBar = openTabs;
  var crumbsForBar = visibleBreadcrumbs(breadcrumbs, widthBand);
  var landingStats = workspaceStats;
  var landingRecent = takeList(landingRecentFiles, 6);
  var landingConnections = gitConnections;
  var showStatusBar = 0;
  var showDockedSearch = 0;
  var showDockedChat = 0;
  var showDockedTerminal = 0;
  var showCompactLabels = 1;
  var compactMainView = compactSurface == 'landing' ? 'landing' : compactSurface == 'settings' ? 'settings' : 'editor';

  if (widthBand == 'medium') mediumMode = 1;
  if (widthBand == 'widget') {
    compactMode = 1;
    widgetMode = 1;
  }
  if (widthBand == 'narrow') compactMode = 1;
  if (widthBand == 'minimum') {
    compactMode = 1;
    widgetMode = 1;
    minimumMode = 1;
    showCompactLabels = 0;
  }

  if (compactMode == 1) {
    if (minimumMode == 1) tabsForBar = visibleTabs(openTabs, activeTabId, 2);
    else if (widgetMode == 1) tabsForBar = visibleTabs(openTabs, activeTabId, 3);
    else tabsForBar = visibleTabs(openTabs, activeTabId, 4);
  } else if (mediumMode == 1) {
    tabsForBar = visibleTabs(openTabs, activeTabId, 6);
  }

  if (minimumMode == 1) landingStats = takeList(workspaceStats, 2);
  else if (widgetMode == 1) landingStats = takeList(workspaceStats, 3);

  if (minimumMode == 1) landingRecent = takeList(landingRecentFiles, 3);
  else if (widgetMode == 1) landingRecent = takeList(landingRecentFiles, 4);
  else if (compactMode == 1) landingRecent = takeList(landingRecentFiles, 5);

  if (compactMode == 1) {
    if (widgetMode == 1) landingConnections = takeList(gitConnections, 3);
    else landingConnections = takeList(gitConnections, 4);
  }

  if (minimumMode != 1 && windowHeight >= 300) showStatusBar = 1;
  if (compactMode != 1 && rightRail == 'search') showDockedSearch = 1;
  if (compactMode != 1 && rightRail == 'agent') showDockedChat = 1;
  if (showTerminal == 1 && compactMode != 1) showDockedTerminal = 1;

  if (compactSurface != 'landing' && compactSurface != 'editor' && compactSurface != 'settings') compactMainView = mainSurface;

  if (compactMode == 1) {
    return (
      <C.WindowFrame>
        <C.WindowResizeTop />
        <C.WindowFrameMiddle>
          <C.WindowResizeLeft />
          <C.Shell>
            <TopBar
              title={currentFilePath}
              displayTitle={currentFilePath == '__landing__' ? 'Project landing' : currentFilePath == '__settings__' ? 'Settings' : minimumMode == 1 ? shortPathLabel(currentFilePath) : currentFilePath}
              workspaceName={workspaceName}
              workspaceTagline={workspaceTagline}
              gitBranch={gitBranch}
              changedCount={changedCount}
              stagedCount={stagedCount}
              widthBand={widthBand}
              settingsActive={compactSurface == 'settings'}
              searchActive={compactSurface == 'search'}
              chatActive={compactSurface == 'agent'}
              terminalActive={compactSurface == 'terminal'}
              style={{ height: minimumMode == 1 ? 40 : 42, paddingLeft: 10, paddingRight: 10 }}
              onOpenHome={function() { openLandingPage(); }}
              onOpenSettings={function() { openSettingsSurface(); }}
              onRefreshWorkspace={function() { refreshWorkspace(); }}
              onToggleChat={function() {
                if (compactSurface == 'agent') {
                  setShowChat(0);
                  setCompactSurfaceState(mainSurface);
                } else {
                  setShowChat(1);
                  setCompactSurfaceState('agent');
                }
              }}
              onToggleTerminal={function() {
                openTerminal();
                if (compactSurface == 'terminal') {
                  setShowTerminal(0);
                  setCompactSurfaceState(mainSurface);
                } else {
                  setShowTerminal(1);
                  setCompactSurfaceState('terminal');
                }
              }}
              onToggleSearch={function() {
                if (compactSurface == 'search') {
                  setShowSearch(0);
                  setCompactSurfaceState(mainSurface);
                } else {
                  setShowSearch(1);
                  searchProject(searchQuery);
                  setCompactSurfaceState('search');
                }
              }}
            />

            <C.Workspace style={{ flexDirection: 'column' }}>
              <C.CompactSurfaceBar>
                <CompactSurfaceButton label="Files" showLabel={showCompactLabels} active={compactSurface == 'explorer' ? 1 : 0} onPress={function() { setCompactSurfaceState('explorer'); }}><FolderIcon size={11} /></CompactSurfaceButton>
                {mainSurface == 'landing' && <CompactSurfaceButton label="Projects" showLabel={showCompactLabels} active={compactSurface == 'landing' ? 1 : 0} onPress={function() { openLandingPage(); }}><HouseIcon size={11} /></CompactSurfaceButton>}
                {mainSurface == 'editor' && <CompactSurfaceButton label="Editor" showLabel={showCompactLabels} active={compactSurface == 'editor' ? 1 : 0} onPress={function() { setCompactSurfaceState('editor'); }}><PanelLeftIcon size={11} /></CompactSurfaceButton>}
                <CompactSurfaceButton label="Settings" showLabel={showCompactLabels} active={compactSurface == 'settings' ? 1 : 0} onPress={function() { openSettingsSurface(); }}><PaletteIcon size={11} /></CompactSurfaceButton>
                <CompactSurfaceButton label="Search" showLabel={showCompactLabels} active={compactSurface == 'search' ? 1 : 0} onPress={function() { setShowSearch(1); searchProject(searchQuery); setCompactSurfaceState('search'); }}><SearchIcon size={11} /></CompactSurfaceButton>
                <CompactSurfaceButton label="Term" showLabel={showCompactLabels} active={compactSurface == 'terminal' ? 1 : 0} onPress={function() { openTerminal(); setShowTerminal(1); setCompactSurfaceState('terminal'); }}><TerminalIcon size={11} /></CompactSurfaceButton>
                <CompactSurfaceButton label="Agent" showLabel={showCompactLabels} active={compactSurface == 'agent' ? 1 : 0} onPress={function() { setShowChat(1); setCompactSurfaceState('agent'); }}><MessageSquareIcon size={11} /></CompactSurfaceButton>
              </C.CompactSurfaceBar>

              {compactSurface == 'explorer' && <Sidebar
                files={files}
                tabs={openTabs}
                gitChanges={gitChanges}
                workspaceName={workspaceName}
                workDir={workDir}
                gitBranch={gitBranch}
                changedCount={changedCount}
                stagedCount={stagedCount}
                currentFilePath={currentFilePath}
                compactMode={1}
                widthBand={widthBand}
                style={{ width: '100%', borderRightWidth: 0 }}
                onOpenHome={function() { openLandingPage(); }}
                onRefreshWorkspace={function() { refreshWorkspace(); }}
                onSelectPath={function(path) { openFileByPath(path); }}
              />}

              {(compactSurface == 'landing' || compactSurface == 'editor' || compactSurface == 'settings') && <MainSurfacePane
                shellStyle={{ borderLeftWidth: 0, borderRightWidth: 0 }}
                tabs={tabsForBar}
                activeTabId={activeTabId}
                crumbs={crumbsForBar}
                activeView={compactMainView}
                widthBand={widthBand}
                landingStats={landingStats}
                landingProjects={landingProjects}
                landingRecent={landingRecent}
                landingConnections={landingConnections}
                showTerminal={0}
                terminalStyle={{}}
              />}

              {compactSurface == 'search' && <SearchPanel
                query={searchQuery}
                results={searchResults}
                workspaceName={workspaceName}
                gitBranch={gitBranch}
                widthBand={widthBand}
                style={{ width: '100%', borderLeftWidth: 0, flexGrow: 1, flexBasis: 0 }}
                onClose={function() { setShowSearch(0); setCompactSurfaceState(mainSurface); }}
                onOpenResult={function(path, line) { openSearchResult(path, line); }}
              />}

              {compactSurface == 'agent' && <ChatPanel
                messages={chatMessages}
                isGenerating={isGenerating}
                currentFilePath={currentFilePath}
                gitBranch={gitBranch}
                gitRemote={gitRemote}
                changedCount={changedCount}
                workspaceName={workspaceName}
                gitConnections={gitConnections}
                activeView={activeView}
                widthBand={widthBand}
                style={{ width: '100%', borderLeftWidth: 0, flexGrow: 1, flexBasis: 0 }}
              />}

              {compactSurface == 'terminal' && <TerminalPanel
                workDir={workDir}
                gitBranch={gitBranch}
                widthBand={widthBand}
                style={{ flexGrow: 1, flexBasis: 0, minHeight: 0, borderTopWidth: 0 }}
                onClose={function() { setShowTerminal(0); setCompactSurfaceState(mainSurface); }}
              />}
            </C.Workspace>

            {showStatusBar == 1 && <StatusBar
              gitBranch={gitBranch}
              gitStatus={gitStatus}
              gitRemote={gitRemote}
              branchAhead={branchAhead}
              branchBehind={branchBehind}
              changedCount={changedCount}
              stagedCount={stagedCount}
              cursorLine={cursorPosition.line}
              cursorColumn={cursorPosition.column}
              languageMode={languageMode}
              errors={errors}
              warnings={warnings}
              modified={editorModified}
              fileName={currentFilePath}
              workDir={workDir}
              selectedModel={modelDisplayName}
              agentStatusText={agentStatusText}
              widthBand={widthBand}
              compactMode={1}
            />}
          </C.Shell>
          <C.WindowResizeRight />
        </C.WindowFrameMiddle>
        <C.WindowResizeBottom />
      </C.WindowFrame>
    );
  }

  return (
    <C.WindowFrame>
      <C.WindowResizeTop />
      <C.WindowFrameMiddle>
        <C.WindowResizeLeft />
        <C.Shell>
          <TopBar
            title={currentFilePath}
            displayTitle={currentFilePath == '__landing__' ? 'Project landing' : currentFilePath == '__settings__' ? 'Settings' : minimumMode == 1 ? shortPathLabel(currentFilePath) : currentFilePath}
            workspaceName={workspaceName}
            workspaceTagline={workspaceTagline}
            gitBranch={gitBranch}
            changedCount={changedCount}
            stagedCount={stagedCount}
            widthBand={widthBand}
            settingsActive={activeView == 'settings'}
            searchActive={showDockedSearch}
            chatActive={showDockedChat}
            terminalActive={showTerminal}
            style={mediumMode == 1 ? { paddingLeft: 12, paddingRight: 12 } : {}}
            onOpenHome={function() { openLandingPage(); }}
            onOpenSettings={function() { openSettingsSurface(); }}
            onRefreshWorkspace={function() { refreshWorkspace(); }}
            onToggleChat={function() { setShowChat(1 - showChat); }}
            onToggleTerminal={function() { openTerminal(); setShowTerminal(1 - showTerminal); }}
            onToggleSearch={function() { setShowSearch(1 - showSearch); }}
          />

          <C.Workspace>
            <Sidebar
              files={files}
              tabs={openTabs}
              gitChanges={gitChanges}
              workspaceName={workspaceName}
              workDir={workDir}
              gitBranch={gitBranch}
              changedCount={changedCount}
              stagedCount={stagedCount}
              currentFilePath={currentFilePath}
              widthBand={widthBand}
              style={mediumMode == 1 ? { width: 248 } : {}}
              onOpenHome={function() { openLandingPage(); }}
              onRefreshWorkspace={function() { refreshWorkspace(); }}
              onSelectPath={function(path) { openFileByPath(path); }}
            />

            <MainSurfacePane
              shellStyle={{}}
              tabs={tabsForBar}
              activeTabId={activeTabId}
              crumbs={crumbsForBar}
              activeView={activeView}
              widthBand={widthBand}
              landingStats={landingStats}
              landingProjects={landingProjects}
              landingRecent={landingRecent}
              landingConnections={landingConnections}
              showTerminal={showDockedTerminal}
              terminalStyle={{ height: mediumMode == 1 ? 210 : 250 }}
            />

            {showDockedSearch == 1 && <SearchPanel
              query={searchQuery}
              results={searchResults}
              workspaceName={workspaceName}
              gitBranch={gitBranch}
              widthBand={widthBand}
              style={{ width: mediumMode == 1 ? 320 : 390 }}
              onClose={function() { setShowSearch(0); }}
              onOpenResult={function(path, line) { openSearchResult(path, line); }}
            />}

            {showDockedChat == 1 && <ChatPanel
              messages={chatMessages}
              isGenerating={isGenerating}
              currentFilePath={currentFilePath}
              gitBranch={gitBranch}
              gitRemote={gitRemote}
              changedCount={changedCount}
              workspaceName={workspaceName}
              gitConnections={gitConnections}
              activeView={activeView}
              widthBand={widthBand}
              style={{ width: mediumMode == 1 ? 340 : 420 }}
            />}
          </C.Workspace>

          {showStatusBar == 1 && <StatusBar
            gitBranch={gitBranch}
            gitStatus={gitStatus}
            gitRemote={gitRemote}
            branchAhead={branchAhead}
            branchBehind={branchBehind}
            changedCount={changedCount}
            stagedCount={stagedCount}
            cursorLine={cursorPosition.line}
            cursorColumn={cursorPosition.column}
            languageMode={languageMode}
            errors={errors}
            warnings={warnings}
            modified={editorModified}
            fileName={currentFilePath}
            workDir={workDir}
            selectedModel={modelDisplayName}
            agentStatusText={agentStatusText}
            widthBand={widthBand}
            compactMode={0}
            style={mediumMode == 1 ? { height: 26 } : {}}
          />}
        </C.Shell>
        <C.WindowResizeRight />
      </C.WindowFrameMiddle>
      <C.WindowResizeBottom />
    </C.WindowFrame>
  );
}
