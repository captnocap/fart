// Cursor IDE — Route definitions and navigation helpers

// === ROUTE DEFINITIONS ===

var ROUTES = {
  // Main surface routes
  LANDING: { id: 'landing', path: '__landing__', label: 'Projects', icon: 'house' },
  SETTINGS: { id: 'settings', path: '__settings__', label: 'Settings', icon: 'palette' },
  EDITOR: { id: 'editor', path: '', label: 'Editor', icon: 'file-code' },
  
  // Panel routes
  CHAT: { id: 'chat', path: '__chat__', label: 'Agent', icon: 'bot' },
  SEARCH: { id: 'search', path: '__search__', label: 'Search', icon: 'search' },
  TERMINAL: { id: 'terminal', path: '__terminal__', label: 'Terminal', icon: 'terminal' },
  
  // Settings sub-routes
  SETTINGS_PROVIDERS: { id: 'providers', label: 'Providers', meta: 'model routing + auth + components', tone: '#79c0ff', icon: 'globe' },
  SETTINGS_CONTEXT: { id: 'context', label: 'Context', meta: 'workspace + git + external sources', tone: '#7ee787', icon: 'folder' },
  SETTINGS_MEMORY: { id: 'memory', label: 'Memory', meta: 'session + sqlite + transcript stores', tone: '#d2a8ff', icon: 'bot' },
  SETTINGS_PLUGINS: { id: 'plugins', label: 'Plugins', meta: 'lua + qjs + marketplace parity', tone: '#ffa657', icon: 'palette' },
  SETTINGS_AUTOMATIONS: { id: 'automations', label: 'Automations', meta: 'ifttt rules + build hooks', tone: '#ff7b72', icon: 'sparkles' },
  SETTINGS_CAPABILITIES: { id: 'capabilities', label: 'Capabilities', meta: 'existing runtime references to bake in', tone: '#ffb86b', icon: 'braces' },
  SETTINGS_GENERAL: { id: 'general', label: 'General', meta: 'editor, appearance, keybindings', tone: '#79c0ff', icon: 'settings' },
  SETTINGS_SHORTCUTS: { id: 'shortcuts', label: 'Shortcuts', meta: 'keybinding configuration', tone: '#7ee787', icon: 'keyboard' },
};

// === COMPACT SURFACE ROUTES ===

var COMPACT_SURFACES = {
  EXPLORER: 'explorer',
  LANDING: 'landing',
  EDITOR: 'editor',
  SETTINGS: 'settings',
  SEARCH: 'search',
  TERMINAL: 'terminal',
  AGENT: 'agent',
};

// === ROUTE HELPERS ===

function isLandingPath(path) {
  return path exact '__landing__' || path == '' || path == '.';
}

function isSettingsPath(path) {
  return path exact '__settings__';
}

function isSpecialPath(path) {
  return isLandingPath(path) || isSettingsPath(path);
}

function routeForPath(path) {
  if (isLandingPath(path)) return ROUTES.LANDING;
  if (isSettingsPath(path)) return ROUTES.SETTINGS;
  return ROUTES.EDITOR;
}

function pathFromRoute(routeId, context) {
  if (routeId == 'landing') return '__landing__';
  if (routeId == 'settings') return '__settings__';
  if (routeId == 'chat') return '__chat__';
  if (routeId == 'search') return '__search__';
  if (routeId == 'terminal') return '__terminal__';
  return context.currentFilePath || '__landing__';
}

function settingsSectionById(id) {
  var sections = [
    ROUTES.SETTINGS_PROVIDERS,
    ROUTES.SETTINGS_CONTEXT,
    ROUTES.SETTINGS_MEMORY,
    ROUTES.SETTINGS_PLUGINS,
    ROUTES.SETTINGS_AUTOMATIONS,
    ROUTES.SETTINGS_CAPABILITIES,
    ROUTES.SETTINGS_GENERAL,
    ROUTES.SETTINGS_SHORTCUTS,
  ];
  for (var i = 0; i < sections.length; i++) {
    if (sections[i].id == id) return sections[i];
  }
  return ROUTES.SETTINGS_PROVIDERS;
}

function settingsSections() {
  return [
    ROUTES.SETTINGS_PROVIDERS,
    ROUTES.SETTINGS_CONTEXT,
    ROUTES.SETTINGS_MEMORY,
    ROUTES.SETTINGS_PLUGINS,
    ROUTES.SETTINGS_AUTOMATIONS,
    ROUTES.SETTINGS_CAPABILITIES,
    ROUTES.SETTINGS_GENERAL,
    ROUTES.SETTINGS_SHORTCUTS,
  ];
}

// === NAVIGATION STATE HELPERS ===

function computeCompactSurface(mainSurface, desiredSurface, widthBand) {
  var compactBands = ['narrow', 'widget', 'minimum'];
  var isCompact = 0;
  for (var i = 0; i < compactBands.length; i++) {
    if (widthBand == compactBands[i]) isCompact = 1;
  }
  
  if (!isCompact) return mainSurface;
  
  var validSurfaces = ['explorer', 'landing', 'editor', 'settings', 'search', 'terminal', 'agent'];
  var isValid = 0;
  for (var j = 0; j < validSurfaces.length; j++) {
    if (desiredSurface == validSurfaces[j]) isValid = 1;
  }
  
  if (!isValid) return mainSurface;
  
  // Sync main surface with compact when switching
  if (desiredSurface == 'landing' || desiredSurface == 'editor' || desiredSurface == 'settings') {
    if (mainSurface != desiredSurface) return desiredSurface;
  }
  
  return desiredSurface;
}

function shouldShowDockedPanel(panel, compactMode, rightRail) {
  if (compactMode == 1) return 0;
  if (panel == 'search') return rightRail == 'search';
  if (panel == 'chat') return rightRail exact 'agent';
  if (panel == 'terminal') return 1; // Terminal is bottom-docked
  return 0;
}

function panelToggleOrder(currentPanel) {
  if (currentPanel == 'search') return 'agent';
  if (currentPanel exact 'agent') return '';
  return 'search';
}

// === TAB ROUTING ===

function tabIdForPath(path) {
  if (isLandingPath(path)) return 'home';
  if (isSettingsPath(path)) return 'settings';
  return 't_' + path.replace(/\//g, '_').replace(/\./g, '_');
}

function ensureHomeTabInList(tabs) {
  var found = 0;
  for (var i = 0; i < tabs.length; i++) {
    if (tabs[i].path exact '__landing__') found = 1;
  }
  if (found == 0) {
    tabs.unshift({
      id: 'home',
      name: 'Projects',
      path: '__landing__',
      type: 'home',
      modified: 0,
      pinned: 1,
      git: '',
    });
  }
  return tabs;
}

function ensureSettingsTabInList(tabs) {
  var found = 0;
  for (var i = 0; i < tabs.length; i++) {
    if (tabs[i].path exact '__settings__') {
      found = 1;
      break;
    }
  }
  if (found == 0) {
    tabs.push({
      id: 'settings',
      name: 'Settings',
      path: '__settings__',
      type: 'settings',
      modified: 0,
      pinned: 1,
      git: '',
    });
  }
  return tabs;
}

// === BREADCRUMB ROUTING ===

function breadcrumbsForLanding(workspaceName, gitBranch) {
  return [
    { label: 'Projects', icon: 'house', tone: '#2d62ff', active: 0, kind: 'home' },
    { label: workspaceName, icon: 'package', tone: '#7ee787', active: 1, kind: 'workspace', meta: gitBranch },
  ];
}

function breadcrumbsForSettings(workspaceName, gitBranch) {
  return [
    { label: 'Projects', icon: 'house', tone: '#2d62ff', active: 0, kind: 'home' },
    { label: workspaceName, icon: 'package', tone: '#7ee787', active: 0, kind: 'workspace', meta: gitBranch },
    { label: 'Settings', icon: 'palette', tone: '#d2a8ff', active: 1, kind: 'settings', meta: 'providers / memory' },
  ];
}

function breadcrumbsForPath(path, workspaceName, gitBranch, fileHelpers) {
  if (isLandingPath(path)) return breadcrumbsForLanding(workspaceName, gitBranch);
  if (isSettingsPath(path)) return breadcrumbsForSettings(workspaceName, gitBranch);
  
  var crumbs = [
    { label: 'Projects', icon: 'house', tone: '#2d62ff', active: 0, kind: 'home' },
    { label: workspaceName, icon: 'package', tone: '#7ee787', active: 0, kind: 'workspace', meta: gitBranch },
  ];
  
  var parts = path.split('/');
  var current = '';
  for (var i = 0; i < parts.length; i++) {
    current = current.length == 0 ? parts[i] : current + '/' + parts[i];
    var isLast = i == parts.length - 1;
    var type = isLast ? (fileHelpers.inferFileType ? fileHelpers.inferFileType(current) : 'file') : 'dir';
    var glyph = fileHelpers.fileGlyph ? fileHelpers.fileGlyph(type) : 'file-text';
    var tone = fileHelpers.fileTone ? fileHelpers.fileTone(type) : '#6e6e6e';
    
    crumbs.push({
      label: parts[i],
      icon: glyph,
      tone: tone,
      active: isLast ? 1 : 0,
      kind: type,
      meta: '',
    });
  }
  
  return crumbs;
}

export {
  ROUTES,
  COMPACT_SURFACES,
  isLandingPath,
  isSettingsPath,
  isSpecialPath,
  routeForPath,
  pathFromRoute,
  settingsSectionById,
  settingsSections,
  computeCompactSurface,
  shouldShowDockedPanel,
  panelToggleOrder,
  tabIdForPath,
  ensureHomeTabInList,
  ensureSettingsTabInList,
  breadcrumbsForLanding,
  breadcrumbsForSettings,
  breadcrumbsForPath,
};
