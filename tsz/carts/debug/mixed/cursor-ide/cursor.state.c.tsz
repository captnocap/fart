// Cursor IDE — Centralized state definitions and helpers

// === CORE STATE TYPES ===

function createTab(id, name, path, type) {
  return {
    id: id,
    name: name,
    path: path,
    type: type || 'file',
    modified: 0,
    pinned: 0,
    git: '',
  };
}

function createFileItem(name, path, type, indent) {
  return {
    name: name,
    path: path,
    type: type || 'file',
    indent: indent || 0,
    expanded: 0,
    selected: 0,
    visible: 1,
    git: '',
    hot: 0,
  };
}

function createMessage(role, text, model) {
  return {
    role: role,
    text: text,
    time: 'now',
    model: model || '',
    mode: '',
    attachments: [],
    toolSnapshot: [],
  };
}

function createAgentCard(id, name, status) {
  return {
    id: id,
    name: name,
    status: status || 'idle',
    mode: 'ask',
    sessionId: '',
    transcript: [],
    tools: [],
    parentId: '',
    childIds: [],
    progress: 0,
    startedAt: 0,
    lastActivity: 0,
  };
}

function createProvider(id, name, short, tone) {
  return {
    id: id,
    short: short || id,
    name: name,
    tone: tone || '#79c0ff',
    status: 'planned',
    driver: '',
    env: '',
    defaultModel: '',
    route: '',
    summary: '',
    detail: '',
    pressure: '',
    capabilities: [],
    models: [],
    endpoints: [],
    auth: {},
  };
}

function createContextItem(name, owner, source) {
  return {
    name: name,
    owner: owner || '',
    source: source || '',
    summary: '',
    stress: '',
    output: '',
    tone: '#79c0ff',
    status: 'planned',
  };
}

function createMemoryBank(name, backend, scope) {
  return {
    name: name,
    backend: backend || 'Lua heap',
    scope: scope || 'session',
    retention: 'ephemeral',
    summary: '',
    risk: '',
    tone: '#79c0ff',
    status: 'planned',
  };
}

function createPluginRuntime(name, runtime) {
  return {
    name: name,
    runtime: runtime || '',
    summary: '',
    stress: '',
    tone: '#79c0ff',
    status: 'reference',
  };
}

function createAutomationRule(name, runtime) {
  return {
    name: name,
    runtime: runtime || '',
    summary: '',
    tone: '#ff7b72',
    status: 'planned',
  };
}

function createCapability(name, status, tone) {
  return {
    name: name,
    status: status || 'planned',
    tone: tone || '#79c0ff',
    surface: '',
    summary: '',
    reference: '',
    pressure: '',
  };
}

function createSearchResult(file, line, text) {
  return {
    file: file,
    line: line || 1,
    text: text || '',
    matches: 1,
  };
}

function createTerminalLine(text, type) {
  return {
    text: text,
    type: type || 'output',
  };
}

function createBreadcrumb(label, icon, tone, kind) {
  return {
    label: label,
    icon: icon || 'file-text',
    tone: tone || '#6e6e6e',
    active: 0,
    kind: kind || 'file',
    meta: '',
  };
}

function createAttachment(type, name, path) {
  return {
    id: 'a' + Math.floor(Math.random() * 1000000),
    type: type,
    name: name,
    path: path,
  };
}

function createToolExecution(id, name, input) {
  return {
    id: id,
    name: name,
    input: input,
    status: 'running',
    percent: 0,
    result: '',
  };
}

function createMarketplaceItem(id, name, type) {
  return {
    id: id,
    name: name,
    type: type || 'extension',
    publisher: '',
    version: '',
    description: '',
    downloads: 0,
    rating: 0,
    tone: '#79c0ff',
    installed: 0,
    enabled: 0,
    categories: [],
  };
}

function createPluginEntry(id, name, runtime) {
  return {
    id: id,
    name: name,
    runtime: runtime || 'lua',
    version: '',
    description: '',
    hooks: [],
    rules: [],
    skills: [],
    commands: [],
    agents: [],
    mcpServers: [],
    permissions: [],
    enabled: 0,
    tone: '#79c0ff',
  };
}

// === DERIVED STATE HELPERS ===

function deriveWidthBand(width, height) {
  if (width <= 360 || height <= 250) return 'minimum';
  if (width <= 560 || height <= 360) return 'widget';
  if (width <= 920) return 'narrow';
  if (width <= 1260) return 'medium';
  return 'desktop';
}

function derivePrimaryView(activeView, currentFilePath) {
  if (activeView == 'landing' || currentFilePath exact '__landing__') return 'landing';
  if (activeView == 'settings' || currentFilePath exact '__settings__') return 'settings';
  return 'editor';
}

function deriveCompactMode(widthBand) {
  return widthBand exact 'narrow' || widthBand exact 'widget' || widthBand exact 'minimum' ? 1 : 0;
}

function deriveWidgetMode(widthBand) {
  return widthBand exact 'widget' || widthBand exact 'minimum' ? 1 : 0;
}

function deriveMinimumMode(widthBand) {
  return widthBand exact 'minimum' ? 1 : 0;
}

function deriveShowStatusBar(widthBand, windowHeight) {
  if (widthBand exact 'minimum') return 0;
  if (windowHeight < 300) return 0;
  return 1;
}

function limitList(list, limit) {
  if (limit <= 0 || list.length <= limit) return list;
  var out = [];
  var start = list.length - limit;
  if (start < 0) start = 0;
  for (var i = start; i < list.length; i++) out.push(list[i]);
  return out;
}

function takeList(list, limit) {
  if (limit <= 0 || list.length <= limit) return list;
  var out = [];
  for (var i = 0; i < list.length && i < limit; i++) out.push(list[i]);
  return out;
}

function visibleTabs(list, activeId, limit) {
  if (limit <= 0 || list.length <= limit) return list;
  var out = limitList(list, limit);
  var hasHome = 0;
  var hasActive = 0;
  for (var i = 0; i < out.length; i++) {
    if (out[i].id == 'home') hasHome = 1;
    if (out[i].id == activeId) hasActive = 1;
  }
  if (hasActive == 0) {
    for (var ai = 0; ai < list.length; ai++) {
      if (list[ai].id == activeId) {
        out.shift();
        out.push(list[ai]);
        break;
      }
    }
  }
  if (hasHome == 0) {
    out.unshift(list[0]);
    if (out.length > limit) out.pop();
  }
  return out;
}

function visibleBreadcrumbs(list, band) {
  if (band exact 'minimum') return [];
  if (band exact 'widget' && list.length > 2) return [list[0], list[list.length - 1]];
  if (band exact 'narrow' && list.length > 3) return [list[0], list[list.length - 2], list[list.length - 1]];
  return list;
}

export {
  createTab,
  createFileItem,
  createMessage,
  createAgentCard,
  createProvider,
  createContextItem,
  createMemoryBank,
  createPluginRuntime,
  createAutomationRule,
  createCapability,
  createSearchResult,
  createTerminalLine,
  createBreadcrumb,
  createAttachment,
  createToolExecution,
  createMarketplaceItem,
  createPluginEntry,
  deriveWidthBand,
  derivePrimaryView,
  deriveCompactMode,
  deriveWidgetMode,
  deriveMinimumMode,
  deriveShowStatusBar,
  limitList,
  takeList,
  visibleTabs,
  visibleBreadcrumbs,
};
