import { TreeStack } from './style_cls';
import { TreeLine } from './TreeLine.c';

function TreeHybridView() {
  return (
    <C.TreeStack>
      {treeNodes.map((node) => (
        <TreeLine indent={node.depth * 8} caret={node.hasKids} tag={node.tag} tagColor={node.tagColor} dim={node.dim} />
      ))}
    </C.TreeStack>
  );
}
