import { TreeStack, TreeRow, TreeBranchOpen, TreeDim } from './style_cls';

function TreeHybridView() {
  return (
    <C.TreeStack>
      {treeNodes.map((node) => (
        <C.TreeRow>
          <C.TreeBranchOpen>{node.caret}</C.TreeBranchOpen>
          <Text fontSize={11} color={node.tagColor}>{node.tag}</Text>
          <C.TreeDim>{node.dim}</C.TreeDim>
        </C.TreeRow>
      ))}
    </C.TreeStack>
  );
}
