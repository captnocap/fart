// Isolated repro: spaceBetween in a row
// Left group and right group should be pushed apart

const [count, setCount] = useState(0);

function App() {
  return (
    <Box style={{ backgroundColor: "#0f0f23", padding: 20, width: "100%", height: "100%", gap: 20 }}>
      <Text fontSize={16} color="#ffffff">Space Between Test</Text>

      <Text fontSize={10} color="#64748b">Row with spaceBetween — LEFT and RIGHT should be on opposite sides:</Text>
      <Box style={{ flexDirection: "row", justifyContent: "spaceBetween", backgroundColor: "#1e293b", padding: 10, borderRadius: 6 }}>
        <Text fontSize={12} color="#e2e8f0">LEFT</Text>
        <Text fontSize={12} color="#e2e8f0">RIGHT</Text>
      </Box>

      <Text fontSize={10} color="#64748b">Two groups with spaceBetween:</Text>
      <Box style={{ flexDirection: "row", justifyContent: "spaceBetween", alignItems: "center", backgroundColor: "#1e293b", padding: 10, borderRadius: 6 }}>
        <Box style={{ flexDirection: "row", gap: 16 }}>
          <Text fontSize={12} color="#e2e8f0">For you</Text>
          <Text fontSize={12} color="#71767b">Following</Text>
        </Box>
        <Box style={{ flexDirection: "row", gap: 12 }}>
          <Text fontSize={12} color="#71767b">Search</Text>
          <Text fontSize={12} color="#71767b">Notifs</Text>
        </Box>
      </Box>

      <Text fontSize={10} color="#64748b">Row with gap=40 (should have big space):</Text>
      <Box style={{ flexDirection: "row", gap: 40, backgroundColor: "#1e293b", padding: 10, borderRadius: 6 }}>
        <Text fontSize={12} color="#ef4444">A</Text>
        <Text fontSize={12} color="#3b82f6">B</Text>
        <Text fontSize={12} color="#22c55e">C</Text>
      </Box>

      <Pressable onPress={() => { setCount(count + 1) }} style={{ padding: 8, backgroundColor: "#7c3aed", borderRadius: 6 }}>
        <Text fontSize={12} color="#ffffff">{`Clicked: ${count}`}</Text>
      </Pressable>
    </Box>
  );
}
