import { Box, Text } from '@reactjit/ui';
import { useState, useEffect } from 'react';

export default function SpinnerTest() {
  const [idx, setIdx] = useState(0);

  useEffect(() => {
    const interval = setInterval(() => {
      setIdx((i) => (i + 1) % 12);
    }, 100);
    return () => clearInterval(interval);
  }, []);

  const colors = ['red', 'blue', 'green', 'yellow', 'cyan', 'magenta'];
  const positions = [0, 45, 90, 135, 180, 225, 270, 315, 0, 45, 90, 135];
  const pos = positions[idx];

  return (
    <Box style={{ width: '100%', height: '100%', backgroundColor: 'black', padding: 20, flexDirection: 'column', gap: 20 }}>
      <Text style={{ fontSize: 24, color: 'white' }}>Spinner Matrix</Text>

      <Box style={{ flexDirection: 'row', gap: 16, flexWrap: 'wrap', flexGrow: 1 }}>
        {colors.map((color, i) => (
          <Box
            key={i}
            style={{
              width: 60,
              height: 60,
              backgroundColor: color,
              borderRadius: 8,
              opacity: (i === (idx % 6)) ? 1 : 0.5,
            }}
          />
        ))}
      </Box>
    </Box>
  );
}
