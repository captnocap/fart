// Creative Concepts script — timer and interaction logic.

var _crTick = 0;
setInterval(function() {
  _crTick = _crTick + 1;
  setCrTurns(_crTick);
  if (_crTick % 7 === 0) {
    setCrMode('tool_use');
    setCrDot(0xf97316);
  } else if (_crTick % 5 === 0) {
    setCrMode('thinking');
    setCrDot(0xa78bfa);
  } else {
    setCrMode('idle');
    setCrDot(0x4ade80);
  }
  if (_crTick % 11 === 0) {
    setCrIncidents(crIncidents + 1);
  }
}, 1500);

function evolve() {
  var n = lifePressCount + 1;
  setLifePressCount(n);
  if (n > 8) setLifePhase(3);
  else if (n > 4) setLifePhase(2);
  else if (n > 1) setLifePhase(1);
}
