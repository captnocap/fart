// Dev Server process manager — polls PID file and log.
// Reads /tmp/tsz-dev.pid to check if dev server is running.
// Reads dev-server.log for scrolling log feed.

var PID_PATH = '/tmp/tsz-dev.pid';
var LOG_PATH = '/run/user/1000/claude-sessions/reactjit/dev-server.log';
var _logLines = [];
var _logOffset = 0;

function pollDevServer() {
  // Check PID file
  var pidRaw = __fs_readfile(PID_PATH);
  if (pidRaw && pidRaw.length > 0) {
    var pid = pidRaw.trim();
    // Check if process is actually running via /proc
    var procStat = __fs_readfile('/proc/' + pid + '/stat');
    if (procStat && procStat.length > 0) {
      setDevRunning(1);
      setDevPid(pid);
      setDevDot(0x4ade80);
      setDevBadgeBg(0x166534);
      setDevStatusText('running');
    } else {
      setDevRunning(0);
      setDevPid('');
      setDevDot(0xf85149);
      setDevBadgeBg(0x2d1214);
      setDevStatusText('stale PID');
    }
  } else {
    setDevRunning(0);
    setDevPid('');
    setDevDot(0x484f58);
    setDevBadgeBg(0x272c33);
    setDevStatusText('stopped');
  }

  // Read log file
  var logRaw = __fs_readfile(LOG_PATH);
  if (logRaw && logRaw.length > 0) {
    var lines = logRaw.split('\n');
    // Keep last 200 lines
    var start = 0;
    if (lines.length > 200) start = lines.length - 200;
    var ll = [];
    var successCount = 0;
    var failCount = 0;
    var lastStatus = '';
    for (var i = start; lines.length > i; i = i + 1) {
      var line = lines[i];
      if (line.length === 0) continue;

      // Detect build status from log lines
      if (line.indexOf('BUILD OK') >= 0 || line.indexOf('build success') >= 0 || line.indexOf('compiled') >= 0) {
        successCount = successCount + 1;
        lastStatus = 'success';
      }
      if (line.indexOf('BUILD FAIL') >= 0 || line.indexOf('error:') >= 0 || line.indexOf('FAILED') >= 0) {
        failCount = failCount + 1;
        lastStatus = 'fail';
      }

      // Color-code log lines
      var lineColor = 0x8b949e;
      if (line.indexOf('error') >= 0 || line.indexOf('FAIL') >= 0) lineColor = 0xf85149;
      else if (line.indexOf('warn') >= 0) lineColor = 0xd29922;
      else if (line.indexOf('OK') >= 0 || line.indexOf('success') >= 0 || line.indexOf('compiled') >= 0) lineColor = 0x3fb950;
      else if (line.indexOf('reload') >= 0 || line.indexOf('hot-reload') >= 0) lineColor = 0x58a6ff;

      ll.push({ text: line, color: lineColor });
    }
    setLogEntries(ll);
    setLogCount(ll.length);

    // Set build status
    if (lastStatus === 'success') {
      setBuildStatus('success');
      setBuildDot(0x3fb950);
      setBuildBadgeBg(0x0d2818);
    } else if (lastStatus === 'fail') {
      setBuildStatus('failed');
      setBuildDot(0xf85149);
      setBuildBadgeBg(0x2d1214);
    } else {
      setBuildStatus('unknown');
      setBuildDot(0x484f58);
      setBuildBadgeBg(0x272c33);
    }
    setBuildSuccessCount(successCount);
    setBuildFailCount(failCount);
  } else {
    setLogEntries([{ text: 'No log file found', color: 0x484f58 }]);
    setLogCount(0);
    setBuildStatus('no log');
    setBuildDot(0x484f58);
    setBuildBadgeBg(0x272c33);
    setBuildSuccessCount(0);
    setBuildFailCount(0);
  }
}

pollDevServer();
setInterval(function() { pollDevServer(); }, 2000);
