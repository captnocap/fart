// Projects script — queries supervisor DB for project overview data.
// Uses __exec to call query.sh json helpers + git log for recent commits.

var DB_DIR = '/home/siah/creative/reactjit/tsz/carts/supervisor-dashboard/db';
var QUERY_SH = DB_DIR + '/query.sh';

function statusColor(status) {
  if (status === 'in-progress') return 0x58a6ff;
  if (status === 'done') return 0x3fb950;
  if (status === 'blocked') return 0xf85149;
  if (status === 'review') return 0xd29922;
  return 0x484f58;
}

function loadProjects() {
  var raw = __exec(QUERY_SH + ' json-projects 2>/dev/null');
  if (!raw || raw.length === 0) {
    // Fall back to direct sqlite query
    raw = __exec("sqlite3 -json /run/user/1000/claude-sessions/supervisor.db \"SELECT id, name, description, repo_path, created_at, updated_at FROM projects ORDER BY updated_at DESC;\" 2>/dev/null");
  }
  if (!raw || raw.length === 0) {
    setProjList([]);
    setProjCount(0);
    return;
  }

  try {
    var projects = JSON.parse(raw);
    var cards = [];

    for (var i = 0; projects.length > i; i = i + 1) {
      var p = projects[i];

      // Get worker count for this project
      var wRaw = __exec("sqlite3 -json /run/user/1000/claude-sessions/supervisor.db \"SELECT COUNT(*) as cnt FROM workers WHERE project_id = " + p.id + ";\" 2>/dev/null");
      var workerCnt = 0;
      try { var wData = JSON.parse(wRaw); workerCnt = wData[0].cnt; } catch(e) {}

      // Get active worker count
      var waRaw = __exec("sqlite3 -json /run/user/1000/claude-sessions/supervisor.db \"SELECT COUNT(*) as cnt FROM workers WHERE project_id = " + p.id + " AND status = 'active';\" 2>/dev/null");
      var activeCnt = 0;
      try { var waData = JSON.parse(waRaw); activeCnt = waData[0].cnt; } catch(e) {}

      // Get task counts by status
      var tRaw = __exec("sqlite3 -json /run/user/1000/claude-sessions/supervisor.db \"SELECT status, COUNT(*) as cnt FROM tasks WHERE project_id = " + p.id + " GROUP BY status;\" 2>/dev/null");
      var taskBacklog = 0;
      var taskProgress = 0;
      var taskDone = 0;
      var taskBlocked = 0;
      var taskTotal = 0;
      try {
        var tData = JSON.parse(tRaw);
        for (var j = 0; tData.length > j; j = j + 1) {
          var row = tData[j];
          taskTotal = taskTotal + row.cnt;
          if (row.status === 'backlog') taskBacklog = row.cnt;
          if (row.status === 'in-progress') taskProgress = row.cnt;
          if (row.status === 'done') taskDone = row.cnt;
          if (row.status === 'blocked') taskBlocked = row.cnt;
        }
      } catch(e) {}

      cards.push({
        name: p.name || 'unnamed',
        path: p.repo_path || '',
        projId: p.id,
        workerLabel: activeCnt + '/' + workerCnt + ' workers',
        taskLabel: taskTotal + ' tasks',
        backlogLabel: taskBacklog + ' backlog',
        progressLabel: taskProgress + ' active',
        doneLabel: taskDone + ' done',
        blockedLabel: taskBlocked + ' blocked',
        lastActivity: (p.updated_at || '').substring(0, 16),
        dotColor: activeCnt > 0 ? 0x3fb950 : 0x484f58,
        hasBlocked: taskBlocked > 0 ? 1 : 0
      });
    }

    setProjList(cards);
    setProjCount(cards.length);
  } catch(e) {
    setProjList([]);
    setProjCount(0);
  }
}

function selectProject(idx) {
  setProjSelectedIdx(idx);
  var proj = null;
  // Re-fetch to get detail
  var raw = __exec("sqlite3 -json /run/user/1000/claude-sessions/supervisor.db \"SELECT id, name, description, repo_path FROM projects ORDER BY updated_at DESC;\" 2>/dev/null");
  try {
    var projects = JSON.parse(raw);
    if (idx >= 0 && projects.length > idx) {
      proj = projects[idx];
    }
  } catch(e) { return; }
  if (!proj) return;

  setProjDetName(proj.name);
  setProjDetPath(proj.repo_path || '');
  setProjDetDesc(proj.description || '');

  // Load tasks for this project
  var tRaw = __exec(QUERY_SH + " json-tasks '" + proj.name + "' 2>/dev/null");
  if (!tRaw || tRaw.length === 0) {
    tRaw = __exec("sqlite3 -json /run/user/1000/claude-sessions/supervisor.db \"SELECT id, title, status, priority, COALESCE(objective,'') as objective FROM tasks WHERE project_id = " + proj.id + " ORDER BY priority, id;\" 2>/dev/null");
  }
  var taskCards = [];
  try {
    var tasks = JSON.parse(tRaw);
    for (var i = 0; tasks.length > i; i = i + 1) {
      var t = tasks[i];
      taskCards.push({
        title: t.title || '',
        status: t.status || 'backlog',
        tid: '#' + t.id,
        statusColor: statusColor(t.status),
        statusBg: t.status === 'in-progress' ? 0x0c2d6b : t.status === 'done' ? 0x0d2818 : t.status === 'blocked' ? 0x3d1117 : 0x21262d
      });
    }
  } catch(e) {}
  setProjDetTasks(taskCards);
  setProjDetTaskCount(taskCards.length);

  // Load workers for this project
  var wRaw = __exec(QUERY_SH + " json-workers '" + proj.name + "' 2>/dev/null");
  if (!wRaw || wRaw.length === 0) {
    wRaw = __exec("sqlite3 -json /run/user/1000/claude-sessions/supervisor.db \"SELECT w.id, w.pane_id, w.session_id, w.status, COALESCE(t.title,'') as current_task FROM workers w LEFT JOIN tasks t ON t.id = w.current_task_id WHERE w.project_id = " + proj.id + " ORDER BY w.last_seen_at DESC;\" 2>/dev/null");
  }
  var workerCards = [];
  try {
    var workers = JSON.parse(wRaw);
    for (var i = 0; workers.length > i; i = i + 1) {
      var w = workers[i];
      workerCards.push({
        session: (w.session_id || '').substring(0, 4),
        pane: 'pane ' + (w.pane_id || 0),
        status: w.status || 'idle',
        task: w.current_task || '--',
        dotColor: w.status === 'active' ? 0x3fb950 : 0x484f58
      });
    }
  } catch(e) {}
  setProjDetWorkers(workerCards);
  setProjDetWorkerCount(workerCards.length);

  // Load recent commits from git log
  var repoPath = proj.repo_path || '/home/siah/creative/reactjit';
  var gitRaw = __exec("cd " + repoPath + " && git log --oneline -10 2>/dev/null");
  var commits = [];
  if (gitRaw && gitRaw.length > 0) {
    var lines = gitRaw.split('\n');
    for (var i = 0; lines.length > i; i = i + 1) {
      var line = lines[i].trim();
      if (line.length === 0) continue;
      var spaceIdx = line.indexOf(' ');
      var hash = spaceIdx > 0 ? line.substring(0, spaceIdx) : line;
      var msg = spaceIdx > 0 ? line.substring(spaceIdx + 1) : '';
      commits.push({ hash: hash, msg: msg });
    }
  }
  setProjDetCommits(commits);
  setProjDetCommitCount(commits.length);

  // Load recent events
  var eRaw = __exec(QUERY_SH + " json-events '" + proj.name + "' 10 2>/dev/null");
  var events = [];
  try {
    var evts = JSON.parse(eRaw);
    for (var i = 0; evts.length > i; i = i + 1) {
      var e = evts[i];
      events.push({
        etype: e.event_type || '',
        time: (e.created_at || '').substring(11, 16),
        worker: (e.worker_session || '').substring(0, 4)
      });
    }
  } catch(e) {}
  setProjDetEvents(events);
  setProjDetEventCount(events.length);
}

loadProjects();
