// Search script — calls fts-search.sh and parses sqlite3 column output.
// Writes results to JSON for the search.tsz component.

var FTS_SEARCH = '/home/siah/creative/reactjit/tsz/carts/supervisor-dashboard/db/fts-search.sh';
var DB_PATH = '/run/user/1000/claude-sessions/supervisor.db';

// Project list cache
var projectsLoaded = 0;

function roleColor(role) {
  if (role === 'human') return 0x58a6ff;
  if (role === 'assistant') return 0x3fb950;
  return 0x8b949e;
}

function roleBg(role) {
  if (role === 'human') return 0x0c2d6b;
  if (role === 'assistant') return 0x0d2818;
  return 0x1f2937;
}

function loadProjects() {
  if (projectsLoaded === 1) return;
  var raw = __exec('sqlite3 -separator "|" ' + DB_PATH + ' "SELECT DISTINCT p.name FROM projects p JOIN sessions s ON s.project_id = p.id JOIN messages m ON m.session_id = s.id GROUP BY p.name ORDER BY COUNT(m.id) DESC;"');
  if (!raw || raw.length === 0) return;
  var lines = raw.split('\n');
  var pl = [{ name: 'all', label: 'All Projects' }];
  for (var i = 0; lines.length > i; i = i + 1) {
    var name = lines[i].trim();
    if (name.length === 0) continue;
    pl.push({ name: name, label: name });
  }
  setSrchProjects(pl);
  setSrchProjectCount(pl.length);
  projectsLoaded = 1;
}

function doSearch() {
  var query = __get_text_input('srch_input');
  if (!query || query.length === 0) {
    setSrchResults([]);
    setSrchResultCount(0);
    return;
  }

  var cmd = FTS_SEARCH + ' search "' + query + '" --limit 50';

  // Apply project filter
  if (srchFilterIdx > 0) {
    var projects = srchProjects;
    if (projects.length > srchFilterIdx) {
      cmd = cmd + ' --project ' + projects[srchFilterIdx].name;
    }
  }

  var raw = __exec(cmd);
  if (!raw || raw.length === 0) {
    setSrchResults([]);
    setSrchResultCount(0);
    return;
  }

  // Parse sqlite3 column output — skip header lines (first 2 lines are header + separator)
  var lines = raw.split('\n');
  var results = [];
  var startLine = 0;
  // Find where data starts (after header and separator)
  for (var i = 0; lines.length > i; i = i + 1) {
    if (lines[i].indexOf('---') === 0 || lines[i].indexOf('------') > -1) {
      startLine = i + 1;
      break;
    }
  }

  for (var j = startLine; lines.length > j; j = j + 1) {
    var line = lines[j].trim();
    if (line.length === 0) continue;

    // sqlite3 column format: id  role  content_preview  timestamp  project  jsonl_path
    // Split by multiple spaces (column mode uses at least 2 spaces between fields)
    var parts = line.split(/\s{2,}/);
    if (parts.length === 0) continue;

    var msgId = parts[0] || '';
    var role = parts[1] || '';
    var content = parts[2] || '';
    var timestamp = parts[3] || '';
    var project = parts[4] || '';

    // Trim and truncate content for display
    if (content.length > 300) {
      content = content.substring(0, 300) + '...';
    }

    // Format time
    var timeStr = timestamp;
    if (timeStr.length > 16) {
      timeStr = timeStr.substring(0, 10) + ' ' + timeStr.substring(11, 16);
    }

    results.push({
      msgId: msgId,
      role: role,
      content: content,
      time: timeStr,
      project: project,
      roleColor: roleColor(role),
      roleBg: roleBg(role)
    });
  }

  setSrchResults(results);
  setSrchResultCount(results.length);
}

function loadStats() {
  var raw = __exec(FTS_SEARCH + ' stats 2>&1');
  if (!raw || raw.length === 0) return;

  // Parse message count from stats output
  var lines = raw.split('\n');
  for (var i = 0; lines.length > i; i = i + 1) {
    var line = lines[i].trim();
    if (line.indexOf('Messages:') === 0) {
      var parts = line.split(/\s+/);
      if (parts.length > 1) {
        setSrchTotalMessages(parseInt(parts[1]) || 0);
      }
    }
    if (line.indexOf('Sessions:') === 0) {
      var parts2 = line.split(/\s+/);
      if (parts2.length > 1) {
        setSrchTotalSessions(parseInt(parts2[1]) || 0);
      }
    }
  }
}

// Initial load
loadProjects();
loadStats();
