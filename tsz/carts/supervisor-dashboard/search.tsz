// Search — FTS5 full-text search across all Claude conversation history.
// Search input + project filter + scrolling results list.

import { Panel, PanelHeader, Title, Badge, BadgeText, CountText } from './style.cls';
import { doSearch, loadProjects, loadStats } from './search.script';

// Search state
const [srchResults, setSrchResults] = useState([{ msgId: '', role: '', content: '', time: '', project: '', roleColor: 0x8b949e, roleBg: 0x1f2937 }]);
const [srchResultCount, setSrchResultCount] = useState(0);
const [srchProjects, setSrchProjects] = useState([{ name: 'all', label: 'All Projects' }]);
const [srchProjectCount, setSrchProjectCount] = useState(0);
const [srchFilterIdx, setSrchFilterIdx] = useState(0);
const [srchTotalMessages, setSrchTotalMessages] = useState(0);
const [srchTotalSessions, setSrchTotalSessions] = useState(0);

function SearchPage() {
  return (
    <Box style={{ flexDirection: 'column', width: '100%', height: '100%', gap: 8 }}>
      <Box style={{ flexDirection: 'row', gap: 8, alignItems: 'center' }}>
        <C.CountText>{`${srchTotalMessages} messages`}</C.CountText>
        <C.CountText>{`${srchTotalSessions} sessions`}</C.CountText>
        {srchResultCount > 0 && <C.Badge style={{ backgroundColor: 0x0c2d6b }}>
          <C.BadgeText>{`${srchResultCount} results`}</C.BadgeText>
        </C.Badge>}
      </Box>

      <Box style={{ flexDirection: 'row', gap: 8, alignItems: 'center' }}>
        <TextInput
          placeholder="Search conversations..."
          onChangeText={() => { doSearch() }}
          inputId="srch_input"
          fontSize={12}
          style={{ flexGrow: 1, height: 32, backgroundColor: '#0d1117', borderWidth: 1, borderColor: '#30363d', borderRadius: 6, paddingLeft: 10, paddingRight: 10 }}
        />
        <ScrollView horizontal style={{ height: 28, flexShrink: 0 }}>
          {srchProjects.map((p, idx) => (
            <Pressable onPress={() => { setSrchFilterIdx(idx); doSearch() }}>
              {idx == srchFilterIdx && <C.Badge style={{ backgroundColor: 0x1f6feb, marginRight: 4 }}>
                <C.BadgeText>{p.label}</C.BadgeText>
              </C.Badge>}
              {idx != srchFilterIdx && <C.Badge style={{ backgroundColor: 0x21262d, marginRight: 4 }}>
                <C.BadgeText>{p.label}</C.BadgeText>
              </C.Badge>}
            </Pressable>
          ))}
        </ScrollView>
      </Box>

      <C.Panel style={{ flexGrow: 1 }}>
        <C.PanelHeader>
          <C.Title>Search Results</C.Title>
          <C.CountText>{`${srchResultCount}`}</C.CountText>
        </C.PanelHeader>
        <ScrollView style={{ flexGrow: 1 }}>
          {srchResults.map((r) => (
            <Box style={{ flexDirection: 'column', gap: 3, paddingTop: 8, paddingBottom: 8, paddingLeft: 10, paddingRight: 10, borderColor: '#21262d', borderWidth: 1 }}>
              <Box style={{ flexDirection: 'row', gap: 8, alignItems: 'center' }}>
                <C.Badge style={{ backgroundColor: r.roleBg }}>
                  <Text fontSize={9} color={r.roleColor}>{r.role}</Text>
                </C.Badge>
                <Text fontSize={9} color="#484f58">{r.time}</Text>
                <C.Badge style={{ backgroundColor: 0x21262d }}>
                  <Text fontSize={9} color="#8b949e">{r.project}</Text>
                </C.Badge>
                <Text fontSize={9} color="#484f58">{r.msgId}</Text>
              </Box>
              <Text fontSize={10} color="#c9d1d9">{r.content}</Text>
            </Box>
          ))}
          {srchResultCount == 0 && <Box style={{ padding: 20, alignItems: 'center' }}>
            <Text fontSize={11} color="#484f58">Type a query to search across all conversation history</Text>
          </Box>}
        </ScrollView>
      </C.Panel>
    </Box>
  );
}
