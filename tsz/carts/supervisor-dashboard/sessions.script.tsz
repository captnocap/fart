// Sessions script — reads live session JSON files from the claude-sessions dir.
// Polls every 2s to keep the session list fresh.

var SESSIONS_DIR = '/run/user/1000/claude-sessions/reactjit';

function statusDotColor(status) {
  if (status === 'active') return 0x3fb950;
  if (status === 'blocked') return 0xf85149;
  return 0x484f58;
}

function statusBadgeBg(status) {
  if (status === 'active') return 0x0d2818;
  if (status === 'blocked') return 0x3d1117;
  return 0x1f2937;
}

function statusBadgeColor(status) {
  if (status === 'active') return 0x3fb950;
  if (status === 'blocked') return 0xf85149;
  return 0x8b949e;
}

function formatAgo(pingEpoch) {
  var now = Math.floor(Date.now() / 1000);
  var diff = now - pingEpoch;
  if (diff < 0) diff = 0;
  if (diff < 60) return diff + 's ago';
  if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
  if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
  return Math.floor(diff / 86400) + 'd ago';
}

function pollSessions() {
  var listing = __exec('ls ' + SESSIONS_DIR + '/*.json 2>/dev/null');
  if (!listing || listing.length === 0) {
    setSessList([]);
    setSessCount(0);
    setSessActiveCount(0);
    return;
  }

  var files = listing.split('\n');
  var sessions = [];
  var activeCount = 0;

  for (var i = 0; files.length > i; i = i + 1) {
    var path = files[i].trim();
    if (path.length === 0) continue;
    if (path.indexOf('.json') < 0) continue;

    var raw = __fs_readfile(path);
    if (!raw || raw.length === 0) continue;

    try {
      var data = JSON.parse(raw);
      var status = data.status || 'idle';
      if (status === 'active') activeCount = activeCount + 1;

      var lastTool = data.tool || '--';
      var lastFile = data.file || '';
      if (lastFile.length > 50) {
        lastFile = '...' + lastFile.substring(lastFile.length - 47);
      }

      var recentEdits = data.recent || [];
      var editCount = recentEdits.length;
      var lastEditSummary = '';
      var lastEditFile = '';
      var lastEditTime = '';
      if (editCount > 0) {
        var last = recentEdits[editCount - 1];
        lastEditSummary = last.summary || '';
        lastEditFile = last.file || '';
        if (lastEditSummary.length > 120) {
          lastEditSummary = lastEditSummary.substring(0, 120) + '...';
        }
        if (last.time) {
          lastEditTime = formatAgo(last.time);
        }
      }

      sessions.push({
        sid: data.sid || '',
        short: data.short || '',
        status: status,
        tool: lastTool,
        file: lastFile,
        pingAgo: formatAgo(data.ping || 0),
        editCount: editCount,
        lastEditSummary: lastEditSummary,
        lastEditFile: lastEditFile,
        lastEditTime: lastEditTime,
        dotColor: statusDotColor(status),
        badgeBg: statusBadgeBg(status),
        badgeColor: statusBadgeColor(status)
      });
    } catch (e) {
      continue;
    }
  }

  setSessList(sessions);
  setSessCount(sessions.length);
  setSessActiveCount(activeCount);
}

function selectSession(idx) {
  setSessSelectedIdx(idx);
  if (idx < 0) {
    setSessDetShort('');
    setSessDetSid('');
    setSessDetStatus('');
    setSessDetTool('');
    setSessDetFile('');
    setSessDetEdits([]);
    setSessDetEditCount(0);
    return;
  }

  var sessions = sessList;
  if (sessions.length > idx) {
    var s = sessions[idx];
    setSessDetShort(s.short);
    setSessDetSid(s.sid);
    setSessDetStatus(s.status);
    setSessDetTool(s.tool);
    setSessDetFile(s.file);
  }

  // Load full recent edits from the JSON file
  var path = SESSIONS_DIR + '/' + sessions[idx].sid + '.json';
  var raw = __fs_readfile(path);
  if (!raw || raw.length === 0) return;

  try {
    var data = JSON.parse(raw);
    var edits = data.recent || [];
    var el = [];
    for (var i = 0; edits.length > i; i = i + 1) {
      var e = edits[i];
      var summary = e.summary || '';
      if (summary.length > 200) {
        summary = summary.substring(0, 200) + '...';
      }
      el.push({
        file: e.file || '',
        summary: summary,
        time: e.time ? formatAgo(e.time) : ''
      });
    }
    setSessDetEdits(el);
    setSessDetEditCount(el.length);
  } catch (e) {
    console.log('Session detail parse error: ' + e.message);
  }
}

// Initial load + polling
pollSessions();
setInterval(pollSessions, 2000);
