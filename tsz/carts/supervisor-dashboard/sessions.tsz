// Sessions — live view of active Claude Code sessions.
// Left: session list with status dots. Right: selected session detail + edit history.

import { Panel, PanelHeader, Title, Badge, BadgeText, StatusDot, CountText } from './style.cls';
import { pollSessions, selectSession } from './sessions.script';

// Session list state
const [sessList, setSessList] = useState([{ sid: '', short: '', status: '', tool: '', file: '', pingAgo: '', editCount: 0, lastEditSummary: '', lastEditFile: '', lastEditTime: '', dotColor: 0x484f58, badgeBg: 0x1f2937, badgeColor: 0x8b949e }]);
const [sessCount, setSessCount] = useState(0);
const [sessActiveCount, setSessActiveCount] = useState(0);
const [sessSelectedIdx, setSessSelectedIdx] = useState(0);

// Session detail state
const [sessDetShort, setSessDetShort] = useState('');
const [sessDetSid, setSessDetSid] = useState('');
const [sessDetStatus, setSessDetStatus] = useState('');
const [sessDetTool, setSessDetTool] = useState('');
const [sessDetFile, setSessDetFile] = useState('');
const [sessDetEdits, setSessDetEdits] = useState([{ file: '', summary: '', time: '' }]);
const [sessDetEditCount, setSessDetEditCount] = useState(0);

function SessionsPage() {
  return (
    <Box style={{ flexDirection: 'column', width: '100%', height: '100%', gap: 8 }}>
      <Box style={{ flexDirection: 'row', gap: 8, alignItems: 'center' }}>
        <C.CountText>{`${sessCount} sessions`}</C.CountText>
        <C.Badge style={{ backgroundColor: 0x0d2818 }}>
          <Text fontSize={10} color="#3fb950">{`${sessActiveCount} active`}</Text>
        </C.Badge>
      </Box>

      <Box style={{ flexDirection: 'row', flexGrow: 1, gap: 8 }}>
        <C.Panel style={{ flexGrow: 1 }}>
          <C.PanelHeader>
            <C.Title>Sessions</C.Title>
            <C.CountText>{`${sessCount}`}</C.CountText>
          </C.PanelHeader>
          <ScrollView style={{ flexGrow: 1 }}>
            {sessList.map((s, idx) => (
              <Pressable onPress={() => { selectSession(idx) }}>
                <Box style={{ flexDirection: 'column', gap: 3, paddingTop: 8, paddingBottom: 8, paddingLeft: 10, paddingRight: 10, borderColor: '#21262d', borderWidth: 1, backgroundColor: idx == sessSelectedIdx ? '#161b22' : '#0d1117' }}>
                  <Box style={{ flexDirection: 'row', gap: 8, alignItems: 'center' }}>
                    <C.StatusDot style={{ backgroundColor: s.dotColor }} />
                    <Text fontSize={12} color="#e6edf3" bold>{s.short}</Text>
                    <C.Badge style={{ backgroundColor: s.badgeBg }}>
                      <Text fontSize={9} color={s.badgeColor}>{s.status}</Text>
                    </C.Badge>
                    <Text fontSize={9} color="#484f58">{s.pingAgo}</Text>
                    <C.Badge style={{ backgroundColor: 0x21262d }}>
                      <Text fontSize={9} color="#8b949e">{s.tool}</Text>
                    </C.Badge>
                  </Box>
                  {s.file != '' && <Text fontSize={9} color="#6e7681">{s.file}</Text>}
                  {s.lastEditSummary != '' && <Box style={{ flexDirection: 'row', gap: 6, alignItems: 'center' }}>
                    <Text fontSize={9} color="#58a6ff">{s.lastEditFile}</Text>
                    <Text fontSize={9} color="#484f58">{s.lastEditTime}</Text>
                  </Box>}
                  {s.lastEditSummary != '' && <Text fontSize={9} color="#8b949e">{s.lastEditSummary}</Text>}
                </Box>
              </Pressable>
            ))}
          </ScrollView>
        </C.Panel>

        <C.Panel style={{ width: 400 }}>
          <C.PanelHeader>
            <C.Title>Session Detail</C.Title>
            {sessDetShort != '' && <Text fontSize={11} color="#58a6ff" bold>{sessDetShort}</Text>}
          </C.PanelHeader>
          {sessDetShort == '' && <Box style={{ padding: 20, alignItems: 'center' }}>
            <Text fontSize={11} color="#484f58">Select a session to view details</Text>
          </Box>}
          {sessDetShort != '' && <Box style={{ flexDirection: 'column', gap: 6, padding: 10 }}>
            <Box style={{ flexDirection: 'row', gap: 8, alignItems: 'center' }}>
              <Text fontSize={10} color="#8b949e">ID:</Text>
              <Text fontSize={10} color="#e6edf3">{sessDetSid}</Text>
            </Box>
            <Box style={{ flexDirection: 'row', gap: 8, alignItems: 'center' }}>
              <Text fontSize={10} color="#8b949e">Status:</Text>
              <Text fontSize={10} color="#e6edf3">{sessDetStatus}</Text>
            </Box>
            <Box style={{ flexDirection: 'row', gap: 8, alignItems: 'center' }}>
              <Text fontSize={10} color="#8b949e">Tool:</Text>
              <Text fontSize={10} color="#e6edf3">{sessDetTool}</Text>
            </Box>
            {sessDetFile != '' && <Box style={{ flexDirection: 'row', gap: 8, alignItems: 'center' }}>
              <Text fontSize={10} color="#8b949e">File:</Text>
              <Text fontSize={10} color="#58a6ff">{sessDetFile}</Text>
            </Box>}
          </Box>}
          {sessDetShort != '' && <Box style={{ flexDirection: 'column', gap: 2, borderColor: '#30363d', borderWidth: 1 }}>
            <Box style={{ paddingLeft: 10, paddingTop: 6, paddingBottom: 4 }}>
              <Text fontSize={10} color="#8b949e" bold>{`Recent Edits (${sessDetEditCount})`}</Text>
            </Box>
            <ScrollView style={{ flexGrow: 1 }}>
              {sessDetEdits.map((e) => (
                <Box style={{ flexDirection: 'column', gap: 2, paddingTop: 5, paddingBottom: 5, paddingLeft: 10, paddingRight: 10, borderColor: '#21262d', borderWidth: 1 }}>
                  <Box style={{ flexDirection: 'row', gap: 6, alignItems: 'center' }}>
                    <Text fontSize={9} color="#58a6ff">{e.file}</Text>
                    <Text fontSize={9} color="#484f58">{e.time}</Text>
                  </Box>
                  <Text fontSize={9} color="#c9d1d9">{e.summary}</Text>
                </Box>
              ))}
            </ScrollView>
          </Box>}
        </C.Panel>
      </Box>
    </Box>
  );
}
