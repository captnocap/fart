  Tab: { type: 'Box', style: { paddingLeft: 14, paddingRight: 14, paddingTop: 8, paddingBottom: 8, borderColor: '#010409', borderWidth: 1 } },
  TabActive: { type: 'Box', style: { paddingLeft: 14, paddingRight: 14, paddingTop: 8, paddingBottom: 8, backgroundColor: '#0d1117', borderColor: '#21262d', borderWidth: 1, borderRadius: 0 } },
  TabText: { type: 'Text', fontSize: 12, color: '#8b949e' },
  TabTextActive: { type: 'Text', fontSize: 12, color: '#e6edf3' },
