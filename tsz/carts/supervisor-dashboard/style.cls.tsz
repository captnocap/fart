  MemDetailTitle: { type: 'Text', fontSize: 16, color: '#e6edf3' },
  MemDetailMeta: { type: 'Text', fontSize: 11, color: '#8b949e' },
  FormLabel: { type: 'Text', fontSize: 10, color: '#8b949e' },
})
