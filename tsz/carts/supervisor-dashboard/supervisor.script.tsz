var VIEW_PATH = '/run/user/1000/claude-sessions/supervisor_view.json';
var PLANS_PATH = '/run/user/1000/claude-sessions/plans_view.json';
var PLAN_DETAIL_PATH = '/run/user/1000/claude-sessions/plan_detail.json';
var PLAN_SH = '/home/siah/creative/reactjit/tsz/carts/supervisor-dashboard/db/plan.sh';

function statusBg(s) {
  if (s === 'active' || s === 'in-progress') return 0x1f6feb;
  if (s === 'completed' || s === 'done') return 0x238636;
  if (s === 'paused' || s === 'pending') return 0x484f58;
  if (s === 'abandoned' || s === 'blocked') return 0xda3633;
  return 0x21262d;
}

function loadPlans() {
  var raw = __fs_readfile(PLANS_PATH);
  if (!raw || raw.length === 0) return;
  try {
    var data = JSON.parse(raw);
    var plans = data.plans || [];
    var pl = [];
    for (var i = 0; i < plans.length; i = i + 1) {
      var p = plans[i];
      pl.push({
        title: p.title,
        status: p.status,
        phaseLabel: (p.phases_done || 0) + '/' + (p.phase_count || 0) + ' phases',
        taskLabel: (p.tasks_done || 0) + '/' + (p.task_count || 0) + ' tasks',
        statusBg: statusBg(p.status),
        planId: p.id
      });
    }
    setPlanList(pl);
  } catch (e) {
    console.log('Plans parse error: ' + e.message);
  }
}

var _activePlanId = 0;

function selectPlan(id) {
  _activePlanId = id;
  // Write the detail JSON first, then read it
  __exec(PLAN_SH + ' refresh ' + id);
  loadPlanDetail(id);
}

function loadPlanDetail(planId) {
  var raw = __fs_readfile(PLAN_DETAIL_PATH);
  if (!raw || raw.length === 0) return;
  try {
    var d = JSON.parse(raw);
    if (d.id !== planId) return;
    setActivePlanTitle(d.title || '');
    setActivePlanGoal(d.goal || '');
    var phases = d.phases || [];
    var phl = [];
    for (var i = 0; i < phases.length; i = i + 1) {
      var ph = phases[i];
      phl.push({
        title: ph.title,
        status: ph.status,
        gate: ph.gate || '',
        taskLabel: (ph.tasks_done || 0) + '/' + (ph.task_count || 0),
        statusBg: statusBg(ph.status),
        phaseNum: ph.phase_number
      });
    }
    setPlanPhases(phl);
  } catch (e) {
    console.log('Plan detail parse error: ' + e.message);
  }
}

function loadAll() {
  var raw = __fs_readfile(VIEW_PATH);
  if (!raw || raw.length === 0) return;

  try {
    var data = JSON.parse(raw);

    var tasks = data.tasks || [];
    var bl = [];
    var ip = [];
    var rv = [];
    var dn = [];
    var bk = [];
    for (var i = 0; i < tasks.length; i = i + 1) {
      var t = tasks[i];
      var priBg = 0x21262d;
      if (11 > t.priority) priBg = 0xda3633;
      else if (21 > t.priority) priBg = 0xd29922;
      else if (31 > t.priority) priBg = 0x1f6feb;
      var item = {
        title: t.title,
        tid: '#' + t.id,
        pane: t.worker_pane > 0 ? 'pane ' + t.worker_pane : '',
        stepsLabel: (t.steps_done || 0) + '/' + (t.steps_total || 0),
        lastEdit: t.last_edit || '',
        priBg: priBg
      };
      if (t.status === 'backlog') bl.push(item);
      else if (t.status === 'in-progress') ip.push(item);
      else if (t.status === 'review') rv.push(item);
      else if (t.status === 'done') dn.push(item);
      else if (t.status === 'blocked') bk.push(item);
    }
    setBacklog(bl);
    setInProgress(ip);
    setReview(rv);
    setDone(dn);
    setBlocked(bk);
    setBacklogCount(bl.length);
    setProgressCount(ip.length);
    setReviewCount(rv.length);
    setDoneCount(dn.length);
    setBlockedCount(bk.length);

    var workers = data.workers || [];
    var wl = [];
    for (var j = 0; j < workers.length; j = j + 1) {
      var w = workers[j];
      var dotColor = 0x484f58;
      var badgeBg = 0x272c33;
      if (w.status === 'active') { dotColor = 0x3fb950; badgeBg = 0x0d2818; }
      else if (w.status === 'idle') { dotColor = 0xd29922; badgeBg = 0x3d2e00; }
      else if (w.status === 'stuck') { dotColor = 0xf85149; badgeBg = 0x2d1214; }
      wl.push({
        pane: 'Pane ' + w.pane_id,
        session: w.session_id,
        status: w.status,
        taskLabel: w.current_task ? w.current_task : 'none',
        dotColor: dotColor,
        badgeBg: badgeBg
      });
    }
    setWorkerList(wl);
    setWorkerCount(wl.length);

    var events = data.events || [];
    var el = [];
    for (var k = 0; k < events.length; k = k + 1) {
      var ev = events[k];
      el.push({
        etype: ev.event_type,
        payload: ev.payload_json,
        time: ev.created_at,
        worker: ev.worker_session || '-'
      });
    }
    setEventList(el);
  } catch (e) {
    console.log('Supervisor parse error: ' + e.message);
  }
}

var DETAIL_PATH = '/run/user/1000/claude-sessions/taskboard_detail.json';
var _selectedTaskId = 0;

function selectTask(id) {
  _selectedTaskId = id;
  setSelectedTask(id);
  loadDetail(id);
}

function closeDetail() {
  _selectedTaskId = 0;
  setSelectedTask(0);
}

function loadDetail(taskId) {
  var raw = __fs_readfile(DETAIL_PATH);
  if (!raw || raw.length === 0) return;
  try {
    var d = JSON.parse(raw);
    if (d.id !== taskId) return;
    setDetTitle(d.title || '');
    setDetId('#' + d.id);
    setDetStatus(d.status || '');
    setDetPriority(d.priority || 50);
    var pri = d.priority || 50;
    var priBg = 0x21262d;
    if (11 > pri) priBg = 0xda3633;
    else if (21 > pri) priBg = 0xd29922;
    else if (31 > pri) priBg = 0x1f6feb;
    setDetPriBg(priBg);
    setDetSpec(d.spec || '');
    setDetPane(d.worker_pane > 0 ? 'Pane ' + d.worker_pane : 'Unassigned');
    var steps = d.steps || [];
    var sl = [];
    for (var i = 0; i < steps.length; i = i + 1) {
      sl.push({ title: steps[i].title, isDone: steps[i].status === 'done' ? 1 : 0 });
    }
    setDetSteps(sl);
    var notes = d.notes || [];
    var nl = [];
    for (var j = 0; j < notes.length; j = j + 1) {
      nl.push({ author: notes[j].author, content: notes[j].content, time: notes[j].timestamp || '' });
    }
    setDetNotes(nl);
    var edits = d.edits || [];
    var el = [];
    for (var k = 0; k < edits.length; k = k + 1) {
      el.push({ file: edits[k].file_path, summary: edits[k].edit_summary, time: edits[k].timestamp || '' });
    }
    setDetEdits(el);
  } catch (e) {
    console.log('Detail parse error: ' + e.message);
  }
}

loadAll();
loadPlans();

// ── New task form ──
var TASKS_SH = '/home/siah/creative/reactjit/tsz/carts/supervisor-dashboard/db/tasks.sh';

function toggleNewTask() {
  if (showNewTask === 1) {
    setShowNewTask(0);
  } else {
    setShowNewTask(1);
    setNewTaskTitle('');
    setNewTaskSpec('');
  }
}

function syncNewTitle() { setNewTaskTitle(getInputText(0)); }
function syncNewSpec() { setNewTaskSpec(getInputText(1)); }

function createTask() {
  var title = getInputText(0) || '';
  if (title.length === 0) return;
  var spec = getInputText(1) || '';
  var cmd = TASKS_SH + ' create reactjit "' + title.replace(/"/g, '\\"') + '"';
  if (spec.length > 0) {
    cmd = cmd + ' --spec "' + spec.replace(/"/g, '\\"') + '"';
  }
  __exec(cmd);
  __exec(TASKS_SH + ' refresh');
  setShowNewTask(0);
  loadAll();
}

// ── Splitter drag ──
var _dragging = 0;
var _dragStartY = 0;
var _dragStartH = 0;

function startDrag() {
  _dragging = 1;
  _dragStartY = getMouseY();
  _dragStartH = topHeight;
}

setInterval(function() {
  if (_dragging === 1) {
    var down = getMouseDown();
    if (down > 0) {
      var dy = getMouseY() - _dragStartY;
      var nh = _dragStartH + dy;
      if (100 > nh) nh = 100;
      if (nh > 800) nh = 800;
      setTopHeight(nh);
    } else {
      _dragging = 0;
    }
  }
}, 16);

setInterval(function() {
  loadAll();
  loadPlans();
  if (_selectedTaskId > 0) loadDetail(_selectedTaskId);
  if (_activePlanId > 0) loadPlanDetail(_activePlanId);
}, 3000);

// Semantic state polling for terminal pane headers
function semDotColor(mode) {
  if (mode === 'idle') return 0x4ade80;
  if (mode === 'thinking') return 0xa78bfa;
  if (mode === 'tool_use') return 0xf97316;
  return 0x64748b;
}

function semBadgeBg(mode) {
  if (mode === 'idle') return 0x166534;
  if (mode === 'thinking') return 0x4c1d95;
  if (mode === 'tool_use') return 0x7c2d12;
  return 0x334155;
}

setInterval(function() {
  var s = __sem_state();
  if (!s) return;
  setSemMode0(s.mode_name);
  setSemTurns0(s.turn_count);
  setSemDot0(semDotColor(s.mode_name));
  setSemBg0(semBadgeBg(s.mode_name));
}, 300);

// ── Memory browser ──
var MEM_DIR = '/home/siah/.claude/projects/-home-siah-supervisor-claude/memory/';
var _allMems = [];
var _memFilter = 'all';
var _selFile = '';
var _selDesc = '';
var _memLoaded = false;

function memBadgeColor(t) {
  if (t === 'feedback') return 0xf97316;
  if (t === 'project') return 0x3b82f6;
  if (t === 'reference') return 0x22c55e;
  if (t === 'user') return 0xa855f7;
  return 0x6b7280;
}

function memBadgeBg(t) {
  if (t === 'feedback') return 0x7c2d12;
  if (t === 'project') return 0x1e3a5f;
  if (t === 'reference') return 0x14532d;
  if (t === 'user') return 0x581c87;
  return 0x1f2937;
}

function parseFrontmatter(raw) {
  var lines = raw.split('\n');
  var name = '';
  var desc = '';
  var type = '';
  var inFm = false;
  var fmDone = false;
  var bodyLines = [];
  for (var k = 0; lines.length > k; k = k + 1) {
    var fl = lines[k];
    if (fl === '---') {
      if (inFm) { fmDone = true; }
      else { inFm = true; }
      continue;
    }
    if (fmDone) {
      bodyLines.push(fl);
    } else if (inFm) {
      if (fl.indexOf('name:') === 0) name = fl.substring(6);
      else if (fl.indexOf('description:') === 0) desc = fl.substring(13);
      else if (fl.indexOf('type:') === 0) type = fl.substring(6);
    }
  }
  return { name: name, description: desc, type: type, content: bodyLines.join('\n') };
}

function applyMemFilter() {
  var search = (getInputText(0) || '').toLowerCase();
  var filtered = [];
  for (var i = 0; _allMems.length > i; i = i + 1) {
    var m = _allMems[i];
    if (_memFilter !== 'all' && m.type !== _memFilter) continue;
    if (search.length > 0) {
      var haystack = (m.name + ' ' + m.description + ' ' + m.content).toLowerCase();
      if (haystack.indexOf(search) < 0) continue;
    }
    filtered.push({
      filename: m.filename || '',
      name: m.name || m.filename || '',
      desc: m.description || '',
      mtype: m.type || '',
      content: m.content || '',
      date: '',
      size: m.size || 0,
      badgeColor: memBadgeColor(m.type),
      badgeBg: memBadgeBg(m.type)
    });
  }
  setMemList(filtered);
  if (filtered.length === 0) return;

  // Preserve current selection if it's still in the filtered list
  var found = -1;
  if (_selFile.length > 0) {
    for (var si = 0; filtered.length > si; si = si + 1) {
      if (filtered[si].filename === _selFile) { found = si; break; }
    }
  }

  // Only update selection if nothing was selected or selection is gone
  if (found >= 0) {
    setSelIdx(found);
  } else {
    found = 0;
    setSelIdx(0);
    _selFile = filtered[0].filename;
    setSelName(filtered[0].name);
    setSelDesc(filtered[0].desc);
    setSelContent(filtered[0].content);
    setSelType(filtered[0].mtype);
    setSelBadgeBg(filtered[0].badgeBg);
    setSelFile(filtered[0].filename);
    _selDesc = filtered[0].desc;
  }
}

function loadMemories() {
  var files = __fs_scandir(MEM_DIR);
  if (!files || files.length === 0) return;

  var mems = [];
  var cF = 0;
  var cP = 0;
  var cR = 0;
  var cU = 0;
  for (var j = 0; files.length > j; j = j + 1) {
    var f = files[j];
    if (f === 'MEMORY.md') continue;
    if (f.indexOf('.md') < 0) continue;
    var raw = __fs_readfile(MEM_DIR + f);
    if (!raw || raw.length === 0) continue;
    var fm = parseFrontmatter(raw);
    if (fm.type === 'feedback') cF = cF + 1;
    else if (fm.type === 'project') cP = cP + 1;
    else if (fm.type === 'reference') cR = cR + 1;
    else if (fm.type === 'user') cU = cU + 1;
    mems.push({
      filename: f,
      name: fm.name || f,
      description: fm.description,
      type: fm.type,
      content: fm.content,
      size: raw.length
    });
  }

  _allMems = mems;
  setMemTotal(mems.length);
  setMemFeedback(cF);
  setMemProject(cP);
  setMemReference(cR);
  setMemUser(cU);
  applyMemFilter();
}

// Called from onPress after setters — tracks selection so polling doesn't stomp it
function mem_pin(fname, desc) {
  _selFile = fname;
  _selDesc = desc;
}

function mem_filter_all() { _memFilter = 'all'; _selFile = ''; applyMemFilter(); }
function mem_filter_feedback() { _memFilter = 'feedback'; _selFile = ''; applyMemFilter(); }
function mem_filter_project() { _memFilter = 'project'; _selFile = ''; applyMemFilter(); }
function mem_filter_reference() { _memFilter = 'reference'; _selFile = ''; applyMemFilter(); }
function mem_filter_user() { _memFilter = 'user'; _selFile = ''; applyMemFilter(); }
function mem_search() { _selFile = ''; applyMemFilter(); }

function typeStr(n) {
  if (n === 0) return 'feedback';
  if (n === 1) return 'project';
  if (n === 2) return 'reference';
  if (n === 3) return 'user';
  return 'feedback';
}

function typeIdx(s) {
  if (s === 'feedback') return 0;
  if (s === 'project') return 1;
  if (s === 'reference') return 2;
  if (s === 'user') return 3;
  return 0;
}

function mem_edit() {
  setEditMode(1);
  setIsNewMem(0);
  setEditName(selName);
  setEditDesc(_selDesc);
  setEditContent(selContent);
  setEditType(typeIdx(selType));
}

function mem_new() {
  setEditMode(1);
  setIsNewMem(1);
  setEditName('');
  setEditDesc('');
  setEditContent('');
  setEditType(0);
}

function mem_cancel() { setEditMode(0); }

function mem_save() {
  var name = getInputText(1) || '';
  var desc = getInputText(2) || '';
  var content = getInputText(3) || '';
  var type = typeStr(editType);
  if (name.length === 0) return;

  var md = '---\nname: ' + name + '\ndescription: ' + desc + '\ntype: ' + type + '\n---\n\n' + content + '\n';
  var path;
  if (isNewMem === 1) {
    var slug = name.toLowerCase().replace(/[^a-z0-9]+/g, '_');
    if (slug.length > 40) slug = slug.substring(0, 40);
    path = MEM_DIR + type + '_' + slug + '.md';
  } else {
    path = MEM_DIR + selFile;
  }
  __fs_writefile(path, md);
  rebuildMemoryIndex();
  setEditMode(0);
  loadMemories();
}

function mem_delete() {
  if (!selFile || selFile.length === 0) return;
  __fs_deletefile(MEM_DIR + selFile);
  rebuildMemoryIndex();
  setEditMode(0);
  loadMemories();
}

function rebuildMemoryIndex() {
  var files = __fs_scandir(MEM_DIR);
  if (!files) return;
  var lines = [];
  for (var i = 0; files.length > i; i = i + 1) {
    var f = files[i];
    if (f === 'MEMORY.md') continue;
    if (f.indexOf('.md') < 0) continue;
    var raw = __fs_readfile(MEM_DIR + f);
    if (!raw) continue;
    var fm = parseFrontmatter(raw);
    lines.push('- [' + f + '](' + f + ') \u2014 ' + (fm.description || fm.name || f));
  }
  __fs_writefile(MEM_DIR + 'MEMORY.md', lines.join('\n') + '\n');
}

function mem_set_type_feedback() { setEditType(0); }
function mem_set_type_project() { setEditType(1); }
function mem_set_type_reference() { setEditType(2); }
function mem_set_type_user() { setEditType(3); }

function mem_sync_name() { setEditName(getInputText(1)); }
function mem_sync_desc() { setEditDesc(getInputText(2)); }
function mem_sync_content() { setEditContent(getInputText(3)); }

loadMemories();
