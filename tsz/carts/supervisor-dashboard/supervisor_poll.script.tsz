// Poll semantic state for both terminal slots.
// Compute colors in JS so the .tsz just binds state → style.

function dotColor(mode) {
  if (mode === 'idle') return 0x4ade80;
  if (mode === 'thinking') return 0xa78bfa;
  if (mode === 'tool_use') return 0xf97316;
  return 0x64748b;
}

function badgeBgColor(mode) {
  if (mode === 'idle') return 0x166534;
  if (mode === 'thinking') return 0x4c1d95;
  if (mode === 'tool_use') return 0x7c2d12;
  return 0x334155;
}

setInterval(function() {
  var s = __sem_state();
  if (!s) return;
  setMode0(s.mode_name);
  setTurns0(s.turn_count);
  setNodes0(s.node_count);
  setStream0(s.streaming ? 1 : 0);
  setStreamKind0(s.streaming_kind_name);
  setDot0(dotColor(s.mode_name));
  setBg0(badgeBgColor(s.mode_name));
}, 300);
