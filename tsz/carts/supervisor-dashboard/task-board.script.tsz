var VIEW_PATH = '/run/user/1000/claude-sessions/taskboard_view.json';
var DETAIL_PATH = '/run/user/1000/claude-sessions/taskboard_detail.json';
var TASKS_SH = __fs_readfile('/proc/self/cwd') + '/../tsz/carts/supervisor-dashboard/db/tasks.sh';

function loadBoard() {
  var raw = __fs_readfile(VIEW_PATH);
  if (!raw || raw.length === 0) return;

  try {
    var data = JSON.parse(raw);
    var tasks = data.tasks || [];

    var bl = [];
    var ip = [];
    var rv = [];
    var dn = [];
    var bk = [];

    for (var i = 0; i < tasks.length; i = i + 1) {
      var t = tasks[i];
      var priBg = 0x21262d;
      if (t.priority <= 10) priBg = 0xda3633;
      else if (t.priority <= 20) priBg = 0xd29922;
      else if (t.priority <= 30) priBg = 0x1f6feb;

      var stepPct = 0;
      if (t.steps_total > 0) stepPct = Math.floor(t.steps_done * 100 / t.steps_total);

      var item = {
        id: t.id,
        title: t.title,
        tid: '#' + t.id,
        priority: t.priority,
        priBg: priBg,
        pane: t.worker_pane > 0 ? 'pane ' + t.worker_pane : '',
        stepsDone: t.steps_done || 0,
        stepsTotal: t.steps_total || 0,
        stepsLabel: (t.steps_done || 0) + '/' + (t.steps_total || 0),
        stepPct: stepPct,
        lastEdit: t.last_edit || '',
        spec: t.spec || ''
      };

      if (t.status === 'backlog') bl.push(item);
      else if (t.status === 'in-progress') ip.push(item);
      else if (t.status === 'review') rv.push(item);
      else if (t.status === 'done') dn.push(item);
      else if (t.status === 'blocked') bk.push(item);
    }

    setBacklogList(bl);
    setProgressList(ip);
    setReviewList(rv);
    setDoneList(dn);
    setBlockedList(bk);
    setBacklogCount(bl.length);
    setProgressCount(ip.length);
    setReviewCount(rv.length);
    setDoneCount(dn.length);
    setBlockedCount(bk.length);
    setTotalCount(tasks.length);

    // Workers
    var workers = data.workers || [];
    var wl = [];
    for (var j = 0; j < workers.length; j = j + 1) {
      var w = workers[j];
      var dotColor = 0x484f58;
      if (w.status === 'active') dotColor = 0x3fb950;
      else if (w.status === 'idle') dotColor = 0xd29922;
      else if (w.status === 'stuck') dotColor = 0xf85149;
      wl.push({
        id: w.id,
        pane: 'Pane ' + w.pane_id,
        paneId: w.pane_id,
        session: w.session_id,
        status: w.status,
        taskLabel: w.current_task ? w.current_task : 'none',
        dotColor: dotColor
      });
    }
    setWorkerList(wl);
  } catch (e) {
    console.log('Task board parse error: ' + e.message);
  }
}

function loadDetail(taskId) {
  var raw = __fs_readfile(DETAIL_PATH);
  if (!raw || raw.length === 0) return;

  try {
    var d = JSON.parse(raw);
    if (d.id !== taskId) return;

    setDetTitle(d.title || '');
    setDetId('#' + d.id);
    setDetStatus(d.status || '');
    setDetPriority(d.priority || 50);
    var pri = d.priority || 50;
    var priBg = 0x21262d;
    if (11 > pri) priBg = 0xda3633;
    else if (21 > pri) priBg = 0xd29922;
    else if (31 > pri) priBg = 0x1f6feb;
    setDetPriBg(priBg);
    setDetSpec(d.spec || '');
    setDetPane(d.worker_pane > 0 ? 'Pane ' + d.worker_pane : 'Unassigned');

    var steps = d.steps || [];
    var sl = [];
    for (var i = 0; i < steps.length; i = i + 1) {
      var s = steps[i];
      sl.push({
        num: s.step_number,
        title: s.title,
        status: s.status,
        desc: s.description || '',
        isDone: s.status === 'done' ? 1 : 0
      });
    }
    setDetSteps(sl);

    var notes = d.notes || [];
    var nl = [];
    for (var j = 0; j < notes.length; j = j + 1) {
      var n = notes[j];
      nl.push({
        author: n.author,
        content: n.content,
        time: n.timestamp || ''
      });
    }
    setDetNotes(nl);

    var edits = d.edits || [];
    var el = [];
    for (var k = 0; k < edits.length; k = k + 1) {
      var ed = edits[k];
      el.push({
        file: ed.file_path,
        summary: ed.edit_summary,
        diff: ed.diff_snippet || '',
        time: ed.timestamp || ''
      });
    }
    setDetEdits(el);
  } catch (e) {
    console.log('Detail parse error: ' + e.message);
  }
}

// Initial load + poll
loadBoard();
setInterval(function() { loadBoard(); }, 3000);
setInterval(function() {
  if (selectedTask > 0) loadDetail(selectedTask);
}, 3000);
