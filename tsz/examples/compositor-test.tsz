function App() {
  const [angle, setAngle] = useState(0);

  return (
    <Box style={{ padding: 32, backgroundColor: '#1e1e2a', width: '100%', height: '100%' }}>
      <Text fontSize={20} color="#ffffff">Compositor Test</Text>
      <Text fontSize={14} color="#808080">Click the button to rotate the card</Text>

      <Box style={{ flexDirection: 'row', gap: 16, marginTop: 16 }}>
        <Pressable onPress={() => setAngle(angle + 15)} style={{ padding: 16, backgroundColor: '#4ec9b0', borderRadius: 8 }}>
          <Text fontSize={14} color="#ffffff">Rotate +15°</Text>
        </Pressable>
        <Pressable onPress={() => setAngle(0)} style={{ padding: 16, backgroundColor: '#569cd6', borderRadius: 8 }}>
          <Text fontSize={14} color="#ffffff">Reset</Text>
        </Pressable>
      </Box>

      <Box style={{ marginTop: 32, padding: 24, backgroundColor: '#2d2d3f', borderRadius: 12, width: 200, height: 120, rotation: 15, opacity: 0.9 }}>
        <Text fontSize={18} color="#ff79c6">Rotated Card</Text>
        <Text fontSize={12} color="#808080">This box is rotated 15°</Text>
      </Box>

      <Box style={{ marginTop: 32, padding: 24, backgroundColor: '#3d3d5f', borderRadius: 12, width: 200, height: 120, scaleX: 1.5, scaleY: 1.5, opacity: 0.8 }}>
        <Text fontSize={18} color="#e5c07b">Scaled Card</Text>
        <Text fontSize={12} color="#808080">This box is 1.5x scaled</Text>
      </Box>
    </Box>
  );
}
