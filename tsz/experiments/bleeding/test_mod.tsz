// test_mod.tsz — minimal module to test Smith --mod transpilation
import std from "std";

const MAX_ITEMS: usize = 256;

function brighten(color: u8, amount: u8): u8 {
    const result: u16 = @as(u16, color) + @as(u16, amount);
    if (result > 255) return 255;
    return @intCast(result);
}

export function init(): void {
    std.debug.print("module initialized\n", .{});
}

export function add(a: i64, b: i64): i64 {
    return a + b;
}
