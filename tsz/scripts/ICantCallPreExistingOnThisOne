#!/bin/bash
# Build a cart against the BLESSED engine — the one the human said is good.
#
# This is what Claude uses when it only touched compiler/ or cart code.
# The engine .so comes from the last human-blessed build.
# If the cart crashes, it's the generated code. Not the engine.
# You can't call it pre-existing because the engine has no pre-existing bugs.
#
# Usage:
#   ./scripts/ICantCallPreExistingOnThisOne carts/app.tsz
#   ./scripts/ICantCallPreExistingOnThisOne carts/app.tsz -n

set -euo pipefail
cd "$(dirname "$0")/.."

if [ "${#@}" -eq 0 ]; then
    echo "Usage: ./scripts/ICantCallPreExistingOnThisOne <cart.tsz> [flags...]"
    echo ""
    echo "Builds the cart against the BLESSED engine."
    echo "The blessed engine has no pre-existing bugs."
    echo "If it breaks: it's your generated code."
    exit 1
fi

BLESSED_SO="zig-out/lib/libreactjit-core-blessed.so"
BLESSED_A="zig-out/lib/libreactjit-core-blessed.a"
DIRTY_SO="zig-out/lib/libreactjit-core.so"
DIRTY_A="zig-out/lib/libreactjit-core.a"
BLESS_STAMP="zig-out/lib/.blessed-stamp"

# ── Require blessed engine ──────────────────────────────────────
if [ ! -f "$BLESSED_SO" ]; then
    echo ""
    echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
    echo "  NO BLESSED ENGINE"
    echo ""
    echo "  The human hasn't blessed an engine yet."
    echo "  Ask them to run: ./scripts/bless-engine"
    echo ""
    echo "  Until then, use ./scripts/buildFromMyShittyNewCode"
    echo "  (and accept that any bugs are yours)."
    echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
    exit 1
fi

echo ""
echo "┌─────────────────────────────────────────────────────────┐"
echo "│  BLESSED ENGINE BUILD                                   │"
echo "│  Using human-verified engine. No pre-existing bugs.     │"
echo "│  If it breaks: it's your compiler/cart code.            │"
echo "└─────────────────────────────────────────────────────────┘"
echo ""

# Show blessed engine info
if [ -f "$BLESS_STAMP" ]; then
    BLESSED_COMMIT=$(grep '^commit:' "$BLESS_STAMP" | cut -d' ' -f2)
    BLESSED_DATE=$(grep '^date:' "$BLESS_STAMP" | cut -d' ' -f2-)
    echo "[blessed] engine from ${BLESSED_COMMIT:0:7} ($BLESSED_DATE)"
fi

# ── Swap blessed engine into place ──────────────────────────────
# Back up the dirty engine, put blessed in its place, build, restore.
BACKUP_SO=""
BACKUP_A=""

if [ -f "$DIRTY_SO" ]; then
    BACKUP_SO=$(mktemp /tmp/rjit-dirty-so.XXXXXX)
    cp "$DIRTY_SO" "$BACKUP_SO"
fi
if [ -f "$DIRTY_A" ]; then
    BACKUP_A=$(mktemp /tmp/rjit-dirty-a.XXXXXX)
    cp "$DIRTY_A" "$BACKUP_A"
fi

# Install blessed as the active engine
cp "$BLESSED_SO" "$DIRTY_SO"
[ -f "$BLESSED_A" ] && cp "$BLESSED_A" "$DIRTY_A"

# Export the blessed engine hash so record_build() uses it even if the .so
# gets overwritten by a parallel session during the build.
export REACTJIT_ENGINE_SHA=$(sha256sum "$BLESSED_SO" | awk '{print $1}')

echo "[blessed] swapped blessed engine into place"
echo "[blessed] engine hash locked: ${REACTJIT_ENGINE_SHA:0:16}..."
echo ""

# ── Build the cart (scripts/build will skip engine rebuild — it's blessed) ──
# Override: tell scripts/build NOT to rebuild the engine
export REACTJIT_SKIP_ENGINE_BUILD=1

BUILD_EXIT=0
./scripts/build "$@" || BUILD_EXIT=$?

# ── Restore dirty engine ────────────────────────────────────────
if [ -n "$BACKUP_SO" ] && [ -f "$BACKUP_SO" ]; then
    cp "$BACKUP_SO" "$DIRTY_SO"
    rm -f "$BACKUP_SO"
fi
if [ -n "$BACKUP_A" ] && [ -f "$BACKUP_A" ]; then
    cp "$BACKUP_A" "$DIRTY_A"
    rm -f "$BACKUP_A"
fi

if [ "$BUILD_EXIT" -ne 0 ]; then
    echo ""
    echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
    echo "  BUILD FAILED against BLESSED engine."
    echo "  The engine is known good."
    echo "  This is your compiler output or cart code."
    echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
    exit "$BUILD_EXIT"
fi

echo ""
echo "[blessed] cart built successfully against blessed engine"
