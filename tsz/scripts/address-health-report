#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import subprocess
from collections import Counter
from datetime import datetime, timezone
from importlib.machinery import SourceFileLoader
from pathlib import Path


REPO_ROOT = Path(__file__).resolve().parents[2]
TSZ_ROOT = REPO_ROOT / "tsz"
REPORTS_DIR = TSZ_ROOT / "reports" / "address-health"
LATEST_JSON = REPORTS_DIR / "latest.json"
LATEST_MD = REPORTS_DIR / "latest.md"
BEST_JSON = REPORTS_DIR / "best.json"
SCHEMA_VERSION = 2

TARGETS = [
    {"label": "claude-sweatshop", "path": "tsz/carts/claude-sweatshop"},
    {"label": "compiler/smith/intent", "path": "tsz/compiler/smith/intent"},
    {"label": "cli/mixed", "path": "tsz/cli/mixed"},
]


def load_module(name: str, path: Path):
    return SourceFileLoader(name, str(path)).load_module()


def git_output(args: list[str]) -> str:
    result = subprocess.run(
        args,
        cwd=REPO_ROOT,
        capture_output=True,
        text=True,
        check=True,
    )
    return result.stdout.strip()


def gather_git_state() -> dict:
    sha = git_output(["git", "rev-parse", "HEAD"])
    short_sha = git_output(["git", "rev-parse", "--short", "HEAD"])
    branch = git_output(["git", "rev-parse", "--abbrev-ref", "HEAD"])
    status = git_output(["git", "status", "--porcelain"])
    status_lines = [line for line in status.splitlines() if line.strip()]
    return {
        "sha": sha,
        "short_sha": short_sha,
        "branch": branch,
        "dirty": bool(status_lines),
        "status_lines": status_lines,
    }


def iter_fart_files(target_path: str) -> list[Path]:
    root = Path(target_path)
    if root.is_dir():
        return sorted(path for path in root.rglob("*.fart") if path.is_file())
    return [root]


def build_address_summary(tree_mod, target_path: str, root_name: str) -> dict:
    root = Path(target_path)
    modules = [tree_mod.parse_fixture_file(path, root_name) for path in sorted(root.rglob("*.fart"))]
    report = tree_mod.summarize(modules, root_name)
    return {
        "module_count": report["module_count"],
        "summary": report["summary"],
        "error_counts": report["error_counts"],
        "unknown_root_counts": report["unknown_root_counts"],
        "top_unknown_roots": report["top_unknown_roots"],
    }


def build_nodrift_summary(nodrift_mod, target_path: str) -> dict:
    files = iter_fart_files(target_path)
    files_with_drift = 0
    total_drifts = 0
    rule_counts: Counter[str] = Counter()
    file_counts: dict[str, int] = {}

    for path in files:
        drifts = nodrift_mod.check_file(path)
        if drifts:
            files_with_drift += 1
            file_counts[str(path)] = len(drifts)
        total_drifts += len(drifts)
        for _, rule, *_ in drifts:
            rule_counts[rule] += 1

    return {
        "files_scanned": len(files),
        "files_with_drift": files_with_drift,
        "total_drifts": total_drifts,
        "rule_counts": dict(sorted(rule_counts.items())),
        "top_rules": [
            {"rule": rule, "count": count}
            for rule, count in sorted(rule_counts.items(), key=lambda item: (-item[1], item[0]))[:20]
        ],
        "file_counts": dict(sorted(file_counts.items())),
        "worst_files": [
            {"path": path, "count": count}
            for path, count in sorted(file_counts.items(), key=lambda item: (-item[1], item[0]))[:10]
        ],
    }


def load_json(path: Path) -> dict | None:
    if not path.exists():
        return None
    data = json.loads(path.read_text(encoding="utf-8"))
    if data.get("schema_version") != SCHEMA_VERSION:
        return None
    return data


def metric_delta(current: int, previous: int) -> str:
    delta = current - previous
    if delta == 0:
        return f"{current} -> {current} (0)"
    sign = "+" if delta > 0 else ""
    return f"{previous} -> {current} ({sign}{delta})"


def diff_map(current: dict[str, int], previous: dict[str, int]) -> dict:
    increases = []
    decreases = []
    new_keys = []
    gone_keys = []

    all_keys = sorted(set(current) | set(previous))
    for key in all_keys:
        cur = current.get(key, 0)
        prev = previous.get(key, 0)
        if prev == 0 and cur > 0:
            new_keys.append({"key": key, "count": cur})
        elif cur == 0 and prev > 0:
            gone_keys.append({"key": key, "count": prev})
        elif cur > prev:
            increases.append({"key": key, "before": prev, "after": cur, "delta": cur - prev})
        elif cur < prev:
            decreases.append({"key": key, "before": prev, "after": cur, "delta": cur - prev})

    return {
        "increases": increases,
        "decreases": decreases,
        "new": new_keys,
        "gone": gone_keys,
    }


def compare_target(current: dict, previous: dict | None, best: dict | None) -> dict:
    current_address = current["address"]
    current_nodrift = current["nodrift"]

    out = {
        "previous": None,
        "best": None,
    }

    if previous is not None:
        prev_address = previous["address"]
        prev_nodrift = previous["nodrift"]
        out["previous"] = {
            "address_summary": {
                key: {
                    "before": prev_address["summary"].get(key, 0),
                    "after": current_address["summary"].get(key, 0),
                    "delta": current_address["summary"].get(key, 0) - prev_address["summary"].get(key, 0),
                }
                for key in sorted(set(current_address["summary"]) | set(prev_address["summary"]))
            },
            "address_unknown_root": {
                "before": prev_address["error_counts"].get("unknown-root", 0),
                "after": current_address["error_counts"].get("unknown-root", 0),
                "delta": current_address["error_counts"].get("unknown-root", 0) - prev_address["error_counts"].get("unknown-root", 0),
            },
            "address_buckets": diff_map(current_address["error_counts"], prev_address["error_counts"]),
            "unknown_roots": diff_map(current_address["unknown_root_counts"], prev_address["unknown_root_counts"]),
            "nodrift_summary": {
                "files_with_drift": {
                    "before": prev_nodrift["files_with_drift"],
                    "after": current_nodrift["files_with_drift"],
                    "delta": current_nodrift["files_with_drift"] - prev_nodrift["files_with_drift"],
                },
                "total_drifts": {
                    "before": prev_nodrift["total_drifts"],
                    "after": current_nodrift["total_drifts"],
                    "delta": current_nodrift["total_drifts"] - prev_nodrift["total_drifts"],
                },
            },
            "nodrift_rules": diff_map(current_nodrift["rule_counts"], prev_nodrift["rule_counts"]),
        }

    if best is not None:
        out["best"] = {
            "address_fail": {
                "best": best["address_fail"],
                "current": current_address["summary"]["fail"],
                "delta_from_best": current_address["summary"]["fail"] - best["address_fail"],
            },
            "address_unknown_root": {
                "best": best["address_unknown_root"],
                "current": current_address["error_counts"].get("unknown-root", 0),
                "delta_from_best": current_address["error_counts"].get("unknown-root", 0) - best["address_unknown_root"],
            },
            "address_buckets": {
                key: {
                    "best": best["address_buckets"].get(key, 0),
                    "current": current_address["error_counts"].get(key, 0),
                    "delta_from_best": current_address["error_counts"].get(key, 0) - best["address_buckets"].get(key, 0),
                }
                for key in sorted(current_address["error_counts"])
            },
            "nodrift_files_with_drift": {
                "best": best["nodrift_files_with_drift"],
                "current": current_nodrift["files_with_drift"],
                "delta_from_best": current_nodrift["files_with_drift"] - best["nodrift_files_with_drift"],
            },
            "nodrift_total_drifts": {
                "best": best["nodrift_total_drifts"],
                "current": current_nodrift["total_drifts"],
                "delta_from_best": current_nodrift["total_drifts"] - best["nodrift_total_drifts"],
            },
            "nodrift_rules": {
                key: {
                    "best": best["nodrift_rules"].get(key, 0),
                    "current": current_nodrift["rule_counts"].get(key, 0),
                    "delta_from_best": current_nodrift["rule_counts"].get(key, 0) - best["nodrift_rules"].get(key, 0),
                }
                for key in sorted(current_nodrift["rule_counts"])
            },
        }

    return out


def build_best_metrics(history: list[dict], label: str) -> dict | None:
    candidates = [
        target
        for snapshot in history
        for target in snapshot.get("targets", [])
        if target["label"] == label
    ]
    if not candidates:
        return None

    address_bucket_keys = sorted(
        {
            key
            for target in candidates
            for key in target["address"]["error_counts"]
        }
    )
    nodrift_rule_keys = sorted(
        {
            key
            for target in candidates
            for key in target["nodrift"]["rule_counts"]
        }
    )

    return {
        "address_fail": min(target["address"]["summary"]["fail"] for target in candidates),
        "address_unknown_root": min(
            target["address"]["error_counts"].get("unknown-root", 0)
            for target in candidates
        ),
        "address_buckets": {
            key: min(target["address"]["error_counts"].get(key, 0) for target in candidates)
            for key in address_bucket_keys
        },
        "nodrift_total_drifts": min(target["nodrift"]["total_drifts"] for target in candidates),
        "nodrift_files_with_drift": min(target["nodrift"]["files_with_drift"] for target in candidates),
        "nodrift_rules": {
            key: min(target["nodrift"]["rule_counts"].get(key, 0) for target in candidates)
            for key in nodrift_rule_keys
        },
    }


def render_count_list(items: list[dict], key_name: str, count_name: str = "count") -> list[str]:
    if not items:
        return ["- none"]
    return [f"- `{item[key_name]}`: `{item[count_name]}`" for item in items]


def render_diff_entries(diff: dict, limit: int = 5) -> list[str]:
    lines: list[str] = []
    for item in diff["new"][:limit]:
        lines.append(f"- new `{item['key']}`: `{item['count']}`")
    for item in sorted(diff["increases"], key=lambda entry: (-entry["delta"], entry["key"]))[:limit]:
        sign = "+" if item["delta"] > 0 else ""
        lines.append(
            f"- `{item['key']}`: `{item['before']}` -> `{item['after']}` ({sign}{item['delta']})"
        )
    for item in sorted(diff["decreases"], key=lambda entry: (entry["delta"], entry["key"]))[:limit]:
        lines.append(
            f"- `{item['key']}`: `{item['before']}` -> `{item['after']}` ({item['delta']})"
        )
    for item in diff["gone"][:limit]:
        lines.append(f"- gone `{item['key']}`: `{item['count']}`")
    return lines or ["- none"]


def render_markdown(snapshot: dict) -> str:
    lines = [
        "# Address Health Report",
        "",
        f"Generated: `{snapshot['timestamp']}`",
        f"Git: `{snapshot['git']['short_sha']}` on `{snapshot['git']['branch']}`",
        f"Working tree: `{'dirty' if snapshot['git']['dirty'] else 'clean'}`",
        "",
        "## Regression Summary",
        "",
    ]

    stdout_lines = snapshot["regression_summary"]["lines"]
    if stdout_lines:
        lines.extend([f"- {line}" for line in stdout_lines])
    elif snapshot["regression_summary"]["has_previous"]:
        lines.append("- no changes vs previous snapshot")
    else:
        lines.append("- no previous snapshot to compare")
    lines.append("")

    for target in snapshot["targets"]:
        address = target["address"]
        nodrift = target["nodrift"]
        compare = target["compare"]
        lines.append(f"## {target['label']}")
        lines.append("")
        lines.append(f"Target: `{target['path']}`")
        lines.append("")
        lines.append("### Address")
        lines.append("")
        lines.append(f"- Module count: `{address['module_count']}`")
        lines.append(f"- `fail`: `{address['summary']['fail']}`")
        lines.append(f"- `local`: `{address['summary']['local']}`")
        lines.append(f"- `ok`: `{address['summary']['ok']}`")
        lines.append(f"- `unknown-root`: `{address['error_counts'].get('unknown-root', 0)}`")
        lines.append("")
        lines.append("Address buckets:")
        lines.append("")
        for key, value in address["error_counts"].items():
            lines.append(f"- `{key}`: `{value}`")
        lines.append("")
        lines.append("Top unknown roots:")
        lines.append("")
        lines.extend(render_count_list(address["top_unknown_roots"], "root"))
        lines.append("")
        lines.append("### Nodrift")
        lines.append("")
        lines.append(f"- Files scanned: `{nodrift['files_scanned']}`")
        lines.append(f"- Files with drift: `{nodrift['files_with_drift']}`")
        lines.append(f"- Total drifts: `{nodrift['total_drifts']}`")
        lines.append("")
        lines.append("Top nodrift rules:")
        lines.append("")
        lines.extend(render_count_list(nodrift["top_rules"], "rule"))
        lines.append("")
        lines.append("Worst-hit files:")
        lines.append("")
        lines.extend(render_count_list(nodrift["worst_files"], "path"))
        lines.append("")

        previous = compare.get("previous")
        best = compare.get("best")
        if previous is not None:
            lines.append("### Previous Delta")
            lines.append("")
            lines.append(
                f"- Address `fail`: "
                f"`{metric_delta(address['summary']['fail'], previous['address_summary']['fail']['before'])}`"
            )
            lines.append(
                f"- Address `unknown-root`: "
                f"`{metric_delta(address['error_counts'].get('unknown-root', 0), previous['address_unknown_root']['before'])}`"
            )
            lines.append(
                f"- Nodrift `total_drifts`: "
                f"`{metric_delta(nodrift['total_drifts'], previous['nodrift_summary']['total_drifts']['before'])}`"
            )
            lines.append("")
            lines.append("Address bucket changes:")
            lines.append("")
            lines.extend(render_diff_entries(previous["address_buckets"]))
            lines.append("")
            lines.append("Nodrift rule changes:")
            lines.append("")
            lines.extend(render_diff_entries(previous["nodrift_rules"]))
            lines.append("")

        if best is not None:
            lines.append("### Best So Far")
            lines.append("")
            lines.append(
                f"- Address `fail`: `{address['summary']['fail']}` "
                f"(best: `{best['address_fail']['best']}`, delta: `{best['address_fail']['delta_from_best']:+d}`)"
            )
            lines.append(
                f"- Address `unknown-root`: `{address['error_counts'].get('unknown-root', 0)}` "
                f"(best: `{best['address_unknown_root']['best']}`, delta: `{best['address_unknown_root']['delta_from_best']:+d}`)"
            )
            lines.append(
                f"- Nodrift `total_drifts`: `{nodrift['total_drifts']}` "
                f"(best: `{best['nodrift_total_drifts']['best']}`, delta: `{best['nodrift_total_drifts']['delta_from_best']:+d}`)"
            )
            lines.append("")

    return "\n".join(lines).rstrip() + "\n"


def build_regression_lines(snapshot: dict, previous: dict | None) -> list[str]:
    if previous is None:
        return []

    lines = []
    prev_by_label = {target["label"]: target for target in previous["targets"]}

    for target in snapshot["targets"]:
        prev = prev_by_label.get(target["label"])
        if prev is None:
            continue

        cur_address = target["address"]
        prev_address = prev["address"]
        cur_nodrift = target["nodrift"]
        prev_nodrift = prev["nodrift"]

        address_fail_delta = cur_address["summary"]["fail"] - prev_address["summary"]["fail"]
        if address_fail_delta != 0:
            sign = "+" if address_fail_delta > 0 else ""
            lines.append(
                f"{target['label']} address fail: {prev_address['summary']['fail']} -> "
                f"{cur_address['summary']['fail']} ({sign}{address_fail_delta})"
            )

        unknown_prev = prev_address["error_counts"].get("unknown-root", 0)
        unknown_cur = cur_address["error_counts"].get("unknown-root", 0)
        unknown_delta = unknown_cur - unknown_prev
        if unknown_delta != 0:
            sign = "+" if unknown_delta > 0 else ""
            lines.append(
                f"{target['label']} unknown-root: {unknown_prev} -> {unknown_cur} "
                f"({sign}{unknown_delta})"
            )

        nodrift_delta = cur_nodrift["total_drifts"] - prev_nodrift["total_drifts"]
        if nodrift_delta != 0:
            sign = "+" if nodrift_delta > 0 else ""
            lines.append(
                f"{target['label']} nodrift total: {prev_nodrift['total_drifts']} -> "
                f"{cur_nodrift['total_drifts']} ({sign}{nodrift_delta})"
            )

        prev_buckets = prev_address["error_counts"]
        cur_buckets = cur_address["error_counts"]
        for key in sorted(set(cur_buckets) - set(prev_buckets)):
            lines.append(f"NEW address bucket in {target['label']}: {key}: {cur_buckets[key]}")
        for key in sorted(set(cur_buckets) & set(prev_buckets)):
            delta = cur_buckets[key] - prev_buckets[key]
            if delta != 0:
                sign = "+" if delta > 0 else ""
                lines.append(
                    f"{target['label']} address bucket {key}: "
                    f"{prev_buckets[key]} -> {cur_buckets[key]} ({sign}{delta})"
                )

        prev_rules = prev_nodrift["rule_counts"]
        cur_rules = cur_nodrift["rule_counts"]
        for key in sorted(set(cur_rules) - set(prev_rules)):
            lines.append(f"NEW nodrift bucket in {target['label']}: {key}: {cur_rules[key]}")
        for key in sorted(set(cur_rules) & set(prev_rules)):
            delta = cur_rules[key] - prev_rules[key]
            if delta != 0:
                sign = "+" if delta > 0 else ""
                lines.append(
                    f"{target['label']} nodrift bucket {key}: "
                    f"{prev_rules[key]} -> {cur_rules[key]} ({sign}{delta})"
                )

    return lines


def print_stdout_summary(snapshot: dict) -> None:
    print(f"snapshot: {snapshot['markdown_path']}")
    print(f"json: {snapshot['json_path']}")
    for line in snapshot["regression_summary"]["lines"]:
        print(line)
    if not snapshot["regression_summary"]["lines"] and snapshot["regression_summary"]["has_previous"]:
        print("no changes vs previous snapshot")
    if not snapshot["regression_summary"]["lines"] and not snapshot["regression_summary"]["has_previous"]:
        print("no previous snapshot to compare")
    print("best-so-far:")
    for target in snapshot["targets"]:
        best = target["compare"].get("best")
        if best is None:
            continue
        print(
            f"{target['label']} address fail: {target['address']['summary']['fail']} "
            f"(best: {best['address_fail']['best']}, "
            f"{best['address_fail']['delta_from_best']:+d} from best)"
        )
        print(
            f"{target['label']} unknown-root: {target['address']['error_counts'].get('unknown-root', 0)} "
            f"(best: {best['address_unknown_root']['best']}, {best['address_unknown_root']['delta_from_best']:+d} from best)"
        )
        print(
            f"{target['label']} nodrift total: {target['nodrift']['total_drifts']} "
            f"(best: {best['nodrift_total_drifts']['best']}, "
            f"{best['nodrift_total_drifts']['delta_from_best']:+d} from best)"
        )


def main() -> int:
    REPORTS_DIR.mkdir(parents=True, exist_ok=True)
    os.chdir(REPO_ROOT)

    tree_mod = load_module("build_uses_fixture_tree", TSZ_ROOT / "scripts" / "build-uses-fixture-tree.py")
    nodrift_mod = load_module("nodrift_report", TSZ_ROOT / "scripts" / "nodrift")

    now = datetime.now(timezone.utc)
    stamp = now.strftime("%Y-%m-%dT%H-%M-%SZ")
    snapshot = {
        "schema_version": SCHEMA_VERSION,
        "timestamp": now.strftime("%Y-%m-%dT%H:%M:%SZ"),
        "timestamp_slug": stamp,
        "git": gather_git_state(),
        "root_name": "compiler",
        "targets": [],
    }

    previous = load_json(LATEST_JSON)
    history = [load_json(path) for path in sorted(REPORTS_DIR.glob("*.json")) if path.name not in {"latest.json", "best.json"}]
    history = [item for item in history if item is not None]

    for target in TARGETS:
        current_target = {
            "label": target["label"],
            "path": target["path"],
            "address": build_address_summary(tree_mod, target["path"], snapshot["root_name"]),
            "nodrift": build_nodrift_summary(nodrift_mod, target["path"]),
        }
        best_target = build_best_metrics(history, target["label"])
        current_target["compare"] = compare_target(
            current_target,
            None if previous is None else next((item for item in previous["targets"] if item["label"] == target["label"]), None),
            best_target,
        )
        snapshot["targets"].append(current_target)

    snapshot["regression_summary"] = {
        "has_previous": previous is not None,
        "lines": build_regression_lines(snapshot, previous),
    }

    markdown = render_markdown(snapshot)
    markdown_path = REPORTS_DIR / f"{stamp}.md"
    json_path = REPORTS_DIR / f"{stamp}.json"
    snapshot["markdown_path"] = str(markdown_path.relative_to(REPO_ROOT))
    snapshot["json_path"] = str(json_path.relative_to(REPO_ROOT))

    json_text = json.dumps(snapshot, indent=2, sort_keys=False) + "\n"
    markdown_path.write_text(markdown, encoding="utf-8")
    json_path.write_text(json_text, encoding="utf-8")
    LATEST_MD.write_text(markdown, encoding="utf-8")
    LATEST_JSON.write_text(json_text, encoding="utf-8")

    best_snapshot = {
        "schema_version": SCHEMA_VERSION,
        "updated_from": snapshot["timestamp"],
        "targets": [],
    }
    full_history = history + [snapshot]
    for target in TARGETS:
        best_target = build_best_metrics(full_history, target["label"])
        if best_target is not None:
            best_snapshot["targets"].append({"label": target["label"], "metrics": best_target})
    BEST_JSON.write_text(json.dumps(best_snapshot, indent=2, sort_keys=False) + "\n", encoding="utf-8")

    print_stdout_summary(snapshot)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
