#!/bin/bash
# Run an autotest against the QuickJS React runtime bridge.
#
# Usage:
#   scripts/autotest-qjs input_lab
#   scripts/autotest-qjs input_lab cart/input_lab.tsx
set -euo pipefail
cd "$(dirname "$0")/.."

if [ $# -lt 1 ]; then
    echo "Usage: scripts/autotest-qjs <test_name> [app_entry]"
    echo "  e.g.: scripts/autotest-qjs input_lab"
    exit 1
fi

NAME="$1"
APP_ENTRY="${2:-$NAME}"
if [[ "$APP_ENTRY" != cart/* ]]; then
    APP_ENTRY="cart/${APP_ENTRY}"
fi
if [[ "$APP_ENTRY" != *.tsx ]]; then
    APP_ENTRY="${APP_ENTRY}.tsx"
fi

TEST_FILE="tests/${NAME}.autotest"
APP_FILE="../experiments/hermes-stack/${APP_ENTRY}"
BUNDLE_SCRIPT="../experiments/hermes-stack/scripts/build-bundle.mjs"
CURRENT_APP_FILE="../experiments/hermes-stack/runtime/current_app.tsx"
DEFAULT_APP_ENTRY="cart/d152.tsx"
BINARY="zig-out/bin/qjs_${NAME}"

if [ ! -f "$TEST_FILE" ]; then
    echo "[autotest-qjs] ERROR: no test file at $TEST_FILE"
    exit 1
fi

if [ ! -f "$APP_FILE" ]; then
    echo "[autotest-qjs] ERROR: no React runtime app at $APP_FILE"
    exit 1
fi

TMP_CURRENT_APP=$(mktemp)
cp "$CURRENT_APP_FILE" "$TMP_CURRENT_APP"
cleanup() {
    cp "$TMP_CURRENT_APP" "$CURRENT_APP_FILE" >/dev/null 2>&1 || true
    node "$BUNDLE_SCRIPT" "$DEFAULT_APP_ENTRY" >/dev/null 2>&1 || true
    rm -f "$TMP_CURRENT_APP"
}
trap cleanup EXIT

echo "[autotest-qjs] bundling $APP_ENTRY..."
node "$BUNDLE_SCRIPT" "$APP_ENTRY" >/dev/null

echo "[autotest-qjs] building $NAME..."
zig build app -Dapp-name="qjs_${NAME}" -Dapp-source=qjs_app.zig -Doptimize=ReleaseFast >/dev/null

if [ ! -x "$BINARY" ]; then
    echo "[autotest-qjs] ERROR: binary not found at $BINARY"
    exit 1
fi

TIMESTAMP=$(date '+%Y%m%d_%H%M%S')
FLAT_DIR="tests/screenshots/${NAME}"
mkdir -p "$FLAT_DIR"
rm -f "$FLAT_DIR"/step_*.png "$FLAT_DIR"/manifest.txt "$FLAT_DIR"/proof.png

echo "[autotest-qjs] running..."
set +e
TMPLOG=$(mktemp)
ZIGOS_HEADLESS=1 ZIGOS_WITNESS=autotest ZIGOS_WITNESS_FILE="$TEST_FILE" timeout -s KILL 5 "$BINARY" >"$TMPLOG" 2>&1 || true
grep -v "AUTOTEST RESULT" "$TMPLOG" | grep -E "hover|rightclick|wheel|focus|type|key|click|expect|reject|color|bg|border|styles|PASS|FAIL|OK|VERIFY" || true
rm -f "$TMPLOG"
set -e

EXIT=1
if [ -f "${FLAT_DIR}/manifest.txt" ]; then
    python3 scripts/autotest-grid "$NAME"

    TAG=$(cat "${FLAT_DIR}/verdict.txt" 2>/dev/null || echo "FAIL")
    [ "$TAG" = "PASS" ] && EXIT=0 || EXIT=1
    TAGGED_DIR="${FLAT_DIR}/${TIMESTAMP}_${TAG}"
    mkdir -p "$TAGGED_DIR"
    mv "${FLAT_DIR}"/step_*.png "${FLAT_DIR}/manifest.txt" "${FLAT_DIR}/proof.png" "${FLAT_DIR}/verdict.txt" "$TAGGED_DIR/" 2>/dev/null
    ln -sfn "$(basename "$TAGGED_DIR")" "${FLAT_DIR}/latest"

    if [ "$TAG" = "PASS" ]; then
        echo "[autotest-qjs] PASS — proof: ${TAGGED_DIR}/proof.png"
    else
        echo "[autotest-qjs] FAIL — proof: ${TAGGED_DIR}/proof.png"
    fi
else
    echo "[autotest-qjs] WARNING: no manifest — screenshots may not have been captured"
fi

exit $EXIT
