#!/bin/bash
# Build a .tsz cart into a native binary.
#
# Usage:
#   ./scripts/build carts/conformance/d01_nested_maps.tsz
#   ./scripts/build carts/conformance/d01_nested_maps.tsz --debug
#   ./scripts/build --fast carts/conformance/d01_nested_maps.tsz
#
# --fast: compile cart against cached engine .a (~500ms vs 25s)
#   On first run, builds the engine .a (one-time ~24s).
#   Subsequent runs compile only the cart and link against the cached .a.

set -euo pipefail
cd "$(dirname "$0")/.."

# ── Parse flags ──────────────────────────────────────────────────────
FAST=0
POSITIONAL=()
for arg in "$@"; do
    case "$arg" in
        --fast) FAST=1 ;;
        *) POSITIONAL+=("$arg") ;;
    esac
done

if [ "${#POSITIONAL[@]}" -eq 0 ]; then
    echo "Usage: scripts/build [--fast] <cart.tsz> [--debug]"
    exit 1
fi

# Auto-rebuild vello if stripped lib is missing (happens after fresh clone or git filter-repo)
VELLO_LIB="../deps/vello_ffi/target/release/libvello_ffi_stripped.a"
if [ ! -f "$VELLO_LIB" ]; then
    echo "[vello_ffi] stripped lib missing — rebuilding..."
    bash ../deps/vello_ffi/build.sh
fi

CART="${POSITIONAL[0]}"
NAME=$(basename "$CART" .tsz)
OPT="${POSITIONAL[1]:---release}"
GEN="generated_${NAME}.zig"
GEN_DIR="generated_${NAME}"

# Pick optimize flag
if [ "$OPT" = "--debug" ]; then
    ZIG_OPT=""
else
    ZIG_OPT="-Doptimize=ReleaseFast"
fi

# ── Fast path: engine .a + cart-only compile ─────────────────────────
if [ "$FAST" -eq 1 ]; then
    CORE_DIR="zig-out/lib"
    CORE_CURRENT="${CORE_DIR}/libreactjit-core.current.a"
    CORE_CANDIDATE="${CORE_DIR}/libreactjit-core.candidate.a"
    CORE_LASTGOOD="${CORE_DIR}/libreactjit-core.lastgood.a"

    # Build engine .a if current artifact is missing
    if [ ! -f "$CORE_CURRENT" ]; then
        echo "[$NAME] engine .a not found — building (one-time, ~24s)..."
        zig build core $ZIG_OPT 2>&1
        # Fresh build: promote directly to current (no prior lastgood)
        mkdir -p "$CORE_DIR"
        mv zig-out/lib/libreactjit-core.a "$CORE_CANDIDATE"
        mv "$CORE_CANDIDATE" "$CORE_CURRENT"
        echo "[$NAME] engine .a ready → $CORE_CURRENT"
    fi

    # Step 1: forge with --fast flag (api.zig imports)
    echo "[$NAME] forge (fast)..."
    ./zig-out/bin/forge build --fast "$CART" 2>&1

    # Step 2: preflight lint (same checks — skipped below via FAST guard)
    # (lint block runs after this section — FAST path falls through to lint)
fi

# Step 1 (normal): forge (smith compiler: tsz → zig)
if [ "$FAST" -eq 0 ]; then
    echo "[$NAME] forge..."
    ./zig-out/bin/forge build --single "$CART" 2>&1
fi

# If split output, concat all files for lint (grep needs a single target)
SPLIT_LINT=0
if [ -d "$GEN_DIR" ] && [ ! -f "$GEN" ]; then
    GEN=$(mktemp /tmp/lint_XXXXXX.zig)
    cat "$GEN_DIR"/*.zig > "$GEN"
    SPLIT_LINT=1
fi

# ── Step 2: preflight lint — catch smith bugs before wasting a zig build ──
LINT_FAIL=0
LINT_WARN=0

# FATAL: Single-quoted multi-char strings (JS leaked into Zig)
# Exclude: lines inside \\ JS string literals, and lines inside double-quoted strings
# (single quotes inside "lua_on_press = '...'" are valid Zig)
BAD_QUOTES=$(grep -n "'\w\w" "$GEN" 2>/dev/null | grep -v '^\s*[0-9]*:\s*\\\\' | grep -v 'lua_on_press' | grep -v 'js_on_press' | grep -v '^\s*[0-9]*:\s*//' | head -5 || true)
if [ -n "$BAD_QUOTES" ]; then
    echo "[$NAME] LINT FAIL: JS string leaked into Zig (single-quoted multi-char):"
    echo "$BAD_QUOTES"
    LINT_FAIL=1
fi

# FATAL: Broken JS_LOGIC multiline string — any line not starting with \\ is raw JS leaking
if grep -q '^const JS_LOGIC =' "$GEN" 2>/dev/null; then
    BAD_JS=$(sed -n '/^const JS_LOGIC =/,/^;$/p' "$GEN" | grep -v '^\s*\\\\' | grep -v '^const \|^;$' | head -5 || true)
    if [ -n "$BAD_JS" ]; then
        echo "[$NAME] LINT FAIL: raw JS leaked into JS_LOGIC Zig string:"
        echo "$BAD_JS"
        LINT_FAIL=1
    fi
fi

# [MIGRATED TO PREFLIGHT] Handler ref missing (F2), handler unassigned (F1/F3),
# map handler string literal (F3), JS + in Lua (F10), duplicate __mapPress (F7)
# — all now caught by smith/preflight.js before emit. Removed from bash lint.

# WARN: Shared static arrays referenced from per-item map nodes
# If _map_inner_N children point to a non-per-item _arr_, all map items render identical content
for MI in $(grep -oP '_map_inner_\d+' "$GEN" 2>/dev/null | sort -u || true); do
    MAP_NUM=${MI#_map_inner_}
    SHARED=$(grep "$MI\[_i\].*&_arr_" "$GEN" 2>/dev/null | head -3 || true)
    if [ -n "$SHARED" ]; then
        echo "[$NAME] LINT WARN: $MI references shared static _arr_ arrays — map items will render identical content"
        LINT_WARN=1
    fi
done

# [MIGRATED TO PREFLIGHT] JS in LUA_LOGIC (F10), _map_lua_ptrs unused (W2),
# Color{} placeholders (F4/W1) — all now caught by smith/preflight.js.

# WARN: __setObjArr in LUA_LOGIC without registration
if grep -q '__setObjArr' "$GEN" 2>/dev/null; then
    echo "[$NAME] LINT WARN: __setObjArr in generated code — verify LuaJIT registration"
    LINT_WARN=1
fi

if [ "$LINT_FAIL" -eq 1 ]; then
    echo "[$NAME] BLOCKED — fix smith before building. Generated file: $GEN"
    exit 1
fi

if [ "$LINT_WARN" -eq 1 ]; then
    echo "[$NAME] warnings above — building anyway but expect visual bugs"
fi

# Clean up temp lint file
if [ "$SPLIT_LINT" -eq 1 ]; then rm -f "$GEN"; fi

# Resolve source: prefer split directory (generated_X/app.zig) over monolith
if [ -d "$GEN_DIR" ] && [ -f "$GEN_DIR/app.zig" ]; then
    APP_SOURCE="$GEN_DIR/app.zig"
else
    APP_SOURCE="$GEN"
fi

# Step 3: zig build
if [ "$FAST" -eq 1 ]; then
    echo "[$NAME] zig build (fast — cart-fast against cached engine)..."
    zig build cart-fast -Dapp-name="$NAME" -Dapp-source="$APP_SOURCE" $ZIG_OPT 2>&1
else
    echo "[$NAME] zig build..."
    zig build app -Dapp-name="$NAME" -Dapp-source="$APP_SOURCE" $ZIG_OPT 2>&1
fi

echo "[$NAME] done → zig-out/bin/$NAME"
