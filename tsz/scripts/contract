#!/bin/bash
# Emit the compiler source contract JSON without running the emit/build phase.
#
# Usage:
#   ./scripts/contract carts/conformance/d01_nested_maps.tsz
#   ./scripts/contract carts/conformance/d01_nested_maps.tsz --out-dir=/tmp/tsz-gen

set -euo pipefail

export PATH="$HOME/miniconda3/bin:$HOME/.local/bin:/home/linuxbrew/.linuxbrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH"
cd "$(dirname "$0")/.."

if [ "$#" -lt 1 ]; then
    echo "Usage: scripts/contract <cart.tsz> [forge flags]"
    exit 1
fi

zig build forge >/dev/null
zig-out/bin/forge contract "$@"
