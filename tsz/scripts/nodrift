#!/usr/bin/env python3
"""
nodrift — validate .fart files against chad-tier syntax rules.

USAGE
  scripts/nodrift path/to/file.fart [more.fart ...]
  scripts/nodrift docs/godfile.fart             # must exit 0
  scripts/nodrift carts/some-drifty-project/    # likely exits 1

PASSING REFERENCE
  docs/godfile.fart and docs/music_primer.fart are the SSoT.
  They must always pass. If they don't, the rule here is wrong and
  should be fixed — NOT the reference files.

RULES (regex-catchable; see godfile denylist for full list)
  - sigils: < > <= >= == === != !== && || !
  - arrow functions / foreign keywords (const / let / var / function)
  - commas inside ( ) arg lists
  - SQL keywords in user source
  - db.read(...) / db.write(...) string-arg form
  - machine sizes without .bytes. prefix (u8..u64, i8..i64, f32, f64)
  - math.* not written as subject.math.* (needs a subject on the left)
  - math.max / math.min / math.clamp / math.atan2 (always banned)
  - UPPER_CASE constants (use lowercase + `exact`)
  - comma-record shorthand in data blocks (id: 1, title: X, ...)
  - requires a, b (use `and`)
  - <for ... as X, Y> (use `at` for index)
  - print('...\\n') with trailing newline
  - fill(x, y, t): effect signature (removed — x/y/t are ambient)
  - .field has types (plural — use `.field exact type`)
  - subscript [i] / .at(i)

NOT CAUGHT (need a parser; future work)
  - bare names in <during>/<if> without up-tree declarations
  - accumulator blocks with hand-repeated `target is target + ...`

EXIT CODES
  0 — clean
  1 — drift found
  2 — usage error / missing file
"""

import json
import re
import sys
from pathlib import Path

BASELINE = {}
_BASELINE_TSV = Path(__file__).parent / 'baseline-lines.tsv'
if _BASELINE_TSV.exists():
    for row in _BASELINE_TSV.read_text(encoding='utf-8').splitlines():
        path, n = row.split('\t')
        BASELINE[path] = int(n)

BASELINE_INVENTORY = {}
_BASELINE_INVENTORY_JSON = Path(__file__).parent / 'baseline-inventory.json'
if _BASELINE_INVENTORY_JSON.exists():
    BASELINE_INVENTORY = json.loads(
        _BASELINE_INVENTORY_JSON.read_text(encoding='utf-8')
    )

_DOC_OPEN_PREFIX = '<~!'
_DOC_OPEN_RE = re.compile(r'<~![^>]*>')
_DOC_CLOSE = '<!~>'
_DOC_CLOSE_LEN = len(_DOC_CLOSE)

# Dedicated lowering payload exceptions.
#
# This must stay exact and small. Only files that currently hold
# forbidden syntax as lowering payload data belong here. Do not add
# general compiler files just because they are noisy.
_PAYLOAD_BLOCK_ALLOWLIST = {
    'tsz/compiler/smith/intent/index.mod.fart': frozenset({
        'zigMarkers',
        'jsMarkers',
        'tsTypeMap',
    }),
}

_REGEX_PAYLOAD_ALLOWLIST = frozenset({
    'tsz/compiler/smith/intent/lua_map_node.mod.fart',
})

# ──────────────────────────────────────────────────────────────────────
# Colors (stripped when stdout isn't a TTY)
# ──────────────────────────────────────────────────────────────────────
RED   = '\033[31m'
GREEN = '\033[32m'
YLW   = '\033[33m'
CYN   = '\033[36m'
DIM   = '\033[2m'
BOLD  = '\033[1m'
RST   = '\033[0m'
if not sys.stdout.isatty():
    RED = GREEN = YLW = CYN = DIM = BOLD = RST = ''


# ──────────────────────────────────────────────────────────────────────
# Line stripping
# Remove // line comments and blank the interior of string literals so
# drift patterns inside strings don't false-positive. Example: the
# godfile's emitQjsStubs contains strings holding Zig source
# ('const qjs_runtime = ... []const u8 ...'). Those are emit output,
# not chad source — the strings must not be scanned for chad rules.
#
# The one exception: print-newline needs to see `\n` inside a string
# literal, so it's checked against the RAW line.
# ──────────────────────────────────────────────────────────────────────

def strip_comments(line: str) -> str:
    """Remove // line comments (skipping // that appear inside strings).
    Preserves string interiors so callers can still see `\\n` etc."""
    i = 0
    in_s = in_d = False
    while i < len(line) - 1:
        c = line[i]
        if c == "\\":
            i += 2
            continue
        if c == "'" and not in_d:
            in_s = not in_s
        elif c == '"' and not in_s:
            in_d = not in_d
        elif not in_s and not in_d and c == '/' and line[i + 1] == '/':
            return line[:i] + ' ' * (len(line) - i)
        i += 1
    return line


def blank_docs(lines):
    """Blank <~!...> ... <!~> doc spans before any other sanitization.

    Returns (doc_free_lines, unclosed_open_line).
    """
    out_lines = []
    in_doc = False
    open_lines = []
    unclosed_open_line = 0

    for lineno, raw in enumerate(lines, 1):
        i = 0
        n = len(raw)
        in_single = False
        in_double = False
        out = []

        while i < n:
            if in_doc:
                close_at = raw.find(_DOC_CLOSE, i)
                if close_at == -1:
                    out.append(' ' * (n - i))
                    i = n
                    break
                out.append(' ' * (close_at - i + _DOC_CLOSE_LEN))
                i = close_at + _DOC_CLOSE_LEN
                in_doc = False
                if open_lines:
                    open_lines.pop()
                unclosed_open_line = open_lines[0] if open_lines else 0
                continue

            ch = raw[i]
            if in_single:
                out.append(ch)
                if ch == "\\" and i + 1 < n:
                    out.append(raw[i + 1])
                    i += 2
                    continue
                if ch == "'":
                    in_single = False
                i += 1
                continue

            if in_double:
                out.append(ch)
                if ch == "\\" and i + 1 < n:
                    out.append(raw[i + 1])
                    i += 2
                    continue
                if ch == '"':
                    in_double = False
                i += 1
                continue

            if ch == "'":
                in_single = True
                out.append(ch)
                i += 1
                continue

            if ch == '"':
                in_double = True
                out.append(ch)
                i += 1
                continue

            if raw.startswith(_DOC_OPEN_PREFIX, i):
                open_match = _DOC_OPEN_RE.match(raw, i)
                if open_match:
                    open_len = open_match.end() - i
                    close_at = raw.find(_DOC_CLOSE, i + open_len)
                    if close_at == -1:
                        out.append(' ' * (n - i))
                        in_doc = True
                        open_lines.append(lineno)
                        unclosed_open_line = open_lines[0]
                        i = n
                        break
                    out.append(' ' * (close_at - i + _DOC_CLOSE_LEN))
                    i = close_at + _DOC_CLOSE_LEN
                    continue

            out.append(ch)
            i += 1

        out_lines.append(''.join(out))

    return out_lines, unclosed_open_line


def blank_strings(line: str) -> str:
    """Blank string interiors (keep quote chars, preserve length)."""
    def blank_sq(m):
        return "'" + ' ' * (len(m.group()) - 2) + "'"
    def blank_dq(m):
        return '"' + ' ' * (len(m.group()) - 2) + '"'
    line = re.sub(r"'[^'\n]*'", blank_sq, line)
    line = re.sub(r'"[^"\n]*"', blank_dq, line)
    return line


def blank_regex_literals(line: str) -> str:
    """Blank JS-style /.../ regex literals while preserving length.

    This is intentionally narrow and only used for explicit lowering
    payload files. It is not a general parser.
    """
    out = []
    i = 0
    n = len(line)

    def prev_nonspace(idx: int) -> str:
        j = idx - 1
        while j >= 0 and line[j].isspace():
            j -= 1
        return line[j] if j >= 0 else ''

    while i < n:
        ch = line[i]
        prev = prev_nonspace(i)
        regex_start = (
            ch == '/'
            and i + 1 < n
            and line[i + 1] not in '/*'
            and (i == 0 or prev in '([{=,:;!?&|')
        )
        if not regex_start:
            out.append(ch)
            i += 1
            continue

        start = i
        i += 1
        in_class = False
        while i < n:
            cur = line[i]
            if cur == '\\':
                i += 2
                continue
            if cur == '[':
                in_class = True
                i += 1
                continue
            if cur == ']' and in_class:
                in_class = False
                i += 1
                continue
            if cur == '/' and not in_class:
                i += 1
                while i < n and line[i].isalpha():
                    i += 1
                break
            i += 1

        out.append(' ' * (i - start))

    return ''.join(out)


def strip_inert(line: str) -> str:
    """Comments AND string interiors blanked. For rules that should not
    match on content inside string literals (the common case)."""
    return blank_strings(strip_comments(line))


def strip_inert_payload_aware(line: str, rel: str) -> str:
    inert = strip_inert(line)
    if rel in _REGEX_PAYLOAD_ALLOWLIST:
        return blank_regex_literals(inert)
    return inert


def blank_allowed_payload_blocks(lines, rel):
    allowed = _PAYLOAD_BLOCK_ALLOWLIST.get(rel)
    if not allowed:
        return list(lines)

    out = []
    current = None
    for raw in lines:
        stripped = raw.strip()
        if current is None and stripped in {f'<{name}>' for name in allowed}:
            current = stripped[1:-1]
            out.append(raw)
            continue
        if current is not None and stripped == f'</{current}>':
            out.append(raw)
            current = None
            continue
        if current is not None:
            out.append(' ' * len(raw))
            continue
        out.append(raw)
    return out


def compute_block_contexts(lines):
    """For each line, return the set of backend-target block names
    (`jscript` / `lscript` / `zscript`) it is currently nested inside.
    A line with an opening tag is considered to be INSIDE the block it
    opens; a closing tag leaves the block at the start of the NEXT line."""
    contexts = []
    stack = []
    open_pat = re.compile(r'<(jscript|lscript|zscript)\b')
    close_pat = re.compile(r'</(jscript|lscript|zscript)>')
    for raw in lines:
        # Caller may already pass doc-blanked lines. Keep defensive stripping
        # here so contexts ignore comments and string content either way.
        sanitized = strip_inert(raw)
        # Opens first (line is now inside the block).
        for m in open_pat.finditer(sanitized):
            stack.append(m.group(1))
        contexts.append(set(stack))
        # Closes take effect for the next line.
        for m in close_pat.finditer(sanitized):
            if stack and stack[-1] == m.group(1):
                stack.pop()
    return contexts


_INV_TAG_RE = re.compile(r'<\s*(/?)\s*([^<>]+?)\s*(/?)\s*>')
_CONTENT_VAR_LINE_RE = re.compile(r'^\s*([a-z_][a-z0-9_]*)\s+(is|exact|has)\b')
_CONTENT_FUNCTION_LINE_RE = re.compile(
    r'^\s*([A-Za-z_][A-Za-z0-9_]*)\s*(\([^)]*\))?\s*:'
)
_CONTENT_FLOW_WORDS = frozenset({'if', 'else', 'for', 'while', 'during', 'switch', 'case'})


def scan_content_inventory(lines):
    """Collect structural names present in <types>, <var>, <functions>, <semantics>."""
    doc_free_lines, _ = blank_docs(lines)
    inventory = {
        'lines': len(lines),
        'real_content_lines': 0,
        'types': [],
        'vars': [],
        'functions': [],
        'semantics': [],
        'legacy_body_locals': [],
        'refs': {},
    }
    seen = {key: set() for key in inventory}
    stack = []
    containers = frozenset(inventory)

    def add(category, name):
        if not name or name in seen[category]:
            return
        seen[category].add(name)
        inventory[category].append(name)

    def container_info():
        for idx in range(len(stack) - 1, -1, -1):
            if stack[idx] in containers:
                return stack[idx], len(stack) - idx - 1
        return None, 0

    for raw in doc_free_lines:
        inert = strip_inert(raw)
        block, depth = container_info()
        if block == 'var' and depth == 0:
            m = _CONTENT_VAR_LINE_RE.match(inert)
            if m:
                add('vars', m.group(1))
        elif block == 'functions' and depth == 0:
            m = _CONTENT_FUNCTION_LINE_RE.match(inert)
            if m and m.group(1) not in _CONTENT_FLOW_WORDS:
                add('functions', m.group(1))

        for m in _INV_TAG_RE.finditer(inert):
            is_close = bool(m.group(1))
            words = m.group(2).strip().split()
            if not words:
                continue
            tag_name = words[0]

            if is_close:
                while stack:
                    if stack.pop() == tag_name:
                        break
                continue

            parent, parent_depth = container_info()
            if parent == 'types' and parent_depth == 0:
                add('types', tag_name)
            elif parent == 'var' and parent_depth == 0 and len(words) >= 2 and words[1] == 'has':
                add('vars', tag_name)
            elif (
                parent == 'semantics'
                and parent_depth == 0
                and len(words) >= 3
                and words[1] == 'exact'
                and words[2] == 'function'
            ):
                add('semantics', tag_name)

            if not m.group(3):
                stack.append(tag_name)

    inventory['legacy_body_locals'] = sorted(_collect_fn_body_local_names(doc_free_lines))
    for raw in doc_free_lines:
        stripped = raw.strip()
        if stripped and not stripped.startswith('//'):
            inventory['real_content_lines'] += 1

    ref_names = set()
    for category in ('types', 'vars', 'functions', 'semantics', 'legacy_body_locals'):
        ref_names.update(inventory.get(category, []))

    refs = {}
    for name in sorted(ref_names):
        refs[name] = 0
        pattern = re.compile(rf'(?<![\w.]){re.escape(name)}(?![\w])')
        for raw in doc_free_lines:
            refs[name] += len(pattern.findall(strip_inert(raw)))
    inventory['refs'] = refs
    return inventory


# ──────────────────────────────────────────────────────────────────────
# Rules
# ──────────────────────────────────────────────────────────────────────
# Each rule: (name, regex, short description, fix hint, use_raw_line,
#             skip_in_blocks)
# use_raw_line=True scans the unstripped line (for print-newline etc.)
# skip_in_blocks=set of block names where this rule does NOT fire.
#   e.g. `{'zscript'}` means the rule is suppressed for lines nested
#   inside <zscript>...</zscript> (legitimate foreign-language
#   passthrough, e.g. `@import(...)` inside a Zig emit block).
# Rules without skip_in_blocks fire everywhere (universal chad rules).

RULES = [
    ('free-comment',
     re.compile(r'^\s*//'),
     'Free-standing `//` comment — forbidden',
     'Wrap doc in <~!>...<!~>. Comments cannot stand alone as lines.',
     True),

    # ── Comparison sigils ────────────────────────────────────────────
    ('sigil-lt',
     re.compile(r'(?<!<)\s<\s(?!/)'),
     'Comparison sigil ` < ` — forbidden',
     'Use `below` or `exact or below`.',
     False),

    ('sigil-gt',
     re.compile(r'(?<!-)\s>\s'),
     'Comparison sigil ` > ` — forbidden',
     'Use `above` or `exact or above`.',
     False),

    ('sigil-le',
     re.compile(r'<='),
     'Sigil `<=` — forbidden',
     'Use `exact or below`.',
     False),

    ('sigil-ge',
     re.compile(r'>='),
     'Sigil `>=` — forbidden',
     'Use `exact or above`.',
     False),

    ('sigil-eq',
     re.compile(r'=='),
     'Sigil `==` / `===` — forbidden',
     'Use `exact`.',
     False),

    ('sigil-neq',
     re.compile(r'!='),
     'Sigil `!=` / `!==` — forbidden',
     'Use `not exact`.',
     False),

    ('sigil-and',
     re.compile(r'&&'),
     'Sigil `&&` — forbidden',
     'Use `and`.',
     False),

    ('sigil-or',
     re.compile(r'\|\|'),
     'Sigil `||` — forbidden',
     'Use `or`.',
     False),

    ('sigil-not',
     re.compile(r'(?<![!=<>])!(?![!=])\w'),
     'Sigil `!` — forbidden',
     'Use `not`.',
     False),

    # ── Arrow fn / foreign keywords ──────────────────────────────────
    ('arrow',
     re.compile(r'=>'),
     'Arrow function `=>` — forbidden',
     'Use `<for>`, `.where(...)`, or composition with `+`.',
     False),

    ('keyword-const',
     re.compile(r'\bconst\s'),
     'Keyword `const` — forbidden',
     'Use `name exact value` in <var>.',
     False),

    ('keyword-let',
     re.compile(r'\blet\s'),
     'Keyword `let` — forbidden',
     'Use `name is value` in <var>.',
     False),

    ('keyword-function',
     re.compile(r'\bfunction\s*\w*\s*\('),
     'Keyword `function(...)` — forbidden',
     'Declare in <functions>, not as a `function` keyword.',
     False),

    ('keyword-new',
     re.compile(r'\bnew\s+[A-Z]'),
     'Keyword `new Foo()` — forbidden',
     'Use `name is Foo` (record instantiation).',
     False),

    ('keyword-typeof',
     re.compile(r'\btypeof\b'),
     'Keyword `typeof` — forbidden',
     'Use `<if x>` guards or positive-shape predicates.',
     False),

    ('keyword-continue',
     re.compile(r'\bcontinue\b'),
     'Keyword `continue` — forbidden',
     'Use `skip` inside <for>, `stop` to break out.',
     False),

    # ── JS idioms ────────────────────────────────────────────────────
    ('optional-chain',
     re.compile(r'\?\.'),
     'Optional chain `?.` — forbidden',
     'Use `<if x> x.y </if>` guard.',
     False),

    ('nullish-coalesce',
     re.compile(r'\?\?'),
     'Nullish coalesce `??` — forbidden',
     'Use `<if x> x </if> <else> y </else>`.',
     False),

    ('array-methods',
     re.compile(r'\.(map|filter|reduce|forEach)\s*\('),
     'JS array method `.map`/`.filter`/`.reduce`/`.forEach` — forbidden',
     'Use `<for>` or `.where(...)` with `item` from scope.',
     False),

    # ── Containment — machine sizes ──────────────────────────────────
    # Legal ONLY when preceded by `.` (either `.bytes.u32` OR bare
    # `.u8` field declarations inside <bytes has>).
    ('machine-size',
     re.compile(r'(?<!\.)\b(u8|u16|u32|u64|i8|i16|i32|i64|f32|f64)\b'),
     'Machine-size token without `.` prefix',
     'Machine sizes live under `.bytes.*`. Use `id.bytes.u32`, never `id is u32`.',
     False),

    # ── Containment — math ───────────────────────────────────────────
    # `math.max`/`min`/`clamp`/`atan2` are always banned (inherent 2-arg).
    ('math-banned',
     re.compile(r'\bmath\.(max|min|clamp|atan2)\b'),
     'Banned `math.max` / `math.min` / `math.clamp` / `math.atan2`',
     'Use `<if ... below ...>` blocks instead of max/min/clamp. '
     'For atan2, use `point.math.angle` (unary on a Vec2).',
     False),

    # Math operations must appear as subject.math.op, never bare
    # math.op(...). Lookbehind for "not preceded by `.` or word char".
    ('math-bare',
     re.compile(r'(?<![\w.])math\.(sqrt|floor|ceil|abs|sin|cos|tan|pow|'
                r'round|log|exp|angle|length|normalized|distanceTo)\b'),
     'Math operation written as `math.op(...)` instead of `x.math.op`',
     'Subject on the left. `x.math.sqrt`, not `math.sqrt(x)`.',
     False),

    # ── Containment — SQL ────────────────────────────────────────────
    ('sql-keyword',
     re.compile(r'\b(SELECT|INSERT\s+INTO|UPDATE|DELETE\s+FROM|FROM|'
                r'WHERE|INNER\s+JOIN|LEFT\s+JOIN|RIGHT\s+JOIN|JOIN|'
                r'ORDER\s+BY|GROUP\s+BY|HAVING|LIMIT|OFFSET|DESC\b|ASC\b)'),
     'SQL keyword in user source',
     'Use `.db.*` address-path chain: `db.users.read.where(...)`.',
     False),

    ('db-read-string',
     re.compile(r'\bdb\.(read|query|exec)\s*\(\s*[\'"]'),
     '`db.read(string)` / `db.query(string)` / `db.exec(string)` form',
     'Chain form: `db.table.read.all`, `db.table.read.where(...)`.',
     False),

    # ── UPPER_CASE constants ─────────────────────────────────────────
    ('upper-const',
     re.compile(r'^\s*[A-Z][A-Z0-9_]{2,}\s+(exact|is)\s'),
     'UPPER_CASE constant name',
     '`exact` already marks immutability. Use lowercase: `max exact 100`.',
     False),

    # ── Commas-in-parens (function arity drift) ──────────────────────
    # NOTE: This rule is intentionally ABSENT from RULES. It is handled
    # by scan_paren_commas() below, which tracks depth across lines and
    # handles nested parens correctly. The old single-line regex missed:
    #   • multiline calls:  foo(\n  a,\n  b\n)
    #   • nested calls:     foo(a, bar(x), baz(y))
    # Do NOT re-add a regex rule here — it will silently under-catch.

    # ── Comma-record shorthand in data blocks ────────────────────────
    ('comma-record',
     re.compile(r'^\s*\w+\s*:\s*\S.*?,\s*\w+\s*:'),
     'Comma-record shorthand `id: 1, title: X` — forbidden',
     'Use chained population: `cards.id(1).title(\'X\').col(todo)`.',
     False),

    # ── requires comma ───────────────────────────────────────────────
    ('requires-comma',
     re.compile(r'\brequires\s+\w+\s*,\s*\w+'),
     '`requires a, b` — forbidden',
     'Use `requires a and b`.',
     False),

    # ── shell.run / subprocess invocation — bash in disguise ─────────
    # Foreign vocabulary (bash argv) must be contained behind a named
    # ambient, same as bytes/math/db. `shell.run(path, arg, arg, arg)`
    # is a crime scene — user source never launches subprocesses via
    # raw argv tuples.
    ('shell-run',
     re.compile(r'\bshell\.(run|run2|runShell|exec|spawn|bash|sh)\s*\('),
     '`shell.run(...)` / subprocess invocation — bash in disguise',
     'Wrap the tool as an ambient namespace: `forge.path(x).check`, '
     '`link.generated(src).named(n)`. Subprocess argv vocabulary '
     'lives in the compiler; user source never writes raw argv.',
     False),

    ('bash-invoke',
     re.compile(r"['\"](bash|sh|zsh|fish|/bin/bash|/bin/sh)['\"]\s*,"),
     'String literal invoking a shell interpreter',
     'Port the shell script into a .mod.fart or wrap the tool as an '
     'ambient namespace.',
     False),

    # ── <for ... as X, Y> — comma index ──────────────────────────────
    ('for-comma',
     re.compile(r'<for\s+[^<>\n]*\bas\s+\w+\s*,\s*\w+'),
     '<for ... as X, Y> — forbidden',
     'Use `<for coll as X at Y>` — `at` for index, `as` for rename.',
     False),

    # ── Subscript / .at() ────────────────────────────────────────────
    ('subscript',
     re.compile(r'\w+\[[^\]]+\]'),
     'Array subscript `[i]`',
     'Use `.first` / `.last` / `.drop(n).first` or <for> iteration.',
     False),

    ('at-subscript',
     re.compile(r'\.at\s*\('),
     '`.at(i)` subscript',
     'Use `.drop(n).first` for the nth element.',
     False),

    # ── Effect fill signature ────────────────────────────────────────
    ('effect-fill',
     re.compile(r'\bfill\s*\(\s*x\s*,\s*y\s*,\s*t\s*\)\s*:'),
     'Effect `fill(x, y, t):` signature — forbidden',
     'Effect body is a single expression. x/y/t are ambient — no signature.',
     False),

    # ── <name ffi> block type — forbidden ────────────────────────────
    ('ffi-block',
     re.compile(r'<\w[\w.]*\s+ffi>'),
     '`<name ffi>` block type — forbidden',
     'Use `<alias from system.libs.lib has>` with `.field exact \'c_symbol\'` '
     'mappings. `<ffi>` as a block type was removed — C-library binding is '
     'just a shape with a source qualifier.',
     False),

    # ── Bare <script> in author source — forbidden ───────────────────
    # Backend-target discipline: author either declares <jscript>,
    # <lscript>, or <zscript> explicitly, OR omits the wrapper and
    # relies on an ancestor script-block's cascade. Bare <script> is
    # the compiler's internal-only wrapper — never appears in source.
    ('bare-script',
     re.compile(r'<script[\s>]|</script>'),
     'Bare `<script>` / `</script>` in author source — forbidden',
     'Declare `<jscript>` / `<lscript>` / `<zscript>` explicitly, or omit '
     'the wrapper entirely (relying on an ancestor script-block cascade). '
     '`<script>` is internal; never author-written.',
     False),

    # ── <var.field> split scoped-type block — forbidden ──────────────
    # Old form put field variants in <types> as <varname.field>. That
    # violates scope lineage — reader sees `<cards.col>` with no idea
    # what cards is yet. Fix: inline as `<.field has>` inside the
    # parent's shape, OR declare as a top-level named type.
    #
    # Regex requires lowercase-first char to avoid false-positive on
    # classifier tags (`<C.Card>`, `<UI.Button>` — all PascalCase).
    # Backend names are lowercase; classifiers are PascalCase (per
    # case-split rule). The lowercase-first anchor catches ONLY the
    # split-scoped-type drift and leaves classifiers alone.
    ('split-scoped-type',
     re.compile(r'<[a-z]\w*\.\w+\s*>'),
     '`<var.field>` split scoped-type block — forbidden',
     'Inline the variants as `<.field has>` inside the parent\'s shape, '
     'OR declare as a top-level named type in <types> and reference via '
     '`.field exact typeName`. Split form violates scope lineage.',
     False),

    # ── .field has types (plural) — use `.field exact type` ─────────
    ('has-types-plural',
     re.compile(r'\.\w+\s+has\s+types\b'),
     '`.field has types` (plural)',
     'Use `.field exact type` (singular). `exact` closes the set.',
     False),

    # ── Inline <if>/<else> ternary ───────────────────────────────────
    ('inline-ternary',
     re.compile(r'</if>\s*<else>'),
     '<if>/<else> written as inline ternary',
     'Expand into block form — each on its own line.',
     False),

    # ── globalThis / window ambient hack ─────────────────────────────
    ('globalThis',
     re.compile(r'\bglobalThis\b'),
     '`globalThis` ambient — forbidden',
     'Use dictionary ambients (framework / app / file / var scope).',
     False),

    # ── Zig stdlib / imports leaking through ─────────────────────────
    # These are drift in plain chad source but LEGITIMATE passthroughs
    # inside <zscript>...</zscript> emit blocks. skip_in_blocks marks
    # the contexts where the rule suppresses.
    ('zig-std',
     re.compile(r'\bstd\.(mem|fmt|heap|fs|debug|process|io|os|time|'
                r'crypto|hash|math|ArrayList|HashMap)\b'),
     'Zig stdlib reference',
     'No Zig stdlib in chad source. Inside <zscript> it is a legit '
     'passthrough; outside, emit as chad composition.',
     False,
     {'zscript'}),

    ('zig-import',
     re.compile(r'@import\s*\('),
     'Zig `@import(...)` — forbidden',
     'Imports are structural. Use block namespacing, not @import. '
     '(Legit inside <zscript> for chad-to-Zig emit passthrough.)',
     False,
     {'zscript'}),

    # `try` and `defer` are NEVER legit, even inside <zscript>.
    # Chad has `<if result>` binding and `cleanup:` pairing.
    ('zig-try',
     re.compile(r'\btry\s+[A-Za-z_]'),
     'Zig `try` keyword — forbidden',
     'Use `<if result>` checks for fallible calls.',
     False),

    ('zig-defer',
     re.compile(r'\bdefer\s+[A-Za-z_]'),
     'Zig `defer` keyword — forbidden',
     'Use `name cleanup:` pairing in <functions>.',
     False),

    # Bit-level casts inside <zscript> are legit passthroughs (chad
    # has no equivalent for `@ptrCast` / `@alignCast`). Outside: drift.
    ('zig-ptr-cast',
     re.compile(r'@(ptrCast|intCast|as|alignCast|bitCast|bitSizeOf|'
                r'sizeOf|typeInfo|TypeOf|Type)\s*\('),
     'Zig `@ptrCast` / `@intCast` / `@as` / etc. — forbidden',
     'No Zig intrinsics in chad source. Legit inside <zscript> for '
     'bit-level passthroughs.',
     False,
     {'zscript'}),

    # ── Foreign ecosystem containment ───────────────────────────────────
    # Workers who can't use shell will pivot to JS. Every entry below is
    # an escape hatch into a foreign runtime. None of these belong in
    # chad source — not even inside <jscript> (which is UI passthrough,
    # not a Node.js sandbox).

    # Node.js require() — brings in any module including child_process
    ('js-require',
     re.compile(r'(?<!\.)\brequire\s*\('),
     '`require(...)` — Node.js module import, forbidden',
     'Imports are structural in chad. Use block namespacing or ambient '
     'declarations. `require` is the front door to the entire Node ecosystem.',
     False),

    # ES module import syntax
    ('js-import',
     re.compile(r'^\s*import\s+.+\bfrom\b'),
     '`import ... from` — ES module syntax, forbidden',
     'Imports are structural. Declare the dependency as a block or ambient.',
     False),

    # Dangerous Node built-in module names as string args to require()
    # or anywhere they appear as standalone string literals.
    ('js-node-module',
     re.compile(r'''['"](child_process|node:child_process|fs|node:fs|'''
                r'''path|node:path|os|node:os|http|https|net|tls|'''
                r'''worker_threads|cluster|vm|v8|inspector)['"']'''),
     'Node.js built-in module name as string literal',
     'Port the capability into a .mod.fart ambient. '
     'These module names are the JS-ecosystem equivalent of shell scripts.',
     False),

    # process.* — Node.js process object (exec, spawn, exit, env, argv…)
    # (?<!\.) guards against `node.process.x` or `app.process.exit` false-positives.
    ('js-process',
     re.compile(r'(?<!\.)\bprocess\.(exit|spawn|exec|fork|kill|env|argv|cwd|'
                r'chdir|stdout|stderr|stdin|hrtime|memoryUsage|cpuUsage)\b'),
     '`process.*` — Node.js process control, forbidden',
     'Use chad ambient namespaces for system interaction. '
     '`process.exit` → `app.stop`, `process.env` → config ambients.',
     False),

    # console.* — use chad print instead
    # (?<!\.) guards against `my.console.log` false-positives.
    ('js-console',
     re.compile(r'(?<!\.)\bconsole\.(log|warn|error|info|debug|trace|assert|dir|'
                r'time|timeEnd|group|groupEnd|table)\s*\('),
     '`console.*` — JS console, forbidden',
     'Use `print` / `print.inline` / `print.line`. '
     '`console` is a JS-ecosystem ambient; chad has `print`.',
     False),

    # async / await — JS async model has no place in chad
    ('js-async',
     re.compile(r'(?<!\.)\basync\s+(function|\(|\w)'),
     '`async function` / `async (` — JS async model, forbidden',
     'Chad has no async. Use reactive state + `<during loading>` guards.',
     False),

    ('js-await',
     re.compile(r'(?<!\.)\bawait\s+\w'),
     '`await` — JS async, forbidden',
     'Chad has no await. Use reactive state + `<during loading>` guards.',
     False),

    # Promise — JS async primitive
    # (?<!\.) guards against field paths. `.then`/`.catch`/`.finally` are
    # inherently method-call form so no guard needed there — they ARE the drift.
    ('js-promise',
     re.compile(r'(?<!\.)\bPromise\s*[.(]|(?<!\.)\bPromise\.(resolve|reject|all|race|'
                r'allSettled|any)\b|\.then\s*\(|\.catch\s*\(|\.finally\s*\('),
     '`Promise` / `.then()` / `.catch()` — JS async primitive, forbidden',
     'Chad has no Promise model. Reactive state handles async outcomes.',
     False),

    # Browser globals — DOM / navigator / storage
    # NOTE: `window` is intentionally excluded here — it is a legitimate
    # chad framework ambient (`window.resize`, `window.title`, etc.).
    # `document`, `navigator`, `localStorage`, etc. have no chad equivalent
    # and are unambiguous browser drift.
    # (?<!\.) ensures we only fire when the name is used as a root expression
    # (a JS global), not as a field on a chad object (`node.location.x`,
    # `result.history`, etc. are valid chad field paths and must not fire).
    ('js-dom',
     re.compile(r'(?<!\.)\b(document|navigator|location|history|'
                r'localStorage|sessionStorage|indexedDB)\s*[.([]'),
     'Browser global (`document` / `navigator` / `localStorage` / etc.) — forbidden',
     'Chad targets its own runtime. No browser globals.',
     False),

    # `window` followed by known browser-only members — not chad framework calls.
    # `window.resize` / `window.title` / `window.open(name)` are chad ambients.
    # `window.alert`, `window.location`, `window.history`, etc. are browser drift.
    ('js-window-browser',
     re.compile(r'\bwindow\.(alert|confirm|prompt|open\s*\(|close\s*\('
                r'|location|history|scrollTo|scrollBy|scroll\b|focus\s*\('
                r'|blur\s*\(|postMessage|addEventListener|removeEventListener'
                r'|dispatchEvent|atob|btoa|fetch\s*\(|getComputedStyle)\b'),
     '`window.<browser-api>` — browser DOM method, forbidden',
     'Chad targets its own runtime. Use chad ambients for window interaction.',
     False),

    # setTimeout / setInterval / clearTimeout / clearInterval
    ('js-timers',
     re.compile(r'\b(setTimeout|setInterval|clearTimeout|clearInterval|'
                r'requestAnimationFrame|cancelAnimationFrame)\s*\('),
     'JS timer API — forbidden',
     'Use `<timer>` blocks or `<during>` reactive guards for timed behavior.',
     False),

    # ── `is null` — null is not a chad concept ───────────────────────
    # Chad has no universal null. Absence is typed (empty array/string,
    # false boolean, or uninitialized bare name). `set_X is null` is
    # usually the smuggled-local pattern — declaring a scratch slot
    # with `null` because the author needed a mutable named value
    # inside a function body and the no-locals rule forced them to
    # hoist it to <var>.
    ('is-null',
     re.compile(r'\bis\s+null\b'),
     '`is null` — null is not a chad concept',
     'Absence in chad is typed, not universal. Use a bare name '
     '(uninitialized), a typed init (`is string`, `is SomeType`), '
     'or `<if expr as name>` for optional unwrap. If this is a '
     'scratchpad for a function body, see fake-reactive-setter rule.',
     False),

    # ── print newline tax — CHECKED ON RAW LINE ──────────────────────
    ('print-newline',
     re.compile(r"print\s*\(\s*['\"][^'\"]*\\n\s*['\"]\s*\)"),
     '`print(\'...\\n\')` — trailing newline is 100% tax',
     'Newline is implicit in print. Use `print.inline(...)` for no-newline, '
     '`print.line` for bare newline.',
     True),
]


# ──────────────────────────────────────────────────────────────────────
# Multi-line scanners (not expressible as per-line regex)
# ──────────────────────────────────────────────────────────────────────

_COMMA_FIX = ('One item is the subject — move outside the parens. '
              '`foo(a, b)` → `a.foo(b)`. `clamp(v, lo, hi)` → two <if> blocks.')

# Words that precede `(` but are NOT function calls — they wrap JSX or
# expressions and may contain commas / multiple words legitimately.
_GROUPING_KEYWORDS = frozenset({'return', 'if', 'else', 'while', 'for'})

# Chad boolean/comparison operators — their presence inside `()` means the
# content is an expression, not a comma-separated or space-separated arg list.
_CHAD_OPERATORS = re.compile(
    r'\b(exact|not|above|below|and|or|stop|skip)\b'
)

# Matches `(word word word ...)` — 3+ bare words separated by spaces only.
# Used by scan_space_separated_args AFTER filtering out operator expressions.
_MULTI_WORD_IN_PARENS_RE = re.compile(
    r'\(\s*[A-Za-z_]\w*(?:\s+[A-Za-z_]\w*){2,}\s*\)'
)

# Matches `word(` — a function call opening. Captures the word before `(`.
_CALL_OPEN_RE = re.compile(r'(\w+)\s*\($')


def _is_grouping_paren(inert, pos):
    """Return True if the `(` at `pos` in `inert` is a grouping/JSX paren,
    not a function-call paren. Grouping parens:
      • preceded only by whitespace / start-of-line  (`return (`, bare `(`)
      • preceded by a grouping keyword like `return`
    """
    before = inert[:pos].rstrip()
    if not before:
        return True  # line starts with `(`
    # Extract the last token before the paren
    m = re.search(r'(\w+)\s*$', before)
    if m and m.group(1) in _GROUPING_KEYWORDS:
        return True
    return False


def scan_paren_commas(lines, contexts):
    """Depth-tracking scanner for commas inside () groups.

    Catches what the old single-line regex missed:
      • multiline calls:  foo(\\n  a,\\n  b\\n)
      • nested calls:     foo(a, bar(x), baz(y))

    Reports one violation per opening-paren line, at depth 1 only.

    Skips `(` that are grouping parens (not function calls): `return(`,
    bare `(` at start of expression, etc.  Those may legitimately contain
    commas in JSX text like `<C.Title>Welcome, {name}</C.Title>`.
    """
    drifts = []
    depth = 0
    group_line = None     # line of the '(' that opened depth-1
    group_raw = ''
    group_reported = False
    group_is_call = False  # whether the depth-1 group is a real call

    for lineno, raw in enumerate(lines, 1):
        inert = strip_inert(raw)
        for col, ch in enumerate(inert):
            if ch == '(':
                depth += 1
                if depth == 1:
                    group_line = lineno
                    group_raw = raw.rstrip()
                    group_reported = False
                    group_is_call = not _is_grouping_paren(inert, col)
            elif ch == ')':
                if depth > 0:
                    depth -= 1
                if depth == 0:
                    group_is_call = False
            elif ch == ',' and depth == 1 and group_is_call and not group_reported:
                drifts.append((
                    group_line, 'comma-in-parens',
                    'Comma inside `()` arg list',
                    _COMMA_FIX,
                    group_raw,
                ))
                group_reported = True

    return drifts


def scan_space_separated_args(lines, contexts):
    """Catch Codex-mini's exploit: remove commas, use spaces between args.

    `foo(a b c)` — no commas, so the comma rule misses it. But multiple
    bare identifiers separated only by whitespace inside () is not valid
    chad call syntax (chad calls take exactly one argument, the subject
    goes outside the parens).

    Fires when a single-line () group contains 3+ bare words with only
    whitespace between them AND none of those words are chad operators
    (exact, not, above, below, and, or) — those signal an expression,
    not a space-delimited arg list.
    """
    drifts = []
    for lineno, raw in enumerate(lines, 1):
        inert = strip_inert(raw)
        m = _MULTI_WORD_IN_PARENS_RE.search(inert)
        if m:
            interior = m.group()[1:-1]  # strip outer parens
            # Skip if this looks like a chad expression (has operator keywords)
            if _CHAD_OPERATORS.search(interior):
                continue
            # Skip grouping parens
            if _is_grouping_paren(inert, m.start()):
                continue
            drifts.append((
                lineno, 'space-separated-args',
                'Multiple bare words inside `()` — looks like args without commas',
                'Chad calls take one subject. Space-separated args are not valid syntax. '
                'Move extra args outside parens or chain as subject.method().',
                raw.rstrip(),
            ))
    return drifts


# ── Function-body local declarations ─────────────────────────────────
# `name is value` inside a <functions> body is a local if `name` is not
# declared in any top-level <var> block. Chad has no function-body locals
# — all state lives in <var>. Loop iter vars (`<for N as i>`) are the
# sole exception and appear as tag attributes, never as bare assignments.

_VAR_DECL_RE    = re.compile(r'^\s{0,8}(\w+)\s+(is|exact)\s')
_FN_HEADER_RE   = re.compile(r'^(\s{2,})(\w[\w.]*)\s*:\s*$')
_FN_ASSIGN_RE   = re.compile(r'^(\s+)(\w+)\s+(is|exact)\s')
_OPEN_TAG_RE    = re.compile(r'<(\w[\w.]*)[\s>]')
_CLOSE_TAG_RE   = re.compile(r'</(\w[\w.]*)>')


def _collect_var_names(lines):
    """Return set of all names declared in top-level <var> blocks."""
    names = set()
    depth = 0  # nesting depth of OTHER blocks inside <var>
    in_var = False
    for raw in lines:
        s = strip_inert(raw).strip()
        if re.match(r'<var\b', s):
            in_var = True
            depth = 0
            continue
        if not in_var:
            continue
        if re.match(r'</var>', s):
            in_var = False
            continue
        # Track inner block nesting so we only grab top-level var names
        if re.match(r'<\w', s) and not s.startswith('</'):
            depth += 1
        elif s.startswith('</'):
            depth = max(0, depth - 1)
        elif depth == 0:
            m = _VAR_DECL_RE.match(raw)
            if m:
                names.add(m.group(1))
    return names


def _collect_fn_body_local_names(lines):
    """Return bare-name assignments found inside function bodies that are
    not declared in top-level <var>. These are legacy illegal locals that
    may later migrate into top-level <var> without counting as drift."""
    var_names = _collect_var_names(lines)

    derived = set()
    for n in var_names:
        derived.add('set_' + n)
        if n.startswith('set_'):
            derived.add(n[4:])
    var_names |= derived

    names = set()
    in_functions = False
    fn_indent = None
    body_indent = None
    fn_params: set = set()

    for raw in lines:
        s = strip_inert(raw).strip()

        if re.match(r'<functions\b', s):
            in_functions = True
            fn_indent = None
            body_indent = None
            fn_params = set()
            continue
        if re.match(r'</functions>', s):
            in_functions = False
            fn_indent = None
            body_indent = None
            fn_params = set()
            continue

        if not in_functions:
            continue

        m = _FN_HEADER_WITH_PARAMS_RE.match(strip_inert(raw))
        if m:
            fn_indent = len(m.group(1))
            body_indent = fn_indent + 2
            raw_params = m.group(3) or ''
            fn_params = {p for p in _PARAM_SPLIT_RE.split(raw_params) if p}
            continue

        if fn_indent is None:
            continue

        m = _FN_ASSIGN_RE.match(raw)
        if not m:
            continue
        this_indent = len(m.group(1))
        name = m.group(2)
        known = var_names | fn_params
        if this_indent >= body_indent and '.' not in name and name not in known:
            names.add(name)

    return names


# Matches function headers with optional params: `  funcName(p1 p2):` or `  funcName:`
_FN_HEADER_WITH_PARAMS_RE = re.compile(
    r'^(\s{2,})(\w[\w.]*)'           # indent + name
    r'(?:\(([^)]*)\))?'              # optional (params) — space-separated in chad
    r'\s*:\s*$'                      # ends with :
)
_PARAM_SPLIT_RE = re.compile(r'[\s,]+')


def scan_fn_body_locals(lines, contexts):
    """Flag bare-name assignments inside <functions> bodies that are not in <var>.

    A function body local looks like:
        resolveSize:
          metrics is size.math.floor    ← local (not in <var>)
          node.width is 0               ← field write, OK (has a dot)

    Known names that are NOT locals:
      • All names declared in any top-level <var> block
      • Derived setter names: if `tasks` is in <var>, `set_tasks` is also known
      • Function parameters declared in the header: `toggle(flag):` → `flag` is param
    """
    var_names = _collect_var_names(lines)

    # Expand: for every name in var, add set_<name> (reactive setter pattern).
    # Also: for every set_<name> in var, the base name is implicitly known.
    derived = set()
    for n in var_names:
        derived.add('set_' + n)
        if n.startswith('set_'):
            derived.add(n[4:])
    var_names |= derived

    drifts = []
    in_functions = False
    fn_indent = None
    body_indent = None
    fn_params: set = set()   # parameter names for the current function

    for lineno, raw in enumerate(lines, 1):
        s = strip_inert(raw).strip()

        if re.match(r'<functions\b', s):
            in_functions = True
            fn_indent = None
            body_indent = None
            fn_params = set()
            continue
        if re.match(r'</functions>', s):
            in_functions = False
            fn_indent = None
            body_indent = None
            fn_params = set()
            continue

        if not in_functions:
            continue

        # Detect function header (with or without params)
        m = _FN_HEADER_WITH_PARAMS_RE.match(strip_inert(raw))
        if m:
            fn_indent = len(m.group(1))
            body_indent = fn_indent + 2
            raw_params = m.group(3) or ''
            fn_params = {p for p in _PARAM_SPLIT_RE.split(raw_params) if p}
            continue

        if fn_indent is None:
            continue

        # Check for bare-name assignment in body
        m = _FN_ASSIGN_RE.match(raw)
        if m:
            this_indent = len(m.group(1))
            name = m.group(2)
            known = var_names | fn_params
            if this_indent >= body_indent and '.' not in name and name not in known:
                drifts.append((
                    lineno, 'fn-body-local',
                    f'Function-body local `{name}` — forbidden',
                    'Declare all state in top-level `<var>`. '
                    'Function bodies only assign to `<var>` names or field paths (`x.y`).',
                    raw.rstrip(),
                ))

    return drifts


# ── Fake reactive setters (smuggled function-body locals) ────────────
# Pattern: author hits the no-locals rule, can't declare `existing is ...`
# inside a function body, so hoists it to <var> as `set_existing is null`
# to satisfy the validator. The "reactive setter" prefix is a disguise —
# nobody reads `existing` outside the one function that writes it.
#
# Real reactive setters are read from multiple functions OR from JSX
# interpolation (`{loading}`) OR from `<during X>` reactive guards. They
# are STATE the whole project sees. Fake ones are scratchpad with a costume.
#
# Heuristic: collect every `set_X` declared in <var>. Walk the rest of
# the file tracking which function (or return/JSX) references `X` or
# `set_X`. If every reference falls inside exactly one function body and
# no reference appears in return(), flag the setter as smuggled.

def scan_fake_reactive_setters(lines, contexts):
    """Flag top-level `set_X` declarations that are only used inside one
    function body — the smuggled-local pattern.

    A legitimate reactive setter is read from:
      • multiple function bodies (state shared across actions), OR
      • a JSX interpolation `{X}` in return(), OR
      • a `<during X>` reactive guard, OR
      • a conditional `<if X ...>` outside the setting function.

    A fake setter is written and read entirely within ONE function body,
    with no outside references.
    """
    # Phase 1 — collect `set_X` declarations at top level of <var>.
    setters = {}           # base_name -> declaration line number
    in_var = False
    inner_depth = 0        # depth of nested blocks inside <var>
    for lineno, raw in enumerate(lines, 1):
        s = strip_inert(raw).strip()
        if re.match(r'<var\b', s):
            in_var = True
            inner_depth = 0
            continue
        if not in_var:
            continue
        if re.match(r'</var>', s):
            in_var = False
            continue
        if re.match(r'<\w', s) and not s.startswith('</'):
            inner_depth += 1
            continue
        if s.startswith('</'):
            inner_depth = max(0, inner_depth - 1)
            continue
        if inner_depth != 0:
            continue
        m = re.match(r'\s*set_(\w+)\s+(is|exact)\s', raw)
        if m:
            setters[m.group(1)] = lineno

    if not setters:
        return []

    # Phase 2 — walk non-<var> content, track enclosing function (or
    # `return`/`top`/`during`/`if-jsx`), and record every reference to each
    # setter base name or its set_ form.
    refs = {base: [] for base in setters}   # base -> [(lineno, location), ...]
    in_var = False
    in_functions = False
    current_fn = None
    fn_indent = None
    return_depth = 0        # depth of open parens inside return(...)

    # Precompile a single alternation for all setters
    name_group = '|'.join(
        re.escape(n) for n in sorted(setters, key=len, reverse=True)
    )
    ref_pat = re.compile(
        rf'(?<![\w.])(?:set_)?(?P<name>{name_group})(?![\w])'
    )

    for lineno, raw in enumerate(lines, 1):
        inert = strip_inert(raw)
        s = inert.strip()

        # Skip <var> entirely — declarations don't count as references.
        if re.match(r'<var\b', s):
            in_var = True
            continue
        if in_var:
            if re.match(r'</var>', s):
                in_var = False
            continue

        # Track <functions> container + function header
        if re.match(r'<functions\b', s):
            in_functions = True
            current_fn = None
            fn_indent = None
        elif re.match(r'</functions>', s):
            in_functions = False
            current_fn = None
            fn_indent = None
        elif in_functions:
            fn_match = _FN_HEADER_WITH_PARAMS_RE.match(inert)
            if fn_match:
                current_fn = fn_match.group(2)
                fn_indent = len(fn_match.group(1))

        # Track return(...) depth — opens on `return(`, closes when the
        # matching `)` appears at depth 0.
        for ch in inert:
            if return_depth == 0 and ch == '(':
                # lazy start: mark return on seeing it
                pass
        # Simpler heuristic: if the line contains `return(` or `return (`
        # we're entering; track paren depth from there on.
        if re.search(r'\breturn\s*\(', inert) and return_depth == 0:
            return_depth = 1
            # Continue scanning parens on this line AFTER the return(
            idx = inert.index('(', inert.index('return'))
            scan_from = idx + 1
        else:
            scan_from = 0
        if return_depth > 0:
            for ch in inert[scan_from:]:
                if ch == '(':
                    return_depth += 1
                elif ch == ')':
                    return_depth -= 1
                    if return_depth == 0:
                        break

        # Determine location label for this line
        if return_depth > 0 or (scan_from and re.search(r'\breturn\s*\(', inert)):
            location = 'return'
        elif in_functions and current_fn:
            location = current_fn
        else:
            location = 'top'

        # Collect references on this line
        for m in ref_pat.finditer(inert):
            base = m.group('name')
            # Skip the declaration itself (when we're NOT in_functions and
            # we're still at the top level — should only be <var>, which
            # we already skip)
            refs[base].append((lineno, location))

    # Phase 3 — for each setter, decide if it's a smuggled local.
    drifts = []
    for base, references in refs.items():
        if not references:
            continue  # dead declaration, not this rule's concern
        locations = {loc for _, loc in references}
        # Smuggled local: every reference is in ONE specific function,
        # never in return()/JSX, never at top level.
        if (
            len(locations) == 1
            and 'return' not in locations
            and 'top' not in locations
            and 'during' not in locations
        ):
            fn_name = next(iter(locations))
            # Require at least 2 refs to reduce noise on truly single-use
            # helper state (which is still drift, but more obvious).
            if len(references) >= 2:
                decl_line = setters[base]
                decl_raw = (
                    lines[decl_line - 1] if 0 < decl_line <= len(lines) else ''
                )
                drifts.append((
                    decl_line,
                    'fake-reactive-setter',
                    f'`set_{base}` only used inside `{fn_name}` '
                    f'({len(references)} refs) — smuggled local',
                    f'This is not reactive state. Nothing outside `{fn_name}` '
                    f'reads `{base}`. If you needed a local value, use '
                    f'`<if expr as {base}>` for optional unwrap, or write '
                    f'through a struct field (`node.{base}`). Don\'t hoist '
                    f'locals into <var> with a set_ prefix.',
                    decl_raw.rstrip(),
                ))

    return drifts


# ── Bare collection contracts ────────────────────────────────────────
# A bare `is array` placeholder is only tolerable while it stays truly
# open-ended. Once code starts using it like a typed builder
# (`parts.push(...).join(...)`), the collection needs a contract:
#   • explicit element type (`string array`, `Node array`, ...)
#   • or a matching `<name> ... </name>` data block
#
# This specifically targets the "JS scratch array in chad clothing"
# drift that keeps showing up in compiler modules.

_BARE_ARRAY_DECL_RE = re.compile(r'^\s*([a-z_][a-z0-9_]*)\s+is\s+array\b')
_ARRAY_BUILDER_METHODS = frozenset({'push', 'join', 'concat'})
_USES_OPEN_ENTRY_RE = re.compile(r'^\s*<([a-z_][a-z0-9_]*)\s+has>\s*$')
_USES_CLOSE_ENTRY_RE = re.compile(r'^\s*</([a-z_][a-z0-9_]*)>\s*$')
_DOTTED_REF_RE = re.compile(r'(?<![\w.])([a-z_][a-z0-9_]*)\.([A-Za-z_][A-Za-z0-9_]*)\b')


def scan_bare_array_contracts(lines, contexts):
    """Flag bare `is array` declarations once usage proves they need a
    real contract."""
    doc_free_lines, _ = blank_docs(lines)
    decls = {}          # name -> (line_no, raw)
    data_blocks = set() # names with `<name> ... </name>` blocks
    stack = []
    containers = frozenset({'types', 'var', 'functions', 'semantics'})

    def container_info():
        for idx in range(len(stack) - 1, -1, -1):
            if stack[idx] in containers:
                return stack[idx], len(stack) - idx - 1
        return None, 0

    # Pass 1 — collect bare-array declarations and matching data blocks.
    for lineno, raw in enumerate(doc_free_lines, 1):
        inert = strip_inert(raw)
        block, depth = container_info()
        if block == 'var' and depth == 0:
            m = _BARE_ARRAY_DECL_RE.match(inert)
            if m and m.group(1) not in decls:
                decls[m.group(1)] = (lineno, lines[lineno - 1].rstrip())

        for m in _INV_TAG_RE.finditer(inert):
            is_close = bool(m.group(1))
            is_self_close = bool(m.group(3))
            words = m.group(2).strip().split()
            if not words:
                continue
            tag_name = words[0]

            if is_close:
                while stack:
                    if stack.pop() == tag_name:
                        break
                continue

            parent, _ = container_info()
            if (
                tag_name in decls
                and len(words) == 1
                and parent not in containers
            ):
                data_blocks.add(tag_name)

            if not is_self_close:
                stack.append(tag_name)

    if not decls:
        return []

    drifts = []
    method_group = '|'.join(sorted(_ARRAY_BUILDER_METHODS))
    for name, (decl_line, decl_raw) in decls.items():
        if name in data_blocks:
            continue
        pat = re.compile(
            rf'(?<![\w.]){re.escape(name)}\.({method_group})\s*\('
        )
        if any(pat.search(strip_inert(raw)) for raw in doc_free_lines):
            drifts.append((
                decl_line,
                'bare-array-contract',
                f'`{name} is array` is used as a typed builder without a contract',
                f'Give `{name}` an element type (`string array`, `Node array`, etc.) '
                f'or populate it through a matching `<{name}> ... </{name}>` data block. '
                'Bare `is array` is only for genuinely open-ended placeholders.',
                decl_raw,
            ))

    return drifts


def scan_uses_member_contracts(lines, contexts):
    """Require `<uses>` to declare explicit module members via
    `<name has> ... </name>` and reject drift where `module.member`
    is used without that contract."""
    del contexts
    structured = {}
    bare_entries = []
    in_uses = False
    current_use = None

    for lineno, raw in enumerate(lines, 1):
        inert = strip_inert(raw)
        trimmed = inert.strip()
        if not trimmed:
            continue
        if trimmed == '<uses>':
            in_uses = True
            current_use = None
            continue
        if trimmed == '</uses>':
            in_uses = False
            current_use = None
            continue
        if not in_uses:
            continue

        open_match = _USES_OPEN_ENTRY_RE.match(trimmed)
        if open_match:
            current_use = open_match.group(1)
            structured.setdefault(current_use, set())
            continue

        close_match = _USES_CLOSE_ENTRY_RE.match(trimmed)
        if close_match:
            current_use = None
            continue

        if trimmed.startswith('<') and trimmed.endswith('>'):
            continue

        if current_use is not None:
            structured.setdefault(current_use, set()).add(trimmed)
            continue

        bare_entries.append((lineno, trimmed, raw.rstrip()))

    drifts = []
    for lineno, name, raw in bare_entries:
        drifts.append((
            lineno,
            'uses-bare-entry',
            f'`<uses>` lists bare `{name}` without an explicit member contract',
            f'Rewrite as `<uses><{name} has>memberName</{name}></uses>` so '
            'cross-file access is declared instead of implied.',
            raw,
        ))

    if not structured:
        return drifts

    for lineno, raw in enumerate(lines, 1):
        inert = strip_inert(raw)
        for match in _DOTTED_REF_RE.finditer(inert):
            root, leaf = match.groups()
            if root not in structured:
                continue
            if leaf in structured[root]:
                continue
            drifts.append((
                lineno,
                'uses-member-missing',
                f'`{root}.{leaf}` is used without being declared under `<{root} has>`',
                f'Add `{leaf}` under `<uses><{root} has> ... </{root}></uses>` '
                'or stop reaching through that module here.',
                raw.rstrip(),
            ))

    return drifts


# ── Closing-tag namespace mismatch ───────────────────────────────────
# Chad rule: an opening tag `<namespace TYPE [qualifier]>` closes as
# `</namespace>`. Type and qualifier words do NOT appear in the close.
#
# Examples:
#   <agent color module>    → </agent color>     (strip `module`)
#   <my piano instrument>   → </my piano>        (strip `instrument`)
#   <sq from system.libs has> → </sq>            (strip qualifier + type)
#   <C.Card is Box>         → </C.Card>          (strip `is Box`)
#   <plasma effect>         → </plasma>          (strip `effect`)
#   <var>                   → </var>             (single word, matches)
#   <for tasks at i>        → </for>             (attribute block)
#
# Common drifts this catches:
#   • Close repeats the type:   <X Y module> ... </X Y module>
#   • Close over-strips:        <X Y module> ... </X>
#   • Close has mangled words:  <X Y> ... </X z>

# Words that END the namespace portion of an open tag. The close tag
# should contain only tokens BEFORE these words.
_TAG_QUALIFIERS = frozenset({
    # Structural prepositions
    'from', 'is', 'as', 'has', 'exact', 'requires', 'at',
    # File / declaration types (typically appear last)
    'app', 'widget', 'lib', 'module', 'page', 'component', 'instrument',
    'union', 'effect', 'glyph', 'semantics', 'function', 'cli',
})

# Block-keyword tags where the open may carry attributes but the close
# is just the keyword (e.g., `<for tasks>` closes `</for>`).
_KEYWORD_BLOCK_NAMES = frozenset({
    'if', 'else', 'for', 'while', 'switch', 'case', 'during',
})


def _is_component_ref(word):
    # Components are dotted (C.Btn) or Capitalized single (Counter).
    # Everything after the component token is attrs/handlers, not namespace.
    if not word:
        return False
    return '.' in word or word[:1].isupper()


def _expected_namespace(tag_words):
    """Return the words that should appear in the matching close tag.

    Rules (in priority order):
      1. Empty / no-op               → return as-is
      2. Single-word tag             → close matches exactly
      3. First word is a block-keyword (`if`, `for`, `during`, ...)
         → close is just that keyword
      4. First word is a component ref (dotted or Capitalized)
         → close is just that token (handler attrs stripped)
      5. Otherwise, consume words from the left until we hit a qualifier
         or type word. Those and everything after are NOT in the close.
    """
    if not tag_words:
        return []
    if len(tag_words) == 1:
        return list(tag_words)
    if tag_words[0] in _KEYWORD_BLOCK_NAMES:
        return [tag_words[0]]
    if _is_component_ref(tag_words[0]):
        return [tag_words[0]]
    ns = []
    for w in tag_words:
        if w in _TAG_QUALIFIERS:
            break
        ns.append(w)
    return ns if ns else [tag_words[0]]


# Match open or close tags. Body captured as group(2). Self-closing tags
# caught via group(3).
_TAG_SCAN_RE = re.compile(r'<(/?)([\w.][\w\s.]*?)(\s*/\s*)?>')


def scan_close_tag_mismatch(lines, contexts):
    """Stack-based paired open/close scan. Flags closes whose content
    doesn't match the expected namespace of their matching open."""
    stack = []   # [(open_line, open_words, open_raw)]
    drifts = []
    reported = set()   # (open_line, close_line) dedupe

    for lineno, raw in enumerate(lines, 1):
        inert = strip_inert(raw)
        for m in _TAG_SCAN_RE.finditer(inert):
            is_close = m.group(1) == '/'
            is_self_close = bool(m.group(3))
            if is_self_close:
                continue

            body = m.group(2).strip()
            if not body:
                continue
            words = body.split()
            if not words:
                continue

            if is_close:
                if not stack:
                    # Orphan close — different drift class, skip.
                    continue
                open_line, open_words, open_raw = stack[-1]
                expected = _expected_namespace(open_words)
                if words == expected:
                    stack.pop()
                    continue
                # First word must match — if not, this close is for
                # something deeper that wasn't properly opened. Skip
                # without popping; we may recover on a later close.
                if words[0] != open_words[0]:
                    continue
                stack.pop()
                key = (open_line, lineno)
                if key in reported:
                    continue
                reported.add(key)
                drifts.append((
                    lineno,
                    'close-tag-mismatch',
                    f'Close `</{" ".join(words)}>` does not match open '
                    f'`<{" ".join(open_words)}>` — expected '
                    f'`</{" ".join(expected)}>`',
                    'Close tags contain only the NAMESPACE from the open '
                    'tag — strip qualifier words (from/is/as/has/exact/at) '
                    'and type words (module/widget/lib/app/page/component/'
                    'union/effect/glyph/semantics/function/instrument/cli). '
                    'Single-word keyword blocks (<if>, <for>, <during>, ...) '
                    'close with just the keyword regardless of attributes.',
                    raw.rstrip(),
                ))
            else:
                stack.append((lineno, words, raw.rstrip()))

    return drifts


# ──────────────────────────────────────────────────────────────────────
# File checker
# ──────────────────────────────────────────────────────────────────────

def check_file(path: Path):
    """Return list of (line_no, rule_name, message, fix, raw_line)."""
    try:
        content = path.read_text(encoding='utf-8')
    except UnicodeDecodeError:
        return [(0, 'encoding', 'file is not valid UTF-8', '', '')]
    except OSError as e:
        return [(0, 'read-error', str(e), '', '')]

    lines = content.splitlines()
    rel = str(path)
    drifts = []
    doc_free_lines, unclosed_doc_line = blank_docs(lines)
    payload_doc_free_lines = blank_allowed_payload_blocks(doc_free_lines, rel)

    if rel in BASELINE:
        base = BASELINE[rel]
        cur = len(lines)
        if base >= 50 and cur < base * 0.6:
            pct = int((1 - cur / base) * 100)
            drifts.append((
                1,
                'stub-collapse',
                f'file shrunk {pct}% vs baseline ({base} → {cur} lines)',
                'Stubbing is not a fix. Restore via '
                f'`git show 5128df733:{rel} > /tmp/{path.name}`, then '
                'drift-fix inline.',
                '',
            ))

    if rel in BASELINE_INVENTORY:
        cur_inv = scan_content_inventory(lines)
        base_inv = BASELINE_INVENTORY[rel]
        for category in ('types', 'vars', 'functions', 'semantics'):
            missing = sorted(set(base_inv.get(category, [])) - set(cur_inv.get(category, [])))
            if missing:
                drifts.append((
                    1,
                    'content-missing',
                    f'<{category}> lost baseline names: {missing}',
                    f'Restore missing names via `git show 5128df733:{rel}` then '
                    'drift-fix inline. Additions are fine; removals are drift.',
                    '',
                ))

        baseline_legacy_locals = set(base_inv.get('legacy_body_locals', []))
        current_legacy_survivors = set(cur_inv.get('legacy_body_locals', []))
        current_legal_var_survivors = set(cur_inv.get('vars', []))
        missing_legacy_locals = sorted(
            baseline_legacy_locals - current_legacy_survivors - current_legal_var_survivors
        )
        if missing_legacy_locals:
            drifts.append((
                1,
                'content-missing',
                'baseline body-local vars vanished instead of surviving or '
                f'migrating to <var>: {missing_legacy_locals}',
                f'Restore these names via `git show 5128df733:{rel}` or move them '
                'into top-level `<var>`. Baseline body-locals are allowed to migrate '
                'upward, but not disappear.',
                '',
            ))

        base_real = int(base_inv.get('real_content_lines', 0))
        cur_real = int(cur_inv.get('real_content_lines', 0))
        if base_real >= 30 and cur_real < base_real * 0.6:
            pct = int((1 - (cur_real / base_real)) * 100)
            drifts.append((
                1,
                'content-missing',
                f'real-content lines shrunk {pct}% vs baseline ({cur_real}/{base_real})',
                'Restore the missing implementation. Additions are allowed, but doc/comment '
                'padding does not count as retained content.',
                '',
            ))

        base_refs = base_inv.get('refs', {})
        cur_refs = cur_inv.get('refs', {})
        low_ref_names = []
        for name, base_count in sorted(base_refs.items()):
            floor = max(2, int(base_count * 0.5 + 0.999999999))
            if cur_refs.get(name, 0) < floor:
                low_ref_names.append(f'{name}:{cur_refs.get(name, 0)}/{base_count}')
        if low_ref_names:
            drifts.append((
                1,
                'content-missing',
                f'baseline names lost usage depth: {low_ref_names}',
                'Preserve baseline usage, not just declarations. A retained name must still '
                'appear in real implementation, not as a dead stub.',
                '',
            ))

    if unclosed_doc_line:
        drifts.append((
            unclosed_doc_line,
            'unclosed-doc',
            'Unclosed <~!> doc block before file end',
            'Close the doc span with <!~> before EOF.',
            lines[unclosed_doc_line - 1].rstrip(),
        ))

    # Per-line set of script-block contexts ({'zscript'}, {'jscript'}, …)
    # Rules tagged with `skip_in_blocks` intersecting this set do NOT fire.
    contexts = compute_block_contexts(payload_doc_free_lines)

    for i, raw in enumerate(lines, 1):
        # Two preparations:
        #   doc_free      — doc spans blanked before any other scan
        #   comments_only — comments stripped, strings preserved
        #                   (for rules that need to see string content,
        #                    like print-newline looking for `\n`)
        #   inert         — comments AND string interiors blanked
        #                   (the default — drift inside strings is noise)
        doc_free = payload_doc_free_lines[i - 1]
        comments_only = strip_comments(doc_free)
        inert = strip_inert_payload_aware(doc_free, rel)
        line_context = contexts[i - 1]
        for rule in RULES:
            # Unpack rule, tolerating the optional skip_in_blocks field.
            if len(rule) == 6:
                name, pat, msg, fix, use_raw, skip_in_blocks = rule
            else:
                name, pat, msg, fix, use_raw = rule
                skip_in_blocks = frozenset()
            # If this line is inside any block in skip_in_blocks, the rule
            # is suppressed — foreign-language passthrough is legit there.
            if skip_in_blocks and line_context & skip_in_blocks:
                continue
            target = doc_free if use_raw else inert
            if name == 'free-comment' and not target.strip():
                continue
            if pat.search(target):
                drifts.append((i, name, msg, fix, raw.rstrip()))

    # Multi-line / depth-aware scanners (cannot be expressed per-line)
    drifts.extend(scan_paren_commas(payload_doc_free_lines, contexts))
    drifts.extend(scan_space_separated_args(payload_doc_free_lines, contexts))
    drifts.extend(scan_fn_body_locals(payload_doc_free_lines, contexts))
    drifts.extend(scan_fake_reactive_setters(payload_doc_free_lines, contexts))
    drifts.extend(scan_bare_array_contracts(payload_doc_free_lines, contexts))
    drifts.extend(scan_uses_member_contracts(payload_doc_free_lines, contexts))
    drifts.extend(scan_close_tag_mismatch(payload_doc_free_lines, contexts))

    # Sort by line number so output is top-to-bottom
    drifts.sort(key=lambda t: t[0])
    return drifts


def iter_fart_files(root: Path):
    """Yield .fart paths under root (or just root if it's a file)."""
    if root.is_file():
        if root.suffix == '.fart':
            yield root
        return
    if root.is_dir():
        yield from sorted(root.rglob('*.fart'))


def format_drifts(path: Path, drifts):
    """Pretty-print the drifts for one file. Returns (drift_count, output)."""
    if not drifts:
        return 0, ''
    lines = [f'{BOLD}{path}{RST}']
    for line_no, name, msg, fix, raw in drifts:
        lines.append(f'  {YLW}{line_no:>5}{RST}  '
                     f'{RED}{name:<18}{RST}  {msg}')
        if raw:
            trimmed = raw[:120] + ('…' if len(raw) > 120 else '')
            lines.append(f'         {DIM}{trimmed}{RST}')
        if fix:
            lines.append(f'         {GREEN}fix:{RST} {fix}')
    return len(drifts), '\n'.join(lines)


def main(argv):
    if len(argv) < 2:
        sys.stderr.write(f'{RED}usage:{RST} nodrift path/to/file.fart '
                         '[more.fart | directory ...]\n')
        return 2

    all_files = []
    for arg in argv[1:]:
        p = Path(arg)
        if not p.exists():
            sys.stderr.write(f'{RED}missing:{RST} {arg}\n')
            return 2
        all_files.extend(iter_fart_files(p))

    if not all_files:
        sys.stderr.write(f'{RED}no .fart files found{RST}\n')
        return 2

    total_drifts = 0
    files_failed = 0

    for fp in all_files:
        drifts = check_file(fp)
        count, output = format_drifts(fp, drifts)
        if count:
            print(output)
            print()
            files_failed += 1
            total_drifts += count

    print(f'{DIM}{"─" * 60}{RST}')
    if total_drifts == 0:
        print(f'{GREEN}✓ {len(all_files)} file(s) clean.{RST}')
        return 0
    else:
        print(f'{RED}✗ {total_drifts} drift(s) in '
              f'{files_failed}/{len(all_files)} file(s).{RST}')
        return 1


if __name__ == '__main__':
    sys.exit(main(sys.argv))
