#!/bin/bash
# Post-build runtime checks for any cart — snapshot + runtime-error scan +
# contract check. Same three gates that scripts/build runs for conformance
# carts (at scripts/build:1228), but WITHOUT the tamper lock and WITHOUT
# writing to conformance.db.
#
# Safe for iteration on carts/cockpit/ and anywhere else you want live
# regression coverage while still editing the source every minute.
#
# Usage:
#   ./scripts/postflight carts/cockpit/cockpit.app.tsz
#   ./scripts/build carts/cockpit/cockpit.app.tsz && ./scripts/postflight carts/cockpit/cockpit.app.tsz
#
# Exit codes: 0 ok | 1 runtime errors | 2 snapshot FAILs | 3 contract contamination | 4 no binary

set -euo pipefail
cd "$(dirname "$0")/.."

if [ $# -lt 1 ]; then
    echo "Usage: scripts/postflight <cart.tsz>"
    exit 64
fi

CART="$1"
if [ ! -f "$CART" ]; then
    echo "[postflight] cart not found: $CART"
    exit 64
fi

NAME=$(basename "$CART" .tsz)
BASENAME=$(basename "$CART" .tsz | sed 's/\.app$//')
BINARY="zig-out/bin/$NAME"
AUTOTEST_FILE="tests/${BASENAME}.autotest"

if [ ! -x "$BINARY" ]; then
    echo "[postflight] no binary at $BINARY — run ./scripts/build first"
    exit 4
fi

mkdir -p tests

# ── 1. Snapshot: run headless, capture visible text as autotest ─────────
SNAP_T0=$(date +%s%N)
SNAP_STDERR=$(mktemp)
ZIGOS_HEADLESS=1 ZIGOS_WITNESS=snapshot ZIGOS_WITNESS_FILE="$AUTOTEST_FILE" \
    timeout -s KILL 5 "$BINARY" >/dev/null 2>"$SNAP_STDERR" || true
SNAP_T1=$(date +%s%N)
SNAP_MS=$(( (SNAP_T1 - SNAP_T0) / 1000000 ))

# ── 2. Runtime error scan ────────────────────────────────────────────────
RUNTIME_ERRORS=$(grep -cE '^error:|^\[luajit-runtime\]|^\[evalExpr error\]|^\[evalToString error\]|^\[evalLuaMapData error\]|^\[js_on_press\].*error|ReferenceError|SyntaxError|TypeError' "$SNAP_STDERR" 2>/dev/null || true)
RUNTIME_ERRORS=${RUNTIME_ERRORS//[^0-9]/}; RUNTIME_ERRORS=${RUNTIME_ERRORS:-0}

if [ "$RUNTIME_ERRORS" -gt 0 ]; then
    echo "[$NAME] runtime: ${RUNTIME_ERRORS} error(s) detected"
    grep -E '^error:|^\[luajit-runtime\]|^\[eval.*error\]|^\[evalLuaMapData error\]|ReferenceError|SyntaxError|TypeError' "$SNAP_STDERR" | head -10
fi

# Forward snapshot progress lines for visibility
grep '^\[snapshot\]' "$SNAP_STDERR" 2>/dev/null || true
rm -f "$SNAP_STDERR"

# ── 3. Autotest metrics + FAIL detection ─────────────────────────────────
EXPECT_COUNT=0; CLICK_COUNT=0; FAIL_COUNT=0
if [ -f "$AUTOTEST_FILE" ]; then
    EXPECT_COUNT=$(grep -c '^expect ' "$AUTOTEST_FILE" 2>/dev/null || true)
    CLICK_COUNT=$(grep -c '^click ' "$AUTOTEST_FILE" 2>/dev/null || true)
    FAIL_COUNT=$(grep -c '^# FAIL' "$AUTOTEST_FILE" 2>/dev/null || true)
    EXPECT_COUNT=${EXPECT_COUNT//[^0-9]/}; EXPECT_COUNT=${EXPECT_COUNT:-0}
    CLICK_COUNT=${CLICK_COUNT//[^0-9]/};   CLICK_COUNT=${CLICK_COUNT:-0}
    FAIL_COUNT=${FAIL_COUNT//[^0-9]/};     FAIL_COUNT=${FAIL_COUNT:-0}
fi

TOTAL_FAILS=$(( FAIL_COUNT + RUNTIME_ERRORS ))

# ── 4. Contract check — JSX contamination in source_contract JSON ────────
CONTRACT_CLEAN=1
CONTRACT_JSON="/tmp/tsz-gen/source_contract_${BASENAME}.json"
if ./zig-out/bin/forge contract "$CART" >/dev/null 2>&1 && [ -f "$CONTRACT_JSON" ]; then
    if grep -qE '"</(Text|Box|Pressable|ScrollView|Image)' "$CONTRACT_JSON" 2>/dev/null; then
        CONTRACT_CLEAN=0
        echo "[$NAME] contract: JSX CONTAMINATION detected"
    fi
fi

# ── Verdict ──────────────────────────────────────────────────────────────
if [ "$TOTAL_FAILS" -gt 0 ]; then
    echo "[$NAME] postflight: ${EXPECT_COUNT} expects + ${CLICK_COUNT} clicks + ${TOTAL_FAILS} FAILS in ${SNAP_MS}ms → $AUTOTEST_FILE"
    if [ "$RUNTIME_ERRORS" -gt 0 ]; then exit 1; fi
    exit 2
fi

if [ "$CONTRACT_CLEAN" -eq 0 ]; then
    exit 3
fi

echo "[$NAME] postflight: ${EXPECT_COUNT} expects + ${CLICK_COUNT} clicks in ${SNAP_MS}ms → $AUTOTEST_FILE [OK]"
exit 0
