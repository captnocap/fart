#!/bin/bash
# Pre-commit structural guard against "stub collapse" / fake-it shrinkage.
# Blocks staged commits when an authored .fart file shrinks too hard in one
# shot or shows a severe delete-heavy numstat profile.
#
# Install: ln -sf ../../tsz/scripts/pre-commit-shrink-guard .git/hooks/pre-commit
# Manual:  tsz/scripts/pre-commit-shrink-guard

set -euo pipefail

cd "$(dirname "$0")/../.."

SHRINK_PCT_THRESHOLD=40
DEL_INS_RATIO_NUM=3
DEL_INS_RATIO_DEN=1
DEL_THRESHOLD=50

should_check_path() {
    local path="$1"

    case "$path" in
        tsz/reference/*|love2d/*|archive/*|bin/tsz)
            return 1
            ;;
        *.gen.zig)
            return 1
            ;;
        *.fart)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

get_head_line_count() {
    local path="$1"

    if ! git cat-file -e "HEAD:$path" 2>/dev/null; then
        echo 0
        return
    fi

    git show "HEAD:$path" | wc -l | tr -d ' '
}

is_binary_numstat() {
    local ins="$1"
    local del="$2"
    [ "$ins" = "-" ] || [ "$del" = "-" ]
}

violations=()

while IFS=$'\t' read -r ins del path; do
    [ -n "${path:-}" ] || continue

    if ! should_check_path "$path"; then
        continue
    fi

    if is_binary_numstat "$ins" "$del"; then
        continue
    fi

    if [ "$del" -le 0 ]; then
        continue
    fi

    before_lines=$(get_head_line_count "$path")

    # New files and files not present in HEAD cannot shrink relative to a prior
    # baseline, so the structural collapse heuristic does not apply.
    if [ "$before_lines" -le 0 ]; then
        continue
    fi

    # Net shrink: only count deletions that aren't offset by insertions.
    # A file that grows (ins >= del) is never shrinking, regardless of how
    # many lines were touched. Prevents false positives on stub RESTORES
    # where HEAD holds a small stubbed version and the staged diff adds
    # hundreds of lines back (big del, even bigger ins).
    net_del=$(( del - ins ))
    [ "$net_del" -lt 0 ] && net_del=0
    shrink_pct=$(( net_del * 100 / before_lines ))

    alarm_reasons=()

    if [ "$shrink_pct" -gt "$SHRINK_PCT_THRESHOLD" ]; then
        alarm_reasons+=("net-shrinks ${shrink_pct}% (${del} del − ${ins} ins vs ${before_lines} before)")
    fi

    if [ "$del" -gt "$DEL_THRESHOLD" ] && [ "$del" -gt $(( ins * DEL_INS_RATIO_NUM / DEL_INS_RATIO_DEN )) ]; then
        alarm_reasons+=("delete-heavy numstat ${del}:${ins} (> ${DEL_INS_RATIO_NUM}:${DEL_INS_RATIO_DEN} with >${DEL_THRESHOLD} deletions)")
    fi

    if [ "${#alarm_reasons[@]}" -gt 0 ]; then
        joined=""
        for reason in "${alarm_reasons[@]}"; do
            if [ -n "$joined" ]; then
                joined="$joined; "
            fi
            joined="${joined}${reason}"
        done
        violations+=("$path|$before_lines|$ins|$del|$joined")
    fi
done < <(git diff --cached --numstat --diff-filter=ACMR)

if [ "${#violations[@]}" -eq 0 ]; then
    exit 0
fi

printf "\n"
printf "pre-commit shrink guard blocked this commit\n"
printf "\n"
printf "The staged diff looks like a structural collapse rather than a normal cleanup.\n"
printf "Thresholds:\n"
printf "  - shrink > %s%% of prior file lines\n" "$SHRINK_PCT_THRESHOLD"
printf "  - delete:insert > %s:%s with > %s deleted lines\n" \
    "$DEL_INS_RATIO_NUM" "$DEL_INS_RATIO_DEN" "$DEL_THRESHOLD"
printf "\n"
printf "Flagged files:\n"

for item in "${violations[@]}"; do
    IFS='|' read -r path before_lines ins del reasons <<< "$item"
    printf "  - %s\n" "$path"
    printf "    before=%s staged +%s -%s\n" "$before_lines" "$ins" "$del"
    printf "    reason=%s\n" "$reasons"
done

printf "\n"
printf "If this shrink is intentional, split the change into smaller commits or revise the file inline so the diff proves the real rewrite instead of a stub collapse.\n"
printf "\n"

exit 1
