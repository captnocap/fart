#!/bin/bash
# Handler Test Runner — zig build test-handlers wrapper
#
# Usage: ./scripts/test-handlers <path/to/app.tsz>
#        ./scripts/test-handlers --cart <path/to/cart.zig> [--js-logic <path>]
#
# This script:
#   1. Compiles the test harness
#   2. Runs it against the specified app
#   3. Reports results

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TSZ_DIR="$(dirname "$SCRIPT_DIR")"
cd "$TSZ_DIR"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

show_help() {
    echo "Handler Test Harness"
    echo ""
    echo "Usage:"
    echo "  $0 <path/to/app.tsz>              # Test handlers in a .tsz file"
    echo "  $0 --cart <path/to/cart.zig>      # Test handlers in compiled cart"
    echo "  $0 --help                         # Show this help"
    echo ""
    echo "Environment:"
    echo "  TSZ_VERBOSE=1    # Enable verbose output"
    echo "  TSZ_TIMEOUT=30   # Timeout per handler (seconds)"
}

# Parse arguments
APP_PATH=""
JS_LOGIC_PATH=""
MODE=""

while [[ $# -gt 0 ]]; do
    case $1 in
        --cart)
            MODE="cart"
            shift
            APP_PATH="$1"
            shift
            ;;
        --js-logic)
            shift
            JS_LOGIC_PATH="$1"
            shift
            ;;
        --help|-h)
            show_help
            exit 0
            ;;
        -*)
            echo "Unknown option: $1"
            show_help
            exit 1
            ;;
        *)
            if [[ -z "$APP_PATH" ]]; then
                APP_PATH="$1"
                MODE="tsz"
            fi
            shift
            ;;
    esac
done

if [[ -z "$APP_PATH" ]]; then
    echo -e "${RED}Error: No app specified${NC}"
    show_help
    exit 1
fi

if [[ ! -f "$APP_PATH" ]]; then
    echo -e "${RED}Error: File not found: $APP_PATH${NC}"
    exit 1
fi

echo "═══════════════════════════════════════════════════════════════"
echo "  Handler Test Harness"
echo "═══════════════════════════════════════════════════════════════"
echo ""

# Build the test harness
echo -n "Building test harness... "
if zig build test-handlers 2>/dev/null; then
    echo -e "${GREEN}OK${NC}"
else
    echo -e "${RED}FAILED${NC}"
    exit 1
fi

# If testing a .tsz file, we need to compile it first
if [[ "$MODE" == "tsz" ]]; then
    echo -n "Compiling $APP_PATH... "
    
    # Extract app name from path
    APP_NAME=$(basename "$APP_PATH" .tsz)
    
    # Compile the .tsz file
    if ./zig-out/bin/forge build "$APP_PATH" --single 2>/dev/null; then
        echo -e "${GREEN}OK${NC}"
        # The compiled output is generated_app.zig
        CART_PATH="$TSZ_DIR/generated_app.zig"
    else
        echo -e "${RED}FAILED${NC}"
        echo "Failed to compile $APP_PATH"
        exit 1
    fi
else
    CART_PATH="$APP_PATH"
fi

echo ""
echo "Running handler tests..."
echo "Cart: $CART_PATH"
echo ""

# Build arguments for test harness
ARGS="$CART_PATH"
if [[ -n "$JS_LOGIC_PATH" ]]; then
    ARGS="$ARGS --js-logic $JS_LOGIC_PATH"
fi

# Run the test harness
# TODO: Implement the full test harness that can load and test carts
# For now, we run the basic harness

./zig-out/bin/test-handlers $ARGS

exit_code=$?

echo ""
if [[ $exit_code -eq 0 ]]; then
    echo -e "${GREEN}All handler tests passed${NC}"
else
    echo -e "${RED}Some handler tests failed${NC}"
fi

exit $exit_code
