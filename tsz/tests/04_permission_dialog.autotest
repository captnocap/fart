# 04_permission_dialog: Permission request dialog with Allow/Deny/Always actions
# Verifies command list, status counts, and approval/denial flow

# Title
expect "Permission Requests"

# Mode toggle
expect "Manual"

# Status counts
expect "5 pending"
expect "0 approved"
expect "0 denied"

# Command entries
expect "$ git status"
expect "Show working tree status"
expect "$ rm -rf node_modules/"
expect "Delete node_modules directory"
expect "$ cat src/auth.ts"
expect "Read auth module"
expect "$ npm install lodash"
expect "Install package dependencies"
expect "$ git push --force origin main"
expect "Force push to main branch"

# Tool badges
expect "Bash"

# Destructive warning
expect "DESTRUCTIVE"

# Action buttons visible for pending commands
expect "Allow"
expect "Always"
expect "Deny"

# Footer
expect "mode: default"

# Approve first command
click "Allow"
expect "Approved"
expect "4 pending"
expect "1 approved"

# Deny a command
click "Deny"
expect "Denied"
expect "3 pending"
expect "1 denied"

# Toggle mode
click "Manual"
expect "Auto-approve"
