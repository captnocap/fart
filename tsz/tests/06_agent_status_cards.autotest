# 06_agent_status_cards: Agent task status cards with progress and foreground toggle
# Verifies agent list, status indicators, and stop/foreground actions

# Title
expect "Agent Tasks"

# Running/background counts
expect "2 running"
expect "1 background"

# Agent names
expect "search-agent"
expect "test-runner"
expect "code-reviewer"
expect "doc-writer"
expect "refactor-agent"

# Model labels
expect "sonnet"
expect "haiku"
expect "opus"

# Descriptions
expect "Searching codebase for auth patterns"
expect "Running test suite"
expect "Reviewed PR #142"
expect "Generating API documentation"

# Progress counts
expect "3/5"
expect "12/47"
expect "8/8"
expect "2/6"
expect "0/3"

# Foreground badge on search-agent
expect "FG"

# Click on an agent to expand it
click "search-agent"
expect "Background"
expect "Stop"

# Click on test-runner to expand
click "test-runner"
expect "Foreground"
expect "Stop"

# Stop an agent
click "Stop"
