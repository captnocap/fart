# 18_shrink_basis_interaction: WPT flex-shrink + flex-basis interaction
# Tests: shrink proportional to basis, shrink:0 absorbs nothing, all shrink:0 overflows

# Verify title and description
expect "WPT: shrink + basis interaction"
expect "VERIFY: Shrink proportional to basis, shrink:0 absorbs nothing, all shrink:0 overflows"

# Verify section labels
expect "Shrink proportional to basis (WPT spec behavior)"
expect "Shrink:0 + shrink:1 — one item absorbs all shrinkage"
expect "All shrink:0 — items overflow (no shrinking)"
expect "Grow and shrink on same item — basis determines direction"

# Verify text content inside flex items
expect "b200 s1"
expect "b100 s1"
expect "no shrink"
expect "shrinks"
expect "100"
expect "grows"
expect "fixed-ish"
