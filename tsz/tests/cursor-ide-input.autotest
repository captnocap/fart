# Cursor IDE — navigation and agent input shell smoke test

# === BASELINE ===
expect "Agent Console"
expect "PROJECT LANDING"
expect "Send"
expect "Ask"
reject "nil"

# === LANDING TO EDITOR ===
click "Open cursor-ide cart"
expect "cursor-ide.tsz"
expect "Scratch Buffer"
expect "native view"
expect "TSZ"
reject "nil"

# === BACK TO LANDING ===
click "Project landing"
expect "Index Workspace"
expect "Recent Focus"

# === SETTINGS SURFACE ===
click "Settings"
expect "SETTINGS SURFACE"
expect "Providers"
expect "Context"
expect "Memory"
expect "Plugins"
expect "Automations"
expect "Capabilities"
reject "nil"

click "Memory"
expect "Memory Orchestration"
expect "Workspace Memory"
expect "Agent Transcript Index"
reject "nil"

# === TERMINAL TOGGLE ===
expect "pty attached to workspace shell"
click "Terminal" #1
reject "pty attached to workspace shell"
click "Terminal" #1
expect "pty attached to workspace shell"

# === SEARCH PANEL ===
click "Search" #1
expect "Project Search"
expect "results in workspace"
click "Search" #1
reject "Project Search"

# === MODE SWITCHING ===
click "Task"
expect "Run Task"
expect "Task mode"
reject "nil"

click "Ask"
expect "Send"
reject "Run Task"
reject "nil"

# === NEW CONVERSATION + MODEL CYCLE ===
click "New"
expect "Send"
click "Opus 4"
