# Cursor IDE — full baseline test
# Verifies rendering, file operations, tabs, icons, panels

# === SHELL & TOP BAR ===
expect "src/components/Sidebar.tsx"

# === SIDEBAR ===
expect "EXPLORER"
expect "+"

# === FILE TREE — directories ===
expect "cursor-ide"
expect "src"
expect "components"
expect "hooks"
expect "utils"
expect "styles"

# === FILE TREE — files ===
expect "Sidebar.tsx"
expect "Editor.tsx"
expect "ChatPanel.tsx"
expect "StatusBar.tsx"
expect "Terminal.tsx"
expect "useAgent.ts"
expect "package.json"
expect "README.md"
expect "tsconfig.json"
expect "theme.css"

# === FILE TYPE ICONS ===
# TS badge appears for .tsx/.ts files
expect "TS"

# === TABS ===
expect "Sidebar.tsx"

# === BREADCRUMBS ===
expect "components"

# === EDITOR ===
expect "lines"

# === CHAT PANEL ===
expect "Agent"
expect "GPT-4"
expect "Cursor Agent"
expect "I have analyzed the codebase"
expect "Search for all components"
expect "Found 3 files"
expect "Send"

# === STATUS BAR ===
expect "git"
expect "main"
expect "No problems"
expect "Ln"
expect "Col"
expect "TypeScript TSX"
expect "UTF-8"
expect "LF"

# === PANEL TOGGLES IN TOP BAR ===
expect "Search"
expect "Terminal"
expect "Chat"

# === CLICK FILES — tabs open ===
click "Editor.tsx"
expect "Editor.tsx"

click "package.json"
expect "package.json"

click "README.md"
expect "README.md"

# === TAB SWITCHING ===
click "Sidebar.tsx"
expect "Sidebar.tsx"

# === COLORS ===
color "EXPLORER" #6e6e6e
color "No problems" #6e6e6e
color "UTF-8" #6e6e6e

# === HIDDEN PANELS (default) ===
reject "Project Search"
