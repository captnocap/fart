# d01_nested_maps: Nested maps with scope capture
# Tests: map inside map, inner closure captures outer item + index

# Verify all groups render with correct names from script data
expect "Group 0: Alpha"
expect "Group 1: Beta"
expect "Group 2: Gamma"

# Verify items from first group (Alpha)
expect "a1"
expect "a2"
expect "a3"

# Verify items from second group (Beta)
expect "b1"
expect "b2"

# Verify items from third group (Gamma)
expect "g1"

# Verify values with indices shown in template: `${value} [${gi},${ii}]`
expect "10 [0,0]"
expect "20 [0,1]"
expect "30 [0,2]"
expect "40 [1,0]"
expect "50 [1,1]"
expect "60 [2,0]"

# Verify initial selected state
expect "selected: 0"

# Click a1: selected = 0*100 + 0 = 0
click "a1"
expect "selected: 0"

# Click a2: selected = 0*100 + 1 = 1
click "a2"
expect "selected: 1"

# Click a3: selected = 0*100 + 2 = 2
click "a3"
expect "selected: 2"

# Click b1: selected = 1*100 + 0 = 100
click "b1"
expect "selected: 100"

# Click b2: selected = 1*100 + 1 = 101
click "b2"
expect "selected: 101"

# Click g1: selected = 2*100 + 0 = 200
click "g1"
expect "selected: 200"

# Verify items persist after interactions
expect "a1"
expect "b1"
expect "g1"
