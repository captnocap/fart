# d04_map_handler_captures: Handler captures item + index + outer state
# Tests: closure capture from three scopes simultaneously

# Verify initial bonus from script: setBonus(5)
expect "Bonus: 5"

# Verify entries from script data
expect "Alice"
expect "Bob"
expect "Carol"

# Verify item detail text with template: `score=${entry.score} i=${i} bonus=${bonus}`
expect "score=100 i=0 bonus=5"
expect "score=200 i=1 bonus=5"
expect "score=300 i=2 bonus=5"

# Verify initial result
expect "result: 0"

# Click Alice: result = 100 + 0 + 5 = 105
click "Alice"
expect "result: 105"

# Click Bob: result = 200 + 1 + 5 = 206
click "Bob"
expect "result: 206"

# Click Carol: result = 300 + 2 + 5 = 307
click "Carol"
expect "result: 307"

# Increase bonus by 10 (5 -> 15)
click "Bonus: 5"
expect "Bonus: 15"

# Updated item details should show new bonus
expect "score=100 i=0 bonus=15"

# Click Alice with new bonus: 100 + 0 + 15 = 115
click "Alice"
expect "result: 115"

# Click Bob with new bonus: 200 + 1 + 15 = 216
click "Bob"
expect "result: 216"

# Increase bonus again (15 -> 25)
click "Bonus: 15"
expect "Bonus: 25"

# Click Carol with bonus 25: 300 + 2 + 25 = 327
click "Carol"
expect "result: 327"
