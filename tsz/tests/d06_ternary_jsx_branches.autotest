# d06_ternary_jsx_branches: Ternary with full JSX branches
# Tests: both branches are complete subtrees with different structures

# Initially in Branch A (mode=0)
expect "Switch to B"
expect "Branch A"
expect "A taps: 0"

# Branch B should not be visible
reject "Branch B"
reject "B taps"

# Tap in Branch A increments by 1
click "A taps: 0"
expect "A taps: 1"

click "A taps: 1"
expect "A taps: 2"

# Switch to Branch B
click "Switch to B"
expect "Switch to A"
expect "Branch B"
expect "B taps: 2"

# Branch A should be gone
reject "Branch A"

# Tap in Branch B increments by 10
click "B taps: 2"
expect "B taps: 12"

click "B taps: 12"
expect "B taps: 22"

# Switch back to Branch A
click "Switch to A"
expect "Switch to B"
expect "Branch A"
expect "A taps: 22"

# Tap in A again (increments by 1)
click "A taps: 22"
expect "A taps: 23"

# Switch to B and verify it retained the count
click "Switch to B"
expect "B taps: 23"

# Multiple switches work correctly
click "Switch to A"
click "Switch to B"
click "Switch to A"
expect "A taps: 23"
