# d07_sibling_maps_shared_state: Sibling maps sharing state
# Tests: two maps both read and write same state variable

# Verify initial total
expect "Total: 0"

# Verify column headers
expect "Left"
expect "Right"

# Verify left items from script: `${i}: ${item.name}`
expect "0: alpha"
expect "1: beta"
expect "2: gamma"

# Verify right items from script
expect "0: one"
expect "1: two"

# Click left items (increment by 1)
click "0: alpha"
expect "Total: 1"

click "1: beta"
expect "Total: 2"

click "2: gamma"
expect "Total: 3"

# Click right items (increment by 10)
click "0: one"
expect "Total: 13"

click "1: two"
expect "Total: 23"

# Mix of left and right clicks
click "0: alpha"
expect "Total: 24"

click "0: one"
expect "Total: 34"

# All items still visible
expect "0: alpha"
expect "1: beta"
expect "2: gamma"
expect "0: one"
expect "1: two"
