# d105_shell_slot_filter_pipeline: Shell slots + inline filter pipeline + spread cards
# Tests: named slots, filter/sort/map pipeline, prop spread, callbacks

# Verify title and initial state
expect "Shell Slot Filter Pipeline"
expect "Rebuild error-budget dashboard"
expect "0 actions"

# Verify filter toolbar
expect "All"
expect "Ops"
expect "Design"
expect "Infra"
expect "Muted Off"

# Verify initial tickets (All, not muted, sorted by score)
expect "Rebuild error-budget dashboard"
expect "Rotate stale CI tokens"
expect "Audit deploy rollback steps"
expect "Backfill metrics for worker queues"
expect "Trim the onboarding checklist"
expect "Fix card spacing in settings"

# Verify queue labels
expect "ops queue"
expect "design queue"
expect "infra queue"

# Verify score labels
expect "score 98"
expect "score 91"
expect "score 88"
expect "score 84"
expect "score 72"
expect "score 64"

# Verify tags
expect "ops"
expect "urgent"
expect "ux"
expect "copy"
expect "infra"
expect "security"
expect "design"
expect "metrics"
expect "docs"

# Verify action buttons on cards
expect "Open"
expect "Mute"

# Test group filters
click "Ops"
expect "Rebuild error-budget dashboard"
expect "Backfill metrics for worker queues"
reject "Rotate stale CI tokens"

click "Design"
expect "Trim the onboarding checklist"
expect "Fix card spacing in settings"

click "Infra"
expect "Rotate stale CI tokens"
expect "Audit deploy rollback steps"

# Back to all
click "All"

# Test muted toggle
click "Muted Off"
expect "Muted On"

# Should now show muted items too
expect "Rotate stale CI tokens"

# Click mute on a ticket
click "Mute" #1
expect "1 actions"
expect "Unmute"

# Toggle muted off again
click "Muted On"
expect "Muted Off"

# Test opening tickets
click "Open" #1
expect "2 actions"

# Verify selected ticket panel
expect "Selected ticket"
expect "Rebuild error-budget dashboard"

# Select another ticket
click "Trim the onboarding checklist"
expect "3 actions"
expect "Trim the onboarding checklist"
