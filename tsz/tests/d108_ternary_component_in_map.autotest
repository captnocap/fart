# d108_ternary_component_in_map: Ternary-branched components inside map
# Tests: .map() where each item renders different component based on condition

# Verify title
expect "Polymorphic Cards"

# Verify initial state
expect "selected: 0"
expect "taps: 0"

# Verify MetricCard content (kind == 0)
expect "Select Metric"

# Verify StatusCard content (kind == 1)
expect "Select Status"

# Note: This test imports data from d108_ternary_component_in_map.script.tsz
# The cards alternate between MetricCard (score) and StatusCard (status indicator)

# Test selecting a metric card
click "Select Metric" #1
expect "taps: 1"

# Test selecting a status card
click "Select Status" #1
expect "taps: 2"
