# d10_handler_triple_capture: Handler captures item + index + outer state
# Tests: complex accumulator updates with multiple state writes

# Verify title
expect "Triple Capture"

# Verify initial multiplier
expect "multiplier: 1"

# Verify initial status line: `acc: ${accumulator} | lastIdx: ${lastIdx} | lastW: ${lastWeight} | clicks: ${clickLog}`
expect "acc: 0 | lastIdx: 0 | lastW: 0 | clicks: 0"

# Verify first few entries (generated by script)
# labels[i], weight=(i+1)*3, category=i%3
# 0: Mercury, weight=3, category=0 (A)
# 1: Venus, weight=6, category=1 (B)
# 2: Earth, weight=9, category=2 (C)
expect "Mercury"
expect "Venus"
expect "Earth"

# Verify categories display (A=green, B=blue, C=red)
expect "A"
expect "B"
expect "C"

# Click Mercury (idx=0, weight=3)
# accumulator = 0 + 3*1 + 0 = 3
# clickLog = 1
click "Mercury"
expect "acc: 3 | lastIdx: 0 | lastW: 3 | clicks: 1"

# Click Venus (idx=1, weight=6)
# accumulator = 3 + 6*1 + 1 = 10
click "Venus"
expect "acc: 10 | lastIdx: 1 | lastW: 6 | clicks: 2"

# Click Earth (idx=2, weight=9)
# accumulator = 10 + 9*1 + 2 = 21
click "Earth"
expect "acc: 21 | lastIdx: 2 | lastW: 9 | clicks: 3"

# Increase multiplier (1 -> 2)
click "multiplier: 1"
expect "multiplier: 2"

# Click Mars (idx=3, weight=12) with multiplier 2
# accumulator = 21 + 12*2 + 3 = 48
click "Mars"
expect "acc: 48 | lastIdx: 3 | lastW: 12 | clicks: 4"

# Verify Quaoar exists (last item)
expect "Quaoar"
