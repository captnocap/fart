expect "ei="
expect "w="
expect "v="
expect "c="

# Toggle back to normal
click "debug"
expect "normal"

# Verify group headers format: [gi] label (w=weight)
expect "(w="
expect ")"

# Verify entry format: group/entry: val=
expect "val="

# Verify score calculation display
