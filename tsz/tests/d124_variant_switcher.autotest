# d124_variant_switcher: Variant switcher component
# Tests: real source-backed variant switching

// Verify initial content
expect "Variant Switcher"
expect "Inbox"
expect "3 cards loaded | variant: 0"

// Switch across actual variants
click "Magazine"
expect "3 cards loaded | variant: 1"

click "Win95"
expect "3 cards loaded | variant: 4"
