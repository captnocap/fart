# d125_command_classifier: Command Classifier Pipeline
# Tests: Array-based set membership, multi-flag classification, pipeline parsing

# Verify title
expect "Command Classifier"

# Verify classify all button
expect "Classify All"

# Verify category badges
expect "Search"
expect "Read"
expect "List"
expect "Write"
expect "Danger"

# Verify commands
expect "grep -r"
expect "cat package.json"
expect "ls -la"
expect "find . -name"
expect "rm -rf"
expect "cp src/app.ts"
expect "echo hello"
expect "tree src/"
expect "rg pattern"
expect "cat file.txt"

# Verify initial state (unclassified)
expect "tap to classify"
expect "0/10 classified"

# Test classifying a command
click "grep -r"
expect "SEARCH"

# Test classify all
click "Classify All"
expect "10/10 classified"

# Verify classification badges
expect "READ"
expect "LIST"
expect "WRITE"
expect "DANGEROUS"
expect "neutral"

# Verify last result shows
expect "last:"
