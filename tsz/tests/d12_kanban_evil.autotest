# d12_kanban_evil: Complex nested maps with filtering
# Tests: columns.map → tasks.map → filtered → conditionals → component

# Verify header
expect "Evil Kanban"

# Verify initial status: `sel:${selectedTask} exp:${expandedTask} edit:${editingTask} moves:${totalMoves} drag:${dragSource}`
expect "sel:0 exp:0 edit:0 moves:0 drag:0"

# Verify columns from script: Backlog, In Progress, Review, Done
expect "Backlog"
expect "In Progress"
expect "Review"
expect "Done"

# Verify WIP limits: `wip:${col.wip}`
expect "wip:0"
expect "wip:3"
expect "wip:2"

# Verify filter buttons
expect "All"
expect "Med+"
expect "High"

# Verify done toggle (initially showDone=1)
expect "Done: show"

# Verify some tasks from script
expect "Auth flow redesign"
expect "Fix Safari z-index"
expect "Dark mode tokens"

# Click a task to select
click "Auth flow redesign"
expect "sel:0"
expect "moves:1"

# Click "..." to edit
click "..."
expect "Editing"
expect "edit:0"

# Cancel edit
click "Cancel"
reject "Editing"

# Edit again and save
click "..."
click "Save"
expect "moves:2"

# Toggle filters
click "Med+"
expect "Med+"
click "High"
expect "High"
click "All"

# Toggle done visibility
click "Done: show"
expect "Done: hide"
click "Done: hide"
expect "Done: show"
