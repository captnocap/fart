# d16_state_stress: State system stress test
# Tests: many state vars, derived state, rapid updates

# Verify title and initial status
expect "State Stress"
expect "total:0 phase:0 history:0"

# Verify 8 counter buttons with initial values
expect "a:0"
expect "b:0"
expect "c:0"
expect "d:0"
expect "e:0"
expect "f:0"
expect "g:0"
expect "h:0"

# Click various counters
click "a:0"
click "b:0"
click "c:0"
expect "a:1"
expect "b:1"
expect "c:1"
expect "total:3"

# Click more counters
click "d:0"
click "e:0"
click "f:0"
click "g:0"
click "h:0"
expect "total:8"

# Verify derived totals in StatBox components
expect "a+b+c+d"
expect "e+f+g+h"
expect "sum"

# Test bar width controls (initially 50px)
expect "50px"
click "+"
expect "60px"
click "-"
expect "50px"

# Phase handler: setPhase(phase+1), setHistory(history+phase), setTotal(total+1)
# JS setters are immediate: after setPhase(0+1), phase=1. Then setHistory(0+1)=1.
click "Phase 0"
expect "total:9 phase:1 history:1"

# Second phase: setPhase(1+1)=2. setHistory(1+2)=3. setTotal(9+1)=10.
click "Phase 1"
expect "total:10 phase:2 history:3"

# Reset all
click "Reset Everything"
expect "a:0"
expect "b:0"
expect "c:0"
expect "d:0"
expect "e:0"
expect "f:0"
expect "g:0"
expect "h:0"
expect "total:0 phase:0 history:0"
expect "50px"
