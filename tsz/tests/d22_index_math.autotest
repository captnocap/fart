# d22_index_math: Index arithmetic in map
# Tests: zebra striping, first/last item detection, index-based colors

# Verify title
expect "Leaderboard"

# Verify users from script data
expect "speedrunner99"
expect "alice_dev"
expect "bob_hax"
expect "carol_ml"
expect "dave_ops"
expect "eve_sec"
expect "frank_ui"
expect "grace_db"

# Verify values shown
expect "14280"
expect "11340"
expect "9870"
expect "7650"
expect "5210"
expect "3890"
expect "2100"
expect "980"

# Verify first 3 places have special badges with numbers 1, 2, 3
expect "1"
expect "2"
expect "3"

# Verify row numbers for 4+ (i+1)
expect "4"
expect "5"
expect "6"
expect "7"
expect "8"

# Verify initial tapped state
expect "tapped row: 0"

# Click rows and verify tapped index
click "speedrunner99"
expect "tapped row: 0"

click "alice_dev"
expect "tapped row: 1"

click "grace_db"
expect "tapped row: 7"

# All rows still visible
expect "speedrunner99"
expect "grace_db"
