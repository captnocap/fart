# d30a_math_derived_script: Math utilities + derived state — <script> variant
# Tests: Math.floor, Math.round, Math.min, Math.max, Math.random, computed stats

# Verify title
expect "Stats Dashboard"

# Verify action buttons
expect "+ Random"
expect "- First"
expect "x2 All"
expect "Normalize"

# Verify data values
expect "A"
expect "B"
expect "C"
expect "D"
expect "E"
expect "F"
expect "G"
expect "H"

# Verify stats labels
expect "count"
expect "sum"
expect "mean"
expect "median"
expect "min / max"
