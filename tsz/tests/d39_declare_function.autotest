# d39_declare_function: Declare function (FFI)
# Tests: FFI declaration syntax for external functions

# Verify title
expect "Declare Function (FFI)"

# Verify button
expect "Get Time"

# Verify initial state (all zeros)
expect "timestamp"
expect "0"
expect "calls"
expect "0"

# Initial output is empty
expect "output:"

# Click Get Time to call FFI function
click "Get Time"

# After call, timestamp should be non-zero (Unix timestamp)
# calls should be 1
expect "calls"
expect "1"

# Output should show the call result
expect "called time(0)"

# Click again
click "Get Time"
expect "calls"
expect "2"
