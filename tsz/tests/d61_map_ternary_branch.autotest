# d61_map_ternary_branch: Map inside ternary branches
# Tests: ternary where both branches contain .map()

# Verify title
expect "Map in Ternary"

# Verify mode tabs
expect "Files"
expect "Commits"

# Initially mode=0, Files tab active
# Files should show from script
expect "index.tsx"
expect "4200 B"
expect "styles.css"
expect "1800 B"
expect "utils.ts"
expect "920 B"
expect "api.ts"
expect "3100 B"

# Commits should NOT be visible
reject "fix auth flow"
reject "add dark mode"

# Verify initial taps
expect "mode: 0"
expect "taps: 0"

# Click a file
click "index.tsx"
expect "taps: 1"

# Switch to Commits
click "Commits"
expect "mode: 1"

# Now commits should show
expect "fix auth flow"
expect "alice"
expect "add dark mode"
expect "bob"
expect "update deps"
expect "carol"
expect "perf: lazy load"
expect "docs: api guide"
expect "dave"

# Files should NOT be visible
reject "index.tsx"
reject "4200 B"

# Click a commit
click "update deps"
expect "taps: 2"

# Switch back to Files
click "Files"
expect "mode: 0"
expect "index.tsx"
reject "fix auth flow"
