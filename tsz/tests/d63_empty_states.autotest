# d63_empty_states: Empty/zero/initial state edge cases
# Tests: empty string state, zero state, empty array

# Verify title
expect "Empty State Edge Cases"

# Verify buttons
expect "Load Data"
expect "Load Empty"
expect "Clear All"
expect "Set Name"
expect "Clear Name"
expect "+1"

# Initially empty states should show
expect "Not loaded yet"
expect "No name set"
expect "Counter at zero"

# Verify status line with empty string: `name:"${name}"`
expect "name:"
expect "count:0"
expect "items:0"
expect "loaded:0"

# Load data
click "Load Data"
expect "Hello, Alice"
expect "First item"
expect "Second item"
expect "Third item"
expect "items:3"
expect "loaded:1"

# Load empty (clears items, shows empty message)
click "Load Empty"
expect "Empty — no items"
reject "First item"
expect "items:0"

# Clear name
click "Clear Name"
expect "No name set"
expect "Name cannot be empty"

# Set name
click "Set Name"
expect "Hello, Alice"
expect "name:"
expect "Alice"

# Increment counter
click "+1"
expect "Count: 1"
click "+1"
expect "Count: 2"

# Clear all
click "Clear All"
expect "Not loaded yet"
expect "No name set"
expect "Counter at zero"
expect "items:0"
