# d64_multi_import: Multiple imports from multiple script files
# Tests: importing from two different script files

# Verify title
expect "Multi-Import"

# Verify Users section (from import A script)
expect "Users (import A)"
expect "Alice (role:3)"
expect "Bob (role:1)"
expect "Carol (role:2)"
expect "Dave (role:0)"

# Verify Permissions section (from import B script)
expect "Permissions (import B)"
expect "read (min:0)"
expect "write (min:1)"
expect "admin (min:2)"
expect "super (min:3)"

# Initially no selection
expect "selected:"

# Select Alice and check super permission (Alice role 3 >= 3, should pass)
click "Alice (role:3)"
expect "selected: Alice"
click "super (min:3)"
expect "Alice CAN super"

# Select Bob and check admin permission (Bob role 1 < 2, should fail)
click "Bob (role:1)"
expect "selected: Bob"
click "admin (min:2)"
expect "Bob CANNOT admin (role 1 < 2)"

# Dave (role 0) can only read
click "Dave (role:0)"
click "read (min:0)"
expect "Dave CAN read"

click "write (min:1)"
expect "Dave CANNOT write (role 0 < 1)"

# Carol (role 2) can read, write, admin but not super
click "Carol (role:2)"
click "admin (min:2)"
expect "Carol CAN admin"

click "super (min:3)"
expect "Carol CANNOT super (role 2 < 3)"
