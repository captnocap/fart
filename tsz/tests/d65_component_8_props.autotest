# d65_component_8_props: Component with many props (8+)
# Tests: ProfileCard with 8 props

# Verify title
expect "8-Prop Component"

# Verify all ProfileCard instances with their props
# Alice: name="Alice" role="Admin" score=980 avatar=0x7c3aed verified=1 premium=1 online=1
expect "Alice"
expect "Admin"
expect "980"

# Bob: name="Bob" role="Developer" score=720 verified=1 premium=0 online=1
expect "Bob"
expect "Developer"
expect "720"

# Carol: name="Carol" role="Designer" score=850 verified=0 premium=1 online=0
expect "Carol"
expect "Designer"
expect "850"

# Dave: name="Dave" role="Intern" score=310 verified=0 premium=0 online=1
expect "Dave"
expect "Intern"
expect "310"

# Eve: name="Eve" role="Manager" score=640 verified=1 premium=0 online=0
expect "Eve"
expect "Manager"
expect "640"

# Frank: name="Frank" role="DevOps" score=770 verified=1 premium=1 online=1
expect "Frank"
expect "DevOps"
expect "770"

# Verified badge (✓) - Alice, Bob, Eve, Frank
# Premium badge (★) - Alice, Carol, Frank

# Online indicator (green dot) - Alice, Bob, Dave, Frank
# Offline indicator (gray dot) - Carol, Eve

# Click a card and verify selection
expect "selected: 0"
click "Alice"
expect "selected: 0"
expect "Alice · Admin · score:980"

click "Dave"
expect "selected: 3"
expect "Dave · Intern · score:310"
