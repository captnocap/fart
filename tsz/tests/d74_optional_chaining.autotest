# d74_optional_chaining: Optional chaining ?.
# Tests: optional chaining operator

# Verify optional chaining works
expect "Optional Chaining"
expect "value: undefined"

# Read nested property that exists
click "Read A"
expect "value: present"

# Read nested property that doesn't exist (should not crash)
click "Read B"
