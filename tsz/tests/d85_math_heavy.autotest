# d85_math_heavy: Heavy math operations
# Tests: Math.floor, Math.round, Math.abs, Math.min, Math.max

# Verify title
expect "Math Operations"

# Verify initial A and B values
expect "A"
expect "100"
expect "B"
expect "7"

# Verify computed results (initial: a=100, b=7)
# a + b = 107
# a - b = 93
# a * b = 700
# a / b (floor) = floor(100/7) = 14
# a % b = 100 % 7 = 2
# abs(b - a) = abs(7 - 100) = 93
# min(a, b) = 7
# max(a, b) = 100
# round(a/b) = round(14.28) = 14
# a * a + b * b = 10000 + 49 = 10049
expect "a + b"
expect "107"
expect "a - b"
expect "93"
expect "a * b"
expect "700"
expect "a / b (floor)"
expect "14"
expect "a % b"
expect "2"
expect "abs(b - a)"
expect "93"
expect "min(a, b)"
expect "7"
expect "max(a, b)"
expect "100"
expect "round(a/b)"
expect "14"
expect "a * a + b * b"
expect "10049"

# Verify output
expect "computed 10 ops with a=100 b=7"

# Change A and verify recalculation
click "-10"
expect "90"

click "+10" # back to 100

# Change B
click "+1"
expect "8"
expect "computed 10 ops with a=100 b=8"
