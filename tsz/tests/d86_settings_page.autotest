# d86_settings_page: Real-world settings page
# Tests: sidebar nav, tabbed content, toggle switches

# Verify sidebar
expect "Settings"
expect "Appearance"
expect "Editor"
expect "Notifications"
expect "saved 0x"

# Initially Appearance tab active
expect "Appearance"

# Verify Dark Mode toggle (initially on, darkMode=1)
expect "Dark Mode"

# Verify Language selector
expect "Language"
expect "EN"
expect "ES"
expect "JP"

# Switch to Editor tab
click "Editor"
expect "Editor"
expect "Font Size: 14"
expect "-"
expect "+"
expect "Auto-save"

# Change font size
click "+"
expect "Font Size: 16"

# Switch to Notifications tab
click "Notifications"
expect "Notifications"
expect "Email Notifications"

# Verify dirty state and save
# Changing settings sets dirty=1
click "+" # increase font size more

# Navigate back to see save button
click "Editor"
# After changes, should see Unsaved changes and Save button
expect "Unsaved changes"
expect "Save"

# Save
click "Save"
expect "saved 1x"
