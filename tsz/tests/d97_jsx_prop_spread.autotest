# d97_jsx_prop_spread: JSX prop spread into components
# Tests: `{...item}` spread syntax, explicit props after spread, callbacks mixed with spread

# Verify header
expect "JSX Prop Spread"
expect "0 picks"

# Verify description
expect "Cards are rendered by spreading mapped object data into component props."

# Verify metric cards (4 cards with spread props)
expect "Revenue"
expect "Latency"
expect "Errors"
expect "Trials"

# Verify metric values
expect "142000"
expect "86"
expect "7"
expect "381"

# Verify delta chips (positive/negative formatting)
expect "+12%"
expect "-4%"
expect "-2%"
expect "+19%"

# Verify slot labels
expect "M1"
expect "M2"
expect "M3"
expect "M4"

# Verify initial selection state (first item selected by script)
expect "selected"
expect "idle"

# Verify selected metric panel
expect "Selected metric"
expect "Revenue"
expect "active id: 101"

# Test clicking different metrics
click "Latency"
expect "1 picks"
expect "active id: 102"

click "Errors"
expect "2 picks"
expect "active id: 103"

click "Trials"
expect "3 picks"
expect "active id: 104"

# Go back to first
click "Revenue"
expect "4 picks"
expect "active id: 101"

# Verify selection state updates
expect "selected"
