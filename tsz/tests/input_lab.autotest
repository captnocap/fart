expect "QJS Input Lab"
expect "state.name = Ada"
expect "state.query = bridge parity"
expect "last submit = none"
expect "hover status = outside"
expect "active field = none"

focus "Name"
clear
type "Grace"
expect "state.name = Grace"

focus "Search"
expect "active field = query"
key "shift+tab"
expect "active field = name"
key "tab"
expect "active field = query"

focus "Press Enter to submit"
type "ship it"
key "enter"
expect "draft = (empty)"
expect "last submit = ship it"

hover "Hover and right-click this box"
expect "hover status = inside"
expect "right click count = 0"
rightclick "Hover and right-click this box"
expect "right click count = 1"
hover "QJS Input Lab"
expect "hover status = outside"

scroll "panel vertical = idle"
wheel "scroll row 2"
expect "panel vertical = scrollY="
scroll "panel horizontal = idle"
wheelx "lane 2"
expect "panel horizontal = scrollX="
