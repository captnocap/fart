# s01a_counter: Basic counter with increment/decrement/reset (soup variant)
# Verifies initial render state and button interactions

# Initial state
expect "Counter"
expect "Zero"
expect "0"

# Buttons present
expect "-"
expect "+"
expect "Reset"

# Click increment
click "+"
expect "1"
expect "Positive"

# Click increment again
click "+"
expect "2"

# Click decrement
click "-"
expect "1"

# Click reset
click "Reset"
expect "0"
expect "Zero"

# Click decrement to negative
click "-"
expect "-1"
expect "Negative"
