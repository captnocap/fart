# s05a_settings: Settings page with section navigation and profile form
# Verifies section tabs, profile form, and navigation between sections

# Title
expect "Settings Page"

# Navigation tabs
expect "Profile"
expect "Appearance"
expect "Notifications"
expect "Security"

# Profile section visible by default
expect "Profile Settings"
expect "Save"

# Navigate to Appearance
click "Appearance"
reject "Profile Settings"

# Navigate back to Profile
click "Profile"
expect "Profile Settings"
