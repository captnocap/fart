# s07b_node_editor: Node Editor — mixed tier
# Tests: node/edge data structure, graph visualization

# Verify title
expect "Node Editor"

# Verify controls
expect "+ Node"
expect "Deselect"

# Verify instructions
expect "Tap a node to select, then tap another to connect"

# Verify initial nodes
expect "Input"
expect "Process"
