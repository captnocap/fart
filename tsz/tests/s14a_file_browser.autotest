# s14a_file_browser: File explorer with tree view toggle and folder navigation
# Verifies title, tree view toggle, and folder content display

# Title
expect "File Explorer"

# Toggle button
expect "Toggle Tree View"

# Tree view should NOT be open initially
reject "Home"
reject "Documents"
reject "Pictures"

# Open tree view
click "Toggle Tree View"
expect "Home"
expect "Documents"
expect "Pictures"

# Select Documents folder
click "Documents"
expect "File 1.txt"
expect "File 2.pdf"
expect "File 3.jpg"

# Select Pictures folder
click "Pictures"
expect "Image 1.png"
expect "Image 2.gif"
expect "Image 3.jpeg"

# Close tree view
click "Toggle Tree View"
reject "Home"
